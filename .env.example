# Firebase – copy to .env and fill with your project values from Firebase Console
# https://console.firebase.google.com/ → Project settings → Your apps

PUBLIC_FIREBASE_API_KEY=your-api-key
PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
PUBLIC_FIREBASE_PROJECT_ID=your-project-id
PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
PUBLIC_FIREBASE_APP_ID=1:123456789:web:abc123

# Google Maps – needed for route display on the transfer results page
# Enable: Maps JavaScript API, Directions API, Geocoding API
PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Stripe – needed for payment processing
PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
