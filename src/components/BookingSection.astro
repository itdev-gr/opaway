---
import LuggageCounters from './LuggageCounters.astro';
import { renderTimePickerHTML } from '../lib/time-picker';
const vehicles = [
	{
		title: 'Sedan',
		titleEl: 'Σεντάν',
		titleEs: 'Sedán',
		models: 'Mercedes-Benz E-Class, or similar.',
		modelsEl: 'Mercedes-Benz E-Class ή αντίστοιχο.',
		modelsEs: 'Mercedes-Benz Clase E o similar.',
		image: '/about-sedan.jpg',
		features: [
			{ en: 'Fits up to 3 people', el: 'Έως 3 επιβάτες', es: 'Hasta 3 pasajeros' },
			{ en: '1 big + 1 small luggage per person', el: '1 μεγάλη και 1 μικρή αποσκευή ανά άτομο', es: '1 maleta grande + 1 pequeña por persona' },
			{ en: 'Available for airport transfers & city tours', el: 'Για μεταφορές από/προς αεροδρόμιο και ξεναγήσεις στην πόλη', es: 'Disponible para traslados al aeropuerto y tours por la ciudad' },
		],
	},
	{
		title: 'Van',
		titleEl: 'Βαν',
		titleEs: 'Furgoneta',
		models: 'Mercedes Vito Tourer, or similar.',
		modelsEl: 'Mercedes Vito Tourer ή αντίστοιχο.',
		modelsEs: 'Mercedes Vito Tourer o similar.',
		image: '/about-van.jpg',
		features: [
			{ en: 'Fits up to 8 people', el: 'Έως 8 επιβάτες', es: 'Hasta 8 pasajeros' },
			{ en: '1 big + 1 small luggage per person', el: '1 μεγάλη και 1 μικρή αποσκευή ανά άτομο', es: '1 maleta grande + 1 pequeña por persona' },
			{ en: 'Ideal for group transfers & private tours', el: 'Ιδανικό για ομαδικές μεταφορές και ιδιωτικές ξεναγήσεις', es: 'Ideal para traslados en grupo y tours privados' },
		],
	},
	{
		title: 'Minibus (or two Vans)',
		titleEl: 'Μίνι λεωφορείο (ή δύο βαν)',
		titleEs: 'Minibús (o dos furgonetas)',
		models: 'Mercedes Sprinter, or similar.',
		modelsEl: 'Mercedes Sprinter ή αντίστοιχο.',
		modelsEs: 'Mercedes Sprinter o similar.',
		image: '/about-minibus.jpg',
		features: [
			{ en: 'Fits up to 18 people', el: 'Έως 18 επιβάτες', es: 'Hasta 18 pasajeros' },
			{ en: '1 big + 1 small luggage per person', el: '1 μεγάλη και 1 μικρή αποσκευή ανά άτομο', es: '1 maleta grande + 1 pequeña por persona' },
			{ en: 'Perfect for large groups & corporate events', el: 'Ιδανικό για μεγάλες ομάδες και εταιρικές εκδηλώσεις', es: 'Perfecto para grupos grandes y eventos corporativos' },
		],
	},
];
---

<section class="bg-white py-12 lg:py-16 px-6 lg:px-10">
	<div class="max-w-6xl mx-auto">

		<div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-10 items-start">

			<!-- ── Booking form panel ── -->
			<div class="bg-neutral-100 rounded-2xl p-6 lg:p-8 shadow-sm">

				<!-- Tabs -->
				<div class="flex border-b border-neutral-200 mb-6">
					<button type="button" data-booking-tab="transfer" class="booking-tab px-4 py-3 font-medium text-black bg-neutral-200/80 border-b-2 border-black -mb-px rounded-t-lg transition-colors" data-i18n-el="Μεταφορά" data-i18n-es="Traslado">
						Transfer
					</button>
					<button type="button" data-booking-tab="hourly" class="booking-tab px-4 py-3 font-medium text-neutral-500 hover:text-neutral-700 -mb-px rounded-t-lg transition-colors" data-i18n-el="Με την ώρα" data-i18n-es="Por hora">
						Rent per hour
					</button>
					<button type="button" data-booking-tab="tours" class="booking-tab px-4 py-3 font-medium text-neutral-500 hover:text-neutral-700 -mb-px rounded-t-lg transition-colors" data-i18n-el="Ξεναγήσεις" data-i18n-es="Tours">
						Tours
					</button>
				</div>

				<!-- ═══ Transfer form ═══ -->
				<div id="form-transfer">
					<!-- From -->
					<div class="mb-4">
						<label class="block text-sm font-medium text-neutral-700 mb-1" data-i18n-el="Από" data-i18n-es="Desde">From</label>
						<div class="relative">
							<span class="absolute left-3 top-1/2 -translate-y-1/2 text-neutral-500">
								<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
							</span>
							<input id="tf-from" type="text" placeholder="Address, airport, hotel, ..." data-i18n-placeholder-el="Διεύθυνση, αεροδρόμιο, ξενοδοχείο…" data-i18n-placeholder-es="Dirección, aeropuerto, hotel, ..." autocomplete="off" class="w-full pl-10 pr-4 py-3 bg-white border border-neutral-200 rounded-xl text-neutral-800 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95]" />
						</div>
						<p data-error-for="tf-from" class="text-sm text-red-500 mt-1.5 hidden"></p>
					</div>

					<!-- To -->
					<div class="mb-4">
						<label class="block text-sm font-medium text-neutral-700 mb-1" data-i18n-el="Προς" data-i18n-es="Hacia">To</label>
						<div class="relative">
							<span class="absolute left-3 top-1/2 -translate-y-1/2 text-neutral-500">
								<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
							</span>
							<input id="tf-to" type="text" placeholder="Address, airport, hotel, ..." data-i18n-placeholder-el="Διεύθυνση, αεροδρόμιο, ξενοδοχείο…" data-i18n-placeholder-es="Dirección, aeropuerto, hotel, ..." autocomplete="off" class="w-full pl-10 pr-4 py-3 bg-white border border-neutral-200 rounded-xl text-neutral-800 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95]" />
						</div>
						<p data-error-for="tf-to" class="text-sm text-red-500 mt-1.5 hidden"></p>
					</div>

					<!-- Date & Time -->
					<div class="grid grid-cols-2 gap-4 mb-5">
						<div>
							<label class="block text-sm font-medium text-neutral-700 mb-1" data-i18n-el="Ημερομηνία παραλαβής" data-i18n-es="Fecha de recogida">Pickup date</label>
							<div class="relative">
								<span class="absolute left-3 top-1/2 -translate-y-1/2 text-neutral-500">
									<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
								</span>
								<input id="tf-date" type="date" class="w-full pl-10 pr-4 py-3 bg-white border border-neutral-200 rounded-xl text-neutral-800 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95] cursor-pointer" />
							</div>
							<p data-error-for="tf-date" class="text-sm text-red-500 mt-1.5 hidden"></p>
						</div>
						<div>
							<label class="block text-sm font-medium text-neutral-700 mb-1" data-i18n-el="Ώρα παραλαβής" data-i18n-es="Hora de recogida">Pickup time</label>
							<Fragment set:html={renderTimePickerHTML('tf-time', { required: true, selectClass: 'flex-1 px-3 py-3 rounded-xl border border-neutral-200 bg-white text-neutral-800 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95]' })} />
							<p data-error-for="tf-time" class="text-sm text-red-500 mt-1.5 hidden"></p>
						</div>
					</div>

					<!-- Add Return button -->
					<button
						type="button"
						id="add-return-btn"
						class="flex items-center gap-2 text-sm font-semibold text-[#0C6B95] border border-[#0C6B95]/40 hover:border-[#0C6B95] hover:bg-[#0C6B95]/5 px-4 py-2.5 rounded-xl transition-all duration-200 mb-6 group"
					>
						<svg class="w-4 h-4 transition-transform duration-300 group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
							<path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
						</svg>
						Add Return
					</button>

					<!-- Return date row (hidden by default) -->
					<div id="return-row" class="hidden grid grid-cols-2 gap-4 mb-6">
						<div>
							<label class="block text-sm font-medium text-neutral-700 mb-1" data-i18n-el="Ημερομηνία επιστροφής" data-i18n-es="Fecha de regreso">Return date</label>
							<div class="relative">
								<span class="absolute left-3 top-1/2 -translate-y-1/2 text-neutral-500">
									<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
								</span>
								<input id="tf-return-date" type="date" class="w-full pl-10 pr-4 py-3 bg-white border border-neutral-200 rounded-xl text-neutral-800 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95] cursor-pointer" />
							</div>
							<p data-error-for="tf-return-date" class="text-sm text-red-500 mt-1.5 hidden"></p>
						</div>
						<div>
							<label class="block text-sm font-medium text-neutral-700 mb-1" data-i18n-el="Ώρα επιστροφής" data-i18n-es="Hora de regreso">Return time</label>
							<Fragment set:html={renderTimePickerHTML('tf-return-time', { selectClass: 'flex-1 px-3 py-3 rounded-xl border border-neutral-200 bg-white text-neutral-800 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95]' })} />
							<p data-error-for="tf-return-time" class="text-sm text-red-500 mt-1.5 hidden"></p>
						</div>
					</div>

					<!-- Passengers -->
					<div class="mb-6">
						<label class="block text-sm font-medium text-neutral-700 mb-2" data-i18n-el="Επιβάτες" data-i18n-es="Pasajeros">Passengers</label>
						<div class="flex items-center gap-3">
							<div class="flex-1 flex items-center gap-2 pl-4 py-3 bg-white border border-neutral-200 rounded-xl">
								<svg class="w-5 h-5 text-neutral-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" /></svg>
								<span class="text-neutral-800 font-medium" id="passenger-count">2</span>
							</div>
							<button type="button" id="pax-minus" class="w-10 h-10 flex items-center justify-center rounded-xl bg-neutral-800 text-white hover:bg-neutral-700 transition-colors text-lg font-bold" aria-label="Fewer passengers" data-i18n-aria-el="Λιγότεροι επιβάτες" data-i18n-aria-es="Menos pasajeros">−</button>
							<button type="button" id="pax-plus" class="w-10 h-10 flex items-center justify-center rounded-xl bg-neutral-800 text-white hover:bg-neutral-700 transition-colors text-lg font-bold" aria-label="More passengers" data-i18n-aria-el="Περισσότεροι επιβάτες" data-i18n-aria-es="Más pasajeros">+</button>
						</div>
					</div>

					<div class="mb-5">
						<LuggageCounters rootId="home-xfer-luggage" />
					</div>

					<!-- Form-level error banner -->
					<div data-form-error class="hidden mb-4 rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-600" role="alert"></div>

					<!-- See prices -->
					<button id="see-prices-btn" type="button" class="w-full py-4 bg-[#0C6B95] hover:bg-[#0a5c82] text-white font-semibold rounded-xl transition-colors flex items-center justify-center gap-2" data-i18n-el="Δείτε τιμές" data-i18n-es="Ver precios">
						<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
						See prices
					</button>
				</div>

				<!-- ═══ Rent per hour form ═══ -->
				<div id="form-hourly" class="hidden">
					<!-- Pickup location -->
					<div class="mb-4">
						<label class="block text-sm font-medium text-neutral-700 mb-1" data-i18n-el="Τοποθεσία παραλαβής" data-i18n-es="Lugar de recogida">Pickup location</label>
						<div class="relative">
							<span class="absolute left-3 top-1/2 -translate-y-1/2 text-neutral-500">
								<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
							</span>
							<input type="text" id="hourly-pickup" placeholder="Address, airport, hotel, ..." data-i18n-placeholder-el="Διεύθυνση, αεροδρόμιο, ξενοδοχείο…" data-i18n-placeholder-es="Dirección, aeropuerto, hotel, ..." autocomplete="off" class="w-full pl-10 pr-4 py-3 bg-white border border-neutral-200 rounded-xl text-neutral-800 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95]" />
						</div>
						<p data-error-for="hourly-pickup" class="text-sm text-red-500 mt-1.5 hidden"></p>
					</div>

					<!-- Date & Time -->
					<div class="grid grid-cols-2 gap-4 mb-5">
						<div>
							<label class="block text-sm font-medium text-neutral-700 mb-1" data-i18n-el="Ημερομηνία παραλαβής" data-i18n-es="Fecha de recogida">Pickup date</label>
							<div class="relative">
								<span class="absolute left-3 top-1/2 -translate-y-1/2 text-neutral-500">
									<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
								</span>
								<input id="hourly-date" type="date" class="w-full pl-10 pr-4 py-3 bg-white border border-neutral-200 rounded-xl text-neutral-800 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95] cursor-pointer" />
							</div>
							<p data-error-for="hourly-date" class="text-sm text-red-500 mt-1.5 hidden"></p>
						</div>
						<div>
							<label class="block text-sm font-medium text-neutral-700 mb-1" data-i18n-el="Ώρα παραλαβής" data-i18n-es="Hora de recogida">Pickup time</label>
							<Fragment set:html={renderTimePickerHTML('hourly-time', { required: true, selectClass: 'flex-1 px-3 py-3 rounded-xl border border-neutral-200 bg-white text-neutral-800 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95]' })} />
							<p data-error-for="hourly-time" class="text-sm text-red-500 mt-1.5 hidden"></p>
						</div>
					</div>

					<!-- Hours -->
					<div class="mb-4">
						<label class="block text-sm font-medium text-neutral-700 mb-2" data-i18n-el="Ώρες" data-i18n-es="Horas">Hours</label>
						<div class="flex items-center gap-3">
							<div class="flex-1 flex items-center gap-2 pl-4 py-3 bg-white border border-neutral-200 rounded-xl" id="hours-display-wrapper">
								<svg class="w-5 h-5 text-neutral-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
								<span class="text-neutral-800 font-medium" id="hours-count">3</span>
							</div>
							<button type="button" id="hours-minus" class="w-10 h-10 flex items-center justify-center rounded-xl bg-neutral-800 text-white hover:bg-neutral-700 transition-colors text-lg font-bold" aria-label="Fewer hours" data-i18n-aria-el="Λιγότερες ώρες" data-i18n-aria-es="Menos horas">−</button>
							<button type="button" id="hours-plus" class="w-10 h-10 flex items-center justify-center rounded-xl bg-neutral-800 text-white hover:bg-neutral-700 transition-colors text-lg font-bold" aria-label="More hours" data-i18n-aria-el="Περισσότερες ώρες" data-i18n-aria-es="Más horas">+</button>
						</div>
						<p id="hours-warning" class="hidden text-sm text-amber-600 mt-2 flex items-center gap-1.5" data-i18n-el="Ελάχιστη διάρκεια κράτησης: 3 ώρες" data-i18n-es="El alquiler mínimo es de 3 horas">
							<svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z" /></svg>
							Minimum rental is 3 hours
						</p>
					</div>

					<!-- Passengers -->
					<div class="mb-6">
						<label class="block text-sm font-medium text-neutral-700 mb-2" data-i18n-el="Επιβάτες" data-i18n-es="Pasajeros">Passengers</label>
						<div class="flex items-center gap-3">
							<div class="flex-1 flex items-center gap-2 pl-4 py-3 bg-white border border-neutral-200 rounded-xl">
								<svg class="w-5 h-5 text-neutral-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" /></svg>
								<span class="text-neutral-800 font-medium" id="hourly-passenger-count">2</span>
							</div>
							<button type="button" id="hourly-pax-minus" class="w-10 h-10 flex items-center justify-center rounded-xl bg-neutral-800 text-white hover:bg-neutral-700 transition-colors text-lg font-bold" aria-label="Fewer passengers" data-i18n-aria-el="Λιγότεροι επιβάτες" data-i18n-aria-es="Menos pasajeros">−</button>
							<button type="button" id="hourly-pax-plus" class="w-10 h-10 flex items-center justify-center rounded-xl bg-neutral-800 text-white hover:bg-neutral-700 transition-colors text-lg font-bold" aria-label="More passengers" data-i18n-aria-el="Περισσότεροι επιβάτες" data-i18n-aria-es="Más pasajeros">+</button>
						</div>
					</div>

					<div class="mb-5">
						<LuggageCounters rootId="home-hourly-luggage" />
					</div>

					<!-- Form-level error banner -->
					<div data-form-error class="hidden mb-4 rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-600" role="alert"></div>

					<!-- See prices -->
					<button id="hourly-see-prices-btn" type="button" class="w-full py-4 bg-[#0C6B95] hover:bg-[#0a5c82] text-white font-semibold rounded-xl transition-colors flex items-center justify-center gap-2" data-i18n-el="Δείτε τιμές" data-i18n-es="Ver precios">
						<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
						See prices
					</button>
				</div>

				<!-- ═══ Tours form ═══ -->
				<div id="form-tours" class="hidden">
					<!-- Tour Experience -->
					<div class="mb-4">
						<label class="block text-sm font-medium text-neutral-700 mb-1" data-i18n-el="Επιλέξτε ξενάγηση" data-i18n-es="Experiencia del tour">Tour Experience</label>
						<div class="relative">
							<span class="absolute left-3 top-1/2 -translate-y-1/2 text-neutral-500 pointer-events-none">
								<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" /></svg>
							</span>
							<select id="tours-select" class="w-full pl-10 pr-10 py-3 bg-white border border-neutral-200 rounded-xl text-neutral-800 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95] appearance-none cursor-pointer">
								<option value="" disabled selected data-i18n-el="Φόρτωση ξεναγήσεων…" data-i18n-es="Cargando tours…">Loading tours…</option>
							</select>
							<span class="absolute right-3 top-1/2 -translate-y-1/2 text-neutral-500 pointer-events-none">
