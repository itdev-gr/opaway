<script>
import { attachPlacesAutocomplete } from '../lib/places-autocomplete';
import { showFieldError, showFormError, clearFormErrors, wireAutoClear } from '../lib/form-errors';
import { supabase } from '../lib/supabase';
import { initLuggageCounters, getLuggageCounts } from '../lib/luggage-counters';
import { readTimePickerValue } from '../lib/time-picker';
import { applyMinBookingDate, isPastBookingDate } from '../lib/booking-date';
import { renderImageCarouselHTML, initImageCarousels } from '../lib/image-carousel';

function trackBookSearch(flow: 'transfer' | 'hourly' | 'tour', extra: Record<string, unknown> = {}) {
	const gtag = (window as typeof window & { gtag?: (...args: unknown[]) => void }).gtag;
	if (typeof gtag !== 'function') return;
	gtag('event', 'generate_lead', {
		currency: 'EUR',
		value: 0,
		lead_source: `booking_form_${flow}`,
		...extra,
	});
}

document.addEventListener('astro:page-load', () => {
	if (!document.getElementById('form-transfer')) return;

	// ── Tab switching ──
	const tabs = document.querySelectorAll('[data-booking-tab]') as NodeListOf<HTMLButtonElement>;
	const formTransfer = document.getElementById('form-transfer') as HTMLElement;
	const formHourly = document.getElementById('form-hourly') as HTMLElement;
	const formTours = document.getElementById('form-tours') as HTMLElement;
	const panelTransfer = document.querySelector('[data-service-panel="transfer"]') as HTMLElement | null;
	const panelHourly = document.querySelector('[data-service-panel="hourly"]') as HTMLElement | null;
	const panelTours = document.querySelector('[data-service-panel="tours"]') as HTMLElement | null;

	const activeClasses = ['text-black', 'bg-neutral-200/80', 'border-b-2', 'border-black'];
	const inactiveClasses = ['text-neutral-500', 'hover:text-neutral-700'];

	function switchTab(tabName: string) {
		tabs.forEach((tab) => {
			const isActive = tab.dataset.bookingTab === tabName;
			activeClasses.forEach((c) => tab.classList.toggle(c, isActive));
			inactiveClasses.forEach((c) => tab.classList.toggle(c, !isActive));
		});

		formTransfer.classList.toggle('hidden', tabName !== 'transfer');
		formHourly.classList.toggle('hidden', tabName !== 'hourly');
		formTours.classList.toggle('hidden', tabName !== 'tours');

		panelTransfer?.classList.toggle('hidden', tabName !== 'transfer');
		panelHourly?.classList.toggle('hidden', tabName !== 'hourly');
		panelTours?.classList.toggle('hidden', tabName !== 'tours');
	}

	tabs.forEach((tab) => {
		tab.addEventListener('click', () => switchTab(tab.dataset.bookingTab!));
	});

	// ── Transfer passenger counter ──
	const countEl = document.getElementById('passenger-count');
	let count = 2;
	document.getElementById('pax-minus')?.addEventListener('click', () => {
		if (count > 1) { count--; if (countEl) countEl.textContent = String(count); }
	});
	document.getElementById('pax-plus')?.addEventListener('click', () => {
		count++; if (countEl) countEl.textContent = String(count);
	});

	// ── Add Return toggle ──
	const returnBtn = document.getElementById('add-return-btn');
	const returnRow = document.getElementById('return-row');
	let returnOpen = false;
	returnBtn?.addEventListener('click', () => {
		returnOpen = !returnOpen;
		returnRow?.classList.toggle('hidden', !returnOpen);
		if (returnBtn.lastChild?.nodeType === Node.TEXT_NODE) {
			returnBtn.lastChild.textContent = returnOpen ? ' Remove Return' : ' Add Return';
		}
	});

	// ── Hours counter ──
	const hoursEl = document.getElementById('hours-count');
	const hoursWarning = document.getElementById('hours-warning');
	let hours = 3;

	function updateHoursDisplay() {
		if (hoursEl) hoursEl.textContent = String(hours);
		hoursWarning?.classList.toggle('hidden', hours >= 3);
	}

	document.getElementById('hours-minus')?.addEventListener('click', () => {
		if (hours > 1) { hours--; updateHoursDisplay(); }
	});
	document.getElementById('hours-plus')?.addEventListener('click', () => {
		hours++; updateHoursDisplay();
	});

	// ── Hourly passenger counter ──
	const hourlyCountEl = document.getElementById('hourly-passenger-count');
	let hourlyCount = 2;
	document.getElementById('hourly-pax-minus')?.addEventListener('click', () => {
		if (hourlyCount > 1) { hourlyCount--; if (hourlyCountEl) hourlyCountEl.textContent = String(hourlyCount); }
	});
	document.getElementById('hourly-pax-plus')?.addEventListener('click', () => {
		hourlyCount++; if (hourlyCountEl) hourlyCountEl.textContent = String(hourlyCount);
	});

	// ── Luggage counters ──
	initLuggageCounters('home-xfer-luggage');
	initLuggageCounters('home-hourly-luggage');

	// ── Tours participant counter ──
	const toursCountEl = document.getElementById('tours-participant-count');
	let toursCount = 2;
	document.getElementById('tours-pax-minus')?.addEventListener('click', () => {
		if (toursCount > 1) { toursCount--; if (toursCountEl) toursCountEl.textContent = String(toursCount); }
	});
	document.getElementById('tours-pax-plus')?.addEventListener('click', () => {
		toursCount++; if (toursCountEl) toursCountEl.textContent = String(toursCount);
	});

	// ── Tours: populate dropdown + build carousel synced with it ──
	(async () => {
		const select = document.getElementById('tours-select') as HTMLSelectElement | null;
		if (!select) return;
		const panel = document.querySelector('[data-service-panel="tours"]');
		const inner = document.getElementById('home-tours-carousel-inner');
		const prevBtn = panel?.querySelector('[data-home-tour-prev]') as HTMLButtonElement | null;
		const nextBtn = panel?.querySelector('[data-home-tour-next]') as HTMLButtonElement | null;
		const indicator = panel?.querySelector('[data-home-tour-indicator]') as HTMLElement | null;

		const esc = (s: unknown) => String(s ?? '')
			.replace(/&/g, '&amp;').replace(/</g, '&lt;')
			.replace(/>/g, '&gt;').replace(/"/g, '&quot;');

		try {
			const { data, error } = await supabase
				.from('tours_catalog')
				.select('id, title, description, duration, image_url, images, highlight1, highlight2, highlight3')
				.neq('published', false)
				.order('created_at', { ascending: false });
			if (error) throw error;
			const docs = (data ?? []) as any[];

			// Dropdown
			const placeholder = select.querySelector('option');
			if (placeholder) placeholder.textContent = 'Select a tour...';
			docs.forEach((t) => {
				const opt = document.createElement('option');
				opt.value = t.id;
				opt.textContent = t.title;
				select.appendChild(opt);
			});

			if (!inner) return;

			if (docs.length === 0) {
				inner.innerHTML = `
					<div class="bg-white border border-neutral-200 rounded-2xl overflow-hidden shadow-sm p-12 flex items-center justify-center">
						<p class="text-neutral-400 text-sm text-center" data-i18n-el="Δεν υπάρχουν διαθέσιμα τουρ αυτή τη στιγμή." data-i18n-es="No hay tours disponibles en este momento.">No tours available at the moment.</p>
					</div>`;
				prevBtn?.classList.add('invisible');
				nextBtn?.classList.add('invisible');
				if (indicator) indicator.textContent = '';
				(window as any).opawayApplyI18n?.();
				return;
			}

			inner.innerHTML = docs.map((t, i) => {
				const images = (Array.isArray(t.images) && t.images.length > 0) ? t.images : (t.image_url ? [t.image_url] : []);
				const highlights = [t.highlight1, t.highlight2, t.highlight3].filter(Boolean);
				return `
				<article data-home-tour-card data-tour-id="${esc(t.id)}" class="bg-white border border-neutral-200 rounded-2xl overflow-hidden shadow-sm flex flex-col ${i === 0 ? '' : 'hidden'}">
					${renderImageCarouselHTML(images, { alt: esc(t.title), wrapperClass: 'aspect-[16/9] overflow-hidden' })}
					<div class="p-6 flex flex-col">
						${t.duration ? `<div class="flex items-center gap-2 mb-2"><svg class="w-4 h-4 text-[#0C6B95] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg><span class="text-xs font-semibold text-[#0C6B95] uppercase tracking-wide">${esc(t.duration)}</span></div>` : ''}
						<h3 class="text-2xl font-bold text-neutral-900 mb-2">${esc(t.title)}</h3>
						${t.description ? `<p class="text-sm text-neutral-500 mb-4 leading-relaxed">${esc(t.description)}</p>` : ''}
						${highlights.length > 0 ? `<div class="w-16 h-1 bg-[#0C6B95] rounded-full mb-5"></div><ul class="flex flex-col gap-3">${highlights.map((h: string) => `<li class="flex items-start gap-3"><svg class="w-4 h-4 text-[#0C6B95] mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg><span class="text-sm text-neutral-600 leading-snug">${esc(h)}</span></li>`).join('')}</ul>` : ''}
					</div>
				</article>`;
			}).join('');

			initImageCarousels(inner);
			(window as any).opawayApplyI18n?.();

			const cards = Array.from(inner.querySelectorAll<HTMLElement>('[data-home-tour-card]'));
			let current = 0;
			if (indicator) indicator.textContent = `1 / ${cards.length}`;
			if (cards.length <= 1) {
				prevBtn?.classList.add('invisible');
				nextBtn?.classList.add('invisible');
			}

			const goTo = (idx: number) => {
				cards[current].classList.add('hidden');
				current = (idx + cards.length) % cards.length;
				cards[current].classList.remove('hidden');
				if (indicator) indicator.textContent = `${current + 1} / ${cards.length}`;
				const id = cards[current].dataset.tourId;
				if (id && select.value !== id) select.value = id;
			};

			prevBtn?.addEventListener('click', () => goTo(current - 1));
			nextBtn?.addEventListener('click', () => goTo(current + 1));

			// Selecting a tour in the dropdown drives the carousel to that tour.
			select.addEventListener('change', () => {
				if (!select.value) return;
				const idx = cards.findIndex((c) => c.dataset.tourId === select.value);
				if (idx >= 0 && idx !== current) goTo(idx);
			});
		} catch (err) {
			console.error('[BookingSection] tours load failed:', err);
			const placeholder = select.querySelector('option');
			if (placeholder) placeholder.textContent = 'Tours unavailable';
		}
	})();

	// ── Google Places autocomplete ──
	attachPlacesAutocomplete(document.getElementById('tf-from') as HTMLInputElement);
	attachPlacesAutocomplete(document.getElementById('tf-to') as HTMLInputElement);
	attachPlacesAutocomplete(document.getElementById('hourly-pickup') as HTMLInputElement);
	attachPlacesAutocomplete(document.getElementById('tours-pickup') as HTMLInputElement);

	// ── Auto-clear per-field errors when user edits ──
	wireAutoClear([
		document.getElementById('tf-from'),
		document.getElementById('tf-to'),
		document.getElementById('tf-date'),
		document.getElementById('tf-time-hh'),
		document.getElementById('tf-time-mm'),
		document.getElementById('tf-return-time-hh'),
		document.getElementById('tf-return-time-mm'),
		document.getElementById('hourly-pickup'),
		document.getElementById('hourly-date'),
		document.getElementById('hourly-time-hh'),
		document.getElementById('hourly-time-mm'),
		document.getElementById('tours-select'),
		document.getElementById('tours-date'),
	]);

	applyMinBookingDate('tf-date', 'tf-return-date', 'hourly-date', 'tours-date');

	// ── Transfer: See prices ──
	document.getElementById('see-prices-btn')?.addEventListener('click', () => {
		clearFormErrors(formTransfer);

		const fromEl = document.getElementById('tf-from') as HTMLInputElement;
		const toEl = document.getElementById('tf-to') as HTMLInputElement;
		const dateEl = document.getElementById('tf-date') as HTMLInputElement;
		const returnDateEl = document.getElementById('tf-return-date') as HTMLInputElement;

		const from = fromEl?.value.trim() ?? '';
		const to = toEl?.value.trim() ?? '';
		const date = dateEl?.value.trim() ?? '';
		const time = readTimePickerValue('tf-time');
		const passengers = document.getElementById('passenger-count')?.textContent?.trim() || '2';
		const returnDate = returnDateEl?.value.trim() ?? '';
		const returnTime = readTimePickerValue('tf-return-time');

		// For field-level errors on the picker, target the HH select as anchor element
		const tfTimeHhEl = document.getElementById('tf-time-hh') as HTMLSelectElement | null;
		const tfReturnTimeHhEl = document.getElementById('tf-return-time-hh') as HTMLSelectElement | null;

		let firstErr: HTMLElement | null = null;
		if (!from) { showFieldError(fromEl, 'Please enter a pickup location.'); firstErr ??= fromEl; }
		if (!to) { showFieldError(toEl, 'Please enter a destination.'); firstErr ??= toEl; }
		if (!date) { showFieldError(dateEl, 'Please select a pickup date.'); firstErr ??= dateEl; }
		else if (isPastBookingDate(date)) { showFieldError(dateEl, 'Please select a future date.'); firstErr ??= dateEl; }
		if (returnDate && isPastBookingDate(returnDate)) { showFieldError(returnDateEl, 'Please select a future date.'); firstErr ??= returnDateEl; }
		else if (returnDate && date && returnDate < date) { showFieldError(returnDateEl, 'Return date cannot be before the pickup date.'); firstErr ??= returnDateEl; }
		if (!time) { showFieldError(tfTimeHhEl, 'Please select a pickup time.'); firstErr ??= tfTimeHhEl; }
		if (returnDate && !returnTime) { showFieldError(tfReturnTimeHhEl, 'Please select a return time.'); firstErr ??= tfReturnTimeHhEl; }

		if (firstErr) {
			firstErr.scrollIntoView({ behavior: 'smooth', block: 'center' });
			(firstErr as HTMLInputElement).focus?.();
			return;
		}

		const params = new URLSearchParams({ from, to, date, time, passengers });
		if (returnDate) { params.set('returnDate', returnDate); params.set('returnTime', returnTime); }
		const xferLuggage = getLuggageCounts('home-xfer-luggage');
		if (xferLuggage.small > 0) params.set('luggageSmall', String(xferLuggage.small));
		if (xferLuggage.big   > 0) params.set('luggageBig',   String(xferLuggage.big));
		trackBookSearch('transfer', { from, to, date, passengers: Number(passengers) });
		window.location.href = `/book/transfer/results?${params.toString()}`;
	});

	// ── Hourly: See prices ──
	document.getElementById('hourly-see-prices-btn')?.addEventListener('click', () => {
		clearFormErrors(formHourly);

		const pickupEl = document.getElementById('hourly-pickup') as HTMLInputElement;
		const dateEl = document.getElementById('hourly-date') as HTMLInputElement;

		const pickup = pickupEl?.value.trim() ?? '';
		const date = dateEl?.value.trim() ?? '';
		const time = readTimePickerValue('hourly-time');
		const passengers = document.getElementById('hourly-passenger-count')?.textContent?.trim() || '2';

		const hourlyTimeHhEl = document.getElementById('hourly-time-hh') as HTMLSelectElement | null;

		let firstErr: HTMLElement | null = null;
		if (!pickup) { showFieldError(pickupEl, 'Please enter a pickup location.'); firstErr ??= pickupEl; }
		if (!date) { showFieldError(dateEl, 'Please select a pickup date.'); firstErr ??= dateEl; }
		else if (isPastBookingDate(date)) { showFieldError(dateEl, 'Please select a future date.'); firstErr ??= dateEl; }
		if (!time) { showFieldError(hourlyTimeHhEl, 'Please select a pickup time.'); firstErr ??= hourlyTimeHhEl; }

		if (firstErr) {
			firstErr.scrollIntoView({ behavior: 'smooth', block: 'center' });
			(firstErr as HTMLInputElement).focus?.();
			return;
		}
		if (hours < 3) {
			showFormError(formHourly, 'Minimum rental is 3 hours.');
			return;
		}

		const params = new URLSearchParams({ pickup, date, time, hours: String(hours), passengers });
		const hourlyLuggage = getLuggageCounts('home-hourly-luggage');
		if (hourlyLuggage.small > 0) params.set('luggageSmall', String(hourlyLuggage.small));
		if (hourlyLuggage.big   > 0) params.set('luggageBig',   String(hourlyLuggage.big));
		trackBookSearch('hourly', { pickup, date, hours, passengers: Number(passengers) });
		window.location.href = `/book/hourly/results?${params.toString()}`;
	});

	// ── Tours: See prices ──
	document.getElementById('tours-see-prices-btn')?.addEventListener('click', () => {
		clearFormErrors(formTours);

		const select = document.getElementById('tours-select') as HTMLSelectElement;
		const pickupEl = document.getElementById('tours-pickup') as HTMLInputElement;
		const dateEl = document.getElementById('tours-date') as HTMLInputElement;

		const tourId = select?.value || '';
		const tourName = tourId ? select.options[select.selectedIndex]?.text ?? '' : '';
		const pickup = pickupEl?.value.trim() ?? '';
		const date = dateEl?.value.trim() ?? '';
		const time = readTimePickerValue('tours-time');
		const participants = document.getElementById('tours-participant-count')?.textContent?.trim() || '2';

		let firstErr: HTMLElement | null = null;
		if (!tourId) { showFieldError(select, 'Please select a tour.'); firstErr ??= select; }
		if (!date) { showFieldError(dateEl, 'Please select a tour date.'); firstErr ??= dateEl; }
		else if (isPastBookingDate(date)) { showFieldError(dateEl, 'Please select a future date.'); firstErr ??= dateEl; }

		if (firstErr) {
			firstErr.scrollIntoView({ behavior: 'smooth', block: 'center' });
			(firstErr as HTMLElement).focus?.();
			return;
		}

		const params = new URLSearchParams({ tourId, tourName, pickup, date, time, participants });
		trackBookSearch('tour', { tourName, date, participants: Number(participants) });
		window.location.href = `/book/tour/results?${params.toString()}`;
	});
});
</script>
