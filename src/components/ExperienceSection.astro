---
---

<section class="bg-white py-16 lg:py-24 px-6 lg:px-10">
	<div class="max-w-6xl mx-auto">
		<div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-center">

			<!-- Left: Content -->
			<div class="flex flex-col order-2 lg:order-1">

				<!-- Label -->
				<div class="flex items-center gap-2 mb-5">
					<span class="w-2 h-2 rounded-full bg-[#0C6B95] shrink-0"></span>
					<span class="text-sm font-medium text-neutral-500 tracking-wide" data-i18n-el="Ο προσωπικός σας οδηγός, στα χέρια σας" data-i18n-es="Su conductor personal, a su alcance">Your Personal Chauffeur, At Your Fingertips</span>
				</div>

				<!-- Heading -->
				<h2 class="text-4xl lg:text-5xl font-bold text-neutral-900 leading-tight mb-6" data-i18n-el="Εμπειρία" data-i18n-es="Experiencia">
					Experience
				</h2>

				<!-- Description -->
				<p class="text-neutral-500 text-base leading-relaxed mb-4" data-i18n-el="Από πολυσύχναστα κέντρα πόλεων μέχρι απομακρυσμένα αεροδρόμια, οι επαγγελματίες οδηγοί μας είναι διαθέσιμοι όλο το 24ωρο για να εξασφαλίσουν ότι το ταξίδι σας θα είναι αψεγάδιαστο και χωρίς άγχος." data-i18n-es="Desde los bulliciosos centros urbanos hasta los aeropuertos más remotos, nuestros conductores profesionales están disponibles las 24 horas del día para garantizar que su viaje sea impecable y sin estrés.">
					From bustling city centers to remote airports, our professional chauffeurs are available around the clock to ensure your journey is seamless and stress-free.
				</p>
				<p class="text-neutral-500 text-base leading-relaxed mb-8" data-i18n-el="Με το εκτεταμένο δίκτυό μας που καλύπτει πάνω από 100 χώρες, σας συνδέουμε με χιλιάδες πόλεις και αεροδρόμια παγκοσμίως, προσφέροντας ασύγκριτη ευκολία οπουδήποτε ταξιδεύετε." data-i18n-es="Con nuestra extensa red que abarca más de 100 países, le conectamos con miles de ciudades y aeropuertos en todo el mundo, ofreciéndole una comodidad sin igual donde quiera que viaje.">
					With our extensive network spanning over 100 countries, we connect you to thousands of cities and airports worldwide, offering unmatched convenience wherever you travel.
				</p>

				<!-- CTA Button -->
				<div>
					<a
						href="/experiences"
						class="inline-flex items-center gap-2 bg-[#0C6B95] hover:bg-[#0a5c82] text-white font-semibold px-8 py-4 rounded-xl transition-colors duration-200 shadow-lg shadow-[#0C6B95]/25"
						data-i18n-el="Εξερευνήστε εμπειρίες"
						data-i18n-es="Explore experiencias"
					>
						Explore Experiences
						<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
							<path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
						</svg>
					</a>
				</div>

			</div>

			<!-- Right: Illustration -->
			<div class="rounded-2xl overflow-hidden shadow-sm bg-white aspect-[4/3] lg:aspect-auto lg:h-[480px] order-1 lg:order-2">
				<img
					src="/experience_image.avif"
					alt="Experience illustration"
					class="w-full h-full object-cover"
				/>
			</div>

		</div>
	</div>
</section>
