---
const features = [
	{
		title: 'Global',
		titleEl: 'Παγκόσμια κάλυψη',
		titleEs: 'Cobertura global',
		description: 'Wherever your journey leads, Opawey ensures your comfort along the way.',
		descriptionEl: 'Όπου κι αν σας πάει το ταξίδι σας, η Opawey φροντίζει για την άνεσή σας σε κάθε διαδρομή.',
		descriptionEs: 'Donde sea que te lleve tu viaje, Opawey garantiza su comodidad durante todo el recorrido.',
		icon: 'globe',
	},
	{
		title: 'Professional drivers',
		titleEl: 'Επαγγελματίες οδηγοί',
		titleEs: 'Conductores profesionales',
		description: 'Professional Drivers, Timely Rides, Relaxed Travel',
		descriptionEl: 'Επαγγελματίες οδηγοί, απόλυτη συνέπεια στην ώρα, ταξίδι χωρίς άγχος.',
		descriptionEs: 'Conductores profesionales, trayectos puntuales, viajes relajados.',
		icon: 'driver',
	},
	{
		title: 'Chauffeur by the hour',
		titleEl: 'Οδηγός στη διάθεσή σας',
		titleEs: 'Conductor por hora',
		description: 'Hire an hourly chauffeur for your business or leisure needs.',
		descriptionEl: 'Κλείστε οδηγό με την ώρα για τις επαγγελματικές σας υποχρεώσεις ή τις εξορμήσεις σας.',
		descriptionEs: 'Contrata un conductor por hora para sus necesidades de negocio o de ocio.',
		icon: 'clock',
	},
	{
		title: 'City rides',
		titleEl: 'Μετακινήσεις εντός πόλης',
		titleEs: 'Trayectos por la ciudad',
		description: 'Explore the city anytime, anywhere—even long distances.',
		descriptionEl: 'Εξερευνήστε την πόλη όποτε και όπου θέλετε — ακόμη και σε μεγάλες αποστάσεις.',
		descriptionEs: 'Explora la ciudad en cualquier momento y lugar, incluso en largas distancias.',
		icon: 'car',
	},
];
---

<section class="bg-white py-16 lg:py-20 px-6 lg:px-10">
	<div class="max-w-6xl mx-auto">
		<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-8">
			{features.map((feature) => (
				<article class="bg-[#F5F6F8] rounded-xl p-6 flex flex-col">
					<div class="flex justify-between items-start gap-4 mb-4">
						<h3 class="text-lg font-bold text-neutral-900 pr-2" data-i18n-el={feature.titleEl} data-i18n-es={feature.titleEs}>{feature.title}</h3>
						<span class="shrink-0 w-10 h-10 rounded-full bg-neutral-200 flex items-center justify-center text-neutral-700" aria-hidden="true">
							{feature.icon === 'globe' && (
								<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 21a9 9 0 100-18 9 9 0 000 18zm0 0c2.5-2.5 4-6 4-9s-1.5-6.5-4-9m0 18c-2.5-2.5-4-6-4-9s1.5-6.5 4-9M3.6 9h16.8M3.6 15h16.8" /></svg>
							)}
							{feature.icon === 'driver' && (
								<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>
							)}
							{feature.icon === 'clock' && (
								<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
							)}
							{feature.icon === 'car' && (
								<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10a1 1 0 001 1h1m8-1a1 1 0 01-1 1h-1m4-4V6a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1z" /></svg>
							)}
						</span>
					</div>
					<p class="text-sm text-neutral-600 flex-1" data-i18n-el={feature.descriptionEl} data-i18n-es={feature.descriptionEs}>{feature.description}</p>
				</article>
			))}
		</div>
	</div>
</section>
