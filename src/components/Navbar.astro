---
---

<nav class="absolute top-0 left-0 right-0 z-50 bg-[#000724] text-white font-sans flex items-center justify-between px-6 py-1 lg:px-10">
	<!-- Logo -->
	<a href="/" class="flex items-center shrink-0" aria-label="Opawey - Home" data-i18n-aria-el="Opawey - Αρχική" data-i18n-aria-es="Opawey - Inicio">
		<img src="/logo-opaway-white.svg" alt="Opawey" class="h-16 w-auto object-contain" width="187" height="64" />
	</a>

	<!-- Center nav links -->
	<div class="hidden lg:flex items-center gap-8 flex-1 justify-center font-medium tracking-wide">

		<a href="/" data-navlink data-href="/"
			class="pb-0.5 border-b-2 border-transparent text-white hover:text-white/70 hover:border-white/30 transition-colors duration-300"
			data-i18n-el="ΑΡΧΙΚΗ" data-i18n-es="INICIO">
			HOME
		</a>

		<a href="/about" data-navlink data-href="/about"
			class="pb-0.5 border-b-2 border-transparent text-white hover:text-white/70 hover:border-white/30 transition-colors duration-300"
			data-i18n-el="ΣΧΕΤΙΚΑ ΜΕ ΕΜΑΣ" data-i18n-es="SOBRE NOSOTROS">
			ABOUT US
		</a>

		<!-- BOOK ONLINE — hover dropdown -->
		<div class="relative group">
			<button
				data-navlink
				data-href="/book"
				class="flex items-center gap-1 pb-0.5 border-b-2 border-transparent text-white hover:text-white/70 hover:border-white/30 transition-colors duration-300 cursor-default select-none"
				data-i18n-el="ΚΡΑΤΗΣΗ ONLINE" data-i18n-es="RESERVAR ONLINE"
			>
				BOOK ONLINE
				<svg class="w-3.5 h-3.5 mt-0.5 transition-transform duration-200 group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5" aria-hidden="true">
					<path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
				</svg>
			</button>

			<!-- Dropdown panel -->
			<div class="absolute top-full left-1/2 -translate-x-1/2 pt-4 opacity-0 invisible translate-y-1 group-hover:opacity-100 group-hover:visible group-hover:translate-y-0 transition-all duration-200 z-50">
				<!-- little arrow pointer -->
				<div class="absolute top-2.5 left-1/2 -translate-x-1/2 w-3 h-3 bg-white border-l border-t border-neutral-100 rotate-45 shadow-[-1px_-1px_0_0_#f3f4f6]"></div>
				<div class="bg-white rounded-2xl shadow-xl border border-neutral-100 overflow-hidden p-2 min-w-[230px]">

					<!-- Book a Transfer -->
					<a href="/book/transfer" class="flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-sky-50 transition-colors duration-150 group/item">
						<div class="w-9 h-9 rounded-xl bg-[#0C6B95]/10 flex items-center justify-center shrink-0 group-hover/item:bg-[#0C6B95]/15 transition-colors">
							<svg class="w-4 h-4 text-[#0C6B95]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
								<path stroke-linecap="round" stroke-linejoin="round" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
							</svg>
						</div>
						<div>
							<div class="font-semibold text-sm text-neutral-900 group-hover/item:text-[#0C6B95] transition-colors" data-i18n-el="Κράτηση μεταφοράς" data-i18n-es="Reservar un traslado">Book a Transfer</div>
							<div class="text-xs text-neutral-400 mt-0.5" data-i18n-el="Παραλαβές από αεροδρόμιο & μετακινήσεις στην πόλη" data-i18n-es="Recogidas en el aeropuerto y traslados urbanos">Airport pickups & city transfers</div>
						</div>
					</a>

					<!-- Rent per hour -->
					<a href="/book/hourly" class="flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-sky-50 transition-colors duration-150 group/item">
						<div class="w-9 h-9 rounded-xl bg-[#0C6B95]/10 flex items-center justify-center shrink-0 group-hover/item:bg-[#0C6B95]/15 transition-colors">
							<svg class="w-4 h-4 text-[#0C6B95]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
								<path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
							</svg>
						</div>
						<div>
							<div class="font-semibold text-sm text-neutral-900 group-hover/item:text-[#0C6B95] transition-colors" data-i18n-el="Ενοικίαση με την ώρα" data-i18n-es="Alquiler por hora">Rent per hour</div>
							<div class="text-xs text-neutral-400 mt-0.5" data-i18n-el="Υπηρεσία οδηγού με την ώρα" data-i18n-es="Servicio de chófer por hora">Chauffeur service by the hour</div>
						</div>
					</a>

					<!-- Book a Tour -->
					<a href="/book/tour" class="flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-sky-50 transition-colors duration-150 group/item">
						<div class="w-9 h-9 rounded-xl bg-[#0C6B95]/10 flex items-center justify-center shrink-0 group-hover/item:bg-[#0C6B95]/15 transition-colors">
							<svg class="w-4 h-4 text-[#0C6B95]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
								<path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" />
							</svg>
						</div>
						<div>
							<div class="font-semibold text-sm text-neutral-900 group-hover/item:text-[#0C6B95] transition-colors" data-i18n-el="Κράτηση τουρ" data-i18n-es="Reservar un tour">Book a Tour</div>
							<div class="text-xs text-neutral-400 mt-0.5" data-i18n-el="Ιδιωτικά τουρ σε όλη την Ελλάδα" data-i18n-es="Tours privados por Grecia">Private tours across Greece</div>
						</div>
					</a>

					<!-- Experiences -->
					<a href="/experiences" class="flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-sky-50 transition-colors duration-150 group/item">
						<div class="w-9 h-9 rounded-xl bg-[#0C6B95]/10 flex items-center justify-center shrink-0 group-hover/item:bg-[#0C6B95]/15 transition-colors">
							<svg class="w-4 h-4 text-[#0C6B95]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
								<path stroke-linecap="round" stroke-linejoin="round" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
							</svg>
						</div>
						<div>
							<div class="font-semibold text-sm text-neutral-900 group-hover/item:text-[#0C6B95] transition-colors" data-i18n-el="Εμπειρίες" data-i18n-es="Experiencias">Experiences</div>
							<div class="text-xs text-neutral-400 mt-0.5" data-i18n-el="Οινογνωσία, κρουαζιέρες και πολλά άλλα" data-i18n-es="Catas de vino, cruceros y más">Wine tastings, cruises & more</div>
						</div>
					</a>

				</div>
			</div>
		</div>

		<a href="/work-with-us" data-navlink data-href="/work-with-us"
			class="pb-0.5 border-b-2 border-transparent text-white hover:text-white/70 hover:border-white/30 transition-colors duration-300"
			data-i18n-el="ΣΥΝΕΡΓΑΣΙΑ" data-i18n-es="TRABAJA CON NOSOTROS">
			WORK WITH US
		</a>

		<a href="/contact" data-navlink data-href="/contact"
			class="pb-0.5 border-b-2 border-transparent text-white hover:text-white/70 hover:border-white/30 transition-colors duration-300"
			data-i18n-el="ΕΠΙΚΟΙΝΩΝΙΑ" data-i18n-es="CONTACTO">
			CONTACT
		</a>

	</div>

	<!-- Right: Language toggle + Profile icon + Sign-in (guest) or Profile link (logged-in) -->
	<div class="flex items-center gap-3 shrink-0">
		<!-- Language toggle (placeholder for future i18n; persists selection only) -->
		<div id="nav-language-toggle" class="hidden lg:flex items-center gap-0.5 rounded-full border border-neutral-200 bg-white p-0.5 shrink-0">
			<button type="button" data-lang="el" aria-label="Greek" class="lang-btn px-2.5 py-1 text-xs font-semibold rounded-full transition-colors">GR</button>
			<button type="button" data-lang="en" aria-label="English" class="lang-btn px-2.5 py-1 text-xs font-semibold rounded-full transition-colors">EN</button>
			<button type="button" data-lang="es" aria-label="Spanish" class="lang-btn px-2.5 py-1 text-xs font-semibold rounded-full transition-colors">ES</button>
		</div>
		<!-- Hamburger (mobile + tablet only) -->
		<button
			id="nav-burger"
			type="button"
			class="lg:hidden w-10 h-10 rounded-full border border-white/20 hover:bg-white/10 flex items-center justify-center transition-colors duration-200 shrink-0"
			aria-label="Open menu"
			aria-expanded="false"
			aria-controls="nav-drawer"
		>
			<svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true">
				<path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
			</svg>
		</button>
		<!-- Guest: profile icon + Sign in -->
		<div id="nav-auth-guest" class="flex items-center gap-3">
			<a href="/login" aria-label="My Account" data-i18n-aria-el="Ο λογαριασμός μου" data-i18n-aria-es="Mi cuenta" class="w-10 h-10 rounded-full border-2 border-neutral-200 bg-white hover:border-[#0C6B95] hover:bg-sky-50 flex items-center justify-center transition-colors duration-200">
				<svg class="w-5 h-5 text-neutral-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8" aria-hidden="true">
					<circle cx="12" cy="8" r="4" stroke-linecap="round" stroke-linejoin="round"/>
					<path stroke-linecap="round" stroke-linejoin="round" d="M4 20c0-4 3.582-7 8-7s8 3 8 7"/>
				</svg>
			</a>
			<a href="/login" class="hidden sm:inline-flex items-center gap-2 bg-white text-[#000724] font-medium px-5 py-2.5 rounded-full hover:bg-neutral-100 transition-colors" data-i18n-el="Συνδεθείτε" data-i18n-es="Iniciar sesión">
				Sign in
			</a>
		</div>
		<!-- Logged-in: Admin (if admin) + user name + profile link (hidden by default) -->
		<div id="nav-auth-user" class="hidden">
			<div class="flex items-center gap-3">
			<a id="nav-admin-btn" href="/admin" target="_blank" rel="noopener noreferrer" class="hidden items-center gap-2 bg-[#0C6B95] text-white font-medium px-4 py-2 rounded-full hover:bg-[#0a5c82] transition-colors text-sm shrink-0" aria-label="Admin">Admin</a>
			<a id="nav-driver-btn" href="/driver" class="hidden items-center gap-2 bg-emerald-600 text-white font-medium px-4 py-2 rounded-full hover:bg-emerald-700 transition-colors text-sm shrink-0" aria-label="Driver Dashboard">Driver</a>
			<a id="nav-hotel-btn" href="/hotel" class="hidden items-center gap-2 bg-amber-600 text-white font-medium px-4 py-2 rounded-full hover:bg-amber-700 transition-colors text-sm shrink-0" aria-label="Hotel Dashboard">Hotel</a>
			<a id="nav-agency-btn" href="/agency" class="hidden items-center gap-2 bg-violet-600 text-white font-medium px-4 py-2 rounded-full hover:bg-violet-700 transition-colors text-sm shrink-0" aria-label="Agency Dashboard">Agency</a>
			<span id="nav-user-name" class="text-sm font-medium text-neutral-200 truncate max-w-[140px] sm:max-w-[180px]" title=""></span>
			<a href="/profile" aria-label="My profile" data-i18n-aria-el="Το προφίλ μου" data-i18n-aria-es="Mi perfil" class="w-10 h-10 rounded-full border-2 border-neutral-200 bg-white hover:border-[#0C6B95] hover:bg-sky-50 flex items-center justify-center transition-colors duration-200 shrink-0">
				<svg class="w-5 h-5 text-neutral-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8" aria-hidden="true">
					<circle cx="12" cy="8" r="4" stroke-linecap="round" stroke-linejoin="round"/>
					<path stroke-linecap="round" stroke-linejoin="round" d="M4 20c0-4 3.582-7 8-7s8 3 8 7"/>
				</svg>
			</a>
			</div>
		</div>
	</div>
</nav>

<!-- Mobile/tablet backdrop -->
<div
	id="nav-drawer-backdrop"
	class="fixed inset-0 bg-black/60 z-40 hidden lg:hidden"
	aria-hidden="true"
></div>

<!-- Mobile/tablet drawer -->
<div
	id="nav-drawer"
	class="fixed top-0 left-0 right-0 z-50 lg:hidden bg-[#000724] text-white shadow-2xl -translate-y-full transition-transform duration-300 ease-out"
	role="dialog"
	aria-modal="true"
	aria-label="Mobile navigation"
>
	<!-- Drawer header (logo + close) -->
	<div class="flex items-center justify-between px-6 py-1 border-b border-white/10">
		<a href="/" class="flex items-center shrink-0" aria-label="Opawey - Home">
			<img src="/logo-opaway-white.svg" alt="Opawey" class="h-14 w-auto object-contain" width="187" height="56" />
		</a>
		<button
			id="nav-drawer-close"
			type="button"
			class="w-10 h-10 rounded-full border border-white/20 hover:bg-white/10 flex items-center justify-center transition-colors duration-200"
			aria-label="Close menu"
		>
			<svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true">
				<path stroke-linecap="round" stroke-linejoin="round" d="M6 6l12 12M6 18L18 6" />
			</svg>
		</button>
	</div>

	<!-- Scrollable nav body -->
	<nav class="overflow-y-auto max-h-[calc(100vh-4.5rem)] py-4">
		<a href="/" data-drawer-link class="block px-6 py-3 text-base font-medium tracking-wide hover:bg-white/5" data-i18n-el="ΑΡΧΙΚΗ" data-i18n-es="INICIO">HOME</a>
		<a href="/about" data-drawer-link class="block px-6 py-3 text-base font-medium tracking-wide hover:bg-white/5" data-i18n-el="ΣΧΕΤΙΚΑ ΜΕ ΕΜΑΣ" data-i18n-es="SOBRE NOSOTROS">ABOUT US</a>

		<!-- Book Online (always expanded inline on mobile) -->
		<div class="px-6 pt-3 pb-1 text-xs uppercase tracking-widest text-white/50" data-i18n-el="ΚΡΑΤΗΣΗ ONLINE" data-i18n-es="RESERVAR ONLINE">BOOK ONLINE</div>
		<a href="/book/transfer" data-drawer-link class="block pl-10 pr-6 py-3 text-sm hover:bg-white/5" data-i18n-el="Κράτηση μεταφοράς" data-i18n-es="Reservar un traslado">Book a Transfer</a>
		<a href="/book/hourly" data-drawer-link class="block pl-10 pr-6 py-3 text-sm hover:bg-white/5" data-i18n-el="Ενοικίαση με την ώρα" data-i18n-es="Alquiler por hora">Rent per hour</a>
		<a href="/book/tour" data-drawer-link class="block pl-10 pr-6 py-3 text-sm hover:bg-white/5" data-i18n-el="Κράτηση τουρ" data-i18n-es="Reservar un tour">Book a Tour</a>
		<a href="/experiences" data-drawer-link class="block pl-10 pr-6 py-3 text-sm hover:bg-white/5" data-i18n-el="Εμπειρίες" data-i18n-es="Experiencias">Experiences</a>

		<a href="/work-with-us" data-drawer-link class="block px-6 py-3 mt-2 text-base font-medium tracking-wide hover:bg-white/5" data-i18n-el="ΣΥΝΕΡΓΑΣΙΑ" data-i18n-es="TRABAJA CON NOSOTROS">WORK WITH US</a>
		<a href="/contact" data-drawer-link class="block px-6 py-3 text-base font-medium tracking-wide hover:bg-white/5" data-i18n-el="ΕΠΙΚΟΙΝΩΝΙΑ" data-i18n-es="CONTACTO">CONTACT</a>

		<!-- Language toggle (drawer) -->
		<div class="px-6 pt-5 pb-2 border-t border-white/10 mt-3">
			<div class="text-xs uppercase tracking-widest text-white/50 mb-2" data-i18n-el="Γλώσσα" data-i18n-es="Idioma">Language</div>
			<div class="inline-flex items-center gap-0.5 rounded-full border border-white/20 bg-white p-0.5">
				<button type="button" data-lang="el" aria-label="Greek" class="lang-btn px-3 py-1.5 text-xs font-semibold rounded-full transition-colors">GR</button>
				<button type="button" data-lang="en" aria-label="English" class="lang-btn px-3 py-1.5 text-xs font-semibold rounded-full transition-colors">EN</button>
				<button type="button" data-lang="es" aria-label="Spanish" class="lang-btn px-3 py-1.5 text-xs font-semibold rounded-full transition-colors">ES</button>
			</div>
		</div>

		<!-- Drawer auth: guest -->
		<div data-drawer-auth-guest class="px-6 pt-3 pb-4">
			<a href="/login" data-drawer-link class="inline-flex items-center justify-center w-full gap-2 bg-white text-[#000724] font-medium px-5 py-3 rounded-full hover:bg-neutral-100 transition-colors" data-i18n-el="Συνδεθείτε" data-i18n-es="Iniciar sesión">Sign in</a>
		</div>

		<!-- Drawer auth: logged-in user (hidden until JS confirms session) -->
		<div data-drawer-auth-user class="hidden px-6 pt-3 pb-4 space-y-2">
			<p data-drawer-user-name class="text-sm text-white/70 truncate"></p>
			<a data-drawer-role-btn="admin" href="/admin" target="_blank" rel="noopener noreferrer" data-drawer-link class="hidden items-center justify-center w-full gap-2 bg-[#0C6B95] text-white font-medium px-4 py-2.5 rounded-full hover:bg-[#0a5c82] transition-colors text-sm">Admin</a>
			<a data-drawer-role-btn="driver" href="/driver" data-drawer-link class="hidden items-center justify-center w-full gap-2 bg-emerald-600 text-white font-medium px-4 py-2.5 rounded-full hover:bg-emerald-700 transition-colors text-sm">Driver</a>
			<a data-drawer-role-btn="hotel" href="/hotel" data-drawer-link class="hidden items-center justify-center w-full gap-2 bg-amber-600 text-white font-medium px-4 py-2.5 rounded-full hover:bg-amber-700 transition-colors text-sm">Hotel</a>
			<a data-drawer-role-btn="agency" href="/agency" data-drawer-link class="hidden items-center justify-center w-full gap-2 bg-violet-600 text-white font-medium px-4 py-2.5 rounded-full hover:bg-violet-700 transition-colors text-sm">Agency</a>
			<a href="/profile" data-drawer-link class="inline-flex items-center justify-center w-full gap-2 bg-white text-[#000724] font-medium px-5 py-3 rounded-full hover:bg-neutral-100 transition-colors" data-i18n-el="Το προφίλ μου" data-i18n-es="Mi perfil">My Profile</a>
		</div>
	</nav>
</div>

<script>
	import { supabase } from '../lib/supabase';

	const LANG_KEY = 'opaway:lang';
	const SUPPORTED_LANGS = ['el', 'en', 'es'] as const;
	type Lang = typeof SUPPORTED_LANGS[number];

	function getStoredLang(): Lang {
		try {
			const v = localStorage.getItem(LANG_KEY);
			if (v && (SUPPORTED_LANGS as readonly string[]).includes(v)) return v as Lang;
		} catch {}
		return 'en';
	}

	function applyLang(lang: Lang) {
		document.documentElement.lang = lang;
		document.querySelectorAll<HTMLButtonElement>('.lang-btn').forEach((btn) => {
			const isActive = btn.dataset.lang === lang;
			btn.classList.toggle('bg-[#0C6B95]', isActive);
			btn.classList.toggle('text-white', isActive);
			btn.classList.toggle('text-neutral-600', !isActive);
			btn.classList.toggle('hover:bg-neutral-100', !isActive);
		});
	}

	function setLang(lang: Lang) {
		try { localStorage.setItem(LANG_KEY, lang); } catch {}
		applyLang(lang);
		document.dispatchEvent(new CustomEvent('opaway:lang-changed', { detail: lang }));
	}

	function initDrawer() {
		const burger = document.getElementById('nav-burger');
		const drawer = document.getElementById('nav-drawer');
		const backdrop = document.getElementById('nav-drawer-backdrop');
		const closeBtn = document.getElementById('nav-drawer-close');
		if (!burger || !drawer || !backdrop) return;

		const open = () => {
			drawer.classList.remove('-translate-y-full');
			backdrop.classList.remove('hidden');
			burger.setAttribute('aria-expanded', 'true');
			document.body.style.overflow = 'hidden';
		};
		const close = () => {
			drawer.classList.add('-translate-y-full');
			backdrop.classList.add('hidden');
			burger.setAttribute('aria-expanded', 'false');
			document.body.style.overflow = '';
		};

		burger.addEventListener('click', () => {
			const isOpen = burger.getAttribute('aria-expanded') === 'true';
			isOpen ? close() : open();
		});
		closeBtn?.addEventListener('click', close);
		backdrop.addEventListener('click', close);
		document.querySelectorAll<HTMLAnchorElement>('[data-drawer-link]').forEach((a) => {
			a.addEventListener('click', close);
		});
		document.addEventListener('keydown', (e) => {
			if (e.key === 'Escape' && burger.getAttribute('aria-expanded') === 'true') close();
		});
	}

	function initDesktopDropdownTap() {
		const trigger = document.querySelector<HTMLButtonElement>('[data-href="/book"]');
		const panel = trigger?.nextElementSibling as HTMLElement | null;
		if (!trigger || !panel) return;
		trigger.addEventListener('click', (e) => {
			e.preventDefault();
			const isOpen = panel.classList.contains('group-tap-open');
			panel.classList.toggle('group-tap-open', !isOpen);
			panel.classList.toggle('opacity-100', !isOpen);
			panel.classList.toggle('visible', !isOpen);
			panel.classList.toggle('translate-y-0', !isOpen);
			panel.classList.toggle('opacity-0', isOpen);
			panel.classList.toggle('invisible', isOpen);
			panel.classList.toggle('translate-y-1', isOpen);
		});
		document.addEventListener('click', (e) => {
			if (!trigger.parentElement?.contains(e.target as Node)) {
				panel.classList.remove('group-tap-open', 'opacity-100', 'visible', 'translate-y-0');
				panel.classList.add('opacity-0', 'invisible', 'translate-y-1');
			}
		});
	}

	async function initNavbar() {
		// Drawer + dropdown setup (idempotent — re-runs on every astro:page-load)
		initDrawer();
		initDesktopDropdownTap();

		// Active link highlight
		const pathname = window.location.pathname;
		document.querySelectorAll('[data-navlink]').forEach((el) => {
			const link = el as HTMLElement;
			const href = link.getAttribute('data-href') ?? '';
			const isActive = href === '/' ? pathname === '/' : pathname.startsWith(href);
			link.classList.toggle('border-white', isActive);
			link.classList.toggle('border-transparent', !isActive);
		});

		// Language toggle: paint current selection + wire clicks (DOM is fresh on each
		// page-load, so re-binding doesn't accumulate listeners).
		applyLang(getStoredLang());
		document.querySelectorAll<HTMLButtonElement>('.lang-btn').forEach((btn) => {
			btn.addEventListener('click', () => {
				const lang = btn.dataset.lang as Lang | undefined;
				if (lang && (SUPPORTED_LANGS as readonly string[]).includes(lang)) {
					setLang(lang);
				}
			});
		});

		// Auth state — get current session from localStorage (instant, no network)
		const guest = document.getElementById('nav-auth-guest');
		const userEl = document.getElementById('nav-auth-user');
		const nameEl = document.getElementById('nav-user-name');
		const adminBtn = document.getElementById('nav-admin-btn');
		const driverBtn = document.getElementById('nav-driver-btn');
		const hotelBtn = document.getElementById('nav-hotel-btn');
		const agencyBtn = document.getElementById('nav-agency-btn');

		// Drawer counterparts
		const drawerGuest = document.querySelector<HTMLElement>('[data-drawer-auth-guest]');
		const drawerUser = document.querySelector<HTMLElement>('[data-drawer-auth-user]');
		const drawerNameEl = document.querySelector<HTMLElement>('[data-drawer-user-name]');
		const drawerRoleBtn = (role: string) => document.querySelector<HTMLAnchorElement>(`[data-drawer-role-btn="${role}"]`);
		const drawerAdmin = drawerRoleBtn('admin');
		const drawerDriver = drawerRoleBtn('driver');
		const drawerHotel = drawerRoleBtn('hotel');
		const drawerAgency = drawerRoleBtn('agency');

		const { data: { session } } = await supabase.auth.getSession();
		const user = session?.user ?? null;

		// Toggle guest vs logged-in UI (topbar + drawer)
		if (guest) guest.classList.toggle('hidden', !!user);
		if (userEl) userEl.classList.toggle('hidden', !user);
		if (drawerGuest) drawerGuest.classList.toggle('hidden', !!user);
		if (drawerUser) drawerUser.classList.toggle('hidden', !user);

		// Reset role buttons (topbar uses inline-flex, drawer uses flex)
		const resetTopbar = (b: HTMLElement | null) => { if (b) { b.classList.add('hidden'); b.classList.remove('inline-flex'); } };
		const resetDrawer = (b: HTMLElement | null) => { if (b) { b.classList.add('hidden'); b.classList.remove('flex'); } };
		resetTopbar(adminBtn); resetTopbar(driverBtn); resetTopbar(hotelBtn); resetTopbar(agencyBtn);
		resetDrawer(drawerAdmin); resetDrawer(drawerDriver); resetDrawer(drawerHotel); resetDrawer(drawerAgency);

		const showTopbar = (b: HTMLElement | null) => { if (b) { b.classList.remove('hidden'); b.classList.add('inline-flex'); } };
		const showDrawer = (b: HTMLElement | null) => { if (b) { b.classList.remove('hidden'); b.classList.add('flex'); } };

		if (!user) return;

		// Drop the surname on the mobile drawer when the full name would
		// overflow the row (>12 chars). Topbar keeps the full name.
		const drawerName = (full: string) => (full.length > 12 ? (full.split(/\s+/)[0] || full) : full);

		// Set name from auth metadata first (instant)
		const initialName = user.user_metadata?.full_name?.trim() || user.email || 'Account';
		if (nameEl) { nameEl.textContent = initialName; nameEl.setAttribute('title', initialName); }
		if (drawerNameEl) drawerNameEl.textContent = drawerName(initialName);

		// Then fetch DB data for role + display name
		const { data: dbUser } = await supabase
			.from('users')
			.select('display_name, type')
			.eq('id', user.id)
			.maybeSingle();

		if (dbUser?.display_name?.trim()) {
			const dn = dbUser.display_name.trim();
			if (nameEl) { nameEl.textContent = dn; nameEl.setAttribute('title', dn); }
			if (drawerNameEl) drawerNameEl.textContent = drawerName(dn);
		}

		if (dbUser?.type === 'admin') {
			showTopbar(adminBtn);
			showDrawer(drawerAdmin);
		}

		// Check driver status
		const { data: pData } = await supabase
			.from('partners')
			.select('type, status')
			.eq('id', user.id)
			.maybeSingle();

		if (pData?.type === 'driver' && pData?.status === 'approved') {
			showTopbar(driverBtn);
			showDrawer(drawerDriver);
		}
		if (pData?.type === 'hotel' && pData?.status === 'approved') {
			showTopbar(hotelBtn);
			showDrawer(drawerHotel);
		}
		if (pData?.type === 'agency' && pData?.status === 'approved') {
			showTopbar(agencyBtn);
			showDrawer(drawerAgency);
		}
	}

	// Run on every page load (initial + view transitions)
	document.addEventListener('astro:page-load', () => {
		// Reset body scroll lock and drawer position from any previous page
		document.body.style.overflow = '';
		document.getElementById('nav-drawer')?.classList.add('-translate-y-full');
		document.getElementById('nav-drawer-backdrop')?.classList.add('hidden');
		document.getElementById('nav-burger')?.setAttribute('aria-expanded', 'false');
		initNavbar();
	});
</script>
