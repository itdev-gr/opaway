---
import ScrollReveal from './ScrollReveal.astro';

const vehicles = [
	{
		title: 'Sedan',
		titleEl: 'Σεντάν',
		titleEs: 'Sedán',
		models: 'Mercedes-Benz E-Class, or similar.',
		modelsEl: 'Mercedes-Benz E-Class ή αντίστοιχο.',
		modelsEs: 'Mercedes-Benz Clase E o similar.',
		image: '/about-sedan.jpg',
		features: [
			{ en: 'Fits up to 3 people', el: 'Έως 3 επιβάτες', es: 'Hasta 3 pasajeros' },
			{ en: '1 big + 1 small luggage per person', el: '1 μεγάλη και 1 μικρή αποσκευή ανά άτομο', es: '1 maleta grande + 1 pequeña por persona' },
			{ en: 'Available for airport transfers & city tours', el: 'Για μεταφορές από/προς αεροδρόμιο και ξεναγήσεις στην πόλη', es: 'Disponible para traslados al aeropuerto y tours por la ciudad' },
		],
	},
	{
		title: 'Van',
		titleEl: 'Βαν',
		titleEs: 'Furgoneta',
		models: 'Mercedes Vito Tourer, or similar.',
		modelsEl: 'Mercedes Vito Tourer ή αντίστοιχο.',
		modelsEs: 'Mercedes Vito Tourer o similar.',
		image: '/about-van.jpg',
		features: [
			{ en: 'Fits up to 8 people', el: 'Έως 8 επιβάτες', es: 'Hasta 8 pasajeros' },
			{ en: '1 big + 1 small luggage per person', el: '1 μεγάλη και 1 μικρή αποσκευή ανά άτομο', es: '1 maleta grande + 1 pequeña por persona' },
			{ en: 'Ideal for group transfers & private tours', el: 'Ιδανικό για ομαδικές μεταφορές και ιδιωτικές ξεναγήσεις', es: 'Ideal para traslados en grupo y tours privados' },
		],
	},
	{
		title: 'Minibus (or two Vans)',
		titleEl: 'Μίνι λεωφορείο (ή δύο βαν)',
		titleEs: 'Minibús (o dos furgonetas)',
		models: 'Mercedes Sprinter, or similar.',
		modelsEl: 'Mercedes Sprinter ή αντίστοιχο.',
		modelsEs: 'Mercedes Sprinter o similar.',
		image: '/about-minibus.jpg',
		features: [
			{ en: 'Fits up to 18 people', el: 'Έως 18 επιβάτες', es: 'Hasta 18 pasajeros' },
			{ en: '1 big + 1 small luggage per person', el: '1 μεγάλη και 1 μικρή αποσκευή ανά άτομο', es: '1 maleta grande + 1 pequeña por persona' },
			{ en: 'Perfect for large groups & corporate events', el: 'Ιδανικό για μεγάλες ομάδες και εταιρικές εκδηλώσεις', es: 'Perfecto para grupos grandes y eventos corporativos' },
		],
	},
];

function paxCount(features: { en: string; el: string }[]): string | null {
	const match = features.find((f) => /Fits up to/.test(f.en))?.en.match(/Fits up to (\d+)/);
	return match ? match[1] : null;
}
---

<section class="bg-[#EFF6FB] py-20 lg:py-28 px-6 lg:px-10">
	<div class="max-w-6xl mx-auto">

		<ScrollReveal>
			<div class="mb-12">
				<div class="flex items-center gap-3 mb-3">
					<span class="text-[#C97B4A] text-lg leading-none">✦</span>
					<span class="text-sm font-medium text-[#6b5a47] tracking-widest uppercase" data-i18n-el="Ο στόλος μας" data-i18n-es="Nuestra flota">Our Fleet</span>
				</div>
				<h2 class="font-serif text-4xl lg:text-5xl font-bold text-[#2B3A3A] leading-tight" data-i18n-el="Επιλέξτε την κατηγορία που σας ταιριάζει" data-i18n-es="Descubra nuestras clases de servicio">
					Discover our service <span class="italic text-[#C97B4A]">classes</span>
				</h2>
			</div>
		</ScrollReveal>

		<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
			{vehicles.map((v, i) => {
				const pax = paxCount(v.features);
				return (
					<ScrollReveal delay={i * 100}>
						<article
							class="group bg-white rounded-3xl overflow-hidden flex flex-col h-full transition-all duration-500 hover:-translate-y-1"
							style="box-shadow: 0 20px 50px -20px rgba(201,123,74,0.25);"
						>
							<div class="relative bg-neutral-100 aspect-[4/3] overflow-hidden">
								<img
									src={v.image}
									alt={v.title}
									class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.02]"
								/>
								<div
									aria-hidden="true"
									class="absolute inset-0 pointer-events-none"
									style="background: linear-gradient(to top, rgba(201,123,74,0.25), transparent 50%);"
								/>

								{pax && (
									<div
										aria-label={`Fits up to ${pax} passengers`}
										data-i18n-aria-el={`Έως ${pax} επιβάτες`}
										data-i18n-aria-es={`Hasta ${pax} pasajeros`}
										class="absolute top-4 left-4 w-14 h-14 rounded-full bg-[#0C6B95] text-white ring-4 ring-[#EFF6FB] flex flex-col items-center justify-center shadow-lg"
									>
										<span aria-hidden="true" class="font-serif text-lg leading-none font-bold">{pax}</span>
										<span aria-hidden="true" class="text-[9px] tracking-wider uppercase opacity-80 mt-0.5">pax</span>
									</div>
								)}
							</div>

							<div class="p-6 flex flex-col flex-1">
								<h3 class="font-serif text-2xl font-bold text-[#2B3A3A] mb-1" data-i18n-el={v.titleEl} data-i18n-es={v.titleEs}>{v.title}</h3>
								<p class="text-sm italic text-[#6b5a47] mb-4" data-i18n-el={v.modelsEl} data-i18n-es={v.modelsEs}>{v.models}</p>

								<svg
									width="40"
									height="8"
									viewBox="0 0 40 8"
									fill="none"
									aria-hidden="true"
									class="mb-5"
								>
									<path d="M0 4 Q 6 0 12 4 T 24 4 T 36 4 L 40 4" stroke="#C97B4A" stroke-width="1.5" stroke-linecap="round" />
								</svg>

								<ul class="flex flex-col gap-3">
									{v.features.map((f) => (
										<li class="flex items-start gap-3">
											<span class="text-[#C97B4A] font-bold text-base leading-tight mt-0.5 shrink-0">✓</span>
											<span class="text-sm text-[#6b5a47] leading-snug" data-i18n-el={f.el} data-i18n-es={f.es}>{f.en}</span>
										</li>
									))}
								</ul>
							</div>

						</article>
					</ScrollReveal>
				);
			})}
		</div>
	</div>
</section>
