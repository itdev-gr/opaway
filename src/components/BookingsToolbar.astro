---
// Filter/sort toolbar for the admin booking lists (transfers, tours, experiences).
// One instance per page. Each page's script wires these controls by id:
//   bk-status · bk-sort · bk-from · bk-to · bk-today · bk-upcoming · bk-clear
// and re-renders its table from the in-memory rows. See src/lib/booking-filters.ts.
const selectCls =
  'px-3 py-2 border border-neutral-200 rounded-lg text-sm text-neutral-700 bg-white focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95]';
const labelCls = 'text-xs font-semibold text-neutral-500 uppercase tracking-wider';
const btnCls =
  'px-3 py-2 text-sm font-medium rounded-lg border border-neutral-200 text-neutral-600 hover:border-[#0C6B95]/40 hover:text-[#0C6B95] transition-colors';
---

<div class="px-6 py-3 border-b border-neutral-100 flex flex-wrap items-center gap-x-4 gap-y-3 bg-neutral-50/60">
	<div class="flex items-center gap-2">
		<label for="bk-status" class={labelCls}>Show</label>
		<select id="bk-status" class={selectCls}>
			<option value="active" selected>Active</option>
			<option value="cancelled">Cancelled</option>
			<option value="all">All</option>
		</select>
	</div>

	<div class="flex items-center gap-2">
		<label for="bk-sort" class={labelCls}>Sort</label>
		<select id="bk-sort" class={selectCls}>
			<option value="date_asc" selected>Date ↑ (soonest first)</option>
			<option value="date_desc">Date ↓ (latest first)</option>
			<option value="added">Recently added</option>
		</select>
	</div>

	<div class="flex items-center gap-2">
		<label for="bk-from" class={labelCls}>From</label>
		<input id="bk-from" type="date" class={selectCls} />
		<label for="bk-to" class={labelCls}>To</label>
		<input id="bk-to" type="date" class={selectCls} />
	</div>

	<div class="flex items-center gap-2 sm:ml-auto">
		<button id="bk-today" type="button" class={btnCls}>Today</button>
		<button id="bk-upcoming" type="button" class={btnCls}>Upcoming</button>
		<button id="bk-clear" type="button" class={btnCls}>Clear</button>
	</div>
</div>
