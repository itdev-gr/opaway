---
import '../styles/global.css';
import SidebarBadge from './SidebarBadge.astro';

interface Props {
	pageTitle: string;
	pageDescription?: string;
	activeSection?: string;
	docTitle?: string;
}

const {
	pageTitle,
	pageDescription = '',
	activeSection = '',
	docTitle,
} = Astro.props;

const nav = [
	{
		group: 'Main',
		items: [
			{ key: 'reservations', label: 'Reservations', href: '/hotel',             icon: 'inbox', notifId: 'hotel-reservations' },
			{ key: 'commissions',  label: 'Commissions',  href: '/hotel/commissions', icon: 'chart' },
		],
	},
	{
		group: 'Account',
		items: [
			{ key: 'profile', label: 'Profile', href: '/hotel/profile', icon: 'user' },
		],
	},
];
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<title>{docTitle ?? `${pageTitle} — Opawey Hotel`}</title>
	</head>
	<body class="flex min-h-screen bg-neutral-100 font-sans">

		<!-- Mobile overlay -->
		<div id="hotel-sidebar-overlay" class="fixed inset-0 bg-black/40 z-30 hidden md:hidden" aria-hidden="true"></div>

		<!-- Mobile burger -->
		<button
			type="button"
			id="hotel-burger"
			class="fixed top-4 right-4 z-50 md:hidden w-12 h-12 rounded-full bg-[#0C6B95] text-white flex items-center justify-center shadow-lg hover:bg-[#0a5c82] transition-colors"
			aria-label="Open menu"
		>
			<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
				<path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
			</svg>
		</button>

		<!-- Sidebar -->
		<aside
			id="hotel-sidebar"
			class="fixed md:sticky top-0 left-0 h-screen z-40 w-72 shrink-0 bg-[#0C6B95] flex flex-col -translate-x-full md:translate-x-0 transition-transform duration-300 ease-out"
		>
			<!-- Logo -->
			<div class="flex items-center justify-center px-6 py-5 border-b border-white/20">
				<a href="/" target="_blank" rel="noopener noreferrer" aria-label="Opawey — Home">
					<img src="/logo-opawey.png" alt="Opawey" class="h-20 w-auto object-contain brightness-0 invert" width="240" height="80" />
				</a>
			</div>

			<!-- Nav -->
			<nav class="flex-1 pt-4 px-4 flex flex-col overflow-y-auto gap-0.5">
				{nav.map(({ group, items }) => (
					<>
						<p class="text-white/50 text-xs font-semibold tracking-widest uppercase px-3 mb-1 mt-4 first:mt-2">{group}</p>
						{items.map(({ key, label, href, icon, notifId }: { key: string; label: string; href: string; icon: string; notifId?: string }) => {
							const active = activeSection === key;
							return (
								<a
									href={href}
									class={`flex items-center gap-3 py-2.5 px-3 rounded-lg text-white transition-colors border-b border-white/10 ${active ? 'bg-white/20 font-semibold' : 'hover:bg-white/10'}`}
								>
									{icon === 'inbox' && (
										<svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8">
											<path stroke-linecap="round" stroke-linejoin="round" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0H4m13-3l-4 4-4-4" />
										</svg>
									)}
									{icon === 'user' && (
										<svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8">
											<path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
										</svg>
									)}
									{icon === 'chart' && (
										<svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8">
											<path stroke-linecap="round" stroke-linejoin="round" d="M3 3v18h18M7 14l4-4 4 4 6-6" />
										</svg>
									)}
									<span>{label}</span>
									{notifId && <SidebarBadge id={notifId} />}
								</a>
							);
						})}
					</>
				))}

				<!-- Logout -->
				<button
					type="button"
					id="hotel-sidebar-logout"
					class="mt-auto flex items-center gap-3 py-2.5 px-3 rounded-lg text-white/70 hover:text-white hover:bg-white/10 transition-colors w-full text-left mb-2"
				>
					<svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8">
						<path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
					</svg>
					Logout
				</button>
			</nav>

			<div class="px-6 py-4 border-t border-white/20">
				<p class="text-white/50 text-xs">&copy; 2025 Opawey. Hotel Panel.</p>
			</div>
		</aside>

		<!-- Main -->
		<div class="flex-1 flex flex-col min-h-screen min-w-0">

			<!-- Top bar -->
			<header class="bg-white border-b border-neutral-200 px-6 py-4 flex items-center justify-between shrink-0 shadow-sm">
				<div>
					<h1 class="text-xl font-bold text-neutral-900">{pageTitle}</h1>
					{pageDescription && <p class="text-xs text-neutral-400 mt-0.5">{pageDescription}</p>}
				</div>
				<div class="flex items-center gap-3">
					<span id="hotel-user-name" class="text-sm font-medium text-neutral-600 hidden sm:block"></span>
					<div class="flex items-center gap-2 text-xs font-medium text-emerald-600 bg-emerald-50 border border-emerald-200 px-3 py-1.5 rounded-full">
						<span class="w-2 h-2 rounded-full bg-emerald-500 shrink-0"></span>
						Hotel
					</div>
				</div>
			</header>

			<!-- Page content -->
			<main class="flex-1 p-6 md:p-8 overflow-auto">

				<!-- Auth checking overlay -->
				<div id="hotel-auth-check" class="fixed inset-0 bg-white z-50 flex items-center justify-center">
					<div class="flex flex-col items-center gap-4">
						<svg class="w-10 h-10 text-[#0C6B95] animate-spin" fill="none" viewBox="0 0 24 24">
							<circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
							<path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"></path>
						</svg>
						<p class="text-neutral-500 text-sm">Verifying access&hellip;</p>
					</div>
				</div>

				<slot />
			</main>
		</div>

	</body>
</html>

<script>
	import { supabase } from '../lib/supabase';
	import { partnerReservationsCount, markPartnerReservationsSeen, subscribeTables } from '../lib/notifications';

	function initHotelLayout() {
		const overlay    = document.getElementById('hotel-sidebar-overlay');
		const sidebar    = document.getElementById('hotel-sidebar');
		const burger     = document.getElementById('hotel-burger');
		const authCheck  = document.getElementById('hotel-auth-check');
		const userNameEl = document.getElementById('hotel-user-name');

		function openSidebar()  { sidebar?.classList.remove('-translate-x-full'); overlay?.classList.remove('hidden'); document.body.style.overflow = 'hidden'; }
		function closeSidebar() { sidebar?.classList.add('-translate-x-full');    overlay?.classList.add('hidden');    document.body.style.overflow = ''; }
		burger?.addEventListener('click', () => sidebar?.classList.contains('-translate-x-full') ? openSidebar() : closeSidebar());
		overlay?.addEventListener('click', closeSidebar);
		sidebar?.querySelectorAll('a').forEach(l => l.addEventListener('click', closeSidebar));

		document.getElementById('hotel-sidebar-logout')?.addEventListener('click', () => {
			closeSidebar();
			window.location.href = '/logout';
		});

		/* -- Hotel guard (one-time check) -- */
		(async () => {
			const { data: { session } } = await supabase.auth.getSession();
			if (!session?.user) { window.location.href = '/login'; return; }
			try {
				const { data } = await supabase
					.from('partners')
					.select('type, status, hotel_name, full_name')
					.eq('id', session.user.id)
					.maybeSingle();
				if (data?.type !== 'hotel' || data?.status !== 'approved') { window.location.href = '/login'; return; }
				if (userNameEl) {
					userNameEl.textContent =
						data?.hotel_name?.trim() ||
						data?.full_name?.trim() ||
						session.user.user_metadata?.full_name?.trim() ||
						session.user.email || 'Hotel';
				}
				authCheck?.classList.add('hidden');

				const hotelUserId = session.user.id;

				async function refreshHotelBadge() {
					try {
						const n = await partnerReservationsCount(hotelUserId);
						const el = document.querySelector('[data-notif-badge="hotel-reservations"]');
						if (!el) return;
						el.textContent = n > 99 ? '99+' : String(n);
						el.classList.toggle('hidden', n === 0);
					} catch (err) {
						console.error('Hotel badge refresh failed:', err);
					}
				}

				if (window.location.pathname === '/hotel' || window.location.pathname === '/hotel/') {
					markPartnerReservationsSeen(hotelUserId);
				}

				await refreshHotelBadge();
				const unsubHotelNotif = subscribeTables(['transfers', 'tours', 'experiences'], refreshHotelBadge);
				window.addEventListener('beforeunload', () => unsubHotelNotif());
			} catch { window.location.href = '/login'; }
		})();
	}

	initHotelLayout();
	document.addEventListener('astro:page-load', initHotelLayout);
</script>
