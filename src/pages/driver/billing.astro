---
import DriverLayout from '../../components/DriverLayout.astro';
---

<DriverLayout pageTitle="Payment Reports" pageDescription="View your billing history and download reports" activeSection="billing">

	<!-- Loading state -->
	<div id="billing-loading" class="flex items-center justify-center py-20">
		<svg class="w-8 h-8 text-[#0C6B95] animate-spin" fill="none" viewBox="0 0 24 24">
			<circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
			<path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"></path>
		</svg>
	</div>

	<!-- Billing content -->
	<div id="billing-content" class="hidden space-y-6">

		<!-- Filters -->
		<div class="bg-white rounded-2xl border border-neutral-200 shadow-sm p-4 flex flex-wrap items-end gap-4">
			<div class="flex flex-col gap-1">
				<label for="filter-status" class="text-xs font-semibold text-neutral-500 uppercase tracking-wider">Status</label>
				<select id="filter-status" class="px-3 py-2 border border-neutral-200 rounded-lg text-sm bg-white text-neutral-800">
					<option value="all">All</option>
					<option value="paid">Paid</option>
					<option value="pending">Pending</option>
				</select>
			</div>
			<div class="flex flex-col gap-1">
				<label for="filter-year" class="text-xs font-semibold text-neutral-500 uppercase tracking-wider">Year</label>
				<select id="filter-year" class="px-3 py-2 border border-neutral-200 rounded-lg text-sm bg-white text-neutral-800">
					<option value="all">All</option>
				</select>
			</div>
			<div class="flex flex-col gap-1">
				<label for="filter-month" class="text-xs font-semibold text-neutral-500 uppercase tracking-wider">Month</label>
				<select id="filter-month" class="px-3 py-2 border border-neutral-200 rounded-lg text-sm bg-white text-neutral-800">
					<option value="all">All</option>
				</select>
			</div>
			<button type="button" id="filter-reset" class="px-3 py-2 text-xs text-neutral-600 hover:text-[#0C6B95] border border-neutral-200 rounded-lg hover:border-[#0C6B95]/30 hover:bg-sky-50 transition-colors">Reset</button>
			<div class="ml-auto text-sm text-neutral-500"><span id="billing-count">0</span> report(s)</div>
		</div>

		<!-- Table -->
		<div class="bg-white rounded-2xl border border-neutral-200 shadow-sm overflow-hidden">
			<div class="overflow-x-auto">
				<table class="w-full text-sm text-left">
					<thead class="bg-neutral-50 border-b border-neutral-200">
						<tr>
							<th class="px-6 py-3.5 text-xs font-semibold text-neutral-500 uppercase tracking-wider">Status</th>
							<th class="px-6 py-3.5 text-xs font-semibold text-neutral-500 uppercase tracking-wider">Date</th>
							<th class="px-6 py-3.5 text-xs font-semibold text-neutral-500 uppercase tracking-wider">Amount</th>
							<th class="px-6 py-3.5 text-xs font-semibold text-neutral-500 uppercase tracking-wider">Payment Report</th>
							<th class="px-6 py-3.5 text-xs font-semibold text-neutral-500 uppercase tracking-wider">Invoice</th>
						</tr>
					</thead>
					<tbody id="billing-tbody" class="divide-y divide-neutral-100">
						<tr><td colspan="5" class="px-6 py-10 text-center text-neutral-400">No billing reports yet.</td></tr>
					</tbody>
				</table>
			</div>
		</div>

	</div>
</DriverLayout>

<script>
	import { supabase } from '../../lib/supabase';

	function initBilling() {
		const loadingEl = document.getElementById('billing-loading');
		const contentEl = document.getElementById('billing-content');
		const authCheck = document.getElementById('driver-auth-check');
		const tbody     = document.getElementById('billing-tbody');
		const countEl   = document.getElementById('billing-count');

		function waitForAuth(): Promise<void> {
			return new Promise((resolve) => {
				if (authCheck?.classList.contains('hidden')) { resolve(); return; }
				const obs = new MutationObserver(() => {
					if (authCheck?.classList.contains('hidden')) { obs.disconnect(); resolve(); }
				});
				if (authCheck) obs.observe(authCheck, { attributes: true, attributeFilter: ['class'] });
			});
		}

		const monthNames = ['January','February','March','April','May','June','July','August','September','October','November','December'];

		let allReports: any[] = [];

		function applyFilters(): any[] {
			const status = (document.getElementById('filter-status') as HTMLSelectElement)?.value || 'all';
			const year   = (document.getElementById('filter-year')   as HTMLSelectElement)?.value || 'all';
			const month  = (document.getElementById('filter-month')  as HTMLSelectElement)?.value || 'all';
			return allReports.filter(r => {
				if (status !== 'all' && r.status !== status) return false;
				if (year   !== 'all' && String(r.year)  !== year) return false;
				if (month  !== 'all' && String(r.month) !== month) return false;
				return true;
			});
		}

		function populateYearOptions() {
			const yearSel = document.getElementById('filter-year') as HTMLSelectElement | null;
			if (!yearSel) return;
			const years = Array.from(new Set(allReports.map(r => r.year).filter(Boolean))).sort((a, b) => b - a);
			yearSel.innerHTML = '<option value="all">All</option>' + years.map(y => `<option value="${y}">${y}</option>`).join('');
		}

		function populateMonthOptions() {
			const monthSel = document.getElementById('filter-month') as HTMLSelectElement | null;
			if (!monthSel) return;
			monthSel.innerHTML = '<option value="all">All</option>' + monthNames.map((n, i) => `<option value="${i + 1}">${n}</option>`).join('');
		}

		function rerender() { renderRows(applyFilters()); }

		function renderRows(reports: any[]) {
			if (!tbody) return;
			if (countEl) countEl.textContent = String(reports.length);
			if (reports.length === 0) {
				tbody.innerHTML = '<tr><td colspan="5" class="px-6 py-10 text-center text-neutral-400">No billing reports yet.</td></tr>';
				return;
			}
			tbody.innerHTML = reports.map(r => {
				const isPaid = r.status === 'paid';
				const badge = isPaid
					? '<span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-emerald-50 text-emerald-700 border border-emerald-200">Paid</span>'
					: '<span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-amber-50 text-amber-700 border border-amber-200">Pending</span>';
				const monthLabel = monthNames[(r.month || 1) - 1] || '';
				const amount = r.amount != null ? `€${(Number(r.amount) || 0).toFixed(2)}` : '-';
				const reportBtn = r.report_url
					? `<a href="${r.report_url}" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 text-xs px-3 py-1.5 rounded-lg border border-[#0C6B95]/30 text-[#0C6B95] hover:bg-[#0C6B95]/5 transition-colors">
						<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
						Download</a>`
					: '<span class="text-neutral-400 text-xs">-</span>';
				const invoiceBtn = r.invoice_url
					? `<a href="${r.invoice_url}" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 text-xs px-3 py-1.5 rounded-lg border border-[#0C6B95]/30 text-[#0C6B95] hover:bg-[#0C6B95]/5 transition-colors">
						<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
						Download</a>`
					: '<span class="text-neutral-400 text-xs">-</span>';

				return `<tr class="hover:bg-neutral-50 transition-colors">
					<td class="px-6 py-4">${badge}</td>
					<td class="px-6 py-4 font-medium text-neutral-800">${monthLabel} ${r.year || ''}</td>
					<td class="px-6 py-4 text-neutral-800">${amount}</td>
					<td class="px-6 py-4">${reportBtn}</td>
					<td class="px-6 py-4">${invoiceBtn}</td>
				</tr>`;
			}).join('');
		}

		(async () => {
			const { data: { session } } = await supabase.auth.getSession();
			if (!session?.user) return;
			await waitForAuth();

			const { data, error } = await supabase
				.from('billing_reports')
				.select('*')
				.eq('partner_id', session.user.id)
				.order('year', { ascending: false })
				.order('month', { ascending: false });

			allReports = !error ? (data || []) : [];
			populateYearOptions();
			populateMonthOptions();
			rerender();

			// Filter change listeners
			['filter-status', 'filter-year', 'filter-month'].forEach(id => {
				document.getElementById(id)?.addEventListener('change', rerender);
			});
			document.getElementById('filter-reset')?.addEventListener('click', () => {
				(document.getElementById('filter-status') as HTMLSelectElement).value = 'all';
				(document.getElementById('filter-year')   as HTMLSelectElement).value = 'all';
				(document.getElementById('filter-month')  as HTMLSelectElement).value = 'all';
				rerender();
			});

			loadingEl?.classList.add('hidden');
			contentEl?.classList.remove('hidden');
		})();
	}

	initBilling();
	document.addEventListener('astro:page-load', initBilling);
</script>
