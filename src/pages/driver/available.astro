---
import DriverLayout from '../../components/DriverLayout.astro';
---

<DriverLayout pageTitle="Available Rides" activeSection="available">

	<!-- Rides list -->
	<div id="rides-list" class="space-y-3">
		<div class="flex items-center justify-center py-12 text-neutral-400 text-sm">Loading...</div>
	</div>

	<!-- Empty state -->
	<div id="empty-state" class="hidden flex flex-col items-center justify-center py-16 text-center">
		<svg class="w-12 h-12 text-neutral-300 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
			<path stroke-linecap="round" stroke-linejoin="round" d="M8 17a2 2 0 100-4 2 2 0 000 4zm8 0a2 2 0 100-4 2 2 0 000 4zM5 17H3v-5l2-5h14l2 5v5h-2m-9 0h6" />
		</svg>
		<p class="text-neutral-500 font-medium">No available rides</p>
		<p class="text-sm text-neutral-400 mt-1">New ride requests will appear here when available.</p>
	</div>

	<!-- Success toast -->
	<div id="toast" class="fixed bottom-6 right-6 z-50 hidden">
		<div class="flex items-center gap-3 px-5 py-3 bg-emerald-600 text-white rounded-xl shadow-lg text-sm font-medium">
			<svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
				<path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
			</svg>
			<span id="toast-message">Ride accepted successfully!</span>
		</div>
	</div>

	<!-- Confirm modal -->
	<div id="confirm-modal" class="fixed inset-0 z-50 hidden flex items-center justify-center bg-black/40 backdrop-blur-sm px-4">
		<div class="bg-white rounded-2xl shadow-2xl border border-neutral-200 w-full max-w-sm p-6">
			<h3 class="text-lg font-bold text-neutral-900 mb-2">Accept this ride?</h3>
			<p class="text-sm text-neutral-500 mb-6">This ride will be assigned to you. You can view it in your upcoming rides.</p>
			<div class="flex gap-3">
				<button id="confirm-cancel" type="button"
					class="flex-1 py-2.5 rounded-xl border border-neutral-200 text-neutral-700 text-sm font-semibold hover:bg-neutral-50 transition-colors">
					Cancel
				</button>
				<button id="confirm-accept" type="button"
					class="flex-1 py-2.5 rounded-xl bg-emerald-600 hover:bg-emerald-700 text-white text-sm font-semibold transition-colors">
					Accept
				</button>
			</div>
		</div>
	</div>

</DriverLayout>

<script>
	import { supabase } from '../../lib/supabase';

	interface Ride {
		id: string;
		date: string;
		time: string;
		from: string;
		to: string;
		vehicle_name: string;
		passengers: number;
		driver_uid: string;
		total_price: number;
	}

	let allRides: Ride[] = [];
	let hiddenIds = new Set<string>();
	let pendingAcceptId: string | null = null;
	let partnerName = '';

	const escHtml = (s: string) => s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');

	function getVisibleRides(): Ride[] {
		return allRides.filter(r => !hiddenIds.has(r.id));
	}

	function renderRides(rides: Ride[]) {
		const listEl = document.getElementById('rides-list')!;
		const emptyEl = document.getElementById('empty-state')!;

		if (rides.length === 0) {
			listEl.innerHTML = '';
			emptyEl.classList.remove('hidden');
			return;
		}

		emptyEl.classList.add('hidden');

		listEl.innerHTML = rides.map(r => {
			const ref = r.id.substring(0, 8).toUpperCase();
			const priceStr = `€${(r.total_price || 0).toFixed(2)}`;

			return `
				<div class="bg-white rounded-2xl border border-neutral-200 shadow-sm" data-ride-id="${escHtml(r.id)}">
					<div class="grid grid-cols-1 md:grid-cols-6 gap-4 p-5 items-center">
						<!-- Booking Ref + Date -->
						<div class="flex flex-col gap-1">
							<p class="text-xs font-semibold text-neutral-500 uppercase tracking-wider">Booking Ref</p>
							<p class="text-sm font-bold text-neutral-900 font-mono">${escHtml(ref)}</p>
							<p class="text-xs text-neutral-500 mt-1">${r.date ? `${escHtml(r.date)} ${escHtml(r.time || '')}`.trim() : '—'}</p>
						</div>
						<!-- Pickup -->
						<div class="flex flex-col gap-1">
							<p class="text-xs font-semibold text-neutral-500 uppercase tracking-wider">Pickup</p>
							<div class="flex items-start gap-2">
								<svg class="w-4 h-4 text-emerald-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
									<circle cx="12" cy="12" r="3" />
									<path stroke-linecap="round" stroke-linejoin="round" d="M12 2v4m0 12v4m10-10h-4M6 12H2" />
								</svg>
								<p class="text-sm text-neutral-800">${escHtml(r.from || '—')}</p>
							</div>
						</div>
						<!-- Dropoff -->
						<div class="flex flex-col gap-1">
							<p class="text-xs font-semibold text-neutral-500 uppercase tracking-wider">Dropoff</p>
							<div class="flex items-start gap-2">
								<svg class="w-4 h-4 text-red-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
									<path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
									<path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
								</svg>
								<p class="text-sm text-neutral-800">${escHtml(r.to || '—')}</p>
							</div>
						</div>
						<!-- Details -->
						<div class="flex flex-col gap-2">
							<div class="flex items-center gap-2 flex-wrap">
								${r.vehicle_name ? `<span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-neutral-100 text-neutral-700 border border-neutral-200">${escHtml(r.vehicle_name)}</span>` : ''}
								<span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-sky-50 text-sky-700 border border-sky-200">New</span>
							</div>
							<div class="flex items-center gap-1.5 text-xs text-neutral-500">
								<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
									<path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
								</svg>
								${r.passengers || '—'} passenger${(r.passengers || 0) !== 1 ? 's' : ''}
							</div>
						</div>
						<!-- Price -->
						<div class="flex flex-col gap-1 md:items-end">
							<p class="text-xs font-semibold text-neutral-500 uppercase tracking-wider">Total</p>
							<p class="text-lg font-bold text-neutral-900">${priceStr}</p>
						</div>
						<!-- Actions -->
						<div class="flex items-center gap-2 justify-end">
							<button type="button" data-accept="${escHtml(r.id)}"
								class="px-4 py-2 rounded-xl bg-emerald-600 hover:bg-emerald-700 text-white text-sm font-semibold transition-colors shadow-sm">
								Accept
							</button>
							<button type="button" data-reject="${escHtml(r.id)}"
								class="px-4 py-2 rounded-xl border border-neutral-200 text-neutral-600 text-sm font-semibold hover:bg-neutral-50 transition-colors">
								Reject
							</button>
						</div>
					</div>
				</div>
			`;
		}).join('');

		// Attach accept handlers
		listEl.querySelectorAll<HTMLButtonElement>('[data-accept]').forEach(btn => {
			btn.addEventListener('click', () => {
				pendingAcceptId = btn.dataset.accept || null;
				document.getElementById('confirm-modal')?.classList.remove('hidden');
			});
		});

		// Attach reject handlers
		listEl.querySelectorAll<HTMLButtonElement>('[data-reject]').forEach(btn => {
			btn.addEventListener('click', () => {
				const rideId = btn.dataset.reject || '';
				hiddenIds.add(rideId);
				// Remove the card with animation
				const card = listEl.querySelector(`[data-ride-id="${rideId}"]`);
				if (card) {
					(card as HTMLElement).style.transition = 'opacity 0.3s, transform 0.3s';
					(card as HTMLElement).style.opacity = '0';
					(card as HTMLElement).style.transform = 'translateX(20px)';
					setTimeout(() => {
						renderRides(getVisibleRides());
					}, 300);
				}
			});
		});
	}

	function showToast(message: string) {
		const toast = document.getElementById('toast')!;
		const msgEl = document.getElementById('toast-message')!;
		msgEl.textContent = message;
		toast.classList.remove('hidden');
		setTimeout(() => toast.classList.add('hidden'), 3000);
	}

	async function loadRides() {
		const { data: { user } } = await supabase.auth.getUser();
		if (!user) return;

		{
			// Load partner name
			const { data: partnerData } = await supabase
				.from('partners')
				.select('*')
				.eq('id', user.id)
				.single();

			if (partnerData) {
				partnerName = partnerData.full_name || partnerData.name || '';
			}

			// Load all rides with status 'new'
			const { data: rows, error } = await supabase
				.from('transfers')
				.select('*')
				.eq('ride_status', 'new')
				.eq('released_to_drivers', true)
				.order('created_at', { ascending: false });

			if (error) {
				console.error('Driver available rides load failed:', error);
				document.getElementById('rides-list')!.innerHTML =
					`<div class="flex items-center justify-center py-12 text-neutral-400 text-sm">Could not load rides.</div>`;
				return;
			}

			// Client-side filter: only rides without a driver assigned
			allRides = (rows || [])
				.map((data: any) => ({
					id: data.id,
					date: data.date || '',
					time: data.time || '',
					from: data.from || '',
					to: data.to || '',
					vehicle_name: data.vehicle_name || '',
					passengers: data.passengers || 0,
					driver_uid: data.driver_uid || '',
					total_price: Number(data.total_price) || 0,
				}))
				.filter(r => !r.driver_uid || r.driver_uid === '');

			renderRides(getVisibleRides());
		}
	}

	// Confirm modal handlers
	document.getElementById('confirm-cancel')?.addEventListener('click', () => {
		pendingAcceptId = null;
		document.getElementById('confirm-modal')?.classList.add('hidden');
	});

	document.getElementById('confirm-modal')?.addEventListener('click', (e) => {
		if (e.target === e.currentTarget) {
			pendingAcceptId = null;
			document.getElementById('confirm-modal')?.classList.add('hidden');
		}
	});

	document.getElementById('confirm-accept')?.addEventListener('click', async () => {
		if (!pendingAcceptId) return;
		const rideId = pendingAcceptId;
		const { data: { user } } = await supabase.auth.getUser();
		if (!user) return;

		const btn = document.getElementById('confirm-accept') as HTMLButtonElement;
		btn.disabled = true;
		btn.textContent = 'Accepting...';

		try {
			const { error } = await supabase
				.from('transfers')
				.update({
					driver_uid: user.id,
					driver: partnerName,
					ride_status: 'assigned',
				})
				.eq('id', rideId);

			if (error) {
				console.error('Driver accept ride failed:', error);
				showToast(`Failed to accept ride: [${error.code ?? 'unknown'}] ${error.message}`);
				return;
			}

			// Remove from local list
			allRides = allRides.filter(r => r.id !== rideId);
			hiddenIds.delete(rideId);

			document.getElementById('confirm-modal')?.classList.add('hidden');
			renderRides(getVisibleRides());
			showToast('Ride accepted successfully!');
		} finally {
			btn.disabled = false;
			btn.textContent = 'Accept';
			pendingAcceptId = null;
		}
	});

	// Auth guard
	const authEl = document.getElementById('driver-auth-check');
	const observer = new MutationObserver(() => {
		if (authEl?.classList.contains('hidden')) {
			observer.disconnect();
			loadRides();
		}
	});
	if (authEl) observer.observe(authEl, { attributes: true, attributeFilter: ['class'] });
</script>
