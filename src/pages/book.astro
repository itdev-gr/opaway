---
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<main class="min-h-screen bg-sky-50 pt-36 pb-24 px-6 lg:px-10">
		<div class="max-w-3xl mx-auto">

			<!-- Header -->
			<div class="text-center mb-14">
				<div class="flex items-center justify-center gap-2 mb-4">
					<span class="w-2 h-2 rounded-full bg-[#0C6B95] shrink-0"></span>
					<span class="text-sm font-medium text-[#0C6B95] tracking-widest uppercase" data-i18n-el="Τι θα θέλατε να κλείσετε;" data-i18n-es="¿Qué le gustaría reservar?">What would you like to book?</span>
				</div>
				<h1 class="text-5xl lg:text-6xl font-bold text-neutral-900 leading-tight" data-i18n-el="Online Κράτηση" data-i18n-es="Reservar online">Book Online</h1>
				<p class="text-neutral-500 text-lg mt-4 max-w-xl mx-auto" data-i18n-el="Επιλέξτε την υπηρεσία που σας ενδιαφέρει και αναλαμβάνουμε εμείς τα υπόλοιπα." data-i18n-es="Elija el tipo de servicio que desea reservar y nosotros nos encargamos del resto.">Choose the type of service you'd like to book and we'll take care of the rest.</p>
			</div>

			<!-- Option cards -->
			<div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-6">

				<!-- Book a Transfer -->
				<a
					href="/book/transfer"
					class="group bg-white rounded-3xl p-8 border border-neutral-200 shadow-sm hover:shadow-xl hover:border-[#0C6B95]/30 transition-all duration-300 flex flex-col"
				>
					<div class="w-14 h-14 rounded-2xl bg-[#0C6B95] flex items-center justify-center mb-6 shadow-lg shadow-[#0C6B95]/25 group-hover:scale-110 transition-transform duration-300">
						<svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8">
							<path stroke-linecap="round" stroke-linejoin="round" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
						</svg>
					</div>
					<h2 class="text-2xl font-bold text-neutral-900 mb-2" data-i18n-el="Κλείστε μεταφορά" data-i18n-es="Reservar un traslado">Book a Transfer</h2>
					<p class="text-neutral-500 text-sm leading-relaxed flex-1 mb-6" data-i18n-el="Παραλαβές από αεροδρόμιο, μεταφορές σε ξενοδοχεία και διαδρομές μεταξύ πόλεων με ιδιωτικό σοφέρ." data-i18n-es="Recogidas en aeropuerto, traslados a hoteles y trayectos entre ciudades con chófer privado.">Airport pickups, hotel drop-offs, and city-to-city transfers with a private chauffeur.</p>
					<span class="inline-flex items-center gap-2 text-[#0C6B95] font-semibold text-sm group-hover:gap-3 transition-all duration-200" data-i18n-el="Κράτηση τώρα" data-i18n-es="Reservar ahora">
						Book Now
						<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
							<path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
						</svg>
					</span>
				</a>

				<!-- Rent per Hour -->
				<a
					href="/book/hourly"
					class="group bg-white rounded-3xl p-8 border border-neutral-200 shadow-sm hover:shadow-xl hover:border-[#0C6B95]/30 transition-all duration-300 flex flex-col"
				>
					<div class="w-14 h-14 rounded-2xl bg-[#0C6B95] flex items-center justify-center mb-6 shadow-lg shadow-[#0C6B95]/25 group-hover:scale-110 transition-transform duration-300">
						<svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8">
							<path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
						</svg>
					</div>
					<h2 class="text-2xl font-bold text-neutral-900 mb-2" data-i18n-el="Ενοικίαση με την ώρα" data-i18n-es="Alquiler por hora">Rent per Hour</h2>
					<p class="text-neutral-500 text-sm leading-relaxed flex-1 mb-6" data-i18n-el="Ιδιωτικός σοφέρ στη διάθεσή σας με χρέωση ανά ώρα — ιδανικό για εργάσιμες ημέρες ή διαδρομές με πολλές στάσεις." data-i18n-es="Disponga de un chófer privado por hora — ideal para jornadas de trabajo o trayectos con varias paradas.">Keep a private chauffeur at your disposal by the hour — ideal for business days or multi-stop trips.</p>
					<span class="inline-flex items-center gap-2 text-[#0C6B95] font-semibold text-sm group-hover:gap-3 transition-all duration-200" data-i18n-el="Κράτηση τώρα" data-i18n-es="Reservar ahora">
						Book Now
						<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
							<path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
						</svg>
					</span>
				</a>

				<!-- Book a Tour -->
				<a
					href="/book/tour"
					class="group bg-white rounded-3xl p-8 border border-neutral-200 shadow-sm hover:shadow-xl hover:border-[#0C6B95]/30 transition-all duration-300 flex flex-col"
				>
					<div class="w-14 h-14 rounded-2xl bg-[#0C6B95] flex items-center justify-center mb-6 shadow-lg shadow-[#0C6B95]/25 group-hover:scale-110 transition-transform duration-300">
						<svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8">
							<path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" />
						</svg>
					</div>
					<h2 class="text-2xl font-bold text-neutral-900 mb-2" data-i18n-el="Κλείστε ένα τουρ" data-i18n-es="Reservar un tour">Book a Tour</h2>
					<p class="text-neutral-500 text-sm leading-relaxed flex-1 mb-6" data-i18n-el="Οινογνωσίες, κρουαζιέρες στην Αθηναϊκή Ριβιέρα και προσεκτικά επιλεγμένες εμπειρίες σε όλη την Ελλάδα, με έμπειρους ξεναγούς." data-i18n-es="Catas de vino, cruceros por la Riviera y experiencias seleccionadas por toda Grecia con guías expertos.">Wine tastings, Riviera cruises, and curated experiences across Greece with expert guides.</p>
					<span class="inline-flex items-center gap-2 text-[#0C6B95] font-semibold text-sm group-hover:gap-3 transition-all duration-200" data-i18n-el="Κράτηση τώρα" data-i18n-es="Reservar ahora">
						Book Now
						<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
							<path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
						</svg>
					</span>
				</a>

				<!-- Book an Experience -->
				<a
					href="/experiences"
					class="group bg-white rounded-3xl p-8 border border-neutral-200 shadow-sm hover:shadow-xl hover:border-[#0C6B95]/30 transition-all duration-300 flex flex-col"
				>
					<div class="w-14 h-14 rounded-2xl bg-[#0C6B95] flex items-center justify-center mb-6 shadow-lg shadow-[#0C6B95]/25 group-hover:scale-110 transition-transform duration-300">
						<svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8">
							<path stroke-linecap="round" stroke-linejoin="round" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
						</svg>
					</div>
					<h2 class="text-2xl font-bold text-neutral-900 mb-2" data-i18n-el="Κλείστε μια εμπειρία" data-i18n-es="Reservar una experiencia">Book an Experience</h2>
					<p class="text-neutral-500 text-sm leading-relaxed flex-1 mb-6" data-i18n-el="Μοναδικές, επιλεγμένες εμπειρίες σε όλη την Ελλάδα — από οινογνωσίες μέχρι κρουαζιέρες ηλιοβασιλέματος και πολιτιστικές αποδράσεις." data-i18n-es="Experiencias únicas seleccionadas por toda Grecia — desde catas de vino hasta cruceros al atardecer e inmersiones culturales.">Unique curated experiences across Greece — from wine tastings to sunset cruises and cultural immersions.</p>
					<span class="inline-flex items-center gap-2 text-[#0C6B95] font-semibold text-sm group-hover:gap-3 transition-all duration-200" data-i18n-el="Κράτηση τώρα" data-i18n-es="Reservar ahora">
						Book Now
						<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
							<path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
						</svg>
					</span>
				</a>

			</div>
		</div>
	</main>
</Layout>
