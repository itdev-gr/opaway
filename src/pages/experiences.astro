---
import Layout from '../layouts/Layout.astro';
import { renderTimePickerHTML } from '../lib/time-picker';
---

<Layout>
	<main class="min-h-screen bg-[#EFF6FB] pt-36 pb-24 px-6 lg:px-10">
		<div class="max-w-6xl mx-auto">

			<!-- Sub-navigation tabs — quick links to the other booking flows -->
			<div class="flex items-center gap-3 mb-10">
				<a href="/book/transfer" class="flex items-center gap-2 px-5 py-2.5 rounded-xl bg-white border border-neutral-200 text-neutral-600 font-semibold text-sm hover:border-[#0C6B95]/40 hover:text-[#0C6B95] transition-colors">
					<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
						<path stroke-linecap="round" stroke-linejoin="round" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
					</svg>
					<span data-i18n-el="Κράτηση μεταφοράς" data-i18n-es="Reserva de traslado">Book a Transfer</span>
				</a>
				<a href="/book/hourly" class="flex items-center gap-2 px-5 py-2.5 rounded-xl bg-white border border-neutral-200 text-neutral-600 font-semibold text-sm hover:border-[#0C6B95]/40 hover:text-[#0C6B95] transition-colors">
					<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
						<path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
					</svg>
					<span data-i18n-el="Ενοικίαση με την ώρα" data-i18n-es="Alquiler por horas">Rent per Hour</span>
				</a>
				<a href="/book/tour" class="flex items-center gap-2 px-5 py-2.5 rounded-xl bg-white border border-neutral-200 text-neutral-600 font-semibold text-sm hover:border-[#0C6B95]/40 hover:text-[#0C6B95] transition-colors">
					<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
						<path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" />
					</svg>
					<span data-i18n-el="Κράτηση εκδρομής" data-i18n-es="Reserva de excursión">Book a Tour</span>
				</a>
			</div>

			<div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-10 items-start">

				<!-- ── Request form panel ── -->
				<div id="experience-form" class="bg-white rounded-2xl p-6 lg:p-8 border border-neutral-200 shadow-sm scroll-mt-36">
					<span id="request-form" class="sr-only"></span>

					<!-- Success panel (hidden until a successful insert) -->
					<div id="request-success" class="hidden">
						<div class="flex flex-col items-center text-center py-10">
							<div class="w-16 h-16 rounded-full bg-emerald-50 flex items-center justify-center mb-5">
								<svg class="w-8 h-8 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
									<path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
								</svg>
							</div>
							<h2 class="text-2xl font-bold text-neutral-900 mb-3" data-i18n-el="Το αίτημά σας στάλθηκε!" data-i18n-es="¡Solicitud enviada!">Request sent!</h2>
							<p class="text-neutral-600 text-base leading-relaxed mb-2 max-w-md" data-i18n-el="Ευχαριστούμε για το ενδιαφέρον σας. Η ομάδα μας θα εξετάσει το αίτημά σας και θα σας απαντήσει σύντομα." data-i18n-es="Gracias por contactarnos. Nuestro equipo revisará su solicitud de experiencia y se pondrá en contacto con usted en breve.">
								Thanks for reaching out. Our team will review your experience request and get back to you shortly.
							</p>
							<p class="text-sm text-neutral-500 mb-8 max-w-md" data-i18n-el="Θα λάβετε email επιβεβαίωσης στη διεύθυνση που δηλώσατε." data-i18n-es="Recibirá un correo electrónico de confirmación en la dirección indicada.">
								You'll receive a confirmation email at the address you provided.
							</p>
							<a href="/" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-[#0C6B95] hover:bg-[#0a5c82] text-white font-semibold text-sm shadow-md shadow-[#0C6B95]/25 transition-colors">
								<span data-i18n-el="Επιστροφή στην αρχική" data-i18n-es="Volver al inicio">Back to home</span>
								<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
									<path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
								</svg>
							</a>
						</div>
					</div>

					<!-- Form body -->
					<div id="request-form-body">
						<h2 class="text-2xl font-bold text-neutral-900 mb-6" data-i18n-el="Αίτημα εμπειρίας" data-i18n-es="Solicitud de experiencia">Experience Request</h2>
						<p class="text-sm text-neutral-500 mb-6 leading-relaxed" data-i18n-el="Συμπληρώστε τα παρακάτω στοιχεία και θα σας απαντήσουμε με μια εξατομικευμένη προσφορά." data-i18n-es="Complete los datos a continuación y le responderemos con una oferta personalizada.">
							Fill in the details below and we'll reply with a personalised offer.
						</p>

						<!-- Experience Type -->
						<div class="mb-4">
							<label class="block text-sm font-medium text-neutral-700 mb-1" data-i18n-el="Εμπειρία" data-i18n-es="Experiencia">Experience</label>
							<div class="relative">
								<span class="absolute left-3 top-1/2 -translate-y-1/2 text-neutral-400 pointer-events-none">
									<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" /></svg>
								</span>
								<select id="experience-select" class="w-full pl-10 pr-10 py-3 bg-neutral-50 border border-neutral-200 rounded-xl text-neutral-800 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95] appearance-none cursor-pointer">
									<option value="" disabled selected data-i18n-el="Επιλέξτε μια εμπειρία..." data-i18n-es="Seleccione una experiencia...">Select an experience...</option>
								</select>
								<span class="absolute right-3 top-1/2 -translate-y-1/2 text-neutral-400 pointer-events-none">
									<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
								</span>
							</div>
							<p data-error-for="experience-select" class="text-sm text-red-500 mt-1.5 hidden"></p>
						</div>

						<!-- Pickup Location -->
						<div class="mb-4">
							<label class="block text-sm font-medium text-neutral-700 mb-1" data-i18n-el="Σημείο παραλαβής" data-i18n-es="Lugar de recogida">Pickup location</label>
							<div class="relative">
								<span class="absolute left-3 top-1/2 -translate-y-1/2 text-neutral-400">
									<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
								</span>
								<input id="experience-pickup" type="text" placeholder="Hotel, address or landmark..." data-i18n-placeholder-el="Ξενοδοχείο, διεύθυνση ή ορόσημο..." data-i18n-placeholder-es="Hotel, dirección o punto de referencia..." autocomplete="off" class="w-full pl-10 pr-4 py-3 bg-neutral-50 border border-neutral-200 rounded-xl text-neutral-800 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95]" />
							</div>
						</div>

						<!-- Date & Time -->
						<div class="grid grid-cols-2 gap-4 mb-5">
							<div>
								<label class="block text-sm font-medium text-neutral-700 mb-1" data-i18n-el="Ημερομηνία εμπειρίας" data-i18n-es="Fecha de la experiencia">Experience date</label>
								<div class="relative">
									<span class="absolute left-3 top-1/2 -translate-y-1/2 text-neutral-400">
										<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
									</span>
									<input id="experience-date" type="date" class="w-full pl-10 pr-4 py-3 bg-neutral-50 border border-neutral-200 rounded-xl text-neutral-800 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95] cursor-pointer" />
								</div>
								<p data-error-for="experience-date" class="text-sm text-red-500 mt-1.5 hidden"></p>
							</div>
							<div>
								<label class="block text-sm font-medium text-neutral-700 mb-1" data-i18n-el="Ώρα παραλαβής" data-i18n-es="Hora de recogida">Pickup time</label>
								<div class="relative">
									<Fragment set:html={renderTimePickerHTML('experience-time', { required: true, selectClass: 'flex-1 px-3 py-2.5 bg-neutral-50 border border-neutral-200 rounded-xl text-neutral-800 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95]' })} />
								</div>
							</div>
						</div>

						<!-- Participants -->
						<div class="mb-5">
							<label class="block text-sm font-medium text-neutral-700 mb-2" data-i18n-el="Συμμετέχοντες" data-i18n-es="Participantes">Participants</label>
							<div class="flex items-center gap-3">
								<div class="flex-1 flex items-center gap-2 pl-4 py-3 bg-neutral-50 border border-neutral-200 rounded-xl">
									<svg class="w-5 h-5 text-neutral-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" /></svg>
									<span class="text-neutral-800 font-medium" id="participant-count">2</span>
								</div>
								<button type="button" id="pax-minus" class="w-10 h-10 flex items-center justify-center rounded-xl bg-neutral-800 text-white hover:bg-neutral-700 transition-colors text-lg font-bold" aria-label="Fewer participants" data-i18n-aria-el="Λιγότεροι συμμετέχοντες" data-i18n-aria-es="Menos participantes">−</button>
								<button type="button" id="pax-plus" class="w-10 h-10 flex items-center justify-center rounded-xl bg-neutral-800 text-white hover:bg-neutral-700 transition-colors text-lg font-bold" aria-label="More participants" data-i18n-aria-el="Περισσότεροι συμμετέχοντες" data-i18n-aria-es="Más participantes">+</button>
							</div>
						</div>

						<!-- Contact details -->
						<div class="border-t border-neutral-100 pt-5 mt-5 mb-5">
							<h3 class="text-sm font-semibold text-neutral-800 uppercase tracking-wider mb-4" data-i18n-el="Τα στοιχεία επικοινωνίας σας" data-i18n-es="Sus datos de contacto">Your contact details</h3>

							<div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
								<div>
									<label class="block text-sm font-medium text-neutral-700 mb-1" data-i18n-el="Όνομα" data-i18n-es="Nombre">First name</label>
									<input id="r-first-name" type="text" autocomplete="given-name" placeholder="Jane" data-i18n-placeholder-el="Γιάννα" data-i18n-placeholder-es="Ana"
										class="w-full px-4 py-3 bg-neutral-50 border border-neutral-200 rounded-xl text-neutral-800 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95]" />
									<p data-error-for="r-first-name" class="text-sm text-red-500 mt-1.5 hidden"></p>
								</div>
								<div>
									<label class="block text-sm font-medium text-neutral-700 mb-1" data-i18n-el="Επώνυμο" data-i18n-es="Apellidos">Last name</label>
									<input id="r-last-name" type="text" autocomplete="family-name" placeholder="Doe" data-i18n-placeholder-el="Παπαδόπουλος" data-i18n-placeholder-es="García"
										class="w-full px-4 py-3 bg-neutral-50 border border-neutral-200 rounded-xl text-neutral-800 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95]" />
									<p data-error-for="r-last-name" class="text-sm text-red-500 mt-1.5 hidden"></p>
								</div>
							</div>

							<div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
								<div>
									<label class="block text-sm font-medium text-neutral-700 mb-1" data-i18n-el="Email" data-i18n-es="Correo electrónico">Email</label>
									<input id="r-email" type="email" autocomplete="email" placeholder="you@email.com"
										class="w-full px-4 py-3 bg-neutral-50 border border-neutral-200 rounded-xl text-neutral-800 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95]" />
									<p data-error-for="r-email" class="text-sm text-red-500 mt-1.5 hidden"></p>
								</div>
								<div>
									<label class="block text-sm font-medium text-neutral-700 mb-1" data-i18n-el="Τηλέφωνο" data-i18n-es="Teléfono">Phone</label>
									<input id="r-phone" type="tel" autocomplete="tel" placeholder="+30 6912345678"
										class="w-full px-4 py-3 bg-neutral-50 border border-neutral-200 rounded-xl text-neutral-800 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95]" />
									<p data-error-for="r-phone" class="text-sm text-red-500 mt-1.5 hidden"></p>
								</div>
							</div>

							<div class="mb-1">
								<label class="block text-sm font-medium text-neutral-700 mb-1"><span data-i18n-el="Σημειώσεις" data-i18n-es="Notas">Notes</span> <span class="text-neutral-400 font-normal" data-i18n-el="(προαιρετικό)" data-i18n-es="(opcional)">(optional)</span></label>
								<textarea id="r-notes" rows="3" placeholder="Anything we should know? Dietary restrictions, accessibility needs, etc." data-i18n-placeholder-el="Κάτι που πρέπει να γνωρίζουμε; Διατροφικοί περιορισμοί, ανάγκες προσβασιμότητας κ.λπ." data-i18n-placeholder-es="¿Algo que debamos saber? Restricciones dietéticas, necesidades de accesibilidad, etc."
									class="w-full px-4 py-3 bg-neutral-50 border border-neutral-200 rounded-xl text-neutral-800 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95] resize-none"></textarea>
							</div>
						</div>

						<!-- Form-level error banner -->
						<div data-form-error class="hidden mb-4 rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-600" role="alert"></div>

						<!-- Send request -->
						<button id="experience-submit-btn" type="button" class="w-full py-4 bg-[#0C6B95] hover:bg-[#0a5c82] text-white font-semibold rounded-xl transition-colors flex items-center justify-center gap-2 shadow-lg shadow-[#0C6B95]/25 disabled:opacity-60 disabled:cursor-not-allowed">
							<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" /></svg>
							<span data-i18n-el="Αποστολή αιτήματος" data-i18n-es="Enviar solicitud">Send request</span>
						</button>
					</div>
				</div>

				<!-- ── Experience carousel ── -->
				<div data-experience-carousel class="flex flex-col">
					<div class="mb-5">
						<div class="flex items-center gap-2 mb-2">
							<span class="w-2 h-2 rounded-full bg-[#0C6B95] shrink-0"></span>
							<span class="text-sm font-medium text-neutral-500 tracking-widest uppercase" data-i18n-el="Οι εμπειρίες μας" data-i18n-es="Nuestras experiencias">Our Experiences</span>
						</div>
						<h2 class="text-2xl lg:text-3xl font-bold text-neutral-900" data-i18n-el="Επιλεγμένες Εμπειρίες στην Ελλάδα" data-i18n-es="Experiencias seleccionadas en Grecia">Curated Experiences in Greece</h2>
					</div>

					<!-- Cards container — filled by JS -->
					<div id="experience-carousel-inner" class="relative overflow-hidden rounded-2xl flex-1">
						<div class="bg-white border border-neutral-200 rounded-2xl overflow-hidden shadow-sm p-12 flex items-center justify-center">
							<p class="text-neutral-400 text-sm" data-i18n-el="Φόρτωση εμπειριών…" data-i18n-es="Cargando experiencias…">Loading experiences…</p>
						</div>
					</div>

					<div class="flex items-center justify-between mt-4">
						<button data-experience-prev class="w-10 h-10 flex items-center justify-center rounded-full border border-neutral-200 bg-white hover:bg-[#0C6B95] hover:border-[#0C6B95] hover:text-white text-neutral-600 transition-all duration-200 shadow-sm" aria-label="Previous" data-i18n-aria-el="Προηγούμενο" data-i18n-aria-es="Anterior">
							<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
						</button>
						<span data-experience-indicator class="text-sm font-semibold text-neutral-500">— / —</span>
						<button data-experience-next class="w-10 h-10 flex items-center justify-center rounded-full border border-neutral-200 bg-white hover:bg-[#0C6B95] hover:border-[#0C6B95] hover:text-white text-neutral-600 transition-all duration-200 shadow-sm" aria-label="Next" data-i18n-aria-el="Επόμενο" data-i18n-aria-es="Siguiente">
							<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
						</button>
					</div>
				</div>

			</div>
		</div>
	</main>

	<!-- ── Published Experiences Catalog ── -->
	<section id="catalog-section" class="py-20 lg:py-24 px-6 lg:px-10 bg-white hidden">
		<div class="max-w-6xl mx-auto">

			<!-- Header -->
			<div class="mb-12 text-center">
				<div class="flex items-center justify-center gap-2 mb-4">
					<span class="w-2 h-2 rounded-full bg-[#0C6B95]"></span>
					<span class="text-sm font-medium text-neutral-500 tracking-widest uppercase" data-i18n-el="Οι εμπειρίες μας" data-i18n-es="Nuestras experiencias">Our Experiences</span>
				</div>
				<h2 class="text-4xl font-bold text-neutral-900 mb-4" data-i18n-el="Εξερευνήστε τις διαθέσιμες εμπειρίες" data-i18n-es="Explore las experiencias disponibles">Explore Available Experiences</h2>
				<div class="w-16 h-1 bg-[#0C6B95] rounded-full mx-auto mb-4"></div>
				<p class="text-neutral-500 text-base max-w-xl mx-auto leading-relaxed" data-i18n-el="Διαλέξτε από τη συλλογή ιδιωτικών εμπειριών μας — σχεδιασμένων να σας χαρίσουν μια ξεχωριστή γεύση της Ελλάδας." data-i18n-es="Elija entre nuestra colección seleccionada de experiencias privadas, cada una diseñada para ofrecerle una muestra excepcional de Grecia.">
					Choose from our curated selection of private experiences, each designed to give you an extraordinary taste of Greece.
				</p>
			</div>

			<!-- Cards grid (filled by JS) -->
			<div id="experiences-catalog-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8"></div>

		</div>
	</section>

</Layout>

<script>
	// Participant counter
	const countEl = document.getElementById('participant-count');
	let count = 2;
	document.getElementById('pax-minus')?.addEventListener('click', () => {
		if (count > 1) { count--; if (countEl) countEl.textContent = String(count); }
	});
	document.getElementById('pax-plus')?.addEventListener('click', () => {
		count++; if (countEl) countEl.textContent = String(count);
	});
</script>

<script>
	import { supabase } from '../lib/supabase';
	import { showFieldError, showFormError, clearFormErrors, wireAutoClear } from '../lib/form-errors';
	import { attachPlacesAutocomplete } from '../lib/places-autocomplete';
	import { renderImageCarouselHTML, initImageCarousels } from '../lib/image-carousel';
	import { readTimePickerValue } from '../lib/time-picker';

	attachPlacesAutocomplete(document.getElementById('experience-pickup') as HTMLInputElement | null);

	// Experiences are quote-only: no pricing or partner discounts surfaced on
	// the public page. Partner discounts still apply internally once an agent
	// converts the request into a booking.

	/* ── Auto-fill contact details from signed-in user (if any) ── */
	supabase.auth.onAuthStateChange(async (_event, session) => {
		const user = session?.user;
		if (!user) return;
		const display = (user.user_metadata?.display_name || user.user_metadata?.full_name || '').trim();
		if (display) {
			const [first, ...rest] = display.split(/\s+/);
			const firstEl = document.getElementById('r-first-name') as HTMLInputElement | null;
			const lastEl = document.getElementById('r-last-name') as HTMLInputElement | null;
			if (firstEl && !firstEl.value) firstEl.value = first;
			if (lastEl && !lastEl.value && rest.length > 0) lastEl.value = rest.join(' ');
		}
		const emailEl = document.getElementById('r-email') as HTMLInputElement | null;
		if (emailEl && !emailEl.value && user.email) emailEl.value = user.email;
	});

	interface ExperienceItem {
		id: string;
		title: string;
		description: string;
		image_url: string;
		images?: string[];
		duration: string;
		highlight1: string;
		highlight2: string;
		highlight3: string;
		published: boolean;
	}

	const esc = (s: string) => String(s)
		.replace(/&/g, '&amp;').replace(/</g, '&lt;')
		.replace(/>/g, '&gt;').replace(/"/g, '&quot;');

	async function loadExperiences() {
		try {
			const { data: docs, error: loadErr } = await supabase
				.from('experiences_catalog')
				.select('*')
				.neq('published', false)
				.order('created_at', { ascending: false });

			if (loadErr) throw loadErr;
			if (!docs) return;

			/* ── Carousel ──────────────────────────────────────────────── */
			const inner = document.getElementById('experience-carousel-inner')!;

			if (docs.length === 0) {
				inner.innerHTML = `
					<div class="bg-white border border-neutral-200 rounded-2xl overflow-hidden shadow-sm p-12 flex items-center justify-center">
						<p class="text-neutral-400 text-sm text-center" data-i18n-el="Δεν υπάρχουν διαθέσιμες εμπειρίες αυτή τη στιγμή.<br/>Δοκιμάστε ξανά σύντομα." data-i18n-es="No hay experiencias disponibles en este momento.<br/>Vuelva a intentarlo pronto.">No experiences available at the moment.<br/>Check back soon.</p>
					</div>`;
			} else {
				inner.innerHTML = docs.map((t, i) => {
					const images = (Array.isArray(t.images) && t.images.length > 0)
						? t.images
						: (t.image_url ? [t.image_url] : []);
					const highlights = [t.highlight1, t.highlight2, t.highlight3].filter(Boolean);
					return `
					<article data-experience-card class="bg-white border border-neutral-200 rounded-2xl overflow-hidden shadow-sm flex flex-col ${i === 0 ? '' : 'hidden'}">
						${renderImageCarouselHTML(images, {
							alt: esc(t.title),
							wrapperClass: 'aspect-[16/9] overflow-hidden',
						})}
						<div class="p-6 flex flex-col">
							${t.duration ? `
							<div class="flex items-center gap-2 mb-2">
								<svg class="w-4 h-4 text-[#0C6B95] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
									<path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
								</svg>
								<span class="text-xs font-semibold text-[#0C6B95] uppercase tracking-wide">${esc(t.duration)}</span>
							</div>` : ''}
							<h3 class="text-2xl font-bold text-neutral-900 mb-2">${esc(t.title)}</h3>
							${t.description ? `<p class="text-sm text-neutral-500 mb-4 leading-relaxed">${esc(t.description)}</p>` : ''}
							${highlights.length > 0 ? `
							<div class="w-16 h-1 bg-[#0C6B95] rounded-full mb-5"></div>
							<ul class="flex flex-col gap-3">
								${highlights.map(h => `
								<li class="flex items-start gap-3">
									<svg class="w-4 h-4 text-[#0C6B95] mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
										<path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
									</svg>
									<span class="text-sm text-neutral-600 leading-snug">${esc(h)}</span>
								</li>`).join('')}
							</ul>` : ''}
						</div>
					</article>`;
				}).join('');

				initImageCarousels(inner);

				/* Init carousel */
				const carousel  = inner.closest('[data-experience-carousel]')!;
				const cards     = Array.from(inner.querySelectorAll<HTMLElement>('[data-experience-card]'));
				const prevBtn   = carousel.querySelector('[data-experience-prev]') as HTMLButtonElement;
				const nextBtn   = carousel.querySelector('[data-experience-next]') as HTMLButtonElement;
				const indicator = carousel.querySelector('[data-experience-indicator]') as HTMLElement;

				if (indicator) indicator.textContent = `1 / ${cards.length}`;

				if (cards.length <= 1) {
					if (prevBtn) prevBtn.classList.add('invisible');
					if (nextBtn) nextBtn.classList.add('invisible');
				} else {
					let current = 0;
					let animating = false;

					const wait = (ms: number) => new Promise<void>(r => setTimeout(r, ms));

					async function goTo(idx: number, dir: 'prev' | 'next') {
						if (animating) return;
						animating = true;
						const out = cards[current];
						const nextIdx = (idx + cards.length) % cards.length;
						const inc = cards[nextIdx];

						out.style.transition = 'transform 220ms ease, opacity 220ms ease';
						out.style.transform  = dir === 'next' ? 'translateX(-48px)' : 'translateX(48px)';
						out.style.opacity    = '0';
						await wait(220);
						out.classList.add('hidden');
						out.style.cssText = '';

						inc.style.transition = 'none';
						inc.style.transform  = dir === 'next' ? 'translateX(48px)' : 'translateX(-48px)';
						inc.style.opacity    = '0';
						inc.classList.remove('hidden');
						inc.getBoundingClientRect();
						inc.style.transition = 'transform 220ms ease, opacity 220ms ease';
						inc.style.transform  = 'translateX(0)';
						inc.style.opacity    = '1';

						current = nextIdx;
						if (indicator) indicator.textContent = `${current + 1} / ${cards.length}`;
						await wait(220);
						inc.style.cssText = '';
						animating = false;
					}

					prevBtn?.addEventListener('click', () => goTo(current - 1, 'prev'));
					nextBtn?.addEventListener('click', () => goTo(current + 1, 'next'));
				}
			}

			/* ── Select dropdown ───────────────────────────────────────── */
			const select = document.getElementById('experience-select') as HTMLSelectElement;
			if (select && docs.length > 0) {
				docs.forEach(t => {
					const opt = document.createElement('option');
					opt.value = t.id;
					opt.textContent = t.title;
					select.appendChild(opt);
				});
			}

			/* ── Catalog grid ──────────────────────────────────────────── */
			if (docs.length === 0) return;

			const catalogSection = document.getElementById('catalog-section')!;
			const catalogGrid    = document.getElementById('experiences-catalog-grid')!;

			// Experiences are quote-only — no pricing shown on the public website.
			catalogGrid.innerHTML = docs.map(t => {
				const images = (Array.isArray(t.images) && t.images.length > 0)
					? t.images
					: (t.image_url ? [t.image_url] : []);
				return `
				<div class="group bg-white rounded-2xl overflow-hidden shadow-sm border border-neutral-100 hover:shadow-xl transition-shadow duration-300">
					${renderImageCarouselHTML(images, {
						alt: esc(t.title),
						wrapperClass: 'aspect-[4/3] overflow-hidden',
						imgClass: 'transition-transform duration-500 group-hover:scale-105',
					})}
					<div class="p-6">
						<h3 class="text-xl font-bold text-neutral-900 mb-2 leading-snug">${esc(t.title)}</h3>
						<p class="text-neutral-500 text-sm leading-relaxed mb-5 overflow-hidden" style="display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical">${esc(t.description)}</p>
						<a
							href="/experiences#request-form"
							class="inline-flex items-center justify-center gap-2 w-full bg-[#0C6B95] hover:bg-[#0a5c82] text-white text-sm font-semibold px-5 py-2.5 rounded-xl transition-colors duration-200 shadow-sm shadow-[#0C6B95]/20"
						>
							<span data-i18n-el="Ζητήστε προσφορά" data-i18n-es="Solicitar presupuesto">Request a quote</span>
							<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
								<path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
							</svg>
						</a>
					</div>
				</div>`;
			}).join('');

			initImageCarousels(catalogGrid);

			catalogSection.classList.remove('hidden');

		} catch (err) {
			console.error('Experiences load error:', err);
		}
	}

	/* ── Submit: send request to Supabase ──────────────────────── */
	const experienceFormScope = document.getElementById('experience-form');

	wireAutoClear([
		document.getElementById('experience-select'),
		document.getElementById('experience-date'),
		document.getElementById('r-first-name'),
		document.getElementById('r-last-name'),
		document.getElementById('r-email'),
		document.getElementById('r-phone'),
	]);

	document.getElementById('experience-submit-btn')?.addEventListener('click', async () => {
		clearFormErrors(experienceFormScope);

		const select = document.getElementById('experience-select') as HTMLSelectElement;
		const pickupEl = document.getElementById('experience-pickup') as HTMLInputElement;
		const dateEl = document.getElementById('experience-date') as HTMLInputElement;
		const firstEl = document.getElementById('r-first-name') as HTMLInputElement;
		const lastEl = document.getElementById('r-last-name') as HTMLInputElement;
		const emailEl = document.getElementById('r-email') as HTMLInputElement;
		const phoneEl = document.getElementById('r-phone') as HTMLInputElement;
		const notesEl = document.getElementById('r-notes') as HTMLTextAreaElement;

		const experienceId = select?.value || '';
		const experienceName = experienceId ? select.options[select.selectedIndex]?.text ?? '' : '';
		const pickup = pickupEl?.value.trim() ?? '';
		const date = dateEl?.value.trim() ?? '';
		const time = readTimePickerValue('experience-time');
		const participants = document.getElementById('participant-count')?.textContent?.trim() || '2';
		const firstName = firstEl?.value.trim() ?? '';
		const lastName = lastEl?.value.trim() ?? '';
		const email = emailEl?.value.trim() ?? '';
		const phone = phoneEl?.value.trim() ?? '';
		const notes = notesEl?.value.trim() ?? '';

		let firstErr: HTMLElement | null = null;
		if (!experienceId) { showFieldError(select, 'Please select an experience.'); firstErr ??= select; }
		if (!date)        { showFieldError(dateEl, 'Please select an experience date.'); firstErr ??= dateEl; }
		if (!firstName)   { showFieldError(firstEl, 'First name is required.'); firstErr ??= firstEl; }
		if (!lastName)    { showFieldError(lastEl, 'Last name is required.'); firstErr ??= lastEl; }
		if (!email)       { showFieldError(emailEl, 'Email is required.'); firstErr ??= emailEl; }
		else if (!email.includes('@')) { showFieldError(emailEl, 'Please enter a valid email address.'); firstErr ??= emailEl; }
		if (!phone)       { showFieldError(phoneEl, 'Phone number is required.'); firstErr ??= phoneEl; }

		if (firstErr) {
			firstErr.scrollIntoView({ behavior: 'smooth', block: 'center' });
			firstErr.focus?.();
			return;
		}

		const btn = document.getElementById('experience-submit-btn') as HTMLButtonElement;
		btn.disabled = true;
		btn.textContent = 'Sending…';

		const { data: { user } } = await supabase.auth.getUser();

		try {
			const { error } = await supabase.from('requests').insert({
				source: 'experience',
				status: 'new',
				experience_id: experienceId,
				experience_name: experienceName,
				pickup_location: pickup || null,
				date,
				time: time || null,
				participants: parseInt(participants, 10),
				name: firstName,
				last_name: lastName,
				email,
				phone,
				special_requests: notes || null,
				user_id: user?.id ?? null,
				user_display_name: user?.user_metadata?.display_name ?? null,
				user_email: user?.email ?? null,
			});

			if (error) throw error;

			document.getElementById('request-form-body')?.classList.add('hidden');
			document.getElementById('request-success')?.classList.remove('hidden');
			window.scrollTo({ top: 0, behavior: 'smooth' });
		} catch (err) {
			console.error('Experience request failed:', err);
			showFormError(experienceFormScope, 'Something went wrong. Please try again or contact us directly.');
			btn.disabled = false;
			btn.innerHTML = `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" /></svg> Send request`;
		}
	});

	loadExperiences();
</script>
