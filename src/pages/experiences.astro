---
import Layout from '../layouts/Layout.astro';
import ExperiencesHero from '../components/experiences/ExperiencesHero.astro';
import ExperiencesList from '../components/experiences/ExperiencesList.astro';
---

<Layout>
	<main class="min-h-screen bg-white">
		<ExperiencesHero />
		<ExperiencesList />

		<!-- ── Dynamic Experiences from Catalog ── -->
		<!-- This section is hidden until Firestore returns items -->
		<section id="catalog-section" class="py-20 lg:py-24 px-6 lg:px-10 bg-[#F5F6F8] hidden">
			<div class="max-w-6xl mx-auto">

				<!-- Header -->
				<div class="mb-12 text-center">
					<div class="flex items-center justify-center gap-2 mb-4">
						<span class="w-2 h-2 rounded-full bg-[#0C6B95]"></span>
						<span class="text-sm font-medium text-neutral-500 tracking-widest uppercase">More Experiences</span>
					</div>
					<h2 class="text-4xl font-bold text-neutral-900 mb-4">Additional Offerings</h2>
					<div class="w-16 h-1 bg-[#0C6B95] rounded-full mx-auto mb-4"></div>
					<p class="text-neutral-500 text-base max-w-xl mx-auto leading-relaxed">
						Discover even more curated experiences, each designed to create lasting memories in Greece.
					</p>
				</div>

				<!-- Cards grid -->
				<div id="exp-catalog-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8"></div>

				<!-- CTA strip -->
				<div class="mt-14 text-center">
					<p class="text-neutral-500 text-sm mb-4">Looking for something unique?</p>
					<a
						href="/contact"
						class="inline-flex items-center gap-2 bg-neutral-900 hover:bg-[#0C6B95] text-white text-sm font-semibold px-8 py-4 rounded-xl transition-colors duration-200"
					>
						Request a Custom Experience
						<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
							<path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
						</svg>
					</a>
				</div>

			</div>
		</section>

		<!-- ── Request Quote Form ── -->
		<section id="request-form-section" class="py-20 lg:py-24 px-6 lg:px-10 bg-white">
			<div class="max-w-2xl mx-auto">

				<!-- Header -->
				<div class="mb-12 text-center">
					<div class="flex items-center justify-center gap-2 mb-4">
						<span class="w-2 h-2 rounded-full bg-[#0C6B95]"></span>
						<span class="text-sm font-medium text-neutral-500 tracking-widest uppercase">Request a Quote</span>
					</div>
					<h2 class="text-4xl font-bold text-neutral-900 mb-4">Book Your Experience</h2>
					<div class="w-16 h-1 bg-[#0C6B95] rounded-full mx-auto mb-4"></div>
					<p class="text-neutral-500 text-base max-w-xl mx-auto leading-relaxed">
						Fill in the details below and we will get back to you with a personalized quote.
					</p>
				</div>

				<!-- Form -->
				<div class="bg-white rounded-2xl p-6 lg:p-8 border border-neutral-200 shadow-sm">

					<!-- Experience Selection -->
					<div class="mb-4">
						<label class="block text-sm font-medium text-neutral-700 mb-1">Experience</label>
						<div class="relative">
							<span class="absolute left-3 top-1/2 -translate-y-1/2 text-neutral-400 pointer-events-none">
								<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" /></svg>
							</span>
							<select id="exp-select" class="w-full pl-10 pr-4 py-3 bg-neutral-50 border border-neutral-200 rounded-xl text-neutral-800 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95] appearance-none cursor-pointer">
								<option value="" disabled selected>Select an experience...</option>
							</select>
							<span class="absolute right-3 top-1/2 -translate-y-1/2 text-neutral-400 pointer-events-none">
								<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
							</span>
						</div>
					</div>

					<!-- Pickup Location -->
					<div class="mb-4">
						<label class="block text-sm font-medium text-neutral-700 mb-1">Pickup Location</label>
						<div class="relative">
							<span class="absolute left-3 top-1/2 -translate-y-1/2 text-neutral-400">
								<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
							</span>
							<input id="exp-pickup" type="text" placeholder="Hotel, address or landmark..." class="w-full pl-10 pr-4 py-3 bg-neutral-50 border border-neutral-200 rounded-xl text-neutral-800 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95]" />
						</div>
					</div>

					<!-- Date & Time -->
					<div class="grid grid-cols-2 gap-4 mb-4">
						<div>
							<label class="block text-sm font-medium text-neutral-700 mb-1">Date</label>
							<div class="relative">
								<span class="absolute left-3 top-1/2 -translate-y-1/2 text-neutral-400">
									<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
								</span>
								<input id="exp-date" type="date" class="w-full pl-10 pr-4 py-3 bg-neutral-50 border border-neutral-200 rounded-xl text-neutral-800 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95] cursor-pointer" />
							</div>
						</div>
						<div>
							<label class="block text-sm font-medium text-neutral-700 mb-1">Time</label>
							<div class="relative">
								<span class="absolute left-3 top-1/2 -translate-y-1/2 text-neutral-400">
									<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
								</span>
								<input id="exp-time" type="time" class="w-full pl-10 pr-4 py-3 bg-neutral-50 border border-neutral-200 rounded-xl text-neutral-800 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95] cursor-pointer" />
							</div>
						</div>
					</div>

					<!-- Participants -->
					<div class="mb-4">
						<label class="block text-sm font-medium text-neutral-700 mb-1">Number of Participants</label>
						<div class="relative">
							<span class="absolute left-3 top-1/2 -translate-y-1/2 text-neutral-400">
								<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" /></svg>
							</span>
							<input id="exp-participants" type="number" min="1" value="1" class="w-full pl-10 pr-4 py-3 bg-neutral-50 border border-neutral-200 rounded-xl text-neutral-800 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95]" />
						</div>
					</div>

					<!-- Full Name -->
					<div class="mb-4">
						<label class="block text-sm font-medium text-neutral-700 mb-1">Full Name</label>
						<div class="relative">
							<span class="absolute left-3 top-1/2 -translate-y-1/2 text-neutral-400">
								<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>
							</span>
							<input id="exp-name" type="text" placeholder="e.g. John Smith" class="w-full pl-10 pr-4 py-3 bg-neutral-50 border border-neutral-200 rounded-xl text-neutral-800 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95]" />
						</div>
					</div>

					<!-- Email -->
					<div class="mb-4">
						<label class="block text-sm font-medium text-neutral-700 mb-1">Email</label>
						<div class="relative">
							<span class="absolute left-3 top-1/2 -translate-y-1/2 text-neutral-400">
								<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
							</span>
							<input id="exp-email" type="email" placeholder="email@example.com" class="w-full pl-10 pr-4 py-3 bg-neutral-50 border border-neutral-200 rounded-xl text-neutral-800 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95]" />
						</div>
					</div>

					<!-- Phone -->
					<div class="mb-4">
						<label class="block text-sm font-medium text-neutral-700 mb-1">Phone</label>
						<div class="relative">
							<span class="absolute left-3 top-1/2 -translate-y-1/2 text-neutral-400">
								<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
							</span>
							<input id="exp-phone" type="tel" placeholder="+30 69..." class="w-full pl-10 pr-4 py-3 bg-neutral-50 border border-neutral-200 rounded-xl text-neutral-800 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95]" />
						</div>
					</div>

					<!-- Special Requests -->
					<div class="mb-6">
						<label class="block text-sm font-medium text-neutral-700 mb-1">Special Requests <span class="text-neutral-400 font-normal">(optional)</span></label>
						<textarea
							id="exp-notes"
							rows="3"
							placeholder="Dietary requirements, accessibility needs, preferences..."
							class="w-full px-4 py-3 bg-neutral-50 border border-neutral-200 rounded-xl text-neutral-800 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95] resize-none"
						></textarea>
					</div>

					<!-- Error message -->
					<p id="exp-form-error" class="hidden text-sm text-red-600 mb-3 px-1"></p>

					<!-- Success state -->
					<div id="exp-form-success" class="hidden mb-4 p-4 bg-emerald-50 border border-emerald-200 rounded-xl flex items-start gap-3">
						<svg class="w-5 h-5 text-emerald-600 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
							<path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
						</svg>
						<div>
							<p class="text-sm font-semibold text-emerald-800">Request sent!</p>
							<p class="text-xs text-emerald-600 mt-0.5">We'll be in touch shortly to confirm your experience.</p>
						</div>
					</div>

					<!-- Request Button -->
					<button id="exp-submit-btn" type="button" class="w-full py-4 bg-[#0C6B95] hover:bg-[#0a5c82] text-white font-semibold rounded-xl transition-colors flex items-center justify-center gap-2 shadow-lg shadow-[#0C6B95]/25 disabled:opacity-60 disabled:cursor-not-allowed">
						<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
						Request Quote
					</button>
				</div>

			</div>
		</section>
	</main>
</Layout>

<script>
	import { supabase } from '../lib/supabase';
	import { applyPartnerDiscount } from '../lib/pricing';

	let partnerDiscount = 0;

	async function detectPartnerDiscount(): Promise<number> {
		return new Promise((resolve) => {
			supabase.auth.onAuthStateChange(async (_event, session) => {
				if (!session?.user) { resolve(0); return; }
				try {
					const { data } = await supabase.from('partners').select('*').eq('id', session.user.id).single();
					if (data && data.status === 'approved' && data.discount > 0) {
						resolve(data.discount);
						return;
					}
				} catch {}
				resolve(0);
			});
		});
	}

	const esc = (s: string) => String(s)
		.replace(/&/g, '&amp;').replace(/</g, '&lt;')
		.replace(/>/g, '&gt;').replace(/"/g, '&quot;');

	async function loadCatalog() {
		try {
			const { data: rows, error } = await supabase.from('experiences_catalog').select('*').order('created_at', { ascending: false });
			if (error || !rows || rows.length === 0) return;

			const section = document.getElementById('catalog-section')!;
			const grid    = document.getElementById('exp-catalog-grid')!;

			const docs = rows.filter(d => d.published !== false);
			if (docs.length === 0) return;

			grid.innerHTML = (partnerDiscount > 0 ? `<div class="col-span-full bg-emerald-50 border border-emerald-200 rounded-xl px-4 py-2 mb-0 text-sm text-emerald-700 font-medium">Partner discount: ${partnerDiscount}% applied</div>` : "") + docs.map(d => {
				const item = d as { title: string; description: string; price: number; image_url: string };
				const dp = applyPartnerDiscount(Number(item.price), partnerDiscount);
				const showOriginal = partnerDiscount > 0 && dp.originalPrice !== dp.discountedPrice;
				return `
					<div class="group bg-white rounded-2xl overflow-hidden shadow-sm border border-neutral-100 hover:shadow-xl transition-shadow duration-300">
						<!-- Image -->
						<div class="aspect-[4/3] overflow-hidden bg-neutral-100">
							<img
								src="${esc(item.image_url)}"
								alt="${esc(item.title)}"
								class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
								onerror="this.closest('[class*=aspect]').innerHTML='<div class=\\'w-full h-full flex items-center justify-center bg-neutral-100\\'><svg class=\\'w-12 h-12 text-neutral-300\\' fill=\\'none\\' stroke=\\'currentColor\\' viewBox=\\'0 0 24 24\\'><path stroke-linecap=\\'round\\' stroke-linejoin=\\'round\\' stroke-width=\\'1.5\\' d=\\'M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z\\'/></svg></div>'"
							/>
						</div>
						<!-- Content -->
						<div class="p-6">
							<h3 class="text-xl font-bold text-neutral-900 mb-2 leading-snug">${esc(item.title)}</h3>
							<p class="text-neutral-500 text-sm leading-relaxed mb-5 overflow-hidden" style="display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical">${esc(item.description)}</p>
							<div class="flex items-center justify-between">
								<div>
									<span class="text-xs text-neutral-400 font-medium uppercase tracking-wider">From</span>
									${showOriginal ? `<del class="text-neutral-400 text-sm block">&euro;${dp.originalPrice.toFixed(2)}</del>` : ""}
									<p class="text-2xl font-bold text-[#0C6B95] leading-none mt-0.5">&euro;${dp.discountedPrice.toFixed(2)}</p>
								</div>
								<a
									href="/contact"
									class="inline-flex items-center gap-2 bg-[#0C6B95] hover:bg-[#0a5c82] text-white text-sm font-semibold px-5 py-2.5 rounded-xl transition-colors duration-200 shadow-sm shadow-[#0C6B95]/20"
								>
									Book Now
									<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
										<path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
									</svg>
								</a>
							</div>
						</div>
					</div>`;
			}).join('');

			section.classList.remove('hidden');

		} catch (err) {
			console.error('Catalog load error:', err);
		}
	}

	/* ── Populate the request form dropdown ── */
	async function populateFormDropdown() {
		const select = document.getElementById('exp-select') as HTMLSelectElement;
		if (!select) return;
		try {
			const { data: rows, error } = await supabase.from('experiences_catalog').select('id, title, published').order('created_at', { ascending: false });
			if (error || !rows) return;
			const docs = rows.filter(d => d.published !== false);
			if (docs.length === 0) return;
			docs.forEach(d => {
				const opt = document.createElement('option');
				opt.value = d.id;
				opt.textContent = d.title;
				select.appendChild(opt);
			});
		} catch {}
	}

	/* ── Form submission ── */
	document.addEventListener('astro:page-load', () => {
		document.getElementById('exp-submit-btn')?.addEventListener('click', async () => {
			const errorEl   = document.getElementById('exp-form-error')!;
			const successEl = document.getElementById('exp-form-success')!;
			const btn       = document.getElementById('exp-submit-btn') as HTMLButtonElement;

			const showError = (msg: string) => {
				errorEl.textContent = msg;
				errorEl.classList.remove('hidden');
			};
			errorEl.classList.add('hidden');

			const select         = document.getElementById('exp-select') as HTMLSelectElement;
			const experienceId   = select?.value || '';
			const experienceName = experienceId ? select.options[select.selectedIndex]?.text : '';

			const pickup       = (document.getElementById('exp-pickup')       as HTMLInputElement)?.value.trim();
			const date         = (document.getElementById('exp-date')         as HTMLInputElement)?.value.trim();
			const time         = (document.getElementById('exp-time')         as HTMLInputElement)?.value.trim();
			const participants = parseInt((document.getElementById('exp-participants') as HTMLInputElement)?.value || '1', 10);
			const name         = (document.getElementById('exp-name')         as HTMLInputElement)?.value.trim();
			const email        = (document.getElementById('exp-email')        as HTMLInputElement)?.value.trim();
			const phone        = (document.getElementById('exp-phone')        as HTMLInputElement)?.value.trim();
			const notes        = (document.getElementById('exp-notes')        as HTMLTextAreaElement)?.value.trim();

			if (!experienceId) { showError('Please select an experience.'); return; }
			if (!name)         { showError('Please enter your full name.'); return; }
			if (!email)        { showError('Please enter your email.'); return; }
			if (!date)         { showError('Please select a date.'); return; }

			btn.disabled = true;
			btn.textContent = 'Sending…';

			const { data: { user: currentUser } } = await supabase.auth.getUser();

			try {
				const { error: insertErr } = await supabase.from('requests').insert({
					source:           'experience',
					experience_id:    experienceId,
					experience_name:  experienceName,
					name,
					email,
					phone:            phone || '',
					pickup_location:  pickup || '',
					date,
					time:             time || '',
					participants,
					special_requests: notes || '',
					status:           'new',
					user_id:            currentUser?.id                                                || null,
					user_display_name:  currentUser?.user_metadata?.display_name || currentUser?.user_metadata?.full_name || null,
					user_email:         currentUser?.email                                             || null,
				});

				if (insertErr) throw insertErr;

				successEl.classList.remove('hidden');
				btn.classList.add('hidden');

				// Reset form
				select.value = '';
				['exp-pickup','exp-date','exp-time','exp-name','exp-email','exp-phone'].forEach(id => {
					const el = document.getElementById(id) as HTMLInputElement;
					if (el) el.value = '';
				});
				(document.getElementById('exp-participants') as HTMLInputElement).value = '1';
				const notesEl = document.getElementById('exp-notes') as HTMLTextAreaElement;
				if (notesEl) notesEl.value = '';

			} catch (err) {
				console.error(err);
				showError('Something went wrong. Please try again.');
				btn.disabled = false;
				btn.textContent = 'Request Quote';
			}
		});
	});

	detectPartnerDiscount().then(d => {
		partnerDiscount = d;
		loadCatalog();
	});

	populateFormDropdown();
</script>
