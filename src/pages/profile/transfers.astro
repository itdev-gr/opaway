---
import ProfileLayout from '../../components/ProfileLayout.astro';
import ProfileContent from '../../components/ProfileContent.astro';
---

<ProfileLayout>
	<ProfileContent label="Bookings" title="My Transfers" description="View and manage your transfer bookings.">
		<p class="text-neutral-500 text-sm">No transfers yet. <a href="/book/transfer" class="text-[#0C6B95] font-medium hover:underline">Book a transfer</a>.</p>
	</ProfileContent>
</ProfileLayout>

<script>
	import { supabase } from '../../lib/supabase';

	const { data: { user } } = await supabase.auth.getUser();
	if (!user) window.location.href = '/login';
</script>
