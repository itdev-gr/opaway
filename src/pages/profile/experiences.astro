---
import ProfileLayout from '../../components/ProfileLayout.astro';
import ProfileContent from '../../components/ProfileContent.astro';
---

<ProfileLayout>
	<ProfileContent label="Experiences" title="My experiences" description="View and manage your experience bookings.">
		<p class="text-neutral-500 text-sm">No experiences yet. <a href="/experiences" class="text-[#0C6B95] font-medium hover:underline">Browse experiences</a>.</p>
	</ProfileContent>
</ProfileLayout>

<script>
	import { supabase } from '../../lib/supabase';

	supabase.auth.onAuthStateChange((_event, session) => {
		if (!session) window.location.href = '/login';
	});
</script>
