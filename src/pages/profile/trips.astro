---
import ProfileLayout from '../../components/ProfileLayout.astro';
import ProfileContent from '../../components/ProfileContent.astro';
---

<ProfileLayout>
	<ProfileContent label="Trips" title="My Trips" description="View and manage your trip bookings.">
		<p class="text-neutral-500 text-sm">No trips yet. <a href="/book/tour" class="text-[#0C6B95] font-medium hover:underline">Book a tour</a>.</p>
	</ProfileContent>
</ProfileLayout>

<script>
	import { supabase } from '../../lib/supabase';

	const { data: { user } } = await supabase.auth.getUser();
	if (!user) window.location.href = '/login';
</script>
