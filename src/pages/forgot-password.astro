---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Reset Password — Opawey">
	<main class="min-h-screen flex items-center justify-center px-6 py-20 bg-gradient-to-br from-sky-50 to-white">
		<div class="w-full max-w-md">
			<div class="text-center mb-8">
				<img src="/logo-opaway.svg" alt="Opawey" class="h-16 mx-auto mb-6" />
				<h1 class="text-2xl font-bold text-neutral-900 mb-2">Reset your password</h1>
				<p class="text-sm text-neutral-500">Enter your email address and we'll send you a link to reset your password.</p>
			</div>

			<div class="bg-white rounded-2xl border border-neutral-200 shadow-sm p-6">
				<div id="form-section">
					<div class="mb-5">
						<label class="block text-xs font-semibold text-neutral-600 mb-1.5 uppercase tracking-wider">Email address</label>
						<input id="reset-email" type="email" placeholder="e.g. john@example.com" required
							class="w-full px-4 py-3 bg-neutral-50 border border-neutral-200 rounded-xl text-sm text-neutral-800 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95]" />
					</div>

					<p id="error-msg" class="hidden text-sm text-red-500 mb-4"></p>

					<button id="reset-btn" type="button"
						class="w-full py-3 bg-[#0C6B95] hover:bg-[#0a5c82] text-white font-semibold rounded-xl transition-colors flex items-center justify-center gap-2">
						Send reset link
					</button>
				</div>

				<div id="success-section" class="hidden text-center py-4">
					<div class="w-14 h-14 rounded-full bg-emerald-100 flex items-center justify-center mx-auto mb-4">
						<svg class="w-7 h-7 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
					</div>
					<h2 class="text-lg font-bold text-neutral-900 mb-2">Check your email</h2>
					<p class="text-sm text-neutral-500 mb-4">We've sent a password reset link to <strong id="sent-email"></strong></p>
					<a href="/login" class="text-sm text-[#0C6B95] font-semibold hover:underline">Back to login</a>
				</div>
			</div>

			<p class="text-center mt-6 text-sm text-neutral-500">
				Remember your password? <a href="/login" class="text-[#0C6B95] font-semibold hover:underline">Sign in</a>
			</p>
		</div>
	</main>
</Layout>

<script>
	import { supabase } from '../lib/supabase';

	function initForgotPassword() {
		const emailInput = document.getElementById('reset-email') as HTMLInputElement;
		const resetBtn = document.getElementById('reset-btn') as HTMLButtonElement;
		const errorMsg = document.getElementById('error-msg');
		const formSection = document.getElementById('form-section');
		const successSection = document.getElementById('success-section');
		const sentEmail = document.getElementById('sent-email');

		if (!resetBtn) return;

		resetBtn.addEventListener('click', async () => {
			const email = emailInput?.value.trim() ?? '';
			errorMsg?.classList.add('hidden');
			// Always keep the success pane hidden at the start of a fresh attempt so
			// a prior success can't bleed into a retry where the user cleared the
			// email (F7).
			successSection?.classList.add('hidden');

			if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
				if (errorMsg) { errorMsg.textContent = 'Please enter a valid email address.'; errorMsg.classList.remove('hidden'); }
				return;
			}

			resetBtn.disabled = true;
			resetBtn.textContent = 'Sending...';

			try {
				const { error } = await supabase.auth.resetPasswordForEmail(email, {
					redirectTo: window.location.origin + '/login',
				});
				if (error) throw error;
				if (sentEmail) sentEmail.textContent = email;
				formSection?.classList.add('hidden');
				successSection?.classList.remove('hidden');
				errorMsg?.classList.add('hidden');
			} catch (err: any) {
				const msg = err?.message || '';
				if (errorMsg) {
					errorMsg.textContent = msg.includes('rate limit') ? 'Too many requests. Please try again later.' : 'Something went wrong. Please try again.';
					errorMsg.classList.remove('hidden');
				}
				// Error state: keep the form visible, never show the success pane.
				successSection?.classList.add('hidden');
				formSection?.classList.remove('hidden');
				resetBtn.disabled = false;
				resetBtn.textContent = 'Send reset link';
			}
		});
	}

	initForgotPassword();
	document.addEventListener('astro:page-load', initForgotPassword);
</script>
