---
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<main class="min-h-screen bg-white flex items-center justify-center px-6" data-astro-reload>
		<p class="text-neutral-500 text-sm">Signing out…</p>
	</main>
</Layout>

<script>
	import { supabase } from '../lib/supabase';

	(async () => {
		try {
			await supabase.auth.signOut();
		} finally {
			// Force a full page reload to clear all auth state and subscriptions
			window.location.replace('/');
		}
	})();
</script>
