<html lang="el">
	<head>
		<meta charset="utf-8" />
		<title>Signing out…</title>
	</head>
	<body style="display:flex;align-items:center;justify-content:center;min-height:100vh;font-family:system-ui;color:#737373;">
		<p data-i18n-el="Αποσύνδεση…" data-i18n-es="Cerrando sesión…">Signing out…</p>
