---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Page Not Found">
	<main class="min-h-screen bg-sky-50 flex items-center justify-center px-6 py-24">
		<div class="text-center max-w-md">
			<div class="w-20 h-20 rounded-full bg-sky-100 flex items-center justify-center mx-auto mb-6">
				<svg class="w-10 h-10 text-[#0C6B95]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8">
					<path stroke-linecap="round" stroke-linejoin="round" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
				</svg>
			</div>
			<h1 class="text-5xl font-bold text-neutral-900 mb-3">404</h1>
			<p class="text-lg text-neutral-600 mb-2" data-i18n-el="Η σελίδα δεν βρέθηκε" data-i18n-es="Página no encontrada">Page not found</p>
			<p class="text-sm text-neutral-400 mb-8" data-i18n-el="Η σελίδα που ψάχνετε δεν υπάρχει ή έχει μεταφερθεί αλλού." data-i18n-es="La página que busca no existe o ha sido movida.">The page you're looking for doesn't exist or has been moved.</p>
			<a href="/" class="inline-flex items-center gap-2 bg-[#0C6B95] text-white font-semibold px-6 py-3 rounded-xl hover:bg-[#0a5c82] transition-colors shadow-lg shadow-[#0C6B95]/25">
				<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
					<path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
				</svg>
				<span data-i18n-el="Επιστροφή στην αρχική" data-i18n-es="Volver al inicio">Back to Home</span>
			</a>
		</div>
	</main>
</Layout>
