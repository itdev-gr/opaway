---
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<main class="min-h-screen bg-white">

		<!-- ── Hero ── -->
		<section class="relative w-full h-[70vh] min-h-[480px] overflow-hidden bg-neutral-900">
			<!-- Background gradient layers -->
			<div class="absolute inset-0 bg-gradient-to-br from-neutral-900 via-[#0a4d6e] to-neutral-900"></div>
			<div class="absolute inset-0" style="background-image: url('data:image/svg+xml,%3Csvg width=\'60\' height=\'60\' viewBox=\'0 0 60 60\' xmlns=\'http://www.w3.org/2000/svg\'%3E%3Cg fill=\'none\' fill-rule=\'evenodd\'%3E%3Cg fill=\'%23ffffff\' fill-opacity=\'0.03\'%3E%3Cpath d=\'M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z\'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>
			<div class="absolute inset-0 bg-black/30"></div>

			<!-- Content -->
			<div class="relative z-10 h-full flex flex-col items-center justify-center text-center px-6 lg:px-10 max-w-4xl mx-auto">
				<div class="flex items-center gap-2 mb-4">
					<span class="w-2 h-2 rounded-full bg-[#0C6B95] shrink-0"></span>
					<span class="text-sm font-medium text-white/70 tracking-widest uppercase" data-i18n-el="Συνεργαστείτε μαζί μας" data-i18n-es="Asóciate con nosotros">Partner With Us</span>
				</div>
				<h1 class="text-5xl lg:text-7xl font-bold text-white mb-6 leading-tight" data-i18n-el="Συνεργαστείτε μαζί μας" data-i18n-es="Trabaja con nosotros">Work With Us</h1>
				<p class="text-white/80 text-lg lg:text-xl leading-relaxed max-w-2xl" data-i18n-el="Γίνετε μέλος του δικτύου της Opaway και αναπτύξτε την επιχείρησή σας μαζί μας. Είτε έχετε ξενοδοχείο, είτε ταξιδιωτικό πρακτορείο, είτε είστε επαγγελματίας οδηγός — υπάρχει μια συνεργασία φτιαγμένη στα μέτρα σας." data-i18n-es="Únete a la red Opaway y haz crecer tu negocio con nosotros. Ya sea que gestiones un hotel, una agencia de viajes o conduzcas profesionalmente, tenemos una colaboración hecha a tu medida.">
					Join the Opaway network and grow your business together. Whether you run a hotel, a travel agency, or drive professionally — we have a partnership made for you.
				</p>
				<!-- Scroll indicator -->
				<div class="absolute bottom-14 flex flex-col items-center gap-2 animate-bounce">
					<svg class="w-5 h-5 text-white/40" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
						<path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
					</svg>
				</div>
			</div>

			<!-- Bottom fade -->
			<div class="absolute bottom-0 left-0 right-0 h-24 bg-gradient-to-t from-white to-transparent"></div>
		</section>

		<!-- ── Partner Cards ── -->
		<section class="py-20 lg:py-28 px-6 lg:px-10 bg-white">
			<div class="max-w-6xl mx-auto">

				<!-- Section header -->
				<div class="text-center mb-16">
					<div class="flex items-center justify-center gap-2 mb-4">
						<span class="w-2 h-2 rounded-full bg-[#0C6B95]"></span>
						<span class="text-sm font-medium text-neutral-500 tracking-widest uppercase" data-i18n-el="Οι συνεργάτες μας" data-i18n-es="Nuestros socios">Our Partners</span>
					</div>
					<h2 class="text-4xl font-bold text-neutral-900 mb-4" data-i18n-el="Διαλέξτε τη συνεργασία που σας ταιριάζει" data-i18n-es="Elige tu colaboración">Choose Your Partnership</h2>
					<div class="w-16 h-1 bg-[#0C6B95] rounded-full mx-auto mb-6"></div>
					<p class="text-neutral-500 text-base max-w-xl mx-auto leading-relaxed" data-i18n-el="Συνεργαζόμαστε με επιχειρήσεις και επαγγελματίες κάθε μεγέθους, για να προσφέρουμε αξέχαστες εμπειρίες σε όλη την Ελλάδα." data-i18n-es="Colaboramos con una amplia gama de empresas y profesionales para ofrecer experiencias excepcionales en toda Grecia.">
						We collaborate with a wide range of businesses and professionals to deliver exceptional experiences across Greece.
					</p>
				</div>

				<!-- Three cards -->
				<div class="grid grid-cols-1 lg:grid-cols-3 gap-8 items-stretch">

					<!-- Card 1: Hotels & Boutiques -->
					<div class="group flex flex-col bg-white rounded-3xl border border-neutral-200 shadow-sm hover:shadow-2xl hover:-translate-y-1 transition-all duration-300 overflow-hidden">
						<div class="h-1.5 bg-[#0C6B95]"></div>
						<div class="flex flex-col flex-1 p-8">
							<!-- Icon -->
							<div class="w-14 h-14 rounded-2xl bg-[#0C6B95]/10 flex items-center justify-center mb-6 group-hover:bg-[#0C6B95]/15 transition-colors">
								<svg class="w-7 h-7 text-[#0C6B95]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8">
									<path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
								</svg>
							</div>
							<h3 class="text-2xl font-bold text-neutral-900 mb-3" data-i18n-el="Ξενοδοχεία & Boutique" data-i18n-es="Hoteles y boutiques">Hotels &amp; Boutiques</h3>
							<p class="text-neutral-500 text-sm leading-relaxed mb-7" data-i18n-el="Αναβαθμίστε τη διαμονή των επισκεπτών σας με άψογες μεταφορές από και προς το αεροδρόμιο, ιδιωτικές περιηγήσεις στην πόλη και επιλεγμένες εκδρομές — όλα οργανωμένα απευθείας μέσω του concierge σας." data-i18n-es="Mejora la estancia de tus huéspedes ofreciendo traslados al aeropuerto impecables, tours privados por la ciudad y excursiones cuidadosamente seleccionadas, todo coordinado directamente a través de su conserjería.">
								Elevate your guests' stay by offering seamless airport transfers, private city tours, and curated excursions — all coordinated directly through your concierge.
							</p>
							<!-- Benefits list -->
							<ul class="space-y-3 mb-8 flex-1">
								<li class="flex items-start gap-3">
									<span class="w-5 h-5 rounded-full bg-sky-50 border border-sky-200 flex items-center justify-center shrink-0 mt-0.5">
										<svg class="w-3 h-3 text-[#0C6B95]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
									</span>
									<span class="text-sm text-neutral-600" data-i18n-el="Αποκλειστική γραμμή για τον concierge" data-i18n-es="Línea de coordinación de conserjería exclusiva">Dedicated concierge coordination line</span>
								</li>
								<li class="flex items-start gap-3">
									<span class="w-5 h-5 rounded-full bg-sky-50 border border-sky-200 flex items-center justify-center shrink-0 mt-0.5">
										<svg class="w-3 h-3 text-[#0C6B95]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
									</span>
									<span class="text-sm text-neutral-600" data-i18n-el="Προμήθεια σε κάθε επιτυχημένη κράτηση" data-i18n-es="Comisión en cada reserva completada">Commission on every completed booking</span>
								</li>
								<li class="flex items-start gap-3">
									<span class="w-5 h-5 rounded-full bg-sky-50 border border-sky-200 flex items-center justify-center shrink-0 mt-0.5">
										<svg class="w-3 h-3 text-[#0C6B95]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
									</span>
									<span class="text-sm text-neutral-600" data-i18n-el="Εμπειρία με τη δική σας ταυτότητα για τους επισκέπτες" data-i18n-es="Experiencia con su marca para sus huéspedes">Branded experience for your guests</span>
								</li>
								<li class="flex items-start gap-3">
									<span class="w-5 h-5 rounded-full bg-sky-50 border border-sky-200 flex items-center justify-center shrink-0 mt-0.5">
										<svg class="w-3 h-3 text-[#0C6B95]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
									</span>
									<span class="text-sm text-neutral-600" data-i18n-el="Υποστήριξη 24/7 για τους επισκέπτες σας" data-i18n-es="Asistencia 24/7 para sus huéspedes">24/7 support for your guests</span>
								</li>
							</ul>
							<a href="/register-partner" class="mt-auto flex items-center justify-center gap-2 w-full py-3.5 bg-[#0C6B95] hover:bg-[#0a5c82] text-white text-sm font-semibold rounded-xl transition-colors duration-200 shadow-sm shadow-[#0C6B95]/20">
								<span data-i18n-el="Επικοινωνήστε μαζί μας" data-i18n-es="Ponte en contacto">Get in Touch</span>
								<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
									<path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
								</svg>
							</a>
						</div>
					</div>

					<!-- Card 2: Travel Agencies (featured / highlighted) -->
					<div class="flex flex-col bg-[#0C6B95] rounded-3xl shadow-2xl shadow-[#0C6B95]/30 overflow-hidden relative hover:-translate-y-1 transition-transform duration-300">
						<div class="flex flex-col flex-1 p-8">
							<!-- Icon -->
							<div class="w-14 h-14 rounded-2xl bg-white/15 flex items-center justify-center mb-6">
								<svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8">
									<path stroke-linecap="round" stroke-linejoin="round" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 004 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
								</svg>
							</div>
							<h3 class="text-2xl font-bold text-white mb-3" data-i18n-el="Ταξιδιωτικά πρακτορεία" data-i18n-es="Agencias de viajes">Travel Agencies</h3>
							<p class="text-white/75 text-sm leading-relaxed mb-7" data-i18n-el="Προσφέρετε στους πελάτες σας μεταφορές υψηλού επιπέδου και επιλεγμένες εμπειρίες σε όλη την Ελλάδα. Ενσωματώστε τις premium υπηρεσίες μας στα πακέτα σας, εύκολα και με απόλυτη εμπιστοσύνη." data-i18n-es="Ofrece a tus clientes traslados de primer nivel y experiencias seleccionadas en Grecia. Integra nuestros servicios premium en tus paquetes con facilidad y total confianza.">
								Offer your clients world-class transfers and curated experiences in Greece. Integrate our premium services into your packages with ease and full confidence.
							</p>
							<!-- Benefits list -->
							<ul class="space-y-3 mb-8 flex-1">
								<li class="flex items-start gap-3">
									<span class="w-5 h-5 rounded-full bg-white/20 flex items-center justify-center shrink-0 mt-0.5">
										<svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
									</span>
									<span class="text-sm text-white/85" data-i18n-el="Εκπτώσεις σε ομαδικές κρατήσεις & προνομιακές τιμές" data-i18n-es="Descuentos por reservas en grupo y tarifas preferentes">Bulk booking discounts &amp; priority rates</span>
								</li>
								<li class="flex items-start gap-3">
									<span class="w-5 h-5 rounded-full bg-white/20 flex items-center justify-center shrink-0 mt-0.5">
										<svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
									</span>
									<span class="text-sm text-white/85" data-i18n-el="Προσωπικός account manager στη διάθεσή σας" data-i18n-es="Gestor de cuentas dedicado asignado a usted">Dedicated account manager assigned to you</span>
								</li>
								<li class="flex items-start gap-3">
									<span class="w-5 h-5 rounded-full bg-white/20 flex items-center justify-center shrink-0 mt-0.5">
										<svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
									</span>
									<span class="text-sm text-white/85" data-i18n-el="Πλατφόρμα κρατήσεων & παρακολούθησης σε πραγματικό χρόνο" data-i18n-es="Portal de reservas y seguimiento en tiempo real">Real-time booking &amp; tracking portal</span>
								</li>
								<li class="flex items-start gap-3">
									<span class="w-5 h-5 rounded-full bg-white/20 flex items-center justify-center shrink-0 mt-0.5">
										<svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
									</span>
									<span class="text-sm text-white/85" data-i18n-el="Ευέλικτες επιλογές τιμολόγησης & χρέωσης" data-i18n-es="Opciones flexibles de facturación y cobro">Flexible invoicing &amp; billing options</span>
								</li>
							</ul>
							<a href="/register-partner" class="mt-auto flex items-center justify-center gap-2 w-full py-3.5 bg-white hover:bg-white/90 text-[#0C6B95] text-sm font-semibold rounded-xl transition-colors duration-200 shadow-sm">
								<span data-i18n-el="Γίνετε συνεργάτης" data-i18n-es="Hazte socio">Become a Partner</span>
								<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
									<path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
								</svg>
							</a>
						</div>
					</div>

					<!-- Card 3: Drivers -->
					<div class="group flex flex-col bg-white rounded-3xl border border-neutral-200 shadow-sm hover:shadow-2xl hover:-translate-y-1 transition-all duration-300 overflow-hidden">
						<div class="h-1.5 bg-neutral-800"></div>
						<div class="flex flex-col flex-1 p-8">
							<!-- Icon -->
							<div class="w-14 h-14 rounded-2xl bg-neutral-100 flex items-center justify-center mb-6 group-hover:bg-neutral-200/70 transition-colors">
								<svg class="w-7 h-7 text-neutral-700" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8">
									<path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
								</svg>
							</div>
							<h3 class="text-2xl font-bold text-neutral-900 mb-3" data-i18n-el="Οδηγοί" data-i18n-es="Conductores">Drivers</h3>
							<p class="text-neutral-500 text-sm leading-relaxed mb-7" data-i18n-el="Είστε επαγγελματίας οδηγός και ψάχνετε περισσότερους πελάτες; Γίνετε μέλος του δικτύου μας και αναλάβετε premium μεταφορές, διαδρομές αεροδρομίου και επιλεγμένες περιηγήσεις — με δικό σας πρόγραμμα." data-i18n-es="¿Eres un conductor profesional en busca de más clientes? Únete a nuestra creciente red y accede a traslados premium, trayectos al aeropuerto y tours seleccionados, según tu propio horario.">
								Are you a professional driver looking for more clients? Join our growing network and get access to premium transfers, airport runs, and curated tours — on your own schedule.
							</p>
							<!-- Benefits list -->
							<ul class="space-y-3 mb-8 flex-1">
								<li class="flex items-start gap-3">
									<span class="w-5 h-5 rounded-full bg-neutral-100 border border-neutral-200 flex items-center justify-center shrink-0 mt-0.5">
										<svg class="w-3 h-3 text-neutral-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
									</span>
									<span class="text-sm text-neutral-600" data-i18n-el="Ευέλικτο ωράριο — εργαστείτε όποτε θέλετε" data-i18n-es="Horario flexible: trabaja cuando quieras">Flexible hours — work when you want</span>
								</li>
								<li class="flex items-start gap-3">
									<span class="w-5 h-5 rounded-full bg-neutral-100 border border-neutral-200 flex items-center justify-center shrink-0 mt-0.5">
										<svg class="w-3 h-3 text-neutral-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
									</span>
									<span class="text-sm text-neutral-600" data-i18n-el="Ανταγωνιστικές αμοιβές ανά διαδρομή" data-i18n-es="Ingresos competitivos por trayecto">Competitive earnings per trip</span>
								</li>
								<li class="flex items-start gap-3">
									<span class="w-5 h-5 rounded-full bg-neutral-100 border border-neutral-200 flex items-center justify-center shrink-0 mt-0.5">
										<svg class="w-3 h-3 text-neutral-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
									</span>
									<span class="text-sm text-neutral-600" data-i18n-el="Σταθερή ροή κρατήσεων υψηλής ποιότητας" data-i18n-es="Flujo constante de reservas de calidad">Steady stream of quality bookings</span>
								</li>
								<li class="flex items-start gap-3">
									<span class="w-5 h-5 rounded-full bg-neutral-100 border border-neutral-200 flex items-center justify-center shrink-0 mt-0.5">
										<svg class="w-3 h-3 text-neutral-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
									</span>
									<span class="text-sm text-neutral-600" data-i18n-el="Υποστήριξη και συντονισμός 24 ώρες το 24ωρο" data-i18n-es="Asistencia de despacho y coordinación a demanda">On-call dispatch &amp; coordination support</span>
								</li>
							</ul>
							<a href="/register-partner" class="mt-auto flex items-center justify-center gap-2 w-full py-3.5 bg-neutral-900 hover:bg-neutral-700 text-white text-sm font-semibold rounded-xl transition-colors duration-200">
								<span data-i18n-el="Κάντε αίτηση τώρα" data-i18n-es="Solicítalo ahora">Apply Now</span>
								<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
									<path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
								</svg>
							</a>
						</div>
					</div>

				</div>
			</div>
		</section>

		<!-- ── Why Opaway ── -->
		<section class="py-20 lg:py-24 px-6 lg:px-10 bg-[#F5F6F8]">
			<div class="max-w-6xl mx-auto">

				<!-- Header -->
				<div class="text-center mb-14">
					<div class="flex items-center justify-center gap-2 mb-4">
						<span class="w-2 h-2 rounded-full bg-[#0C6B95]"></span>
						<span class="text-sm font-medium text-neutral-500 tracking-widest uppercase" data-i18n-el="Γιατί Opaway" data-i18n-es="Por qué Opaway">Why Opaway</span>
					</div>
					<h2 class="text-4xl font-bold text-neutral-900 mb-4" data-i18n-el="Με βάση την εμπιστοσύνη & την αριστεία" data-i18n-es="Construido sobre la confianza y la excelencia">Built on Trust &amp; Excellence</h2>
					<div class="w-16 h-1 bg-[#0C6B95] rounded-full mx-auto"></div>
				</div>

				<!-- Trust pillars -->
				<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">

					<div class="bg-white rounded-2xl p-6 border border-neutral-100 shadow-sm text-center hover:shadow-md transition-shadow">
						<div class="w-12 h-12 rounded-full bg-sky-50 flex items-center justify-center mx-auto mb-4">
							<svg class="w-6 h-6 text-[#0C6B95]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8">
								<path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
							</svg>
						</div>
						<h4 class="font-bold text-neutral-900 mb-2" data-i18n-el="Πάντα στην ώρα μας" data-i18n-es="Siempre puntuales">Always On Time</h4>
						<p class="text-neutral-500 text-xs leading-relaxed" data-i18n-el="Η συνέπεια είναι υπόσχεσή μας — οι πελάτες σας δεν θα περιμένουν ποτέ." data-i18n-es="La puntualidad es nuestra promesa: sus clientes nunca tendrán que esperar.">Punctuality is our promise — your clients will never be kept waiting.</p>
					</div>

					<div class="bg-white rounded-2xl p-6 border border-neutral-100 shadow-sm text-center hover:shadow-md transition-shadow">
						<div class="w-12 h-12 rounded-full bg-sky-50 flex items-center justify-center mx-auto mb-4">
							<svg class="w-6 h-6 text-[#0C6B95]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8">
