---
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<main class="min-h-screen bg-sky-50 flex items-center justify-center px-6 py-24">

		<!-- Soft gradient blobs -->
		<div class="fixed top-0 right-0 w-[600px] h-[600px] bg-[#0C6B95]/6 rounded-full blur-3xl -translate-y-1/3 translate-x-1/4 pointer-events-none"></div>
		<div class="fixed bottom-0 left-0 w-[400px] h-[400px] bg-sky-100/60 rounded-full blur-3xl translate-y-1/3 -translate-x-1/4 pointer-events-none"></div>

		<div class="relative z-10 w-full max-w-xl">

			<!-- Logo -->
			<div class="flex justify-center mb-8">
				<a href="/" aria-label="Go to homepage" data-i18n-aria-el="Μετάβαση στην αρχική σελίδα" data-i18n-aria-es="Ir a la página de inicio">
					<img src="/logo-opaway.svg" alt="Opawey" class="h-16 w-auto object-contain" />
				</a>
			</div>

			<!-- Card -->
			<div class="bg-white rounded-3xl border border-neutral-200 shadow-xl shadow-neutral-200/60 p-8 lg:p-10">

				<!-- Header -->
				<div class="mb-8">
					<div class="flex items-center gap-2 mb-3">
						<span class="w-2 h-2 rounded-full bg-[#0C6B95] shrink-0"></span>
						<span class="text-xs font-medium text-[#0C6B95] tracking-widest uppercase" data-i18n-el="Πρόσβαση Συνεργατών" data-i18n-es="Acceso para socios">Partner Access</span>
					</div>
					<h1 class="text-3xl font-bold text-neutral-900" data-i18n-el="Γίνετε συνεργάτης" data-i18n-es="Hazte socio">Become a Partner</h1>
					<p class="text-neutral-500 text-sm mt-1" data-i18n-el="Επιλέξτε τον τύπο συνεργασίας και συμπληρώστε τα στοιχεία σας για να υποβάλετε αίτηση." data-i18n-es="Seleccione su tipo de socio y rellene sus datos para enviar la solicitud.">Select your partner type and fill in your details to apply.</p>
				</div>

				<!-- Auth / form error -->
				<div id="auth-error" class="hidden mb-4 p-3 rounded-xl bg-red-50 border border-red-200 text-red-700 text-sm" role="alert"></div>

				<!-- ── Partner type dropdown ── -->
				<div class="flex flex-col gap-1.5 mb-6">
					<label for="partner-type" class="text-neutral-700 text-xs font-medium uppercase tracking-widest" data-i18n-el="Τύπος Συνεργάτη" data-i18n-es="Tipo de socio">Partner Type</label>
					<div class="relative">
						<select
							id="partner-type"
							class="w-full appearance-none pl-4 pr-10 py-3.5 bg-neutral-50 border border-neutral-200 rounded-xl text-neutral-800 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95] transition-colors text-sm cursor-pointer"
						>
							<option value="" disabled selected data-i18n-el="Επιλέξτε τύπο συνεργάτη…" data-i18n-es="Seleccione el tipo de socio…">Select partner type…</option>
							<option value="hotel" data-i18n-el="Ξενοδοχεία &amp; Boutique" data-i18n-es="Hoteles y boutiques">Hotels &amp; Boutiques</option>
							<option value="agency" data-i18n-el="Ταξιδιωτικά Πρακτορεία" data-i18n-es="Agencias de viajes">Travel Agencies</option>
							<option value="driver" data-i18n-el="Οδηγοί" data-i18n-es="Conductores">Drivers</option>
						</select>
						<span class="absolute right-3.5 top-1/2 -translate-y-1/2 text-neutral-400 pointer-events-none">
							<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
								<path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
							</svg>
						</span>
					</div>
				</div>

				<!-- ── Form body (shown after type selection) ── -->
				<form id="partner-form" class="hidden flex-col gap-5" novalidate>

					<!-- Type badge -->
					<div id="type-badge" class="flex items-center gap-3 px-4 py-3 rounded-xl border mb-1"></div>

					<!-- ══════════════════════════════════════
					     HOTEL / BOUTIQUE FIELDS
					     ══════════════════════════════════════ -->
					<div id="fields-hotel" class="flex flex-col gap-5" style="display:none">

						<!-- Business Information -->
						<div class="flex items-center gap-3 py-1">
							<div class="flex-1 h-px bg-neutral-100"></div>
							<span class="text-xs text-neutral-400 font-medium uppercase tracking-widest" data-i18n-el="Επιχειρηματικά Στοιχεία" data-i18n-es="Información empresarial">Business Information</span>
							<div class="flex-1 h-px bg-neutral-100"></div>
						</div>

						<div class="flex flex-col gap-1.5">
							<label class="text-neutral-700 text-xs font-medium uppercase tracking-widest" data-i18n-el="Χώρα *" data-i18n-es="País *">Country *</label>
							<div class="relative">
								<select id="h-country"
									class="w-full appearance-none px-4 pr-10 py-3 bg-neutral-50 border border-neutral-200 rounded-xl text-neutral-800 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95] transition-colors text-sm cursor-pointer">
									<option value="" disabled selected data-i18n-el="Επιλέξτε χώρα…" data-i18n-es="Seleccione país…">Select country…</option>
									<option value="Greece" data-i18n-el="Ελλάδα" data-i18n-es="Grecia">Greece</option>
									<option value="United Kingdom" data-i18n-el="Ηνωμένο Βασίλειο" data-i18n-es="Reino Unido">United Kingdom</option>
									<option value="United States" data-i18n-el="Ηνωμένες Πολιτείες" data-i18n-es="Estados Unidos">United States</option>
									<option value="Germany" data-i18n-el="Γερμανία" data-i18n-es="Alemania">Germany</option>
									<option value="France" data-i18n-el="Γαλλία" data-i18n-es="Francia">France</option>
									<option value="Italy" data-i18n-el="Ιταλία" data-i18n-es="Italia">Italy</option>
									<option value="Spain" data-i18n-el="Ισπανία" data-i18n-es="España">Spain</option>
									<option value="Netherlands" data-i18n-el="Ολλανδία" data-i18n-es="Países Bajos">Netherlands</option>
									<option value="Turkey" data-i18n-el="Τουρκία" data-i18n-es="Turquía">Turkey</option>
									<option value="Cyprus" data-i18n-el="Κύπρος" data-i18n-es="Chipre">Cyprus</option>
									<option value="Australia" data-i18n-el="Αυστραλία" data-i18n-es="Australia">Australia</option>
									<option value="Canada" data-i18n-el="Καναδάς" data-i18n-es="Canadá">Canada</option>
									<option value="Switzerland" data-i18n-el="Ελβετία" data-i18n-es="Suiza">Switzerland</option>
									<option value="Austria" data-i18n-el="Αυστρία" data-i18n-es="Austria">Austria</option>
									<option value="Belgium" data-i18n-el="Βέλγιο" data-i18n-es="Bélgica">Belgium</option>
									<option value="Sweden" data-i18n-el="Σουηδία" data-i18n-es="Suecia">Sweden</option>
									<option value="Norway" data-i18n-el="Νορβηγία" data-i18n-es="Noruega">Norway</option>
									<option value="Denmark" data-i18n-el="Δανία" data-i18n-es="Dinamarca">Denmark</option>
									<option value="Portugal" data-i18n-el="Πορτογαλία" data-i18n-es="Portugal">Portugal</option>
									<option value="Ireland" data-i18n-el="Ιρλανδία" data-i18n-es="Irlanda">Ireland</option>
									<option value="Other" data-i18n-el="Άλλο" data-i18n-es="Otro">Other</option>
								</select>
								<span class="absolute right-3.5 top-1/2 -translate-y-1/2 text-neutral-400 pointer-events-none">
									<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
								</span>
							</div>
						</div>

						<div class="flex flex-col gap-1.5">
							<label class="text-neutral-700 text-xs font-medium uppercase tracking-widest" data-i18n-el="Όνομα ξενοδοχείου ή Boutique *" data-i18n-es="Nombre del hotel o boutique *">Hotel or Boutique Name *</label>
							<input id="h-name" type="text" placeholder="e.g. Aegean Boutique Hotel" data-i18n-placeholder-el="π.χ. Aegean Boutique Hotel" data-i18n-placeholder-es="p. ej. Aegean Boutique Hotel"
								class="w-full px-4 py-3 bg-neutral-50 border border-neutral-200 rounded-xl text-neutral-800 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95] transition-colors text-sm" />
						</div>

						<div class="flex flex-col gap-1.5">
							<label class="text-neutral-700 text-xs font-medium uppercase tracking-widest" data-i18n-el="Τύπος *" data-i18n-es="Tipo *">Type *</label>
							<div class="relative">
								<select id="h-type"
									class="w-full appearance-none px-4 pr-10 py-3 bg-neutral-50 border border-neutral-200 rounded-xl text-neutral-800 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95] transition-colors text-sm cursor-pointer">
									<option value="" disabled selected data-i18n-el="Επιλέξτε τύπο…" data-i18n-es="Seleccione el tipo…">Select type…</option>
									<option data-i18n-el="Ξενοδοχείο" data-i18n-es="Hotel">Hotel</option>
									<option data-i18n-el="Boutique Hotel" data-i18n-es="Hotel boutique">Boutique Hotel</option>
									<option data-i18n-el="Resort" data-i18n-es="Resort">Resort</option>
									<option data-i18n-el="Βίλα" data-i18n-es="Villa">Villa</option>
									<option data-i18n-el="B&amp;B" data-i18n-es="B&amp;B">B&amp;B</option>
									<option data-i18n-el="Άλλο" data-i18n-es="Otro">Other</option>
								</select>
								<span class="absolute right-3.5 top-1/2 -translate-y-1/2 text-neutral-400 pointer-events-none">
									<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
								</span>
							</div>
						</div>

						<div class="flex flex-col gap-1.5">
							<label class="text-neutral-700 text-xs font-medium uppercase tracking-widest" data-i18n-el="ΑΦΜ *" data-i18n-es="Número de IVA / NIF *">VAT Number *</label>
							<input id="h-vat" type="text" placeholder="e.g. EL123456789" data-i18n-placeholder-el="π.χ. EL123456789" data-i18n-placeholder-es="p. ej. ES12345678X"
								class="w-full px-4 py-3 bg-neutral-50 border border-neutral-200 rounded-xl text-neutral-800 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95] transition-colors text-sm" />
						</div>

						<div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
							<div class="flex flex-col gap-1.5">
								<label class="text-neutral-700 text-xs font-medium uppercase tracking-widest" data-i18n-el="Τηλέφωνο *" data-i18n-es="Teléfono *">Phone *</label>
								<input id="h-phone" type="tel" placeholder="e.g. +30 210…" data-i18n-placeholder-el="π.χ. +30 210…" data-i18n-placeholder-es="p. ej. +30 210…"
									class="w-full px-4 py-3 bg-neutral-50 border border-neutral-200 rounded-xl text-neutral-800 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95] transition-colors text-sm" />
							</div>
							<div class="flex flex-col gap-1.5">
								<label class="text-neutral-700 text-xs font-medium uppercase tracking-widest" data-i18n-el="Email *" data-i18n-es="Correo electrónico *">Email *</label>
								<input id="h-email" type="email" placeholder="e.g. info@hotel.com" data-i18n-placeholder-el="π.χ. info@hotel.com" data-i18n-placeholder-es="p. ej. info@hotel.com"
									class="w-full px-4 py-3 bg-neutral-50 border border-neutral-200 rounded-xl text-neutral-800 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95] transition-colors text-sm" />
							</div>
						</div>

						<!-- Contact Person -->
						<div class="flex items-center gap-3 py-1">
							<div class="flex-1 h-px bg-neutral-100"></div>
							<span class="text-xs text-neutral-400 font-medium uppercase tracking-widest" data-i18n-el="Υπεύθυνος Επικοινωνίας" data-i18n-es="Persona de contacto">Contact Person</span>
							<div class="flex-1 h-px bg-neutral-100"></div>
						</div>

						<div class="flex flex-col gap-1.5">
							<label class="text-neutral-700 text-xs font-medium uppercase tracking-widest" data-i18n-el="Όνομα υπευθύνου επικοινωνίας *" data-i18n-es="Nombre de la persona de contacto *">Contact Person Name *</label>
							<input id="h-contact-name" type="text" placeholder="e.g. Maria Papadopoulou" data-i18n-placeholder-el="π.χ. Μαρία Παπαδοπούλου" data-i18n-placeholder-es="p. ej. María García"
								class="w-full px-4 py-3 bg-neutral-50 border border-neutral-200 rounded-xl text-neutral-800 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95] transition-colors text-sm" />
						</div>

						<div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
							<div class="flex flex-col gap-1.5">
								<label class="text-neutral-700 text-xs font-medium uppercase tracking-widest" data-i18n-el="Τηλέφωνο επικοινωνίας *" data-i18n-es="Teléfono de contacto *">Contact Phone *</label>
								<input id="h-contact-phone" type="tel" placeholder="e.g. +30 69…" data-i18n-placeholder-el="π.χ. +30 69…" data-i18n-placeholder-es="p. ej. +30 69…"
									class="w-full px-4 py-3 bg-neutral-50 border border-neutral-200 rounded-xl text-neutral-800 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95] transition-colors text-sm" />
							</div>
							<div class="flex flex-col gap-1.5">
								<label class="text-neutral-700 text-xs font-medium uppercase tracking-widest" data-i18n-el="Email επικοινωνίας *" data-i18n-es="Correo electrónico de contacto *">Contact Email *</label>
								<input id="h-contact-email" type="email" placeholder="e.g. maria@hotel.com" data-i18n-placeholder-el="π.χ. maria@hotel.com" data-i18n-placeholder-es="p. ej. maria@hotel.com"
									class="w-full px-4 py-3 bg-neutral-50 border border-neutral-200 rounded-xl text-neutral-800 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95] transition-colors text-sm" />
							</div>
						</div>

						<!-- Property Details -->
						<div class="flex items-center gap-3 py-1">
							<div class="flex-1 h-px bg-neutral-100"></div>
							<span class="text-xs text-neutral-400 font-medium uppercase tracking-widest" data-i18n-el="Στοιχεία Καταλύματος" data-i18n-es="Detalles del alojamiento">Property Details</span>
							<div class="flex-1 h-px bg-neutral-100"></div>
						</div>

						<div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
							<div class="flex flex-col gap-1.5">
								<label class="text-neutral-700 text-xs font-medium uppercase tracking-widest" data-i18n-el="Τοποθεσία / Διεύθυνση *" data-i18n-es="Ubicación / Dirección *">Location / Address *</label>
								<input id="h-location" type="text" placeholder="e.g. Mykonos, Greece" data-i18n-placeholder-el="π.χ. Μύκονος, Ελλάδα" data-i18n-placeholder-es="p. ej. Mikonos, Grecia"
									class="w-full px-4 py-3 bg-neutral-50 border border-neutral-200 rounded-xl text-neutral-800 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95] transition-colors text-sm" />
							</div>
							<div class="flex flex-col gap-1.5">
								<label class="text-neutral-700 text-xs font-medium uppercase tracking-widest" data-i18n-el="Ταχ. Κώδικας *" data-i18n-es="Código postal *">ZIP Code *</label>
								<input id="h-zip" type="text" placeholder="e.g. 84600" data-i18n-placeholder-el="π.χ. 84600" data-i18n-placeholder-es="p. ej. 84600"
									class="w-full px-4 py-3 bg-neutral-50 border border-neutral-200 rounded-xl text-neutral-800 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95] transition-colors text-sm" />
							</div>
						</div>

						<div class="flex flex-col gap-1.5">
							<label class="text-neutral-700 text-xs font-medium uppercase tracking-widest"><span data-i18n-el="Ιστοσελίδα" data-i18n-es="Sitio web">Website</span> <span class="normal-case text-neutral-400 font-normal" data-i18n-el="(προαιρετικό)" data-i18n-es="(opcional)">(optional)</span></label>
							<input id="h-website" type="url" placeholder="https://www.yourhotel.com" data-i18n-placeholder-el="https://www.yourhotel.com" data-i18n-placeholder-es="https://www.yourhotel.com"
								class="w-full px-4 py-3 bg-neutral-50 border border-neutral-200 rounded-xl text-neutral-800 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95] transition-colors text-sm" />
						</div>

					</div>

					<!-- ══════════════════════════════════════
					     TRAVEL AGENCY FIELDS
					     ══════════════════════════════════════ -->
					<div id="fields-agency" class="flex flex-col gap-5" style="display:none">

						<!-- Business Information -->
						<div class="flex items-center gap-3 py-1">
							<div class="flex-1 h-px bg-neutral-100"></div>
							<span class="text-xs text-neutral-400 font-medium uppercase tracking-widest" data-i18n-el="Επιχειρηματικά Στοιχεία" data-i18n-es="Información empresarial">Business Information</span>
							<div class="flex-1 h-px bg-neutral-100"></div>
						</div>

						<div class="flex flex-col gap-1.5">
							<label class="text-neutral-700 text-xs font-medium uppercase tracking-widest" data-i18n-el="Χώρα *" data-i18n-es="País *">Country *</label>
							<div class="relative">
								<select id="a-country"
									class="w-full appearance-none px-4 pr-10 py-3 bg-neutral-50 border border-neutral-200 rounded-xl text-neutral-800 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95] transition-colors text-sm cursor-pointer">
									<option value="" disabled selected data-i18n-el="Επιλέξτε χώρα…" data-i18n-es="Seleccione país…">Select country…</option>
									<option value="Greece" data-i18n-el="Ελλάδα" data-i18n-es="Grecia">Greece</option>
									<option value="United Kingdom" data-i18n-el="Ηνωμένο Βασίλειο" data-i18n-es="Reino Unido">United Kingdom</option>
									<option value="United States" data-i18n-el="Ηνωμένες Πολιτείες" data-i18n-es="Estados Unidos">United States</option>
									<option value="Germany" data-i18n-el="Γερμανία" data-i18n-es="Alemania">Germany</option>
									<option value="France" data-i18n-el="Γαλλία" data-i18n-es="Francia">France</option>
									<option value="Italy" data-i18n-el="Ιταλία" data-i18n-es="Italia">Italy</option>
									<option value="Spain" data-i18n-el="Ισπανία" data-i18n-es="España">Spain</option>
									<option value="Netherlands" data-i18n-el="Ολλανδία" data-i18n-es="Países Bajos">Netherlands</option>
									<option value="Turkey" data-i18n-el="Τουρκία" data-i18n-es="Turquía">Turkey</option>
									<option value="Cyprus" data-i18n-el="Κύπρος" data-i18n-es="Chipre">Cyprus</option>
									<option value="Australia" data-i18n-el="Αυστραλία" data-i18n-es="Australia">Australia</option>
									<option value="Canada" data-i18n-el="Καναδάς" data-i18n-es="Canadá">Canada</option>
									<option value="Switzerland" data-i18n-el="Ελβετία" data-i18n-es="Suiza">Switzerland</option>
									<option value="Austria" data-i18n-el="Αυστρία" data-i18n-es="Austria">Austria</option>
									<option value="Belgium" data-i18n-el="Βέλγιο" data-i18n-es="Bélgica">Belgium</option>
									<option value="Sweden" data-i18n-el="Σουηδία" data-i18n-es="Suecia">Sweden</option>
									<option value="Norway" data-i18n-el="Νορβηγία" data-i18n-es="Noruega">Norway</option>
									<option value="Denmark" data-i18n-el="Δανία" data-i18n-es="Dinamarca">Denmark</option>
									<option value="Portugal" data-i18n-el="Πορτογαλία" data-i18n-es="Portugal">Portugal</option>
									<option value="Ireland" data-i18n-el="Ιρλανδία" data-i18n-es="Irlanda">Ireland</option>
									<option value="Other" data-i18n-el="Άλλο" data-i18n-es="Otro">Other</option>
								</select>
								<span class="absolute right-3.5 top-1/2 -translate-y-1/2 text-neutral-400 pointer-events-none">
									<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
								</span>
							</div>
						</div>

						<div class="flex flex-col gap-1.5">
							<label class="text-neutral-700 text-xs font-medium uppercase tracking-widest" data-i18n-el="Όνομα Πρακτορείου *" data-i18n-es="Nombre de la agencia *">Agency Name *</label>
							<input id="a-name" type="text" placeholder="e.g. Hellas Travel Group" data-i18n-placeholder-el="π.χ. Hellas Travel Group" data-i18n-placeholder-es="p. ej. Hellas Travel Group"
