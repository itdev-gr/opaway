---
import Layout from '../../layouts/Layout.astro';
import LuggageCounters from '../../components/LuggageCounters.astro';

const vehicles = [
	{
		title: 'Sedan',
		titleEl: 'Sedan',
		models: 'Mercedes-Benz E-Class, or similar.',
		modelsEl: 'Mercedes-Benz E-Class ή παρόμοιο.',
		image: '/car.avif',
		features: [
			{ en: 'Fits up to 3 people', el: 'Χωράει έως 3 άτομα' },
			{ en: '1 big + 1 small luggage per person', el: '1 μεγάλη + 1 μικρή αποσκευή ανά άτομο' },
			{ en: 'Available for city tours & custom routes', el: 'Διαθέσιμο για τουρ πόλης & εξατομικευμένες διαδρομές' },
		],
	},
	{
		title: 'Van',
		titleEl: 'Βαν',
		models: 'Mercedes Vito Tourer, or similar.',
		modelsEl: 'Mercedes Vito Tourer ή παρόμοιο.',
		image: '/mini_van.avif',
		features: [
			{ en: 'Fits up to 8 people', el: 'Χωράει έως 8 άτομα' },
			{ en: '1 big + 1 small luggage per person', el: '1 μεγάλη + 1 μικρή αποσκευή ανά άτομο' },
			{ en: 'Ideal for group tours & day trips', el: 'Ιδανικό για ομαδικά τουρ & ημερήσιες εκδρομές' },
		],
	},
	{
		title: 'Minibus (or two Vans)',
		titleEl: 'Μίνι Λεωφορείο (ή δύο Βαν)',
		models: 'Mercedes Sprinter, or similar.',
		modelsEl: 'Mercedes Sprinter ή παρόμοιο.',
		image: '/van.avif',
		features: [
			{ en: 'Fits up to 18 people', el: 'Χωράει έως 18 άτομα' },
			{ en: '1 big + 1 small luggage per person', el: '1 μεγάλη + 1 μικρή αποσκευή ανά άτομο' },
			{ en: 'Perfect for large groups & corporate events', el: 'Ιδανικό για μεγάλες ομάδες & εταιρικές εκδηλώσεις' },
		],
	},
];
---

<Layout title="Rent per Hour — Opawey">
	<main class="min-h-screen bg-sky-50 pt-36 pb-24 px-6 lg:px-10">
		<div class="max-w-6xl mx-auto">

			<!-- Sub-navigation tabs -->
			<div class="flex items-center gap-3 mb-10">
				<a href="/book/transfer" class="flex items-center gap-2 px-5 py-2.5 rounded-xl bg-white border border-neutral-200 text-neutral-600 font-semibold text-sm hover:border-[#0C6B95]/40 hover:text-[#0C6B95] transition-colors">
					<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
						<path stroke-linecap="round" stroke-linejoin="round" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
					</svg>
					<span data-i18n-el="Κράτηση Μεταφοράς">Book a Transfer</span>
				</a>
				<a href="/book/hourly" class="flex items-center gap-2 px-5 py-2.5 rounded-xl bg-[#0C6B95] text-white font-semibold text-sm shadow-md shadow-[#0C6B95]/25">
					<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
						<path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
					</svg>
					<span data-i18n-el="Με την ώρα">Rent per Hour</span>
				</a>
				<a href="/book/tour" class="flex items-center gap-2 px-5 py-2.5 rounded-xl bg-white border border-neutral-200 text-neutral-600 font-semibold text-sm hover:border-[#0C6B95]/40 hover:text-[#0C6B95] transition-colors">
					<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
						<path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" />
					</svg>
					<span data-i18n-el="Κράτηση Τουρ">Book a Tour</span>
				</a>
			</div>

			<div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-10 items-start">

				<!-- ── Booking form panel ── -->
				<div id="hourly-form" class="bg-white rounded-2xl p-6 lg:p-8 border border-neutral-200 shadow-sm">

					<h2 class="text-2xl font-bold text-neutral-900 mb-6" data-i18n-el="Στοιχεία Ωριαίας Χρέωσης">Hourly Details</h2>

					<!-- Pickup location -->
					<div class="mb-4">
						<label class="block text-sm font-medium text-neutral-700 mb-1" data-i18n-el="Σημείο Παραλαβής">Pickup location</label>
						<div class="relative">
							<span class="absolute left-3 top-1/2 -translate-y-1/2 text-neutral-400">
								<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
							</span>
							<input id="h-pickup" type="text" placeholder="Address, airport, hotel, ..." data-i18n-placeholder-el="Διεύθυνση, αεροδρόμιο, ξενοδοχείο, ..." autocomplete="off" class="w-full pl-10 pr-4 py-3 bg-neutral-50 border border-neutral-200 rounded-xl text-neutral-800 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95]" />
						</div>
						<p data-error-for="h-pickup" class="text-sm text-red-500 mt-1.5 hidden"></p>
					</div>

					<!-- Date & Time -->
					<div class="grid grid-cols-2 gap-4 mb-5">
						<div>
							<label class="block text-sm font-medium text-neutral-700 mb-1" data-i18n-el="Ημερομηνία παραλαβής">Pickup date</label>
							<div class="relative">
								<span class="absolute left-3 top-1/2 -translate-y-1/2 text-neutral-400">
									<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
								</span>
								<input id="h-date" type="date" class="w-full pl-10 pr-4 py-3 bg-neutral-50 border border-neutral-200 rounded-xl text-neutral-800 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95] cursor-pointer" />
							</div>
							<p data-error-for="h-date" class="text-sm text-red-500 mt-1.5 hidden"></p>
						</div>
						<div>
							<label class="block text-sm font-medium text-neutral-700 mb-1" data-i18n-el="Ώρα παραλαβής">Pickup time</label>
							<div class="relative">
								<span class="absolute left-3 top-1/2 -translate-y-1/2 text-neutral-400">
									<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
								</span>
								<input id="h-time" type="time" class="w-full pl-10 pr-4 py-3 bg-neutral-50 border border-neutral-200 rounded-xl text-neutral-800 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95] cursor-pointer" />
							</div>
							<p data-error-for="h-time" class="text-sm text-red-500 mt-1.5 hidden"></p>
						</div>
					</div>

					<!-- Hours & Passengers -->
					<div class="grid grid-cols-2 gap-4 mb-6">
						<div>
							<label class="block text-sm font-medium text-neutral-700 mb-2" data-i18n-el="Ώρες">Hours</label>
							<div class="flex items-center gap-3">
								<div class="flex-1 flex items-center gap-2 pl-4 py-3 bg-neutral-50 border border-neutral-200 rounded-xl">
									<svg class="w-5 h-5 text-neutral-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
									<span class="text-neutral-800 font-medium" id="hours-count">3</span>
								</div>
								<button type="button" id="hours-minus" class="w-10 h-10 flex items-center justify-center rounded-xl bg-neutral-800 text-white hover:bg-neutral-700 transition-colors text-lg font-bold" aria-label="Fewer hours" data-i18n-aria-el="Λιγότερες ώρες">−</button>
								<button type="button" id="hours-plus" class="w-10 h-10 flex items-center justify-center rounded-xl bg-neutral-800 text-white hover:bg-neutral-700 transition-colors text-lg font-bold" aria-label="More hours" data-i18n-aria-el="Περισσότερες ώρες">+</button>
							</div>
							<p id="hours-warning" class="hidden text-sm text-amber-600 mt-2 flex items-center gap-1.5">
								<svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z" /></svg>
								<span data-i18n-el="Η ελάχιστη ενοικίαση είναι 3 ώρες">Minimum rental is 3 hours</span>
							</p>
						</div>
						<div>
							<label class="block text-sm font-medium text-neutral-700 mb-2" data-i18n-el="Επιβάτες">Passengers</label>
							<div class="flex items-center gap-3">
								<div class="flex-1 flex items-center gap-2 pl-4 py-3 bg-neutral-50 border border-neutral-200 rounded-xl">
									<svg class="w-5 h-5 text-neutral-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" /></svg>
									<span class="text-neutral-800 font-medium" id="pax-count">2</span>
								</div>
								<button type="button" id="pax-minus" class="w-10 h-10 flex items-center justify-center rounded-xl bg-neutral-800 text-white hover:bg-neutral-700 transition-colors text-lg font-bold" aria-label="Fewer passengers" data-i18n-aria-el="Λιγότεροι επιβάτες">−</button>
								<button type="button" id="pax-plus" class="w-10 h-10 flex items-center justify-center rounded-xl bg-neutral-800 text-white hover:bg-neutral-700 transition-colors text-lg font-bold" aria-label="More passengers" data-i18n-aria-el="Περισσότεροι επιβάτες">+</button>
							</div>
						</div>
					</div>

					<div class="mb-5">
						<LuggageCounters rootId="hourly-page-luggage" />
					</div>

					<!-- Form-level error banner -->
					<div data-form-error class="hidden mb-4 rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-600" role="alert"></div>

					<!-- See prices -->
					<button id="continue-btn" type="button" class="w-full py-4 bg-[#0C6B95] hover:bg-[#0a5c82] text-white font-semibold rounded-xl transition-colors flex items-center justify-center gap-2 shadow-lg shadow-[#0C6B95]/25">
						<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
						<span data-i18n-el="Δείτε τις τιμές">See prices</span>
					</button>
				</div>

				<!-- ── Service class carousel (same as transfer page) ── -->
				<div data-fleet-carousel class="flex flex-col">
					<div class="mb-5">
						<div class="flex items-center gap-2 mb-2">
							<span class="w-2 h-2 rounded-full bg-[#0C6B95] shrink-0"></span>
							<span class="text-sm font-medium text-neutral-500 tracking-widest uppercase" data-i18n-el="Ο στόλος μας">Our Fleet</span>
						</div>
						<h2 class="text-2xl lg:text-3xl font-bold text-neutral-900" data-i18n-el="Ανακαλύψτε τις κατηγορίες υπηρεσιών μας">Discover our service classes</h2>
					</div>

					<div class="relative overflow-hidden rounded-2xl flex-1">
						{vehicles.map((v, i) => (
							<article data-fleet-card class={`bg-white border border-neutral-200 rounded-2xl overflow-hidden shadow-sm flex flex-col ${i === 0 ? '' : 'hidden'}`}>
								<div class="bg-neutral-100 aspect-[16/9] overflow-hidden">
									<img src={v.image} alt={v.title} class="w-full h-full object-cover" />
								</div>
								<div class="p-6 flex flex-col">
									<h3 class="text-2xl font-bold text-neutral-900 mb-1" data-i18n-el={v.titleEl}>{v.title}</h3>
									<p class="text-sm text-neutral-500 mb-4" data-i18n-el={v.modelsEl}>{v.models}</p>
									<div class="w-16 h-1 bg-[#0C6B95] rounded-full mb-5"></div>
									<ul class="flex flex-col gap-3">
										{v.features.map((f) => (
											<li class="flex items-start gap-3">
												<svg class="w-4 h-4 text-[#0C6B95] mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
												<span class="text-sm text-neutral-600 leading-snug" data-i18n-el={f.el}>{f.en}</span>
											</li>
										))}
									</ul>
								</div>
							</article>
						))}
					</div>

					<div class="flex items-center justify-between mt-4">
						<button data-fleet-prev class="w-10 h-10 flex items-center justify-center rounded-full border border-neutral-200 bg-white hover:bg-[#0C6B95] hover:border-[#0C6B95] hover:text-white text-neutral-600 transition-all duration-200 shadow-sm" aria-label="Previous" data-i18n-aria-el="Προηγούμενο">
							<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
						</button>
						<span data-fleet-indicator class="text-sm font-semibold text-neutral-500">1 / {vehicles.length}</span>
						<button data-fleet-next class="w-10 h-10 flex items-center justify-center rounded-full border border-neutral-200 bg-white hover:bg-[#0C6B95] hover:border-[#0C6B95] hover:text-white text-neutral-600 transition-all duration-200 shadow-sm" aria-label="Next" data-i18n-aria-el="Επόμενο">
							<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
						</button>
					</div>
				</div>

			</div>
		</div>
	</main>
</Layout>

<script>
	// Fleet carousel (same as transfer page)
	document.querySelectorAll('[data-fleet-carousel]').forEach((carousel) => {
		const cards = Array.from(carousel.querySelectorAll('[data-fleet-card]')) as HTMLElement[];
		const prevBtn = carousel.querySelector('[data-fleet-prev]') as HTMLButtonElement;
		const nextBtn = carousel.querySelector('[data-fleet-next]') as HTMLButtonElement;
		const indicator = carousel.querySelector('[data-fleet-indicator]') as HTMLElement;
		let current = 0;
		let animating = false;

		function wait(ms: number) { return new Promise<void>(resolve => setTimeout(resolve, ms)); }

		async function goTo(idx: number, direction: 'prev' | 'next') {
			if (animating) return;
			animating = true;
			const outgoing = cards[current];
			const nextIdx = (idx + cards.length) % cards.length;
			const incoming = cards[nextIdx];
			outgoing.style.transition = 'transform 220ms ease, opacity 220ms ease';
			outgoing.style.transform = direction === 'next' ? 'translateX(-48px)' : 'translateX(48px)';
			outgoing.style.opacity = '0';
			await wait(220);
			outgoing.classList.add('hidden');
			outgoing.style.transition = ''; outgoing.style.transform = ''; outgoing.style.opacity = '';
			incoming.style.transition = 'none';
			incoming.style.transform = direction === 'next' ? 'translateX(48px)' : 'translateX(-48px)';
			incoming.style.opacity = '0';
			incoming.classList.remove('hidden');
			incoming.getBoundingClientRect();
			incoming.style.transition = 'transform 220ms ease, opacity 220ms ease';
			incoming.style.transform = 'translateX(0)';
			incoming.style.opacity = '1';
			current = nextIdx;
			if (indicator) indicator.textContent = `${current + 1} / ${cards.length}`;
			await wait(220);
			incoming.style.transition = ''; incoming.style.transform = ''; incoming.style.opacity = '';
			animating = false;
		}

		prevBtn?.addEventListener('click', () => goTo(current - 1, 'prev'));
		nextBtn?.addEventListener('click', () => goTo(current + 1, 'next'));
	});
</script>

<script>
	let hours = 3;
	let paxCount = 2;

	const hoursEl = document.getElementById('hours-count')!;
	const hoursWarning = document.getElementById('hours-warning')!;
	const paxEl = document.getElementById('pax-count')!;

	document.getElementById('hours-minus')?.addEventListener('click', () => {
		if (hours > 1) { hours--; hoursEl.textContent = String(hours); }
		hoursWarning.classList.toggle('hidden', hours >= 3);
	});
	document.getElementById('hours-plus')?.addEventListener('click', () => {
		hours++; hoursEl.textContent = String(hours);
		hoursWarning.classList.toggle('hidden', hours >= 3);
	});

	document.getElementById('pax-minus')?.addEventListener('click', () => {
		if (paxCount > 1) { paxCount--; paxEl.textContent = String(paxCount); }
	});
	document.getElementById('pax-plus')?.addEventListener('click', () => {
		paxCount++; paxEl.textContent = String(paxCount);
	});

	import { showFieldError, showFormError, clearFormErrors, wireAutoClear } from '../../lib/form-errors';
	import { attachPlacesAutocomplete } from '../../lib/places-autocomplete';
	import { initLuggageCounters, getLuggageCounts } from '../../lib/luggage-counters';

	const hourlyFormScope = document.getElementById('hourly-form');

	wireAutoClear([
		document.getElementById('h-pickup'),
		document.getElementById('h-date'),
		document.getElementById('h-time'),
	]);

	attachPlacesAutocomplete(document.getElementById('h-pickup') as HTMLInputElement | null);
	initLuggageCounters('hourly-page-luggage');

	document.getElementById('continue-btn')?.addEventListener('click', () => {
		clearFormErrors(hourlyFormScope);

		const pickupEl = document.getElementById('h-pickup') as HTMLInputElement;
		const dateEl = document.getElementById('h-date') as HTMLInputElement;
		const timeEl = document.getElementById('h-time') as HTMLInputElement;

		const pickup = pickupEl?.value.trim() ?? '';
		const date = dateEl?.value.trim() ?? '';
		const time = timeEl?.value.trim() ?? '';

		let firstErr: HTMLElement | null = null;
		if (!pickup) { showFieldError(pickupEl, 'Please enter a pickup location.'); firstErr ??= pickupEl; }
		if (!date) {
			showFieldError(dateEl, 'Please select a pickup date.');
			firstErr ??= dateEl;
		} else {
			const selectedDate = new Date(date + 'T00:00:00');
			const today = new Date();
			today.setHours(0, 0, 0, 0);
			if (selectedDate < today) {
				showFieldError(dateEl, 'Please select a future date.');
				firstErr ??= dateEl;
			}
		}
		if (!time) { showFieldError(timeEl, 'Please select a pickup time.'); firstErr ??= timeEl; }

		if (firstErr) {
			firstErr.scrollIntoView({ behavior: 'smooth', block: 'center' });
			firstErr.focus?.();
			return;
		}

		if (hours < 3) {
			showFormError(hourlyFormScope, 'Minimum rental is 3 hours.');
			return;
		}

		const params = new URLSearchParams({
			pickup, date, time,
			hours: String(hours),
			passengers: String(paxCount),
		});
		const hourlyLuggage = getLuggageCounts('hourly-page-luggage');
		if (hourlyLuggage.small > 0) params.set('luggageSmall', String(hourlyLuggage.small));
		if (hourlyLuggage.big   > 0) params.set('luggageBig',   String(hourlyLuggage.big));
		window.location.href = `/book/hourly/results?${params.toString()}`;
	});
</script>
