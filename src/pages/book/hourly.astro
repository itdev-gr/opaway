---
import Layout from '../../layouts/Layout.astro';

const vehicles = [
	{
		title: 'Sedan',
		models: 'Mercedes-Benz E-Class, or similar.',
		image: '/car.avif',
		features: [
			'Fits up to 3 people',
			'1 big + 1 small luggage per person',
			'Available for city tours & custom routes',
		],
	},
	{
		title: 'Van',
		models: 'Mercedes Vito Tourer, or similar.',
		image: '/mini_van.avif',
		features: [
			'Fits up to 8 people',
			'1 big + 1 small luggage per person',
			'Ideal for group tours & day trips',
		],
	},
	{
		title: 'Minibus (or two Vans)',
		models: 'Mercedes Sprinter, or similar.',
		image: '/van.avif',
		features: [
			'Fits up to 18 people',
			'1 big + 1 small luggage per person',
			'Perfect for large groups & corporate events',
		],
	},
];
---

<Layout title="Rent per Hour — Opawey">
	<main class="min-h-screen bg-sky-50 pt-36 pb-24 px-6 lg:px-10">
		<div class="max-w-6xl mx-auto">

			<!-- Sub-navigation tabs -->
			<div class="flex items-center gap-3 mb-10">
				<a href="/book/transfer" class="flex items-center gap-2 px-5 py-2.5 rounded-xl bg-white border border-neutral-200 text-neutral-600 font-semibold text-sm hover:border-[#0C6B95]/40 hover:text-[#0C6B95] transition-colors">
					<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
						<path stroke-linecap="round" stroke-linejoin="round" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
					</svg>
					Book a Transfer
				</a>
				<a href="/book/hourly" class="flex items-center gap-2 px-5 py-2.5 rounded-xl bg-[#0C6B95] text-white font-semibold text-sm shadow-md shadow-[#0C6B95]/25">
					<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
						<path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
					</svg>
					Rent per Hour
				</a>
				<a href="/book/tour" class="flex items-center gap-2 px-5 py-2.5 rounded-xl bg-white border border-neutral-200 text-neutral-600 font-semibold text-sm hover:border-[#0C6B95]/40 hover:text-[#0C6B95] transition-colors">
					<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
						<path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" />
					</svg>
					Book a Tour
				</a>
			</div>

			<div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-10 items-start">

				<!-- ── Booking form panel ── -->
				<div class="bg-white rounded-2xl p-6 lg:p-8 border border-neutral-200 shadow-sm">

					<h2 class="text-2xl font-bold text-neutral-900 mb-6">Hourly Details</h2>

					<!-- Pickup location -->
					<div class="mb-4">
						<label class="block text-sm font-medium text-neutral-700 mb-1">Pickup location</label>
						<div class="relative">
							<span class="absolute left-3 top-1/2 -translate-y-1/2 text-neutral-400">
								<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
							</span>
							<input id="h-pickup" type="text" placeholder="Address, airport, hotel, ..." class="w-full pl-10 pr-4 py-3 bg-neutral-50 border border-neutral-200 rounded-xl text-neutral-800 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95]" />
						</div>
					</div>

					<!-- Date & Time -->
					<div class="grid grid-cols-2 gap-4 mb-5">
						<div>
							<label class="block text-sm font-medium text-neutral-700 mb-1">Pickup date</label>
							<div class="relative">
								<span class="absolute left-3 top-1/2 -translate-y-1/2 text-neutral-400">
									<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
								</span>
								<input id="h-date" type="date" class="w-full pl-10 pr-4 py-3 bg-neutral-50 border border-neutral-200 rounded-xl text-neutral-800 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95] cursor-pointer" />
							</div>
						</div>
						<div>
							<label class="block text-sm font-medium text-neutral-700 mb-1">Pickup time</label>
							<div class="relative">
								<span class="absolute left-3 top-1/2 -translate-y-1/2 text-neutral-400">
									<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
								</span>
								<input id="h-time" type="text" placeholder="Select time" class="w-full pl-10 pr-4 py-3 bg-neutral-50 border border-neutral-200 rounded-xl text-neutral-800 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95] cursor-pointer" />
							</div>
						</div>
					</div>

					<!-- Hours & Passengers -->
					<div class="grid grid-cols-2 gap-4 mb-6">
						<div>
							<label class="block text-sm font-medium text-neutral-700 mb-2">Hours</label>
							<div class="flex items-center gap-3">
								<div class="flex-1 flex items-center gap-2 pl-4 py-3 bg-neutral-50 border border-neutral-200 rounded-xl">
									<svg class="w-5 h-5 text-neutral-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
									<span class="text-neutral-800 font-medium" id="hours-count">3</span>
								</div>
								<button type="button" id="hours-minus" class="w-10 h-10 flex items-center justify-center rounded-xl bg-neutral-800 text-white hover:bg-neutral-700 transition-colors text-lg font-bold" aria-label="Fewer hours">−</button>
								<button type="button" id="hours-plus" class="w-10 h-10 flex items-center justify-center rounded-xl bg-neutral-800 text-white hover:bg-neutral-700 transition-colors text-lg font-bold" aria-label="More hours">+</button>
							</div>
							<p id="hours-warning" class="hidden text-sm text-amber-600 mt-2 flex items-center gap-1.5">
								<svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z" /></svg>
								Minimum rental is 3 hours
							</p>
						</div>
						<div>
							<label class="block text-sm font-medium text-neutral-700 mb-2">Passengers</label>
							<div class="flex items-center gap-3">
								<div class="flex-1 flex items-center gap-2 pl-4 py-3 bg-neutral-50 border border-neutral-200 rounded-xl">
									<svg class="w-5 h-5 text-neutral-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" /></svg>
									<span class="text-neutral-800 font-medium" id="pax-count">2</span>
								</div>
								<button type="button" id="pax-minus" class="w-10 h-10 flex items-center justify-center rounded-xl bg-neutral-800 text-white hover:bg-neutral-700 transition-colors text-lg font-bold" aria-label="Fewer passengers">−</button>
								<button type="button" id="pax-plus" class="w-10 h-10 flex items-center justify-center rounded-xl bg-neutral-800 text-white hover:bg-neutral-700 transition-colors text-lg font-bold" aria-label="More passengers">+</button>
							</div>
						</div>
					</div>

					<!-- Vehicle selection -->
					<div class="border-t border-neutral-100 pt-6 mb-6">
						<h3 class="text-base font-bold text-neutral-900 mb-4">Select your vehicle</h3>
						<div id="vehicle-cards" class="space-y-3">

							<!-- Sedan -->
							<label class="vehicle-option flex items-center gap-4 p-4 rounded-xl border-2 border-neutral-200 hover:border-[#0C6B95]/40 cursor-pointer transition-all" data-slug="sedan">
								<input type="radio" name="vehicle" value="sedan" class="hidden" />
								<div class="w-20 h-14 bg-neutral-100 rounded-lg overflow-hidden shrink-0">
									<img src="/car.avif" alt="Sedan" class="w-full h-full object-cover" />
								</div>
								<div class="flex-1 min-w-0">
									<div class="flex items-center gap-2">
										<span class="font-bold text-neutral-900 text-sm">Sedan</span>
										<span class="text-[10px] font-bold px-2 py-0.5 rounded-full bg-emerald-100 text-emerald-700">BEST VALUE</span>
									</div>
									<div class="text-xs text-neutral-500 mt-0.5">Up to 3 people &middot; 1 big + 1 small luggage per person</div>
								</div>
								<div class="text-right shrink-0">
									<span class="text-lg font-bold text-neutral-900" data-price-sedan></span>
									<div class="text-[10px] text-neutral-400">total</div>
								</div>
							</label>

							<!-- Van -->
							<label class="vehicle-option flex items-center gap-4 p-4 rounded-xl border-2 border-neutral-200 hover:border-[#0C6B95]/40 cursor-pointer transition-all" data-slug="van">
								<input type="radio" name="vehicle" value="van" class="hidden" />
								<div class="w-20 h-14 bg-neutral-100 rounded-lg overflow-hidden shrink-0">
									<img src="/mini_van.avif" alt="Van" class="w-full h-full object-cover" />
								</div>
								<div class="flex-1 min-w-0">
									<div class="flex items-center gap-2">
										<span class="font-bold text-neutral-900 text-sm">Van</span>
										<span class="text-[10px] font-bold px-2 py-0.5 rounded-full bg-amber-100 text-amber-700">MOST POPULAR</span>
									</div>
									<div class="text-xs text-neutral-500 mt-0.5">Up to 8 people &middot; 1 big + 1 small luggage per person</div>
								</div>
								<div class="text-right shrink-0">
									<span class="text-lg font-bold text-neutral-900" data-price-van></span>
									<div class="text-[10px] text-neutral-400">total</div>
								</div>
							</label>

							<!-- Minibus -->
							<label class="vehicle-option flex items-center gap-4 p-4 rounded-xl border-2 border-neutral-200 hover:border-[#0C6B95]/40 cursor-pointer transition-all" data-slug="minibus">
								<input type="radio" name="vehicle" value="minibus" class="hidden" />
								<div class="w-20 h-14 bg-neutral-100 rounded-lg overflow-hidden shrink-0">
									<img src="/van.avif" alt="Minibus" class="w-full h-full object-cover" />
								</div>
								<div class="flex-1 min-w-0">
									<div class="flex items-center gap-2">
										<span class="font-bold text-neutral-900 text-sm">Minibus (or two Vans)</span>
										<span class="text-[10px] font-bold px-2 py-0.5 rounded-full bg-violet-100 text-violet-700">TOP CLASS</span>
									</div>
									<div class="text-xs text-neutral-500 mt-0.5">Up to 18 people &middot; 1 big + 1 small luggage per person</div>
								</div>
								<div class="text-right shrink-0">
									<span class="text-lg font-bold text-neutral-900" data-price-minibus></span>
									<div class="text-[10px] text-neutral-400">total</div>
								</div>
							</label>

						</div>
					</div>

					<!-- Error -->
					<p id="form-error" class="hidden text-sm text-red-500 mb-4 flex items-center gap-1.5">
						<svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z" /></svg>
						<span id="form-error-text"></span>
					</p>

					<!-- See prices -->
					<button id="continue-btn" type="button" class="w-full py-4 bg-[#0C6B95] hover:bg-[#0a5c82] text-white font-semibold rounded-xl transition-colors flex items-center justify-center gap-2 shadow-lg shadow-[#0C6B95]/25">
						<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
						See prices
					</button>
				</div>

				<!-- ── Service class carousel (same as transfer page) ── -->
				<div data-fleet-carousel class="flex flex-col">
					<div class="mb-5">
						<div class="flex items-center gap-2 mb-2">
							<span class="w-2 h-2 rounded-full bg-[#0C6B95] shrink-0"></span>
							<span class="text-sm font-medium text-neutral-500 tracking-widest uppercase">Our Fleet</span>
						</div>
						<h2 class="text-2xl lg:text-3xl font-bold text-neutral-900">Discover our service classes</h2>
					</div>

					<div class="relative overflow-hidden rounded-2xl flex-1">
						{vehicles.map((v, i) => (
							<article data-fleet-card class={`bg-white border border-neutral-200 rounded-2xl overflow-hidden shadow-sm flex flex-col ${i === 0 ? '' : 'hidden'}`}>
								<div class="bg-neutral-100 aspect-[16/9] overflow-hidden">
									<img src={v.image} alt={v.title} class="w-full h-full object-cover" />
								</div>
								<div class="p-6 flex flex-col">
									<h3 class="text-2xl font-bold text-neutral-900 mb-1">{v.title}</h3>
									<p class="text-sm text-neutral-500 mb-4">{v.models}</p>
									<div class="w-16 h-1 bg-[#0C6B95] rounded-full mb-5"></div>
									<ul class="flex flex-col gap-3">
										{v.features.map((f) => (
											<li class="flex items-start gap-3">
												<svg class="w-4 h-4 text-[#0C6B95] mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
												<span class="text-sm text-neutral-600 leading-snug">{f}</span>
											</li>
										))}
									</ul>
								</div>
							</article>
						))}
					</div>

					<div class="flex items-center justify-between mt-4">
						<button data-fleet-prev class="w-10 h-10 flex items-center justify-center rounded-full border border-neutral-200 bg-white hover:bg-[#0C6B95] hover:border-[#0C6B95] hover:text-white text-neutral-600 transition-all duration-200 shadow-sm" aria-label="Previous">
							<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
						</button>
						<span data-fleet-indicator class="text-sm font-semibold text-neutral-500">1 / {vehicles.length}</span>
						<button data-fleet-next class="w-10 h-10 flex items-center justify-center rounded-full border border-neutral-200 bg-white hover:bg-[#0C6B95] hover:border-[#0C6B95] hover:text-white text-neutral-600 transition-all duration-200 shadow-sm" aria-label="Next">
							<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
						</button>
					</div>
				</div>

			</div>
		</div>
	</main>
</Layout>

<script>
	// Fleet carousel (same as transfer page)
	document.querySelectorAll('[data-fleet-carousel]').forEach((carousel) => {
		const cards = Array.from(carousel.querySelectorAll('[data-fleet-card]')) as HTMLElement[];
		const prevBtn = carousel.querySelector('[data-fleet-prev]') as HTMLButtonElement;
		const nextBtn = carousel.querySelector('[data-fleet-next]') as HTMLButtonElement;
		const indicator = carousel.querySelector('[data-fleet-indicator]') as HTMLElement;
		let current = 0;
		let animating = false;

		function wait(ms: number) { return new Promise<void>(resolve => setTimeout(resolve, ms)); }

		async function goTo(idx: number, direction: 'prev' | 'next') {
			if (animating) return;
			animating = true;
			const outgoing = cards[current];
			const nextIdx = (idx + cards.length) % cards.length;
			const incoming = cards[nextIdx];
			outgoing.style.transition = 'transform 220ms ease, opacity 220ms ease';
			outgoing.style.transform = direction === 'next' ? 'translateX(-48px)' : 'translateX(48px)';
			outgoing.style.opacity = '0';
			await wait(220);
			outgoing.classList.add('hidden');
			outgoing.style.transition = ''; outgoing.style.transform = ''; outgoing.style.opacity = '';
			incoming.style.transition = 'none';
			incoming.style.transform = direction === 'next' ? 'translateX(48px)' : 'translateX(-48px)';
			incoming.style.opacity = '0';
			incoming.classList.remove('hidden');
			incoming.getBoundingClientRect();
			incoming.style.transition = 'transform 220ms ease, opacity 220ms ease';
			incoming.style.transform = 'translateX(0)';
			incoming.style.opacity = '1';
			current = nextIdx;
			if (indicator) indicator.textContent = `${current + 1} / ${cards.length}`;
			await wait(220);
			incoming.style.transition = ''; incoming.style.transform = ''; incoming.style.opacity = '';
			animating = false;
		}

		prevBtn?.addEventListener('click', () => goTo(current - 1, 'prev'));
		nextBtn?.addEventListener('click', () => goTo(current + 1, 'next'));
	});
</script>

<script>
	import { supabase } from '../../lib/supabase';
	import { calculateHourlyPrice } from '../../lib/pricing';

	let partnerDiscount = 0;

	async function detectPartnerDiscount(): Promise<number> {
		const { data: { user } } = await supabase.auth.getUser();
		if (!user) return 0;
		try {
			const { data: partner } = await supabase
				.from('partners')
				.select('status, discount')
				.eq('id', user.id)
				.maybeSingle();
			if (partner && partner.status === 'approved' && partner.discount > 0) {
				return partner.discount;
			}
		} catch {}
		return 0;
	}

	/* ── State ── */
	let hours = 3;
	let paxCount = 2;
	let selectedVehicle = '';

	const hoursEl = document.getElementById('hours-count')!;
	const hoursWarning = document.getElementById('hours-warning')!;
	const paxEl = document.getElementById('pax-count')!;

	/* ── Update prices ── */
	function updatePrices() {
		let badgeEl = document.getElementById('partner-discount-badge');
		if (partnerDiscount > 0) {
			if (!badgeEl) {
				badgeEl = document.createElement('div');
				badgeEl.id = 'partner-discount-badge';
				badgeEl.className = 'bg-emerald-50 border border-emerald-200 rounded-xl px-4 py-2 mb-4 text-sm text-emerald-700 font-medium';
				const vehicleCards = document.getElementById('vehicle-cards');
				vehicleCards?.parentElement?.insertBefore(badgeEl, vehicleCards);
			}
			badgeEl.textContent = `Partner discount: ${partnerDiscount}% applied`;
		}

		['sedan', 'van', 'minibus'].forEach(slug => {
			const { totalPrice, originalTotal } = calculateHourlyPrice({ vehicleSlug: slug, hours, discount: partnerDiscount });
			const el = document.querySelector(`[data-price-${slug}]`);
			if (el) {
				const showOriginal = partnerDiscount > 0 && originalTotal !== totalPrice;
				el.innerHTML = (showOriginal ? `<del class="text-neutral-400 text-sm">\u20AC${originalTotal.toFixed(2)}</del> ` : '') + `\u20AC${totalPrice.toFixed(2)}`;
			}
		});
	}

	detectPartnerDiscount().then(d => {
		partnerDiscount = d;
		updatePrices();
	});

	/* ── Hours counter ── */
	document.getElementById('hours-minus')?.addEventListener('click', () => {
		if (hours > 1) { hours--; hoursEl.textContent = String(hours); updatePrices(); }
		hoursWarning.classList.toggle('hidden', hours >= 3);
	});
	document.getElementById('hours-plus')?.addEventListener('click', () => {
		hours++; hoursEl.textContent = String(hours); updatePrices();
		hoursWarning.classList.toggle('hidden', hours >= 3);
	});

	/* ── Passenger counter ── */
	document.getElementById('pax-minus')?.addEventListener('click', () => {
		if (paxCount > 1) { paxCount--; paxEl.textContent = String(paxCount); }
	});
	document.getElementById('pax-plus')?.addEventListener('click', () => {
		paxCount++; paxEl.textContent = String(paxCount);
	});

	/* ── Vehicle selection ── */
	document.querySelectorAll<HTMLLabelElement>('.vehicle-option').forEach(label => {
		label.addEventListener('click', () => {
			selectedVehicle = label.dataset.slug || '';
			document.querySelectorAll('.vehicle-option').forEach(l => {
				const isActive = l.dataset.slug === selectedVehicle;
				l.classList.toggle('border-[#0C6B95]', isActive);
				l.classList.toggle('ring-2', isActive);
				l.classList.toggle('ring-[#0C6B95]/20', isActive);
				l.classList.toggle('border-neutral-200', !isActive);
			});
		});
	});

	/* ── Continue ── */
	document.getElementById('continue-btn')?.addEventListener('click', () => {
		const pickup = (document.getElementById('h-pickup') as HTMLInputElement).value.trim();
		const date = (document.getElementById('h-date') as HTMLInputElement).value.trim();
		const time = (document.getElementById('h-time') as HTMLInputElement).value.trim();
		const errorEl = document.getElementById('form-error')!;
		const errorText = document.getElementById('form-error-text')!;

		if (!pickup) { errorText.textContent = 'Please enter a pickup location.'; errorEl.classList.remove('hidden'); return; }
		if (!date) { errorText.textContent = 'Please select a pickup date.'; errorEl.classList.remove('hidden'); return; }
		if (!time) { errorText.textContent = 'Please select a pickup time.'; errorEl.classList.remove('hidden'); return; }
		if (hours < 3) { errorText.textContent = 'Minimum rental is 3 hours.'; errorEl.classList.remove('hidden'); return; }
		if (!selectedVehicle) { errorText.textContent = 'Please select a vehicle.'; errorEl.classList.remove('hidden'); return; }

		errorEl.classList.add('hidden');

		const vehicleNames: Record<string, string> = { sedan: 'Sedan', van: 'Van', minibus: 'Minibus (or two Vans)' };
		const vehicleImages: Record<string, string> = { sedan: '/car.avif', van: '/mini_van.avif', minibus: '/van.avif' };
		const { totalPrice, perHour } = calculateHourlyPrice({ vehicleSlug: selectedVehicle, hours, discount: partnerDiscount });

		const p = new URLSearchParams({
			pickup, date: date || '', time: time || '',
			hours: String(hours), passengers: String(paxCount),
			vehicleSlug: selectedVehicle,
			vehicleName: vehicleNames[selectedVehicle] || selectedVehicle,
			vehicleImage: vehicleImages[selectedVehicle] || '',
			totalPrice: totalPrice.toFixed(2),
			perHour: perHour.toFixed(2),
			bookingType: 'hourly',
		});
		if (partnerDiscount > 0) p.set('discount', String(partnerDiscount));

		window.location.href = `/book/hourly/passenger?${p.toString()}`;
	});
</script>
