---
import Layout from '../../../layouts/Layout.astro';
---

<Layout title="Passenger Details — Opawey">
	<main class="min-h-screen bg-sky-50/40 pt-28 pb-16 px-4 sm:px-6">
		<div class="max-w-7xl mx-auto">

			<!-- ── Step indicator ── -->
			<div class="flex items-center justify-center gap-0 mb-8">
				<!-- Step 1: Vehicle (completed) -->
				<div class="flex items-center gap-2">
					<span class="w-8 h-8 rounded-full bg-emerald-500 text-white text-sm font-bold flex items-center justify-center">
						<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
					</span>
					<span class="text-sm font-medium text-emerald-600" data-i18n-el="Όχημα">Vehicle</span>
				</div>
				<div class="w-16 h-px bg-emerald-400 mx-3"></div>
				<!-- Step 2: Passenger (active) -->
				<div class="flex items-center gap-2">
					<span class="w-8 h-8 rounded-full bg-[#0C6B95] text-white text-sm font-bold flex items-center justify-center">2</span>
					<span class="text-sm font-semibold text-[#0C6B95]" data-i18n-el="Επιβάτης">Passenger</span>
				</div>
				<div class="w-16 h-px bg-neutral-300 mx-3"></div>
				<!-- Step 3: Payment (greyed) -->
				<div class="flex items-center gap-2 opacity-40">
					<span class="w-8 h-8 rounded-full bg-neutral-300 text-white text-sm font-bold flex items-center justify-center">3</span>
					<span class="text-sm font-medium text-neutral-400" data-i18n-el="Πληρωμή">Payment</span>
				</div>
			</div>

			<!-- ── Main grid ── -->
			<div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

				<!-- LEFT COLUMN — Form -->
				<div class="lg:col-span-2">
					<div class="bg-white rounded-2xl border border-neutral-200 shadow-sm p-6 lg:p-8">

						<!-- Lead passenger -->
						<h2 class="text-xl font-bold text-neutral-900 mb-6" data-i18n-el="Επικεφαλής επιβάτης">Lead passenger</h2>

						<div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-5">
							<div>
								<label class="block text-sm font-medium text-neutral-700 mb-1.5"><span data-i18n-el="Όνομα">First name</span> <span class="text-red-400">*</span></label>
								<input id="pax-first" type="text" required placeholder="John" data-i18n-placeholder-el="Γιάννης"
									class="w-full px-4 py-3 bg-white border border-neutral-200 rounded-xl text-neutral-800 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95]" />
							</div>
							<div>
								<label class="block text-sm font-medium text-neutral-700 mb-1.5"><span data-i18n-el="Επώνυμο">Last name</span> <span class="text-red-400">*</span></label>
								<input id="pax-last" type="text" required placeholder="Doe" data-i18n-placeholder-el="Παπαδόπουλος"
									class="w-full px-4 py-3 bg-white border border-neutral-200 rounded-xl text-neutral-800 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95]" />
							</div>
						</div>

						<div class="mb-5">
							<label class="block text-sm font-medium text-neutral-700 mb-1.5"><span data-i18n-el="Διεύθυνση email">Email address</span> <span class="text-red-400">*</span></label>
							<input id="pax-email" type="email" required placeholder="john@example.com"
								class="w-full px-4 py-3 bg-white border border-neutral-200 rounded-xl text-neutral-800 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95]" />
							<p class="text-xs text-neutral-400 mt-1.5 flex items-center gap-1">
								<svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
								<span data-i18n-el="Θα σας στείλουμε εδώ το κουπόνι κράτησης.">We'll send your booking voucher here.</span>
							</p>
						</div>

						<div class="mb-8">
							<label class="block text-sm font-medium text-neutral-700 mb-1.5"><span data-i18n-el="Κινητό τηλέφωνο">Mobile number</span> <span class="text-red-400">*</span></label>
							<div class="flex gap-3">
								<div class="flex items-center gap-2 px-3 py-3 bg-neutral-50 border border-neutral-200 rounded-xl text-sm text-neutral-600 shrink-0">
									<span>🇬🇷</span>
									<span>+30</span>
								</div>
								<input id="pax-phone" type="tel" required placeholder="693 123 4567"
									class="flex-1 px-4 py-3 bg-white border border-neutral-200 rounded-xl text-neutral-800 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95]" />
							</div>
							<p class="text-xs text-neutral-400 mt-1.5 flex items-center gap-1">
								<svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
								<span data-i18n-el="Παρακαλούμε δώστε έναν αριθμό επικοινωνίας ώστε ο οδηγός μας να μπορεί να επικοινωνήσει με τον επιβάτη αν χρειαστεί.">Please provide a contact number so our driver can reach the passenger if needed.</span>
							</p>
						</div>

						<!-- Divider -->
						<div class="border-t border-neutral-100 pt-6 mb-6">
							<h3 class="text-lg font-bold text-neutral-900 mb-4" data-i18n-el="Υποδοχή με πινακίδα">Meet & Greet</h3>
							<div>
								<input id="pax-sign" type="text" placeholder="Enter the name to display on the sign" data-i18n-placeholder-el="Εισαγάγετε το όνομα που θα εμφανιστεί στην πινακίδα"
									class="w-full px-4 py-3 bg-white border border-neutral-200 rounded-xl text-neutral-800 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95]" />
								<p class="text-xs text-neutral-400 mt-1.5 flex items-center gap-1">
									<svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
								<span data-i18n-el="Υποδοχή με πινακίδα — εισαγάγετε το όνομα που θα εμφανιστεί.">Meet & Greet with a sign — enter the name to display.</span>
							</p>
							</div>
						</div>

						<!-- Child / booster seat -->
						<div class="border-t border-neutral-100 pt-6 mb-6">
							<div class="flex items-center gap-3">
								<label class="flex items-center gap-3 cursor-pointer">
									<input id="pax-child-seat" type="checkbox"
										class="w-5 h-5 rounded border-neutral-300 text-amber-500 focus:ring-amber-400/30 cursor-pointer" />
									<span class="text-sm font-medium text-neutral-800" data-i18n-el="Χρειάζεστε παιδικό κάθισμα ή μπούστερ;">Need a child or booster seat?</span>
								</label>
								<div id="child-seat-qty" class="hidden flex items-center gap-2 ml-auto">
									<button type="button" id="child-minus" class="w-8 h-8 flex items-center justify-center rounded-lg border border-neutral-200 text-neutral-600 hover:bg-neutral-50 transition-colors text-sm font-bold">−</button>
									<span id="child-count" class="w-8 text-center text-sm font-semibold text-neutral-800">1</span>
									<button type="button" id="child-plus" class="w-8 h-8 flex items-center justify-center rounded-lg border border-neutral-200 text-neutral-600 hover:bg-neutral-50 transition-colors text-sm font-bold">+</button>
								</div>
							</div>
						</div>

						<!-- Driver notes -->
						<div class="border-t border-neutral-100 pt-6 mb-6">
							<label class="block text-sm font-medium text-neutral-700 mb-1.5 flex items-center gap-1.5">
								<span data-i18n-el="Σημειώσεις για τον οδηγό (Μετάβαση)">Driver notes (Outward)</span>
								<span class="inline-flex items-center justify-center w-4 h-4 rounded-full bg-neutral-400 text-white text-[10px] font-bold cursor-help" title="Add any special requests or other notes for your driver.">?</span>
							</label>
							<textarea id="pax-notes" rows="4" placeholder="Special requests, dietary needs, accessibility requirements... No sensitive data—add phone in next step." data-i18n-placeholder-el="Ειδικά αιτήματα, διατροφικές ανάγκες, απαιτήσεις προσβασιμότητας... Χωρίς ευαίσθητα δεδομένα — προσθέστε τηλέφωνο στο επόμενο βήμα."
								class="w-full px-4 py-3 bg-white border border-neutral-200 rounded-xl text-neutral-800 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95] resize-y"></textarea>
						</div>

						<!-- Validation message -->
						<p id="form-error" class="hidden text-sm text-red-500 mb-4 flex items-center gap-1.5">
							<svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z" /></svg>
							<span id="form-error-text"></span>
						</p>

						<!-- Navigation -->
						<div class="flex items-center gap-4 pt-2">
							<button id="back-btn" type="button"
								class="px-5 py-3 border border-neutral-200 rounded-xl text-neutral-600 font-semibold hover:bg-neutral-50 transition-colors flex items-center gap-2">
								<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
								<span data-i18n-el="Πίσω">Back</span>
							</button>
							<button id="continue-btn" type="button"
								class="flex-1 py-3 bg-neutral-900 hover:bg-neutral-800 text-white font-semibold rounded-xl transition-colors text-center" data-i18n-el="Συνέχεια στην πληρωμή">
								Continue
							</button>
						</div>
					</div>
				</div>

				<!-- RIGHT COLUMN — Sidebar -->
				<div class="lg:col-span-1">
					<div class="sticky top-28 bg-white rounded-2xl border border-neutral-200 shadow-sm p-6 space-y-5">

						<h3 class="text-lg font-bold text-neutral-900" data-i18n-el="Η κράτησή σας">Your Booking</h3>

						<!-- Trip type + passengers -->
						<div class="flex items-center justify-between text-sm">
							<span id="sb-trip-type" class="font-semibold text-neutral-700" data-i18n-el="Απλή διαδρομή">One way</span>
							<span class="flex items-center gap-1.5 text-neutral-500">
								<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" /></svg>
								<span id="sb-passengers">2</span> <span data-i18n-el="Επιβάτες">Passengers</span>
							</span>
						</div>

						<!-- Luggage -->
						<div id="sb-luggage-row" class="hidden flex items-center justify-between text-sm">
							<span class="text-neutral-500" data-i18n-el="Αποσκευές">Luggage</span>
							<span class="text-neutral-800"><span id="sb-luggage-small">0</span> <span data-i18n-el="μικρές">small</span> &middot; <span id="sb-luggage-big">0</span> <span data-i18n-el="μεγάλες">big</span></span>
						</div>

						<!-- Date -->
						<div class="text-sm border-t border-neutral-100 pt-4">
							<span class="text-neutral-500" data-i18n-el="Μετάβαση">Outward</span>
							<span class="mx-1 text-neutral-300">&middot;</span>
							<span id="sb-date" class="font-medium text-neutral-700">—</span>
						</div>

						<!-- Route -->
						<div class="space-y-3">
							<div class="flex gap-3">
								<div class="flex flex-col items-center">
									<span class="w-3 h-3 rounded-full bg-[#0C6B95] shrink-0 mt-1"></span>
									<span class="w-px flex-1 bg-neutral-200"></span>
								</div>
								<div class="flex-1 min-w-0">
									<p id="sb-from" class="text-sm font-semibold text-neutral-800 truncate">—</p>
								</div>
								<span id="sb-pickup-time" class="text-sm font-medium text-neutral-600 shrink-0">—</span>
							</div>
							<div class="flex gap-3">
								<div class="flex flex-col items-center">
									<span class="w-3 h-3 rounded-full bg-neutral-400 shrink-0 mt-1"></span>
								</div>
								<div class="flex-1 min-w-0">
									<p id="sb-to" class="text-sm font-semibold text-neutral-800 truncate">—</p>
								</div>
							</div>
						</div>

						<!-- Your choice -->
						<div class="border-t border-neutral-100 pt-4">
							<p class="text-xs font-semibold text-neutral-500 uppercase tracking-wider mb-3" data-i18n-el="Η επιλογή σας">Your choice</p>
							<div class="flex items-center gap-3">
								<div class="w-16 h-12 bg-neutral-100 rounded-lg overflow-hidden shrink-0">
									<img id="sb-vehicle-img" src="" alt="" class="w-full h-full object-cover" />
								</div>
								<div class="min-w-0">
									<p id="sb-vehicle-name" class="text-sm font-bold text-neutral-900 truncate">—</p>
									<div class="flex items-center gap-3 text-xs text-neutral-500 mt-0.5">
										<span class="flex items-center gap-1">
											<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" /></svg>
											<span id="sb-vehicle-pax">—</span>
										</span>
										<span class="flex items-center gap-1">
											<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" /></svg>
											<span id="sb-vehicle-lug">—</span>
										</span>
									</div>
								</div>
							</div>
						</div>

						<!-- Price details -->
						<div class="border-t border-neutral-100 pt-4 space-y-2">
							<h4 class="text-sm font-bold text-neutral-800" data-i18n-el="Λεπτομέρειες τιμής">Price details</h4>
							<div class="flex justify-between text-sm">
								<span class="font-semibold text-neutral-900" data-i18n-el="Σύνολο">Total</span>
								<span id="sb-total" class="font-bold text-neutral-900">—</span>
							</div>
							<div class="flex justify-between text-sm text-neutral-500">
								<span data-i18n-el="Μετάβαση">Outward</span>
								<span id="sb-outward">—</span>
							</div>
							<div id="sb-return-price-row" class="hidden flex justify-between text-sm text-neutral-500">
								<span data-i18n-el="Επιστροφή">Return</span>
								<span id="sb-return-price">—</span>
							</div>
						</div>

						<!-- Feature badges -->
						<div class="flex flex-wrap gap-2 border-t border-neutral-100 pt-4">
							<span class="inline-flex items-center gap-1.5 text-xs font-medium text-emerald-700 bg-emerald-50 px-2.5 py-1 rounded-full" data-i18n-el="Δωρεάν ακύρωση">
								<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
								Free cancellation
							</span>
							<span class="inline-flex items-center gap-1.5 text-xs font-medium text-neutral-600 bg-neutral-100 px-2.5 py-1 rounded-full" data-i18n-el="Υπηρεσία πόρτα-πόρτα">
								<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
								Door-to-door service
							</span>
							<span class="inline-flex items-center gap-1.5 text-xs font-medium text-neutral-600 bg-neutral-100 px-2.5 py-1 rounded-full" data-i18n-el="Υποδοχή με πινακίδα">
								<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
								Meet & Greet
							</span>
							<span class="inline-flex items-center gap-1.5 text-xs font-medium text-neutral-600 bg-neutral-100 px-2.5 py-1 rounded-full" data-i18n-el="Παρακολούθηση πτήσης">
								<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
								Flight tracking
							</span>
							<span class="inline-flex items-center gap-1.5 text-xs font-medium text-neutral-600 bg-neutral-100 px-2.5 py-1 rounded-full" data-i18n-el="Αδειούχοι οδηγοί">
								<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
								Licensed chauffeurs
							</span>
						</div>

						<!-- Payment icons -->
						<div class="flex items-center gap-3 border-t border-neutral-100 pt-4">
							<span class="text-xs text-neutral-400 font-medium" data-i18n-el="Δεκτές:">Accepted:</span>
							<div class="flex gap-2 text-xs font-bold text-neutral-500">
								<span class="px-2 py-1 bg-neutral-100 rounded">VISA</span>
								<span class="px-2 py-1 bg-neutral-100 rounded">MC</span>
								<span class="px-2 py-1 bg-neutral-100 rounded">AMEX</span>
							</div>
						</div>

					</div>
				</div>

			</div>
		</div>
	</main>
</Layout>

<script>
	import { supabase } from '../../../lib/supabase';

	(async () => {
		const { data: { session } } = await supabase.auth.getSession();
		if (!session?.user) {
			const next = encodeURIComponent(window.location.pathname + window.location.search);
			window.location.href = `/login?next=${next}&reason=booking`;
		}
	})();

	/* ── Parse URL params ── */
	const params = new URLSearchParams(window.location.search);
	const from = params.get('from') || '';
	const to = params.get('to') || '';
	const date = params.get('date') || '';
	const time = params.get('time') || '';
	const passengers = params.get('passengers') || '2';
	const returnDate = params.get('returnDate') || '';
	const returnTime = params.get('returnTime') || '';
	const luggageSmall = parseInt(params.get('luggageSmall') || '0', 10) || 0;
	const luggageBig   = parseInt(params.get('luggageBig')   || '0', 10) || 0;
	const vehicleSlug = params.get('vehicleSlug') || '';
	const vehicleName = params.get('vehicleName') || '';
	const vehicleImage = params.get('vehicleImage') || '';
	const vehicleMaxPax = params.get('vehicleMaxPax') || '';
	const vehicleMaxLug = params.get('vehicleMaxLug') || '';
	const totalPrice = params.get('totalPrice') || '0';
	const outwardPrice = params.get('outwardPrice') || '0';
	const returnPrice = params.get('returnPrice') || '0';
	const hasReturn = !!returnDate;

	/* ── Populate sidebar ── */
	const setText = (id: string, text: string) => { const el = document.getElementById(id); if (el) el.textContent = text; };

	setText('sb-from', from);
	setText('sb-to', to);
	setText('sb-date', date);
	setText('sb-pickup-time', time);
	setText('sb-passengers', passengers);
	if (luggageSmall > 0 || luggageBig > 0) {
		setText('sb-luggage-small', String(luggageSmall));
		setText('sb-luggage-big',   String(luggageBig));
		document.getElementById('sb-luggage-row')?.classList.remove('hidden');
	}
	setText('sb-trip-type', hasReturn ? 'Round trip' : 'One way');
	setText('sb-vehicle-name', vehicleName);
	setText('sb-vehicle-pax', `Up to ${vehicleMaxPax}`);
	setText('sb-vehicle-lug', vehicleMaxLug);
	setText('sb-total', `\u20AC ${totalPrice}`);
	setText('sb-outward', `\u20AC ${outwardPrice}`);

	const vehicleImg = document.getElementById('sb-vehicle-img') as HTMLImageElement;
	if (vehicleImg && vehicleImage) { vehicleImg.src = vehicleImage; vehicleImg.alt = vehicleName; }

	if (hasReturn) {
		setText('sb-return-price', `\u20AC ${returnPrice}`);
		document.getElementById('sb-return-price-row')?.classList.remove('hidden');
	}

	/* ── Auto-fill from Supabase Auth ── */
	supabase.auth.onAuthStateChange((_event, session) => {
		const user = session?.user;
		if (!user) return;
		const firstName = document.getElementById('pax-first') as HTMLInputElement;
		const lastName = document.getElementById('pax-last') as HTMLInputElement;
		const email = document.getElementById('pax-email') as HTMLInputElement;

		if (user.email && !email.value) email.value = user.email;
		const displayName = user.user_metadata?.display_name || user.user_metadata?.full_name || '';
		if (displayName) {
			const parts = displayName.split(' ');
			if (!firstName.value) firstName.value = parts[0] || '';
			if (!lastName.value) lastName.value = parts.slice(1).join(' ') || '';
		}
	});

	/* ── Child seat toggle + counter ── */
	const childCheckbox = document.getElementById('pax-child-seat') as HTMLInputElement;
	const childQty = document.getElementById('child-seat-qty')!;
	const childCountEl = document.getElementById('child-count')!;
	let childCount = 1;

	childCheckbox?.addEventListener('change', () => {
		childQty.classList.toggle('hidden', !childCheckbox.checked);
		if (!childCheckbox.checked) { childCount = 1; childCountEl.textContent = '1'; }
	});

	document.getElementById('child-minus')?.addEventListener('click', () => {
		if (childCount > 1) { childCount--; childCountEl.textContent = String(childCount); }
	});
	document.getElementById('child-plus')?.addEventListener('click', () => {
		childCount++; childCountEl.textContent = String(childCount);
	});

	/* ── Back button ── */
	document.getElementById('back-btn')?.addEventListener('click', () => {
		window.history.back();
	});

	/* ── Continue button ── */
	document.getElementById('continue-btn')?.addEventListener('click', () => {
		const firstName = (document.getElementById('pax-first') as HTMLInputElement).value.trim();
		const lastName = (document.getElementById('pax-last') as HTMLInputElement).value.trim();
		const email = (document.getElementById('pax-email') as HTMLInputElement).value.trim();
		const phone = (document.getElementById('pax-phone') as HTMLInputElement).value.trim();
		const errorEl = document.getElementById('form-error')!;
		const errorText = document.getElementById('form-error-text')!;

		// Validate
		if (!firstName || !lastName || !email || !phone) {
			errorText.textContent = 'Please fill in all required fields.';
			errorEl.classList.remove('hidden');
			return;
		}

		if (!email.includes('@')) {
			errorText.textContent = 'Please enter a valid email address.';
			errorEl.classList.remove('hidden');
			return;
		}

		errorEl.classList.add('hidden');

		const signName = (document.getElementById('pax-sign') as HTMLInputElement)?.value.trim() || '';
		const driverNotes = (document.getElementById('pax-notes') as HTMLTextAreaElement)?.value.trim() || '';
		const childSeats = childCheckbox?.checked ? childCount : 0;

		const p = new URLSearchParams({
			from, to, date, time, passengers,
			vehicleSlug, vehicleName, vehicleImage, vehicleMaxPax, vehicleMaxLug,
			totalPrice, outwardPrice, returnPrice,
			firstName, lastName, email, phone,
			signName, childSeats: String(childSeats), driverNotes,
		});
		if (returnDate) p.set('returnDate', returnDate);
		if (returnTime) p.set('returnTime', returnTime);
		if (luggageSmall > 0) p.set('luggageSmall', String(luggageSmall));
		if (luggageBig   > 0) p.set('luggageBig',   String(luggageBig));

		window.location.href = `/book/transfer/payment?${p.toString()}`;
	});
</script>
