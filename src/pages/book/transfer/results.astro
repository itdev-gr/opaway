---
import Layout from '../../../layouts/Layout.astro';
---

<Layout title="Select Vehicle — Opawey">
	<main class="min-h-screen bg-sky-50/40 pt-28 pb-16 px-4 sm:px-6">
		<div class="max-w-7xl mx-auto">

			<!-- ── Step indicator ── -->
			<div class="flex items-center justify-center gap-0 mb-8">
				<div class="flex items-center gap-2">
					<span class="w-8 h-8 rounded-full bg-[#0C6B95] text-white text-sm font-bold flex items-center justify-center">1</span>
					<span class="text-sm font-semibold text-[#0C6B95]">Vehicle</span>
				</div>
				<div class="w-16 h-px bg-neutral-300 mx-3"></div>
				<div class="flex items-center gap-2 opacity-40">
					<span class="w-8 h-8 rounded-full bg-neutral-300 text-white text-sm font-bold flex items-center justify-center">2</span>
					<span class="text-sm font-medium text-neutral-400">Passenger</span>
				</div>
				<div class="w-16 h-px bg-neutral-300 mx-3"></div>
				<div class="flex items-center gap-2 opacity-40">
					<span class="w-8 h-8 rounded-full bg-neutral-300 text-white text-sm font-bold flex items-center justify-center">3</span>
					<span class="text-sm font-medium text-neutral-400">Payment</span>
				</div>
			</div>

			<!-- ── Main grid: left (map + vehicles) | right (sidebar) ── -->
			<div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

				<!-- LEFT COLUMN -->
				<div class="lg:col-span-2 space-y-5">

					<!-- Map -->
					<div id="map" class="w-full h-80 rounded-2xl border border-neutral-200 bg-neutral-100 overflow-hidden flex items-center justify-center">
						<div id="map-fallback" class="text-center text-neutral-400 p-8">
							<svg class="w-10 h-10 mx-auto mb-3 text-neutral-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" /></svg>
							<p class="font-medium">Loading map...</p>
							<p class="text-sm mt-1" id="map-status">Calculating route</p>
						</div>
					</div>

					<!-- Route info bar -->
					<div id="route-info" class="hidden flex items-center gap-4 text-sm text-neutral-500 px-1">
						<span class="flex items-center gap-1.5">
							<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" /></svg>
							<span id="route-distance">—</span>
						</span>
						<span class="flex items-center gap-1.5">
							<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
							<span id="route-duration">—</span>
						</span>
						<span class="ml-auto text-xs">All prices include VAT, taxes & tolls</span>
					</div>

					<!-- Vehicle cards -->
					<div id="vehicle-cards" class="space-y-4">
						<!-- Skeleton loaders -->
						<div class="animate-pulse bg-white rounded-2xl border border-neutral-200 p-5 flex gap-5">
							<div class="w-36 h-24 bg-neutral-200 rounded-xl shrink-0"></div>
							<div class="flex-1 space-y-3"><div class="h-5 bg-neutral-200 rounded w-40"></div><div class="h-4 bg-neutral-200 rounded w-60"></div><div class="h-4 bg-neutral-200 rounded w-32"></div></div>
							<div class="w-24 h-8 bg-neutral-200 rounded-lg self-center shrink-0"></div>
						</div>
						<div class="animate-pulse bg-white rounded-2xl border border-neutral-200 p-5 flex gap-5">
							<div class="w-36 h-24 bg-neutral-200 rounded-xl shrink-0"></div>
							<div class="flex-1 space-y-3"><div class="h-5 bg-neutral-200 rounded w-40"></div><div class="h-4 bg-neutral-200 rounded w-60"></div><div class="h-4 bg-neutral-200 rounded w-32"></div></div>
							<div class="w-24 h-8 bg-neutral-200 rounded-lg self-center shrink-0"></div>
						</div>
						<div class="animate-pulse bg-white rounded-2xl border border-neutral-200 p-5 flex gap-5">
							<div class="w-36 h-24 bg-neutral-200 rounded-xl shrink-0"></div>
							<div class="flex-1 space-y-3"><div class="h-5 bg-neutral-200 rounded w-40"></div><div class="h-4 bg-neutral-200 rounded w-60"></div><div class="h-4 bg-neutral-200 rounded w-32"></div></div>
							<div class="w-24 h-8 bg-neutral-200 rounded-lg self-center shrink-0"></div>
						</div>
					</div>

					<!-- Selection bar (hidden until vehicle chosen) -->
					<div id="selection-bar" class="hidden sticky bottom-4 bg-white rounded-2xl border border-[#0C6B95]/30 shadow-lg p-4 flex items-center justify-between z-10">
						<div class="flex items-center gap-3">
							<svg class="w-5 h-5 text-[#0C6B95]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
							<span class="font-semibold text-neutral-800">Your choice: <span id="selected-name" class="text-[#0C6B95]"></span></span>
						</div>
						<button id="continue-btn" class="bg-[#0C6B95] hover:bg-[#0a5c82] text-white font-semibold px-8 py-3 rounded-xl transition-colors flex items-center gap-2">
							Continue
							<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
						</button>
					</div>
				</div>

				<!-- RIGHT COLUMN — Sidebar -->
				<div class="lg:col-span-1">
					<div class="sticky top-28 bg-white rounded-2xl border border-neutral-200 shadow-sm p-6 space-y-5">

						<h3 class="text-lg font-bold text-neutral-900">Your Booking</h3>

						<!-- Trip type + passengers -->
						<div class="flex items-center justify-between text-sm">
							<span id="sb-trip-type" class="font-semibold text-neutral-700">One way</span>
							<span class="flex items-center gap-1.5 text-neutral-500">
								<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" /></svg>
								<span id="sb-passengers">2</span> Passengers
							</span>
						</div>

						<!-- Date -->
						<div class="flex items-center justify-between text-sm border-t border-neutral-100 pt-4">
							<div>
								<span class="text-neutral-500">Outward</span>
								<span class="mx-1 text-neutral-300">&middot;</span>
								<span id="sb-date" class="font-medium text-neutral-700">—</span>
							</div>
							<a href="#" id="sb-edit" class="text-[#0C6B95] font-medium hover:underline flex items-center gap-1">
								<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536M9 13l6.586-6.586a2 2 0 112.828 2.828L11.828 15.828a2 2 0 01-1.414.586H9v-2a2 2 0 01.586-1.414z" /></svg>
								Edit
							</a>
						</div>

						<!-- Route -->
						<div class="space-y-3">
							<!-- From -->
							<div class="flex gap-3">
								<div class="flex flex-col items-center">
									<span class="w-3 h-3 rounded-full bg-[#0C6B95] shrink-0 mt-1"></span>
									<span class="w-px flex-1 bg-neutral-200"></span>
								</div>
								<div class="flex-1 min-w-0">
									<p id="sb-from" class="text-sm font-semibold text-neutral-800 truncate">—</p>
									<p class="text-xs text-neutral-400 mt-0.5" id="sb-from-time">—</p>
								</div>
								<span id="sb-pickup-time" class="text-sm font-medium text-neutral-600 shrink-0">—</span>
							</div>

							<!-- Distance -->
							<div class="flex gap-3">
								<div class="flex flex-col items-center">
									<span class="w-px flex-1 bg-neutral-200"></span>
								</div>
								<p class="text-xs text-neutral-400 flex items-center gap-1.5" id="sb-route-meta">
									<span id="sb-dist">—</span>
									<span class="mx-0.5">&middot;</span>
									<span id="sb-dur">—</span>
								</p>
							</div>

							<!-- To -->
							<div class="flex gap-3">
								<div class="flex flex-col items-center">
									<span class="w-3 h-3 rounded-full bg-neutral-400 shrink-0 mt-1"></span>
								</div>
								<div class="flex-1 min-w-0">
									<p id="sb-to" class="text-sm font-semibold text-neutral-800 truncate">—</p>
									<p class="text-xs text-neutral-400 mt-0.5" id="sb-to-detail"></p>
								</div>
								<span id="sb-arrival-time" class="text-sm font-medium text-neutral-600 shrink-0">—</span>
							</div>
						</div>

						<!-- Add return -->
						<button id="sb-add-return" class="w-full py-2.5 border border-dashed border-[#0C6B95]/40 text-[#0C6B95] font-semibold text-sm rounded-xl hover:bg-[#0C6B95]/5 transition-colors flex items-center justify-center gap-2">
							<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" /></svg>
							Add return
						</button>

						<!-- Return section (hidden until toggled) -->
						<div id="sb-return-section" class="hidden space-y-3 border-t border-neutral-100 pt-4">
							<div class="flex items-center justify-between">
								<span class="text-neutral-500 text-sm">Return</span>
								<button id="sb-remove-return" class="text-xs text-red-500 hover:text-red-700 font-medium flex items-center gap-1">
									<svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
									Remove
								</button>
							</div>
							<div class="flex gap-3">
								<div class="flex flex-col items-center">
									<span class="w-3 h-3 rounded-full bg-neutral-400 shrink-0 mt-1"></span>
									<span class="w-px flex-1 bg-neutral-200"></span>
								</div>
								<div class="flex-1 min-w-0">
									<p id="sb-return-from" class="text-sm font-semibold text-neutral-800 truncate">—</p>
								</div>
							</div>
							<div class="flex gap-3">
								<div class="flex flex-col items-center">
									<span class="w-3 h-3 rounded-full bg-[#0C6B95] shrink-0 mt-1"></span>
								</div>
								<div class="flex-1 min-w-0">
									<p id="sb-return-to" class="text-sm font-semibold text-neutral-800 truncate">—</p>
								</div>
							</div>
						</div>

						<!-- Price details -->
						<div class="border-t border-neutral-100 pt-4 space-y-2">
							<h4 class="text-sm font-bold text-neutral-800">Price details</h4>
							<div class="flex justify-between text-sm">
								<span class="font-semibold text-neutral-900">Total</span>
								<span id="sb-total" class="font-bold text-neutral-900">—</span>
							</div>
							<div class="flex justify-between text-sm text-neutral-500">
								<span>Outward</span>
								<span id="sb-outward">—</span>
							</div>
							<div id="sb-return-price-row" class="hidden flex justify-between text-sm text-neutral-500">
								<span>Return</span>
								<span id="sb-return-price">—</span>
							</div>
						</div>

						<!-- Feature badges -->
						<div class="flex flex-wrap gap-2 border-t border-neutral-100 pt-4">
							<span class="inline-flex items-center gap-1.5 text-xs font-medium text-emerald-700 bg-emerald-50 px-2.5 py-1 rounded-full">
								<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
								Free cancellation
							</span>
							<span class="inline-flex items-center gap-1.5 text-xs font-medium text-neutral-600 bg-neutral-100 px-2.5 py-1 rounded-full">
								<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
								Door-to-door service
							</span>
							<span class="inline-flex items-center gap-1.5 text-xs font-medium text-neutral-600 bg-neutral-100 px-2.5 py-1 rounded-full">
								<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
								Meet & Greet
							</span>
							<span class="inline-flex items-center gap-1.5 text-xs font-medium text-neutral-600 bg-neutral-100 px-2.5 py-1 rounded-full">
								<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
								Flight tracking
							</span>
							<span class="inline-flex items-center gap-1.5 text-xs font-medium text-neutral-600 bg-neutral-100 px-2.5 py-1 rounded-full">
								<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
								Licensed chauffeurs
							</span>
						</div>

						<!-- Payment icons -->
						<div class="flex items-center gap-3 border-t border-neutral-100 pt-4">
							<span class="text-xs text-neutral-400 font-medium">Accepted:</span>
							<div class="flex gap-2 text-xs font-bold text-neutral-500">
								<span class="px-2 py-1 bg-neutral-100 rounded">VISA</span>
								<span class="px-2 py-1 bg-neutral-100 rounded">MC</span>
								<span class="px-2 py-1 bg-neutral-100 rounded">AMEX</span>
							</div>
						</div>

					</div>
				</div>

			</div>
		</div>
	</main>
</Layout>

<script>
	import { supabase } from '../../../lib/supabase';
	import { calculatePrice, loadPricing, type PricingData } from '../../../lib/pricing';

	let partnerDiscount = 0;
	let pricingData: PricingData;

	async function detectPartnerDiscount(): Promise<number> {
		const { data: { user } } = await supabase.auth.getUser();
		if (!user) return 0;
		try {
			const { data: partner } = await supabase
				.from('partners')
				.select('status, discount')
				.eq('id', user.id)
				.maybeSingle();
			if (partner && partner.status === 'approved' && partner.discount > 0) {
				return partner.discount;
			}
		} catch (e) { console.error('Partner discount check failed:', e); }
		return 0;
	}

	/* ── Parse URL params ── */
	const params = new URLSearchParams(window.location.search);
	const from = params.get('from') || '';
	const to = params.get('to') || '';
	const date = params.get('date') || '';
	const time = params.get('time') || '';
	const passengers = parseInt(params.get('passengers') || '2', 10);
	const returnDate = params.get('returnDate') || '';
	const returnTime = params.get('returnTime') || '';
	let hasReturn = !!returnDate;

	/* ── Populate sidebar ── */
	const setText = (id: string, text: string) => { const el = document.getElementById(id); if (el) el.textContent = text; };

	setText('sb-from', from);
	setText('sb-to', to);
	setText('sb-date', date);
	setText('sb-pickup-time', time);
	setText('sb-passengers', String(passengers));
	setText('sb-from-time', `Pickup at ${time}`);

	/* ── State (declared early so setReturnState's render call doesn't hit TDZ) ── */
	let routeDistanceKm = 0;
	let routeDurationMin = 0;

	// Persist the selected vehicle so browser-Back from the passenger page
	// restores the highlight + Continue-ready state (F15). Keyed by from/to/
	// date so a fresh funnel with different route doesn't reuse the old pick.
	const SEL_STORAGE_KEY = 'book:transfer:selected-vehicle';
	const currentRouteKey = [from, to, date, time].join('|');
	function readStoredVehicle(): string {
		try {
			const raw = sessionStorage.getItem(SEL_STORAGE_KEY);
			if (!raw) return '';
			const { key, slug } = JSON.parse(raw) as { key: string; slug: string };
			return key === currentRouteKey ? (slug || '') : '';
		} catch { return ''; }
	}
	function persistSelectedVehicle(slug: string) {
		try { sessionStorage.setItem(SEL_STORAGE_KEY, JSON.stringify({ key: currentRouteKey, slug })); }
		catch { /* non-fatal */ }
	}

	let selectedVehicleSlug = readStoredVehicle();

	interface Vehicle {
		id: string;
		slug: string;
		name: string;
		models: string;
		image: string;
		maxPassengers: number;
		maxLuggage: number;
		badge: string;
		sortOrder: number;
	}

	let vehicles: Vehicle[] = [];

	function setReturnState(enabled: boolean) {
		hasReturn = enabled;
		setText('sb-trip-type', enabled ? 'Round trip' : 'One way');
		document.getElementById('sb-add-return')?.classList.toggle('hidden', enabled);
		document.getElementById('sb-return-section')?.classList.toggle('hidden', !enabled);
		document.getElementById('sb-return-price-row')?.classList.toggle('hidden', !enabled);

		if (enabled) {
			setText('sb-return-from', to);   // return goes: To → From
			setText('sb-return-to', from);
		}

		renderVehicles();
		updateSidebarPrices();
	}

	if (hasReturn) {
		setReturnState(true);
	}

	// Add return
	document.getElementById('sb-add-return')?.addEventListener('click', () => setReturnState(true));

	// Remove return
	document.getElementById('sb-remove-return')?.addEventListener('click', () => setReturnState(false));

	// Edit link — navigate back
	document.getElementById('sb-edit')?.addEventListener('click', (e) => {
		e.preventDefault();
		window.history.back();
	});

	/* ── Update sidebar prices ── */
	function updateSidebarPrices() {
		if (!selectedVehicleSlug) return;
		const price = calculatePrice({
			vehicleSlug: selectedVehicleSlug,
			distanceKm: routeDistanceKm,
			durationMinutes: routeDurationMin,
			passengers,
			isReturn: hasReturn,
			discount: partnerDiscount,
			time,
		}, pricingData);
		setText('sb-total', `\u20AC ${price.totalPrice.toFixed(2)}`);
		setText('sb-outward', `\u20AC ${price.outwardPrice.toFixed(2)}`);
		setText('sb-return-price', hasReturn ? `\u20AC ${price.returnPrice.toFixed(2)}` : '—');
	}

	/* ── Escape HTML ── */
	const esc = (s: string) => String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');

	/* ── Badge colors ── */
	function badgeClasses(badge: string): string {
		switch (badge) {
			case 'BEST VALUE': return 'bg-emerald-100 text-emerald-700';
			case 'MOST POPULAR': return 'bg-amber-100 text-amber-700';
			case 'TOP CLASS': return 'bg-violet-100 text-violet-700';
			default: return 'bg-neutral-100 text-neutral-600';
		}
	}

	/* ── Render vehicle cards ── */
	function renderVehicles() {
		const container = document.getElementById('vehicle-cards')!;

		const badgeHtml = partnerDiscount > 0
			? `<div class="bg-emerald-50 border border-emerald-200 rounded-xl px-4 py-2 mb-4 text-sm text-emerald-700 font-medium">Partner discount: ${partnerDiscount}% applied</div>`
			: '';

		container.innerHTML = badgeHtml + vehicles.map(v => {
			const price = calculatePrice({
				vehicleSlug: v.slug,
				distanceKm: routeDistanceKm,
				durationMinutes: routeDurationMin,
				passengers,
				isReturn: hasReturn,
				discount: partnerDiscount,
				time,
			}, pricingData);
			const isSelected = selectedVehicleSlug === v.slug;
			const showOriginal = partnerDiscount > 0 && price.originalTotal !== price.totalPrice;

			return `
			<div
				class="vehicle-card cursor-pointer bg-white rounded-2xl border-2 ${isSelected ? 'border-[#0C6B95] ring-2 ring-[#0C6B95]/20' : 'border-neutral-200 hover:border-[#0C6B95]/40'} shadow-sm transition-all duration-200 p-4"
				data-slug="${esc(v.slug)}" data-name="${esc(v.name)}" data-total="${price.totalPrice}"
			>
				<div class="flex items-center gap-4">
					<!-- Image -->
					<div class="w-28 h-20 bg-neutral-100 rounded-xl overflow-hidden shrink-0">
						<img src="${esc(v.image)}" alt="${esc(v.name)}" class="w-full h-full object-cover" />
					</div>

					<!-- Info -->
					<div class="flex-1 min-w-0">
						<div class="flex items-center gap-2 mb-1 flex-wrap">
							<h3 class="text-base font-bold text-neutral-900">${esc(v.name)}</h3>
							<span class="text-[10px] font-bold px-2 py-0.5 rounded-full ${badgeClasses(v.badge)} whitespace-nowrap">${esc(v.badge)}</span>
						</div>
						<div class="flex items-center gap-3 text-xs text-neutral-500 mb-1">
							<span class="flex items-center gap-1">
								<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" /></svg>
								Up to ${v.maxPassengers}
							</span>
							<span class="flex items-center gap-1">
								<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" /></svg>
								1+1/pax
							</span>
						</div>
						<p class="text-xs text-neutral-400 truncate">${esc(v.models)}</p>
					</div>

					<!-- Price -->
					<div class="flex flex-col items-end justify-center shrink-0 pl-2">
						${showOriginal ? `<del class="text-neutral-400 text-sm">&euro;${price.originalTotal.toFixed(2)}</del>` : ''}
						<span class="text-xl font-bold text-neutral-900">&euro;${price.totalPrice.toFixed(2)}</span>
						<span class="text-[10px] text-neutral-400">${hasReturn ? 'round trip' : 'total price'}</span>
					</div>
				</div>
			</div>`;
		}).join('');

		// Attach click handlers
		document.querySelectorAll<HTMLDivElement>('.vehicle-card').forEach(card => {
			card.addEventListener('click', () => {
				selectedVehicleSlug = card.dataset.slug || '';
				persistSelectedVehicle(selectedVehicleSlug);
				const name = card.dataset.name || '';

				// Update selection bar
				const bar = document.getElementById('selection-bar')!;
				bar.classList.remove('hidden');
				setText('selected-name', name);

				// Update sidebar prices
				updateSidebarPrices();

				// Re-render to update border highlight
				renderVehicles();
			});
		});

		// Restore selection from sessionStorage (browser-Back from passenger page).
		if (selectedVehicleSlug && vehicles.some(v => v.slug === selectedVehicleSlug)) {
			const v = vehicles.find(vv => vv.slug === selectedVehicleSlug)!;
			const bar = document.getElementById('selection-bar');
			bar?.classList.remove('hidden');
			setText('selected-name', v.name);
			updateSidebarPrices();
		}
	}

	/* ── Load vehicles from Supabase ── */
	async function loadVehicles() {
		try {
			const { data, error } = await supabase
				.from('vehicles')
				.select('*');

			if (error) throw error;

			if (data && data.length > 0) {
				vehicles = data.map(d => ({
					id: d.id,
					slug: d.slug,
					name: d.name,
					models: d.models,
					image: d.image,
					maxPassengers: d.max_passengers,
					maxLuggage: d.max_luggage,
					badge: d.badge,
					sortOrder: d.sort_order,
				}));
			} else {
				// Fallback: use hardcoded defaults if table is empty
				vehicles = [
					{ id: '1', slug: 'sedan', name: 'Sedan', models: 'Mercedes-Benz E-Class, or similar.', image: '/car.avif', maxPassengers: 3, maxLuggage: 6, badge: 'BEST VALUE', sortOrder: 1 },
					{ id: '2', slug: 'van', name: 'Van', models: 'Mercedes Vito Tourer, or similar.', image: '/mini_van.avif', maxPassengers: 8, maxLuggage: 16, badge: 'MOST POPULAR', sortOrder: 2 },
					{ id: '3', slug: 'minibus', name: 'Minibus (or two Vans)', models: 'Mercedes Sprinter, or similar.', image: '/van.avif', maxPassengers: 18, maxLuggage: 36, badge: 'TOP CLASS', sortOrder: 3 },
				];
			}
		} catch (e) {
			console.warn('Could not load vehicles from Supabase, using defaults:', e);
			vehicles = [
				{ id: '1', slug: 'sedan', name: 'Sedan', models: 'Mercedes-Benz E-Class, or similar.', image: '/car.avif', maxPassengers: 3, maxLuggage: 6, badge: 'BEST VALUE', sortOrder: 1 },
				{ id: '2', slug: 'van', name: 'Van', models: 'Mercedes Vito Tourer, or similar.', image: '/mini_van.avif', maxPassengers: 8, maxLuggage: 16, badge: 'MOST POPULAR', sortOrder: 2 },
				{ id: '3', slug: 'minibus', name: 'Minibus (or two Vans)', models: 'Mercedes Sprinter, or similar.', image: '/van.avif', maxPassengers: 18, maxLuggage: 36, badge: 'TOP CLASS', sortOrder: 3 },
			];
		}
		renderVehicles();
	}

	/* ── Google Maps ── */
	const MAPS_KEY = import.meta.env.PUBLIC_GOOGLE_MAPS_API_KEY;

	function initMap() {
		const mapEl = document.getElementById('map')!;
		const fallback = document.getElementById('map-fallback')!;

		const map = new google.maps.Map(mapEl, {
			zoom: 10,
			center: { lat: 37.9838, lng: 23.7275 }, // Athens default
			disableDefaultUI: true,
			zoomControl: true,
			styles: [{ featureType: 'poi', stylers: [{ visibility: 'off' }] }],
		});

		fallback.classList.add('hidden');

		const directionsService = new google.maps.DirectionsService();
		const directionsRenderer = new google.maps.DirectionsRenderer({
			map,
			suppressMarkers: false,
			polylineOptions: { strokeColor: '#0C6B95', strokeWeight: 5 },
		});

		directionsService.route(
			{ origin: from, destination: to, travelMode: google.maps.TravelMode.DRIVING },
			(result, status) => {
				if (status === 'OK' && result) {
					directionsRenderer.setDirections(result);

					const leg = result.routes[0]?.legs[0];
					if (leg) {
						routeDistanceKm = (leg.distance?.value || 0) / 1000;
						routeDurationMin = (leg.duration?.value || 0) / 60;

						setText('route-distance', leg.distance?.text || '—');
						setText('route-duration', leg.duration?.text || '—');
						setText('sb-dist', leg.distance?.text || '—');
						setText('sb-dur', leg.duration?.text || '—');
						setText('sb-arrival-time', `~${Math.round(routeDurationMin)} min`);

						document.getElementById('route-info')?.classList.remove('hidden');

						// Re-render vehicles with actual distance-based prices
						renderVehicles();
					}
				} else {
					console.warn('Directions request failed:', status);
					setText('map-status', `Could not calculate route. Showing estimated prices.`);
					fallback.classList.remove('hidden');
					// Use fallback distance
					routeDistanceKm = 30;
					routeDurationMin = 35;
					renderVehicles();
				}
			}
		);
	}

	// Load Maps script or use fallback
	if (MAPS_KEY) {
		if (typeof google !== 'undefined' && google.maps) {
			initMap();
		} else {
			const script = document.createElement('script');
			script.src = `https://maps.googleapis.com/maps/api/js?key=${MAPS_KEY}&libraries=places&callback=initMapCallback`;
			script.async = true;
			script.defer = true;
			(window as any).initMapCallback = initMap;
			script.onerror = () => {
				console.warn('Google Maps failed to load');
				setText('map-status', 'Map unavailable. Showing estimated prices.');
				routeDistanceKm = 30;
				routeDurationMin = 35;
				renderVehicles();
			};
			document.head.appendChild(script);
		}
	} else {
		setText('map-status', 'Map API key not configured. Showing estimated prices.');
		routeDistanceKm = 30;
		routeDurationMin = 35;
	}

	/* ── Continue to passenger page ── */
	document.getElementById('continue-btn')?.addEventListener('click', () => {
		if (!selectedVehicleSlug) return;

		const selectedVehicle = vehicles.find(v => v.slug === selectedVehicleSlug);
		const price = calculatePrice({
			vehicleSlug: selectedVehicleSlug,
			distanceKm: routeDistanceKm,
			durationMinutes: routeDurationMin,
			passengers,
			isReturn: hasReturn,
			discount: partnerDiscount,
			time,
		}, pricingData);

		const p = new URLSearchParams({
			from, to, date, time,
			passengers: String(passengers),
			vehicleSlug: selectedVehicleSlug,
			vehicleName: selectedVehicle?.name || '',
			vehicleImage: selectedVehicle?.image || '',
			vehicleMaxPax: String(selectedVehicle?.maxPassengers || 0),
			vehicleMaxLug: String(selectedVehicle?.maxLuggage || 0),
			totalPrice: price.totalPrice.toFixed(2),
			outwardPrice: price.outwardPrice.toFixed(2),
			returnPrice: price.returnPrice.toFixed(2),
		});
		if (partnerDiscount > 0) {
			p.set('discount', String(partnerDiscount));
		}
		if (hasReturn) {
			p.set('returnDate', returnDate || date);
			p.set('returnTime', returnTime || time);
		}

		window.location.href = `/book/transfer/passenger?${p.toString()}`;
	});

	/* ── Init ── */
	Promise.all([detectPartnerDiscount(), loadPricing()]).then(([d, p]) => {
		partnerDiscount = d;
		pricingData = p;
		loadVehicles();
	});
</script>
