---
import Layout from '../../../layouts/Layout.astro';
---

<Layout title="Payment — Opawey">
	<main class="min-h-screen bg-sky-50/40 pt-28 pb-16 px-4 sm:px-6">
		<div class="max-w-7xl mx-auto">

			<!-- ── Step indicator ── -->
			<div class="flex items-center justify-center gap-0 mb-8">
				<div class="flex items-center gap-2">
					<span class="w-8 h-8 rounded-full bg-emerald-500 text-white text-sm font-bold flex items-center justify-center">
						<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
					</span>
					<span class="text-sm font-medium text-emerald-600">Vehicle</span>
				</div>
				<div class="w-16 h-px bg-emerald-400 mx-3"></div>
				<div class="flex items-center gap-2">
					<span class="w-8 h-8 rounded-full bg-emerald-500 text-white text-sm font-bold flex items-center justify-center">
						<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
					</span>
					<span class="text-sm font-medium text-emerald-600">Passenger</span>
				</div>
				<div class="w-16 h-px bg-emerald-400 mx-3"></div>
				<div class="flex items-center gap-2">
					<span class="w-8 h-8 rounded-full bg-[#0C6B95] text-white text-sm font-bold flex items-center justify-center">3</span>
					<span class="text-sm font-semibold text-[#0C6B95]">Payment</span>
				</div>
			</div>

			<!-- ── Main grid ── -->
			<div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

				<!-- LEFT COLUMN -->
				<div class="lg:col-span-2">

					<!-- Payment form -->
					<div id="payment-form-section" class="bg-white rounded-2xl border border-neutral-200 shadow-sm p-6 lg:p-8">

						<!-- Order summary -->
						<h2 class="text-xl font-bold text-neutral-900 mb-5">Complete your booking</h2>

						<div class="bg-neutral-50 rounded-xl p-4 mb-6 space-y-2">
							<div class="flex items-center justify-between text-sm">
								<span class="text-neutral-500">Route</span>
								<span class="font-medium text-neutral-800"><span id="os-from">—</span> → <span id="os-to">—</span></span>
							</div>
							<div class="flex items-center justify-between text-sm">
								<span class="text-neutral-500">Date & time</span>
								<span class="font-medium text-neutral-800"><span id="os-date">—</span> at <span id="os-time">—</span></span>
							</div>
							<div class="flex items-center justify-between text-sm">
								<span class="text-neutral-500">Vehicle</span>
								<span class="font-medium text-neutral-800" id="os-vehicle">—</span>
							</div>
							<div class="flex items-center justify-between text-sm">
								<span class="text-neutral-500">Passenger</span>
								<span class="font-medium text-neutral-800" id="os-passenger">—</span>
							</div>
							<div class="flex items-center justify-between text-sm border-t border-neutral-200 pt-2 mt-2">
								<span class="font-bold text-neutral-900">Total</span>
								<span class="font-bold text-xl text-[#0C6B95]" id="os-total">—</span>
							</div>
						</div>

						<!-- Payment method selection -->
						<h3 class="text-base font-bold text-neutral-900 mb-4">Choose payment method</h3>

						<div class="space-y-3 mb-6">
							<!-- Option 1: Prepayment (Stripe) -->
							<label class="pay-method-option block cursor-pointer rounded-xl border-2 border-neutral-200 hover:border-[#0C6B95]/40 transition-all p-4" data-method="stripe">
								<div class="flex items-center justify-between">
									<div class="flex items-center gap-3">
										<input type="radio" name="pay-method" value="stripe" class="w-4 h-4 text-[#0C6B95] focus:ring-[#0C6B95]/30" />
										<div>
											<span class="font-semibold text-sm text-neutral-900">Prepayment (Online)</span>
											<p class="text-xs text-neutral-500 mt-0.5">Pay now with credit/debit card</p>
										</div>
									</div>
									<span class="font-bold text-neutral-900" id="method-stripe-price">—</span>
								</div>
								<!-- Stripe card element (shown when selected) -->
								<div id="stripe-expand" class="hidden mt-4 pt-4 border-t border-neutral-100">
									<div id="stripe-available" class="hidden">
										<div id="card-element" class="px-4 py-3.5 bg-white border border-neutral-200 rounded-xl mb-2"></div>
										<p id="card-errors" class="text-sm text-red-500 mb-2 hidden"></p>
										<p class="text-xs text-neutral-400 flex items-center gap-1.5">
											<svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" /></svg>
											Secured by Stripe. Encrypted end-to-end.
										</p>
									</div>
									<div id="stripe-not-configured" class="hidden bg-amber-50 border border-amber-200 rounded-xl p-3">
										<p class="text-xs text-amber-800 font-medium">Stripe not configured — add <code class="bg-amber-100 px-1 rounded">PUBLIC_STRIPE_PUBLISHABLE_KEY</code> to <code class="bg-amber-100 px-1 rounded">.env</code></p>
									</div>
								</div>
							</label>

							<!-- Option 2: Cash on-site -->
							<label class="pay-method-option block cursor-pointer rounded-xl border-2 border-neutral-200 hover:border-[#0C6B95]/40 transition-all p-4" data-method="cash">
								<div class="flex items-center justify-between">
									<div class="flex items-center gap-3">
										<input type="radio" name="pay-method" value="cash" class="w-4 h-4 text-[#0C6B95] focus:ring-[#0C6B95]/30" />
										<div>
											<span class="font-semibold text-sm text-neutral-900">Cash on-site</span>
											<p class="text-xs text-neutral-500 mt-0.5">Pay your driver in cash on arrival</p>
										</div>
									</div>
									<span class="font-bold text-neutral-900" id="method-cash-price">—</span>
								</div>
							</label>

							<!-- Option 3: Card on-site (+5%) -->
							<label class="pay-method-option block cursor-pointer rounded-xl border-2 border-neutral-200 hover:border-[#0C6B95]/40 transition-all p-4" data-method="card-onsite">
								<div class="flex items-center justify-between">
									<div class="flex items-center gap-3">
										<input type="radio" name="pay-method" value="card-onsite" class="w-4 h-4 text-[#0C6B95] focus:ring-[#0C6B95]/30" />
										<div>
											<span class="font-semibold text-sm text-neutral-900">Card on-site</span>
											<p class="text-xs text-neutral-500 mt-0.5">Pay your driver by card on arrival</p>
										</div>
									</div>
									<span class="font-bold text-neutral-900" id="method-card-price">—</span>
								</div>
								<p class="text-xs text-amber-600 mt-2 ml-7 flex items-center gap-1.5">
									<svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z" /></svg>
									5% transaction fee applies (<span id="card-fee-amount">+€0.00</span>)
								</p>
							</label>
						</div>

						<!-- Complete Booking button -->
						<button id="complete-btn" type="button"
							class="w-full py-3.5 bg-[#0C6B95] hover:bg-[#0a5c82] text-white font-semibold rounded-xl transition-colors flex items-center justify-center gap-2 disabled:opacity-50 disabled:cursor-not-allowed">
							<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
							Complete Booking
						</button>

						<!-- Back button -->
						<div class="mt-6 pt-4 border-t border-neutral-100">
							<button id="back-btn" type="button"
								class="px-5 py-3 border border-neutral-200 rounded-xl text-neutral-600 font-semibold hover:bg-neutral-50 transition-colors flex items-center gap-2">
								<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
								Back
							</button>
						</div>
					</div>

					<!-- Success state (hidden initially) -->
					<div id="success-section" class="hidden bg-white rounded-2xl border border-neutral-200 shadow-sm p-6 lg:p-10 text-center">
						<div class="w-20 h-20 rounded-full bg-emerald-100 flex items-center justify-center mx-auto mb-6">
							<svg class="w-10 h-10 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
						</div>
						<h2 class="text-2xl font-bold text-neutral-900 mb-2">Booking confirmed!</h2>
						<p class="text-neutral-500 mb-6">Your transfer has been booked successfully.</p>

						<div class="bg-neutral-50 rounded-xl p-5 mb-6 max-w-md mx-auto text-left space-y-2">
							<div class="flex justify-between text-sm">
								<span class="text-neutral-500">Reference</span>
								<span id="success-ref" class="font-mono font-bold text-[#0C6B95]">—</span>
							</div>
							<div class="flex justify-between text-sm">
								<span class="text-neutral-500">Route</span>
								<span id="success-route" class="font-medium text-neutral-800">—</span>
							</div>
							<div class="flex justify-between text-sm">
								<span class="text-neutral-500">Date</span>
								<span id="success-date" class="font-medium text-neutral-800">—</span>
							</div>
							<div class="flex justify-between text-sm">
								<span class="text-neutral-500">Vehicle</span>
								<span id="success-vehicle" class="font-medium text-neutral-800">—</span>
							</div>
							<div class="flex justify-between text-sm">
								<span class="text-neutral-500">Passenger</span>
								<span id="success-passenger" class="font-medium text-neutral-800">—</span>
							</div>
							<div class="flex justify-between text-sm border-t border-neutral-200 pt-2">
								<span class="font-bold text-neutral-900">Total</span>
								<span id="success-total" class="font-bold text-[#0C6B95]">—</span>
							</div>
						</div>

						<p class="text-sm text-neutral-500 mb-6">A confirmation email will be sent to <strong id="success-email">—</strong></p>

						<a href="/" class="inline-flex items-center gap-2 px-6 py-3 bg-[#0C6B95] hover:bg-[#0a5c82] text-white font-semibold rounded-xl transition-colors">
							<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" /></svg>
							Back to home
						</a>
					</div>
				</div>

				<!-- RIGHT COLUMN — Sidebar -->
				<div class="lg:col-span-1">
					<div class="sticky top-28 bg-white rounded-2xl border border-neutral-200 shadow-sm p-6 space-y-5">

						<h3 class="text-lg font-bold text-neutral-900">Your Booking</h3>

						<div class="flex items-center justify-between text-sm">
							<span id="sb-trip-type" class="font-semibold text-neutral-700">One way</span>
							<span class="flex items-center gap-1.5 text-neutral-500">
								<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" /></svg>
								<span id="sb-passengers">2</span> Passengers
							</span>
						</div>

						<div class="text-sm border-t border-neutral-100 pt-4">
							<span class="text-neutral-500">Outward</span>
							<span class="mx-1 text-neutral-300">&middot;</span>
							<span id="sb-date" class="font-medium text-neutral-700">—</span>
						</div>

						<div class="space-y-3">
							<div class="flex gap-3">
								<div class="flex flex-col items-center">
									<span class="w-3 h-3 rounded-full bg-[#0C6B95] shrink-0 mt-1"></span>
									<span class="w-px flex-1 bg-neutral-200"></span>
								</div>
								<div class="flex-1 min-w-0">
									<p id="sb-from" class="text-sm font-semibold text-neutral-800 truncate">—</p>
								</div>
								<span id="sb-pickup-time" class="text-sm font-medium text-neutral-600 shrink-0">—</span>
							</div>
							<div class="flex gap-3">
								<div class="flex flex-col items-center">
									<span class="w-3 h-3 rounded-full bg-neutral-400 shrink-0 mt-1"></span>
								</div>
								<div class="flex-1 min-w-0">
									<p id="sb-to" class="text-sm font-semibold text-neutral-800 truncate">—</p>
								</div>
							</div>
						</div>

						<div class="border-t border-neutral-100 pt-4">
							<p class="text-xs font-semibold text-neutral-500 uppercase tracking-wider mb-3">Your choice</p>
							<div class="flex items-center gap-3">
								<div class="w-16 h-12 bg-neutral-100 rounded-lg overflow-hidden shrink-0">
									<img id="sb-vehicle-img" src="" alt="" class="w-full h-full object-cover" />
								</div>
								<div class="min-w-0">
									<p id="sb-vehicle-name" class="text-sm font-bold text-neutral-900 truncate">—</p>
								</div>
							</div>
						</div>

						<div class="border-t border-neutral-100 pt-4 space-y-2">
							<h4 class="text-sm font-bold text-neutral-800">Price details</h4>
							<div class="flex justify-between text-sm">
								<span class="font-semibold text-neutral-900">Total</span>
								<span id="sb-total" class="font-bold text-neutral-900">—</span>
							</div>
							<div class="flex justify-between text-sm text-neutral-500">
								<span>Outward</span>
								<span id="sb-outward">—</span>
							</div>
							<div id="sb-return-price-row" class="hidden flex justify-between text-sm text-neutral-500">
								<span>Return</span>
								<span id="sb-return-price">—</span>
							</div>
						</div>

						<div class="flex flex-wrap gap-2 border-t border-neutral-100 pt-4">
							<span class="inline-flex items-center gap-1.5 text-xs font-medium text-emerald-700 bg-emerald-50 px-2.5 py-1 rounded-full">
								<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
								Free cancellation
							</span>
							<span class="inline-flex items-center gap-1.5 text-xs font-medium text-neutral-600 bg-neutral-100 px-2.5 py-1 rounded-full">
								<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
								Door-to-door service
							</span>
							<span class="inline-flex items-center gap-1.5 text-xs font-medium text-neutral-600 bg-neutral-100 px-2.5 py-1 rounded-full">
								<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
								Meet & Greet
							</span>
							<span class="inline-flex items-center gap-1.5 text-xs font-medium text-neutral-600 bg-neutral-100 px-2.5 py-1 rounded-full">
								<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
								Flight tracking
							</span>
							<span class="inline-flex items-center gap-1.5 text-xs font-medium text-neutral-600 bg-neutral-100 px-2.5 py-1 rounded-full">
								<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
								Licensed chauffeurs
							</span>
						</div>

						<div class="flex items-center gap-3 border-t border-neutral-100 pt-4">
							<span class="text-xs text-neutral-400 font-medium">Accepted:</span>
							<div class="flex gap-2 text-xs font-bold text-neutral-500">
								<span class="px-2 py-1 bg-neutral-100 rounded">VISA</span>
								<span class="px-2 py-1 bg-neutral-100 rounded">MC</span>
								<span class="px-2 py-1 bg-neutral-100 rounded">AMEX</span>
							</div>
						</div>

					</div>
				</div>

			</div>
		</div>
	</main>
</Layout>

<script>
	import { supabase } from '../../../lib/supabase';
	import { loadStripe } from '@stripe/stripe-js';

	/* ── Parse URL params ── */
	const params = new URLSearchParams(window.location.search);
	const from = params.get('from') || '';
	const to = params.get('to') || '';
	const date = params.get('date') || '';
	const time = params.get('time') || '';
	const passengers = params.get('passengers') || '2';
	const returnDate = params.get('returnDate') || '';
	const returnTime = params.get('returnTime') || '';
	const vehicleSlug = params.get('vehicleSlug') || '';
	const vehicleName = params.get('vehicleName') || '';
	const vehicleImage = params.get('vehicleImage') || '';
	const totalPrice = params.get('totalPrice') || '0';
	const outwardPrice = params.get('outwardPrice') || '0';
	const returnPrice = params.get('returnPrice') || '0';
	const firstName = params.get('firstName') || '';
	const lastName = params.get('lastName') || '';
	const email = params.get('email') || '';
	const phone = params.get('phone') || '';
	const signName = params.get('signName') || '';
	const childSeats = params.get('childSeats') || '0';
	const driverNotes = params.get('driverNotes') || '';
	const hasReturn = !!returnDate;

	/* ── Helpers ── */
	const setText = (id: string, text: string) => { const el = document.getElementById(id); if (el) el.textContent = text; };

	/* ── Populate order summary ── */
	setText('os-from', from);
	setText('os-to', to);
	setText('os-date', date);
	setText('os-time', time);
	setText('os-vehicle', vehicleName);
	setText('os-passenger', `${firstName} ${lastName}`);
	setText('os-total', `\u20AC${totalPrice}`);

	/* ── Populate sidebar ── */
	setText('sb-from', from);
	setText('sb-to', to);
	setText('sb-date', date);
	setText('sb-pickup-time', time);
	setText('sb-passengers', passengers);
	setText('sb-trip-type', hasReturn ? 'Round trip' : 'One way');
	setText('sb-vehicle-name', vehicleName);
	setText('sb-total', `\u20AC ${totalPrice}`);
	setText('sb-outward', `\u20AC ${outwardPrice}`);

	const vehicleImg = document.getElementById('sb-vehicle-img') as HTMLImageElement;
	if (vehicleImg && vehicleImage) { vehicleImg.src = vehicleImage; vehicleImg.alt = vehicleName; }

	if (hasReturn) {
		setText('sb-return-price', `\u20AC ${returnPrice}`);
		document.getElementById('sb-return-price-row')?.classList.remove('hidden');
	}

	/* ── Payment method state ── */
	const baseTotal = parseFloat(totalPrice);
	const cardOnsiteFee = Math.round(baseTotal * 0.05 * 100) / 100;
	const cardOnsiteTotal = Math.round((baseTotal + cardOnsiteFee) * 100) / 100;
	let selectedMethod = '';
	let stripeInstance: any = null;
	let cardElement: any = null;

	// Set method prices
	setText('method-stripe-price', `\u20AC${baseTotal.toFixed(2)}`);
	setText('method-cash-price', `\u20AC${baseTotal.toFixed(2)}`);
	setText('method-card-price', `\u20AC${cardOnsiteTotal.toFixed(2)}`);
	setText('card-fee-amount', `+\u20AC${cardOnsiteFee.toFixed(2)}`);

	/* ── Method selection ── */
	function selectMethod(method: string) {
		selectedMethod = method;

		// Update card styles
		document.querySelectorAll<HTMLLabelElement>('.pay-method-option').forEach(label => {
			const isActive = label.dataset.method === method;
			label.classList.toggle('border-[#0C6B95]', isActive);
			label.classList.toggle('ring-2', isActive);
			label.classList.toggle('ring-[#0C6B95]/20', isActive);
			label.classList.toggle('border-neutral-200', !isActive);
			const radio = label.querySelector('input[type="radio"]') as HTMLInputElement;
			if (radio) radio.checked = isActive;
		});

		// Toggle stripe expand
		document.getElementById('stripe-expand')?.classList.toggle('hidden', method !== 'stripe');

		// Update totals for card-onsite surcharge
		const displayTotal = method === 'card-onsite' ? cardOnsiteTotal : baseTotal;
		setText('os-total', `\u20AC${displayTotal.toFixed(2)}`);
		setText('sb-total', `\u20AC ${displayTotal.toFixed(2)}`);
	}

	document.querySelectorAll<HTMLLabelElement>('.pay-method-option').forEach(label => {
		label.addEventListener('click', () => selectMethod(label.dataset.method || ''));
	});

	/* ── Stripe setup ── */
	const STRIPE_KEY = import.meta.env.PUBLIC_STRIPE_PUBLISHABLE_KEY;

	if (STRIPE_KEY) {
		document.getElementById('stripe-available')?.classList.remove('hidden');
		(async () => {
			stripeInstance = await loadStripe(STRIPE_KEY);
			if (!stripeInstance) return;
			const elements = stripeInstance.elements();
			cardElement = elements.create('card', { style: { base: { fontSize: '16px', color: '#1a1a1a', '::placeholder': { color: '#a3a3a3' } } } });
			cardElement.mount('#card-element');
			const errorsEl = document.getElementById('card-errors')!;
			cardElement.on('change', (event: any) => {
				if (event.error) { errorsEl.textContent = event.error.message; errorsEl.classList.remove('hidden'); }
				else { errorsEl.classList.add('hidden'); }
			});
		})();
	} else {
		document.getElementById('stripe-not-configured')?.classList.remove('hidden');
	}

	/* ── Save booking to Supabase ── */
	async function saveBooking(paymentMethod: string, paymentToken: string = '') {
		const btn = document.getElementById('complete-btn') as HTMLButtonElement;
		btn.disabled = true; btn.textContent = 'Processing...';

		const finalTotal = paymentMethod === 'card-onsite' ? cardOnsiteTotal : baseTotal;
		const { data: { user } } = await supabase.auth.getUser();

		let partnerId: string | null = null;
		if (user) {
			const { data: partner } = await supabase.from('partners').select('id, status').eq('id', user.id).maybeSingle();
			if (partner?.status === 'approved') partnerId = partner.id;
		}

		try {
			const { data: inserted, error } = await supabase.from('transfers').insert({
				from, to, date, time,
				passengers: parseInt(passengers, 10),
				return_date: returnDate || null,
				return_time: returnTime || null,
				vehicle_slug: vehicleSlug, vehicle_name: vehicleName,
				first_name: firstName, last_name: lastName, email, phone,
				sign_name: signName || null,
				child_seats: parseInt(childSeats, 10),
				driver_notes: driverNotes || null,
				total_price: finalTotal,
				base_price: baseTotal,
				outward_price: parseFloat(outwardPrice),
				return_price: parseFloat(returnPrice),
				card_surcharge: paymentMethod === 'card-onsite' ? cardOnsiteFee : 0,
				ride_status: 'new',
				payment_status: paymentMethod === 'stripe' ? 'paid' : 'pending',
				payment_method: paymentMethod,
				payment_token: paymentToken || null,
				uid: user?.id || null,
				booking_type: 'transfer',
				partner_id: partnerId,
			}).select().single();

			if (error) throw error;
			if (!inserted) throw new Error('Booking was not returned after insert');

			document.getElementById('payment-form-section')?.classList.add('hidden');
			document.getElementById('success-section')?.classList.remove('hidden');
			setText('success-ref', inserted.id.substring(0, 8).toUpperCase());
			setText('success-route', `${from} \u2192 ${to}`);
			setText('success-date', `${date} at ${time}`);
			setText('success-vehicle', vehicleName);
			setText('success-passenger', `${firstName} ${lastName}`);
			setText('success-total', `\u20AC${finalTotal.toFixed(2)}`);
			setText('success-email', email);
		} catch (err) {
			/* error silenced */
			alert('Failed to save booking. Please try again.');
			btn.disabled = false;
			btn.innerHTML = `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Complete Booking`;
		}
	}

	/* ── Complete Booking button ── */
	document.getElementById('complete-btn')?.addEventListener('click', async () => {
		if (!selectedMethod) { alert('Please select a payment method.'); return; }

		if (selectedMethod === 'stripe') {
			if (!stripeInstance || !cardElement) { alert('Stripe is not loaded yet.'); return; }
			const btn = document.getElementById('complete-btn') as HTMLButtonElement;
			btn.disabled = true; btn.textContent = 'Processing...';
			const { error, token } = await stripeInstance.createToken(cardElement);
			if (error) {
				const errorsEl = document.getElementById('card-errors')!;
				errorsEl.textContent = error.message || 'Payment failed.';
				errorsEl.classList.remove('hidden');
				btn.disabled = false;
				btn.innerHTML = `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Complete Booking`;
				return;
			}
			await saveBooking('stripe', token?.id || '');
		} else {
			await saveBooking(selectedMethod);
		}
	});

	/* ── Back button ── */
	document.getElementById('back-btn')?.addEventListener('click', () => {
		window.history.back();
	});
</script>
