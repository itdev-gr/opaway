---
import Layout from '../../../layouts/Layout.astro';
---

<Layout title="Passenger Details — Opawey">
	<main class="min-h-screen bg-sky-50/40 pt-28 pb-16 px-4 sm:px-6">
		<div class="max-w-7xl mx-auto">

			<!-- ── Sub-navigation tabs ── -->
			<div class="flex items-center gap-3 mb-8 flex-wrap">
				<a href="/book/transfer" class="flex items-center gap-2 px-5 py-2.5 rounded-xl bg-white border border-neutral-200 text-neutral-600 font-semibold text-sm hover:border-[#0C6B95]/40 hover:text-[#0C6B95] transition-colors">
					<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
						<path stroke-linecap="round" stroke-linejoin="round" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
					</svg>
					Book a Transfer
				</a>
				<a href="/book/hourly" class="flex items-center gap-2 px-5 py-2.5 rounded-xl bg-white border border-neutral-200 text-neutral-600 font-semibold text-sm hover:border-[#0C6B95]/40 hover:text-[#0C6B95] transition-colors">
					<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
						<path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
					</svg>
					Rent per Hour
				</a>
				<a href="/book/tour" class="flex items-center gap-2 px-5 py-2.5 rounded-xl bg-white border border-neutral-200 text-neutral-600 font-semibold text-sm hover:border-[#0C6B95]/40 hover:text-[#0C6B95] transition-colors">
					<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
						<path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" />
					</svg>
					Book a Tour
				</a>
				<a href="/experiences" class="flex items-center gap-2 px-5 py-2.5 rounded-xl bg-[#0C6B95] text-white font-semibold text-sm shadow-md shadow-[#0C6B95]/25">
					<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
						<path stroke-linecap="round" stroke-linejoin="round" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
					</svg>
					Book an Experience
				</a>
			</div>

			<!-- ── Step indicator ── -->
			<div class="flex items-center justify-center gap-0 mb-8">
				<!-- Step 1: Vehicle (completed) -->
				<div class="flex items-center gap-2">
					<span class="w-8 h-8 rounded-full bg-emerald-500 text-white text-sm font-bold flex items-center justify-center">
						<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
					</span>
					<span class="text-sm font-medium text-emerald-600">Vehicle</span>
				</div>
				<div class="w-16 h-px bg-emerald-400 mx-3"></div>
				<!-- Step 2: Passenger (active) -->
				<div class="flex items-center gap-2">
					<span class="w-8 h-8 rounded-full bg-[#0C6B95] text-white text-sm font-bold flex items-center justify-center">2</span>
					<span class="text-sm font-semibold text-[#0C6B95]">Passenger</span>
				</div>
				<div class="w-16 h-px bg-neutral-300 mx-3"></div>
				<!-- Step 3: Payment (greyed) -->
				<div class="flex items-center gap-2 opacity-40">
					<span class="w-8 h-8 rounded-full bg-neutral-300 text-white text-sm font-bold flex items-center justify-center">3</span>
					<span class="text-sm font-medium text-neutral-400">Payment</span>
				</div>
			</div>

			<!-- ── Main grid ── -->
			<div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

				<!-- LEFT COLUMN — Form -->
				<div class="lg:col-span-2">
					<div class="bg-white rounded-2xl border border-neutral-200 shadow-sm p-6 lg:p-8">

						<!-- Lead passenger -->
						<h2 class="text-xl font-bold text-neutral-900 mb-6">Lead passenger</h2>

						<div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-5">
							<div>
								<label class="block text-sm font-medium text-neutral-700 mb-1.5">First name <span class="text-red-400">*</span></label>
								<input id="pax-first" type="text" required placeholder="John"
									class="w-full px-4 py-3 bg-white border border-neutral-200 rounded-xl text-neutral-800 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95]" />
								<p data-error-for="pax-first" class="text-sm text-red-500 mt-1.5 hidden"></p>
							</div>
							<div>
								<label class="block text-sm font-medium text-neutral-700 mb-1.5">Last name <span class="text-red-400">*</span></label>
								<input id="pax-last" type="text" required placeholder="Doe"
									class="w-full px-4 py-3 bg-white border border-neutral-200 rounded-xl text-neutral-800 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95]" />
								<p data-error-for="pax-last" class="text-sm text-red-500 mt-1.5 hidden"></p>
							</div>
						</div>

						<div class="mb-5">
							<label class="block text-sm font-medium text-neutral-700 mb-1.5">Email address <span class="text-red-400">*</span></label>
							<input id="pax-email" type="email" required placeholder="john@example.com"
								class="w-full px-4 py-3 bg-white border border-neutral-200 rounded-xl text-neutral-800 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95]" />
							<p data-error-for="pax-email" class="text-sm text-red-500 mt-1.5 hidden"></p>
							<p class="text-xs text-neutral-400 mt-1.5 flex items-center gap-1">
								<svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
								We'll send your booking voucher here.
							</p>
						</div>

						<div class="mb-8">
							<label class="block text-sm font-medium text-neutral-700 mb-1.5">Mobile number <span class="text-red-400">*</span></label>
							<div class="flex gap-3">
								<div class="flex items-center gap-2 px-3 py-3 bg-neutral-50 border border-neutral-200 rounded-xl text-sm text-neutral-600 shrink-0">
									<span>🇬🇷</span>
									<span>+30</span>
								</div>
								<input id="pax-phone" type="tel" required placeholder="693 123 4567"
									class="flex-1 px-4 py-3 bg-white border border-neutral-200 rounded-xl text-neutral-800 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95]" />
							</div>
							<p data-error-for="pax-phone" class="text-sm text-red-500 mt-1.5 hidden"></p>
							<p class="text-xs text-neutral-400 mt-1.5 flex items-center gap-1">
								<svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
								Please provide a contact number so our driver can reach the passenger if needed.
							</p>
						</div>

						<!-- Special Requests -->
						<div class="border-t border-neutral-100 pt-6 mb-6">
							<label class="block text-sm font-medium text-neutral-700 mb-1.5 flex items-center gap-1.5">
								Special Requests
								<span class="inline-flex items-center justify-center w-4 h-4 rounded-full bg-neutral-400 text-white text-[10px] font-bold cursor-help" title="Add any special requests or notes for your driver.">?</span>
							</label>
							<textarea id="pax-notes" rows="4" placeholder="Special requests, dietary needs, accessibility requirements..."
								class="w-full px-4 py-3 bg-white border border-neutral-200 rounded-xl text-neutral-800 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95] resize-y"></textarea>
						</div>

						<!-- Validation message -->
						<div data-form-error class="hidden mb-4 rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-600" role="alert"></div>

						<!-- Navigation -->
						<div class="flex items-center gap-4 pt-2">
							<button id="back-btn" type="button"
								class="px-5 py-3 border border-neutral-200 rounded-xl text-neutral-600 font-semibold hover:bg-neutral-50 transition-colors flex items-center gap-2">
								<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
								Back
							</button>
							<button id="continue-btn" type="button"
								class="flex-1 py-3 bg-neutral-900 hover:bg-neutral-800 text-white font-semibold rounded-xl transition-colors text-center">
								Continue
							</button>
						</div>
					</div>
				</div>

				<!-- RIGHT COLUMN — Sidebar -->
				<div class="lg:col-span-1">
					<div class="sticky top-28 bg-white rounded-2xl border border-neutral-200 shadow-sm p-6 space-y-5">

						<h3 class="text-lg font-bold text-neutral-900">Your Booking</h3>

						<!-- Experience name -->
						<div class="text-sm">
							<span class="text-neutral-500">Experience</span>
							<p id="sb-experience-name" class="font-semibold text-neutral-800 mt-0.5">—</p>
						</div>

						<!-- Pickup location -->
						<div class="text-sm border-t border-neutral-100 pt-4">
							<span class="text-neutral-500">Pickup location</span>
							<p id="sb-pickup" class="font-medium text-neutral-700 mt-0.5">—</p>
						</div>

						<!-- Date + time -->
						<div class="text-sm border-t border-neutral-100 pt-4">
							<span class="text-neutral-500">Date</span>
							<span class="mx-1 text-neutral-300">&middot;</span>
							<span id="sb-date" class="font-medium text-neutral-700">—</span>
							<span class="mx-1 text-neutral-300">&middot;</span>
							<span id="sb-time" class="font-medium text-neutral-700">—</span>
						</div>

						<!-- Participants -->
						<div class="flex items-center gap-1.5 text-sm border-t border-neutral-100 pt-4">
							<svg class="w-4 h-4 text-neutral-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" /></svg>
							<span id="sb-participants" class="font-medium text-neutral-700">—</span>
							<span class="text-neutral-500">Participants</span>
						</div>

						<!-- Your choice (vehicle) -->
						<div class="border-t border-neutral-100 pt-4">
							<p class="text-xs font-semibold text-neutral-500 uppercase tracking-wider mb-3">Your choice</p>
							<div class="flex items-center gap-3">
								<div class="w-16 h-12 bg-neutral-100 rounded-lg overflow-hidden shrink-0">
									<img id="sb-vehicle-img" src="" alt="" class="w-full h-full object-cover" />
								</div>
								<div class="min-w-0">
									<p id="sb-vehicle-name" class="text-sm font-bold text-neutral-900 truncate">—</p>
								</div>
							</div>
						</div>

						<!-- Price details -->
						<div class="border-t border-neutral-100 pt-4 space-y-2">
							<h4 class="text-sm font-bold text-neutral-800">Price details</h4>
							<div class="flex justify-between text-sm">
								<span class="font-semibold text-neutral-900">Total</span>
								<span id="sb-total" class="font-bold text-neutral-900">—</span>
							</div>
						</div>

						<!-- Feature badges -->
						<div class="flex flex-wrap gap-2 border-t border-neutral-100 pt-4">
							<span class="inline-flex items-center gap-1.5 text-xs font-medium text-emerald-700 bg-emerald-50 px-2.5 py-1 rounded-full">
								<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
								Free cancellation
							</span>
							<span class="inline-flex items-center gap-1.5 text-xs font-medium text-neutral-600 bg-neutral-100 px-2.5 py-1 rounded-full">
								<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
								Door-to-door service
							</span>
							<span class="inline-flex items-center gap-1.5 text-xs font-medium text-neutral-600 bg-neutral-100 px-2.5 py-1 rounded-full">
								<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
								Licensed chauffeurs
							</span>
						</div>

						<!-- Payment icons -->
						<div class="flex items-center gap-3 border-t border-neutral-100 pt-4">
							<span class="text-xs text-neutral-400 font-medium">Accepted:</span>
							<div class="flex gap-2 text-xs font-bold text-neutral-500">
								<span class="px-2 py-1 bg-neutral-100 rounded">VISA</span>
								<span class="px-2 py-1 bg-neutral-100 rounded">MC</span>
								<span class="px-2 py-1 bg-neutral-100 rounded">AMEX</span>
							</div>
						</div>

					</div>
				</div>

			</div>
		</div>
	</main>
</Layout>

<script>
	import { supabase } from '../../../lib/supabase';
	import { showFieldError, clearFormErrors, wireAutoClear } from '../../../lib/form-errors';

	/* ── Parse URL params ── */
	const params = new URLSearchParams(window.location.search);
	const experienceId = params.get('experienceId') || '';
	const experienceName = params.get('experienceName') || '';
	const pickup = params.get('pickup') || '';
	const date = params.get('date') || '';
	const time = params.get('time') || '';
	const participants = params.get('participants') || '1';
	const vehicleSlug = params.get('vehicleSlug') || '';
	const vehicleName = params.get('vehicleName') || '';
	const vehicleImage = params.get('vehicleImage') || '';
	const totalPrice = params.get('totalPrice') || '0';
	const discount = params.get('discount') || '';

	/* ── Populate sidebar ── */
	const setText = (id: string, text: string) => { const el = document.getElementById(id); if (el) el.textContent = text; };

	setText('sb-experience-name', experienceName);
	setText('sb-pickup', pickup);
	setText('sb-date', date);
	setText('sb-time', time);
	setText('sb-participants', participants);
	setText('sb-vehicle-name', vehicleName);
	setText('sb-total', `\u20AC ${totalPrice}`);

	const vehicleImg = document.getElementById('sb-vehicle-img') as HTMLImageElement;
	if (vehicleImg && vehicleImage) { vehicleImg.src = vehicleImage; vehicleImg.alt = vehicleName; }

	/* ── Wire auto-clear on input fields ── */
	wireAutoClear([
		document.getElementById('pax-first'),
		document.getElementById('pax-last'),
		document.getElementById('pax-email'),
		document.getElementById('pax-phone'),
	]);

	/* ── Auto-fill from Supabase Auth ── */
	supabase.auth.onAuthStateChange((_event, session) => {
		const user = session?.user;
		if (!user) return;
		const firstName = document.getElementById('pax-first') as HTMLInputElement;
		const lastName = document.getElementById('pax-last') as HTMLInputElement;
		const email = document.getElementById('pax-email') as HTMLInputElement;

		if (user.email && !email.value) email.value = user.email;
		const displayName = user.user_metadata?.display_name || user.user_metadata?.full_name || '';
		if (displayName) {
			const parts = displayName.split(' ');
			if (!firstName.value) firstName.value = parts[0] || '';
			if (!lastName.value) lastName.value = parts.slice(1).join(' ') || '';
		}
	});

	/* ── Back button ── */
	document.getElementById('back-btn')?.addEventListener('click', () => {
		window.history.back();
	});

	/* ── Continue button ── */
	document.getElementById('continue-btn')?.addEventListener('click', () => {
		const firstName = (document.getElementById('pax-first') as HTMLInputElement).value.trim();
		const lastName = (document.getElementById('pax-last') as HTMLInputElement).value.trim();
		const email = (document.getElementById('pax-email') as HTMLInputElement).value.trim();
		const phone = (document.getElementById('pax-phone') as HTMLInputElement).value.trim();

		const scope = document.querySelector('form') ?? document.body;
		clearFormErrors(scope);

		const firstEl = document.getElementById('pax-first') as HTMLInputElement;
		const lastEl  = document.getElementById('pax-last')  as HTMLInputElement;
		const emailEl = document.getElementById('pax-email') as HTMLInputElement;
		const phoneEl = document.getElementById('pax-phone') as HTMLInputElement;

		let firstErr: HTMLElement | null = null;
		if (!firstName) { showFieldError(firstEl, 'First name is required.'); firstErr ??= firstEl; }
		if (!lastName)  { showFieldError(lastEl,  'Last name is required.');  firstErr ??= lastEl; }
		if (!email)     { showFieldError(emailEl, 'Email is required.');      firstErr ??= emailEl; }
		else if (!email.includes('@')) { showFieldError(emailEl, 'Please enter a valid email address.'); firstErr ??= emailEl; }
		if (!phone)     { showFieldError(phoneEl, 'Phone number is required.'); firstErr ??= phoneEl; }

		if (firstErr) {
			firstErr.scrollIntoView({ behavior: 'smooth', block: 'center' });
			firstErr.focus?.();
			return;
		}

		const driverNotes = (document.getElementById('pax-notes') as HTMLTextAreaElement)?.value.trim() || '';

		const p = new URLSearchParams({
			experienceId, experienceName, pickup, date, time, participants,
			vehicleSlug, vehicleName, vehicleImage, totalPrice,
			firstName, lastName, email, phone, driverNotes,
			bookingType: 'experience',
		});
		if (discount) p.set('discount', discount);

		window.location.href = `/book/experience/payment?${p.toString()}`;
	});
</script>
