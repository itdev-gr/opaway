---
import AdminLayout from '../../components/AdminLayout.astro';
---

<AdminLayout pageTitle="Experiences Catalog" pageDescription="Add and manage experiences displayed on the website." activeSection="new-entry">

	<!-- Sub-navigation tabs -->
	<div class="flex items-center gap-3 mb-6">
		<a href="/admin/manage-transfers" class="px-5 py-2.5 rounded-xl bg-white border border-neutral-200 text-neutral-600 font-semibold text-sm hover:border-[#0C6B95]/40 hover:text-[#0C6B95] transition-colors">Transfers</a>
		<a href="/admin/manage-tours" class="px-5 py-2.5 rounded-xl bg-white border border-neutral-200 text-neutral-600 font-semibold text-sm hover:border-[#0C6B95]/40 hover:text-[#0C6B95] transition-colors">Tours</a>
		<a href="/admin/manage-experiences" class="px-5 py-2.5 rounded-xl bg-[#0C6B95] text-white font-semibold text-sm shadow-md shadow-[#0C6B95]/25">Experiences</a>
		<a href="/admin/manage-vehicles" class="px-5 py-2.5 rounded-xl bg-white border border-neutral-200 text-neutral-600 font-semibold text-sm hover:border-[#0C6B95]/40 hover:text-[#0C6B95] transition-colors">Vehicles</a>
	</div>

	<!-- Add New Experience Form -->
	<div class="bg-white rounded-2xl border border-neutral-200 shadow-sm p-6 mb-6">
		<h2 class="text-base font-semibold text-neutral-800 mb-5 flex items-center gap-2">
			<svg class="w-4 h-4 text-[#0C6B95]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
				<path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
			</svg>
			Add New Experience
		</h2>

		<form id="exp-form" class="space-y-4" novalidate>

			<!-- Images gallery -->
			<div class="space-y-2">
				<label class="block text-xs font-semibold text-neutral-600 mb-1.5 uppercase tracking-wider">Images *</label>
				<div class="flex flex-wrap items-center gap-2">
					<label class="inline-flex items-center gap-2 px-4 py-2 bg-neutral-50 border border-neutral-200 rounded-xl text-sm text-neutral-600 hover:bg-neutral-100 cursor-pointer transition-colors">
						<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12" /></svg>
						Upload from computer
						<input id="f-file" type="file" accept="image/*" multiple class="hidden" />
					</label>
					<span class="text-xs text-neutral-400">or</span>
					<div class="flex items-center gap-2 flex-1 min-w-[250px]">
						<input id="f-image-url-input" type="url" placeholder="Paste image URL"
							class="flex-1 px-4 py-2.5 bg-white border border-neutral-200 rounded-xl text-sm text-neutral-800 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95] shadow-sm" />
						<button id="f-image-url-add" type="button"
							class="px-4 py-2.5 bg-neutral-100 text-neutral-700 text-sm font-semibold rounded-xl hover:bg-neutral-200 transition-colors">Add URL</button>
					</div>
					<span id="f-upload-status" class="hidden text-xs text-[#0C6B95]"></span>
				</div>
				<p class="text-xs text-neutral-400">Up to 10 images. First image is the cover.</p>
				<ul id="f-image-list" class="grid grid-cols-5 gap-2 mt-2"></ul>
			</div>

			<!-- Title -->
			<div>
				<label class="block text-xs font-semibold text-neutral-600 mb-1.5 uppercase tracking-wider">Title *</label>
				<input
					id="f-title" type="text" required
					placeholder="e.g. Athens Wine Tasting Tour"
					class="w-full px-4 py-2.5 bg-white border border-neutral-200 rounded-xl text-sm text-neutral-800 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95] shadow-sm"
				/>
			</div>

			<!-- Price per vehicle -->
			<div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-4">
				<div>
					<label class="block text-sm font-medium text-neutral-700 mb-1">Price — Sedan (€)</label>
					<input id="f-price-sedan" type="number" step="0.01" min="0" placeholder="0.00"
						class="w-full px-4 py-3 bg-neutral-50 border border-neutral-200 rounded-xl text-neutral-800 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95]" />
				</div>
				<div>
					<label class="block text-sm font-medium text-neutral-700 mb-1">Price — Van (€)</label>
					<input id="f-price-van" type="number" step="0.01" min="0" placeholder="0.00"
						class="w-full px-4 py-3 bg-neutral-50 border border-neutral-200 rounded-xl text-neutral-800 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95]" />
				</div>
				<div>
					<label class="block text-sm font-medium text-neutral-700 mb-1">Price — Minibus (€)</label>
					<input id="f-price-minibus" type="number" step="0.01" min="0" placeholder="0.00"
						class="w-full px-4 py-3 bg-neutral-50 border border-neutral-200 rounded-xl text-neutral-800 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95]" />
				</div>
			</div>

			<!-- Duration -->
			<div class="mb-4">
				<label class="block text-sm font-medium text-neutral-700 mb-1">Duration label</label>
				<input id="f-duration" type="text" placeholder="e.g. Half day · ~4 hours"
					class="w-full px-4 py-3 bg-neutral-50 border border-neutral-200 rounded-xl text-neutral-800 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95]" />
			</div>

			<!-- Category -->
			<div>
				<label class="block text-xs font-semibold text-neutral-600 mb-1.5 uppercase tracking-wider">Category *</label>
				<select id="f-category" required class="w-full px-4 py-2.5 bg-white border border-neutral-200 rounded-xl text-sm text-neutral-800 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95] shadow-sm">
					<option value="day-tour">Day Tour</option>
					<option value="multiday-tour">Multi-day Tour</option>
					<option value="experience-single" selected>Experience (single day)</option>
					<option value="experience-multi">Experience (multi day)</option>
				</select>
			</div>

			<!-- Entrance ticket -->
			<div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
				<div>
					<label class="block text-xs font-semibold text-neutral-600 mb-1.5 uppercase tracking-wider">Entrance ticket per person (€)</label>
					<input id="f-entrance-price" type="number" min="0" step="0.01" placeholder="e.g. 10.00" class="w-full px-4 py-2.5 bg-white border border-neutral-200 rounded-xl text-sm text-neutral-800 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95] shadow-sm" />
					<p class="text-xs text-neutral-400 mt-1.5">Per-passenger archaeological-site entry cost.</p>
				</div>
				<div>
					<label class="block text-xs font-semibold text-neutral-600 mb-1.5 uppercase tracking-wider">Number of tickets</label>
					<input id="f-entrance-count" type="number" min="0" step="1" value="0" class="w-full px-4 py-2.5 bg-white border border-neutral-200 rounded-xl text-sm text-neutral-800 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95] shadow-sm" />
					<p class="text-xs text-neutral-400 mt-1.5">0 or 1 for day tours; multi-day tours may require more.</p>
				</div>
			</div>

			<!-- Hotel option (multi-day only) -->
			<div id="f-hotel-wrap" class="hidden">
				<label class="block text-xs font-semibold text-neutral-600 mb-1.5 uppercase tracking-wider">Hotel option</label>
				<select id="f-hotel-option" class="w-full px-4 py-2.5 bg-white border border-neutral-200 rounded-xl text-sm text-neutral-800 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95] shadow-sm">
					<option value="none">No hotel option</option>
					<option value="self-book">No hotel needed (guest books their own)</option>
					<option value="include-booking">Include hotel booking (agent contacts after booking)</option>
				</select>
			</div>

			<!-- Description -->
			<div>
				<label class="block text-xs font-semibold text-neutral-600 mb-1.5 uppercase tracking-wider">Description *</label>
				<textarea
					id="f-description" required rows="4"
					placeholder="Describe the experience, what's included, highlights…"
					class="w-full px-4 py-2.5 bg-white border border-neutral-200 rounded-xl text-sm text-neutral-800 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95] shadow-sm resize-none"
				></textarea>
			</div>

			<!-- Highlights -->
			<div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-4">
				<div>
					<label class="block text-sm font-medium text-neutral-700 mb-1">Highlight 1</label>
					<input id="f-h1" type="text" placeholder="Short bullet"
						class="w-full px-4 py-3 bg-neutral-50 border border-neutral-200 rounded-xl text-neutral-800 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95]" />
				</div>
				<div>
					<label class="block text-sm font-medium text-neutral-700 mb-1">Highlight 2</label>
					<input id="f-h2" type="text" placeholder="Short bullet"
						class="w-full px-4 py-3 bg-neutral-50 border border-neutral-200 rounded-xl text-neutral-800 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95]" />
				</div>
				<div>
					<label class="block text-sm font-medium text-neutral-700 mb-1">Highlight 3</label>
					<input id="f-h3" type="text" placeholder="Short bullet"
						class="w-full px-4 py-3 bg-neutral-50 border border-neutral-200 rounded-xl text-neutral-800 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95]" />
				</div>
			</div>

			<!-- Status + Submit -->
			<div class="flex items-center justify-between pt-1">
				<span id="form-status" class="text-sm"></span>
				<button
					type="submit"
					id="submit-btn"
					class="inline-flex items-center gap-2 bg-[#0C6B95] hover:bg-[#0a5c82] text-white text-sm font-semibold px-6 py-2.5 rounded-xl transition-colors shadow-sm disabled:opacity-50 disabled:cursor-not-allowed"
				>
					<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
						<path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
					</svg>
					Add Experience
				</button>
			</div>
		</form>
	</div>

	<!-- Experiences Grid -->
	<div class="bg-white rounded-2xl border border-neutral-200 shadow-sm overflow-hidden">
		<div class="px-6 py-4 border-b border-neutral-100 flex items-center justify-between">
			<h2 class="text-base font-semibold text-neutral-800">Experiences Catalog</h2>
			<span id="exp-count" class="text-xs text-neutral-400 font-medium"></span>
		</div>
		<div id="exp-grid" class="p-6 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
			<p class="text-neutral-400 text-sm col-span-full text-center py-10">Loading…</p>
		</div>
	</div>

	<!-- Delete confirmation modal -->
	<div id="delete-modal" class="fixed inset-0 bg-black/50 z-50 hidden items-center justify-center p-4">
		<div class="bg-white rounded-2xl shadow-2xl p-6 w-full max-w-sm">
			<div class="w-12 h-12 rounded-full bg-red-100 flex items-center justify-center mx-auto mb-4">
				<svg class="w-6 h-6 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
					<path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
				</svg>
			</div>
			<h3 class="text-base font-bold text-neutral-900 text-center mb-1">Delete Experience</h3>
			<p id="delete-modal-body" class="text-sm text-neutral-500 text-center mb-6">This experience will be permanently removed from the website.</p>
			<div class="flex gap-3">
				<button id="delete-no"  class="flex-1 py-2.5 rounded-xl border border-neutral-200 text-neutral-700 font-semibold text-sm hover:bg-neutral-50 transition-colors">No</button>
				<button id="delete-yes" class="flex-1 py-2.5 rounded-xl bg-red-600 hover:bg-red-700 font-semibold text-sm text-white transition-colors">Yes</button>
			</div>
		</div>
	</div>

	<!-- Edit modal -->
	<div id="edit-modal" class="fixed inset-0 bg-black/50 z-50 hidden items-center justify-center p-4">
		<div class="bg-white rounded-2xl shadow-2xl p-6 w-full max-w-lg max-h-[90vh] overflow-y-auto">
			<div class="flex items-center justify-between mb-5">
				<h3 class="text-base font-bold text-neutral-900">Edit Experience</h3>
				<button id="edit-close" class="text-neutral-400 hover:text-neutral-600 transition-colors" type="button">
					<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
						<path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
					</svg>
				</button>
			</div>
			<div class="space-y-4">
				<!-- Edit Images gallery -->
				<div class="space-y-2">
					<label class="block text-xs font-semibold text-neutral-600 mb-1.5 uppercase tracking-wider">Images *</label>
					<div class="flex flex-wrap items-center gap-2">
						<label class="inline-flex items-center gap-2 px-4 py-2 bg-neutral-50 border border-neutral-200 rounded-xl text-sm text-neutral-600 hover:bg-neutral-100 cursor-pointer transition-colors">
							<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12" /></svg>
							Upload from computer
							<input id="e-file" type="file" accept="image/*" multiple class="hidden" />
						</label>
						<span class="text-xs text-neutral-400">or</span>
						<div class="flex items-center gap-2 flex-1 min-w-[250px]">
							<input id="e-image-url-input" type="url" placeholder="Paste image URL"
								class="flex-1 px-4 py-2.5 bg-white border border-neutral-200 rounded-xl text-sm text-neutral-800 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95] shadow-sm" />
							<button id="e-image-url-add" type="button"
								class="px-4 py-2.5 bg-neutral-100 text-neutral-700 text-sm font-semibold rounded-xl hover:bg-neutral-200 transition-colors">Add URL</button>
						</div>
						<span id="e-upload-status" class="hidden text-xs text-[#0C6B95]"></span>
					</div>
					<p class="text-xs text-neutral-400">Up to 10 images. First image is the cover.</p>
					<ul id="e-image-list" class="grid grid-cols-5 gap-2 mt-2"></ul>
				</div>
				<!-- Edit Title -->
				<div>
					<label class="block text-xs font-semibold text-neutral-600 mb-1.5 uppercase tracking-wider">Title *</label>
					<input
						id="e-title" type="text"
						class="w-full px-4 py-2.5 bg-white border border-neutral-200 rounded-xl text-sm text-neutral-800 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95] shadow-sm"
					/>
				</div>
				<!-- Edit Price per vehicle -->
				<div class="grid grid-cols-1 md:grid-cols-3 gap-4">
					<div>
						<label class="block text-sm font-medium text-neutral-700 mb-1">Price — Sedan (€)</label>
						<input id="e-price-sedan" type="number" step="0.01" min="0" placeholder="0.00"
							class="w-full px-4 py-3 bg-neutral-50 border border-neutral-200 rounded-xl text-neutral-800 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95]" />
					</div>
					<div>
						<label class="block text-sm font-medium text-neutral-700 mb-1">Price — Van (€)</label>
						<input id="e-price-van" type="number" step="0.01" min="0" placeholder="0.00"
							class="w-full px-4 py-3 bg-neutral-50 border border-neutral-200 rounded-xl text-neutral-800 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95]" />
					</div>
					<div>
						<label class="block text-sm font-medium text-neutral-700 mb-1">Price — Minibus (€)</label>
						<input id="e-price-minibus" type="number" step="0.01" min="0" placeholder="0.00"
							class="w-full px-4 py-3 bg-neutral-50 border border-neutral-200 rounded-xl text-neutral-800 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95]" />
					</div>
				</div>
				<!-- Edit Duration -->
				<div>
					<label class="block text-sm font-medium text-neutral-700 mb-1">Duration label</label>
					<input id="e-duration" type="text" placeholder="e.g. Half day · ~4 hours"
						class="w-full px-4 py-3 bg-neutral-50 border border-neutral-200 rounded-xl text-neutral-800 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95]" />
				</div>
				<!-- Edit Category -->
				<div>
					<label class="block text-xs font-semibold text-neutral-600 mb-1.5 uppercase tracking-wider">Category *</label>
					<select id="e-category" required class="w-full px-4 py-2.5 bg-white border border-neutral-200 rounded-xl text-sm text-neutral-800 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95] shadow-sm">
						<option value="day-tour">Day Tour</option>
						<option value="multiday-tour">Multi-day Tour</option>
						<option value="experience-single">Experience (single day)</option>
						<option value="experience-multi">Experience (multi day)</option>
					</select>
				</div>
				<!-- Edit Entrance ticket -->
				<div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
					<div>
						<label class="block text-xs font-semibold text-neutral-600 mb-1.5 uppercase tracking-wider">Entrance ticket per person (€)</label>
						<input id="e-entrance-price" type="number" min="0" step="0.01" placeholder="e.g. 10.00" class="w-full px-4 py-2.5 bg-white border border-neutral-200 rounded-xl text-sm text-neutral-800 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95] shadow-sm" />
						<p class="text-xs text-neutral-400 mt-1.5">Per-passenger archaeological-site entry cost.</p>
					</div>
					<div>
						<label class="block text-xs font-semibold text-neutral-600 mb-1.5 uppercase tracking-wider">Number of tickets</label>
						<input id="e-entrance-count" type="number" min="0" step="1" value="0" class="w-full px-4 py-2.5 bg-white border border-neutral-200 rounded-xl text-sm text-neutral-800 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95] shadow-sm" />
						<p class="text-xs text-neutral-400 mt-1.5">0 or 1 for day tours; multi-day tours may require more.</p>
					</div>
				</div>
				<!-- Edit Hotel option (multi-day only) -->
				<div id="e-hotel-wrap" class="hidden">
					<label class="block text-xs font-semibold text-neutral-600 mb-1.5 uppercase tracking-wider">Hotel option</label>
					<select id="e-hotel-option" class="w-full px-4 py-2.5 bg-white border border-neutral-200 rounded-xl text-sm text-neutral-800 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95] shadow-sm">
						<option value="none">No hotel option</option>
						<option value="self-book">No hotel needed (guest books their own)</option>
						<option value="include-booking">Include hotel booking (agent contacts after booking)</option>
					</select>
				</div>
				<!-- Edit Description -->
				<div>
					<label class="block text-xs font-semibold text-neutral-600 mb-1.5 uppercase tracking-wider">Description *</label>
					<textarea
						id="e-description" rows="4"
						class="w-full px-4 py-2.5 bg-white border border-neutral-200 rounded-xl text-sm text-neutral-800 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95] shadow-sm resize-none"
					></textarea>
				</div>
				<!-- Edit Highlights -->
				<div class="grid grid-cols-1 md:grid-cols-3 gap-4">
					<div>
						<label class="block text-sm font-medium text-neutral-700 mb-1">Highlight 1</label>
						<input id="e-h1" type="text" placeholder="Short bullet"
							class="w-full px-4 py-3 bg-neutral-50 border border-neutral-200 rounded-xl text-neutral-800 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95]" />
					</div>
					<div>
						<label class="block text-sm font-medium text-neutral-700 mb-1">Highlight 2</label>
						<input id="e-h2" type="text" placeholder="Short bullet"
							class="w-full px-4 py-3 bg-neutral-50 border border-neutral-200 rounded-xl text-neutral-800 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95]" />
					</div>
					<div>
						<label class="block text-sm font-medium text-neutral-700 mb-1">Highlight 3</label>
						<input id="e-h3" type="text" placeholder="Short bullet"
							class="w-full px-4 py-3 bg-neutral-50 border border-neutral-200 rounded-xl text-neutral-800 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95]" />
					</div>
				</div>
				<!-- Edit status + Save -->
				<div class="flex items-center justify-between pt-1">
					<span id="edit-status" class="text-sm"></span>
					<div class="flex gap-3">
						<button id="edit-cancel" type="button" class="px-5 py-2.5 rounded-xl border border-neutral-200 text-neutral-700 font-semibold text-sm hover:bg-neutral-50 transition-colors">Cancel</button>
						<button id="edit-save"   type="button" class="inline-flex items-center gap-2 bg-[#0C6B95] hover:bg-[#0a5c82] text-white text-sm font-semibold px-6 py-2.5 rounded-xl transition-colors shadow-sm disabled:opacity-50 disabled:cursor-not-allowed">Save Changes</button>
					</div>
				</div>
			</div>
		</div>
	</div>

</AdminLayout>

<script>
	import { supabase } from '../../lib/supabase';
	import { uploadImages } from '../../lib/upload';

	/* ── Types ── */
	interface CatalogItem {
		id: string;
		title: string;
		description: string;
		price: number | null;
		price_sedan: number | null;
		price_van: number | null;
		price_minibus: number | null;
		duration: string | null;
		highlight1: string | null;
		highlight2: string | null;
		highlight3: string | null;
		imageUrl: string;
		images: string[];
		published: boolean;
		category: string;
		entrancePrice: number;
		entranceCount: number;
		hotelOption: string;
	}

	/* ── State ── */
	let items: CatalogItem[] = [];
	let pendingDeleteId = '';
	let pendingEditId   = '';

	const MAX_IMAGES = 10;
	let addGallery: string[] = [];
	let editGallery: string[] = [];

	/* ── Escape HTML ── */
	const esc = (s: string) => String(s)
		.replace(/&/g, '&amp;').replace(/</g, '&lt;')
		.replace(/>/g, '&gt;').replace(/"/g, '&quot;');

	/* ── Gallery rendering + controls ── */
	function renderGallery(listId: string, gallery: string[]) {
		const list = document.getElementById(listId);
		if (!list) return;
		list.innerHTML = gallery.map((url, i) => `
			<li class="relative group">
				<img src="${esc(url)}" class="w-full h-20 object-cover rounded-lg border border-neutral-200" />
				${i === 0 ? '<span class="absolute top-1 left-1 text-[10px] bg-emerald-600 text-white px-1.5 py-0.5 rounded">Cover</span>' : ''}
				<button type="button" data-remove="${i}" class="absolute top-1 right-1 w-5 h-5 bg-white/95 text-red-600 rounded-full text-xs leading-5 text-center shadow">×</button>
			</li>
		`).join('');
		list.querySelectorAll<HTMLButtonElement>('[data-remove]').forEach(b => {
			b.addEventListener('click', () => {
				gallery.splice(parseInt(b.dataset.remove!, 10), 1);
				renderGallery(listId, gallery);
			});
		});
	}

	function bindGalleryControls(prefix: 'f' | 'e', gallery: string[], listId: string) {
		const fileEl   = document.getElementById(`${prefix}-file`)            as HTMLInputElement | null;
		const urlInput = document.getElementById(`${prefix}-image-url-input`) as HTMLInputElement | null;
		const urlAdd   = document.getElementById(`${prefix}-image-url-add`);
		const statusEl = document.getElementById(`${prefix}-upload-status`);

		fileEl?.addEventListener('change', async () => {
			if (!fileEl.files?.length) return;
			if (gallery.length + fileEl.files.length > MAX_IMAGES) {
				alert(`Maximum ${MAX_IMAGES} images.`); fileEl.value = ''; return;
			}
			statusEl?.classList.remove('hidden');
			if (statusEl) statusEl.textContent = 'Uploading…';
			try {
				const urls = await uploadImages(fileEl.files, 'experiences');
				gallery.push(...urls);
				renderGallery(listId, gallery);
				if (statusEl) statusEl.textContent = 'Uploaded';
				setTimeout(() => statusEl?.classList.add('hidden'), 2000);
			} catch (err) {
				console.error('Image upload failed:', err);
				if (statusEl) statusEl.textContent = 'Upload failed';
				setTimeout(() => statusEl?.classList.add('hidden'), 3000);
			}
			fileEl.value = '';
		});

		urlAdd?.addEventListener('click', () => {
			if (!urlInput) return;
			if (!urlInput.checkValidity()) { urlInput.reportValidity(); return; }
			const url = urlInput.value.trim();
			if (!url) return;
			if (gallery.length >= MAX_IMAGES) { alert(`Maximum ${MAX_IMAGES} images.`); return; }
			gallery.push(url);
			urlInput.value = '';
			renderGallery(listId, gallery);
		});
	}

	bindGalleryControls('f', addGallery, 'f-image-list');
	bindGalleryControls('e', editGallery, 'e-image-list');

	/* ── Hotel visibility toggle based on category ── */
	const toggleHotel = (categorySelId: string, wrapId: string) => {
		const sel = document.getElementById(categorySelId) as HTMLSelectElement | null;
		const wrap = document.getElementById(wrapId);
		if (!sel || !wrap) return;
		const apply = () => {
			const v = sel.value;
			wrap.classList.toggle('hidden', v !== 'multiday-tour' && v !== 'experience-multi');
		};
		if (!sel.dataset.hotelBound) {
			sel.addEventListener('change', apply);
			sel.dataset.hotelBound = '1';
		}
		apply();
	};
	toggleHotel('f-category', 'f-hotel-wrap');

	/* ── Render grid ── */
	function renderGrid() {
		const grid    = document.getElementById('exp-grid')!;
		const countEl = document.getElementById('exp-count');
		if (countEl) countEl.textContent = `${items.length} experience${items.length !== 1 ? 's' : ''}`;

		if (items.length === 0) {
			grid.innerHTML = `<p class="text-neutral-400 text-sm col-span-full text-center py-12">No experiences added yet. Use the form above to publish your first experience.</p>`;
			return;
		}

		grid.innerHTML = items.map(item => {
			const isLive = item.published !== false;
			const priceLine = [
				item.price_sedan   ? `Sedan €${Number(item.price_sedan).toFixed(0)}`     : null,
				item.price_van     ? `Van €${Number(item.price_van).toFixed(0)}`         : null,
				item.price_minibus ? `Minibus €${Number(item.price_minibus).toFixed(0)}` : null,
			].filter(Boolean).join(' · ') || (item.price ? `€${Number(item.price).toFixed(0)}` : '—');
			return `
			<div class="group rounded-xl border border-neutral-200 overflow-hidden bg-neutral-50 shadow-sm hover:shadow-md transition-shadow duration-200">
				<!-- Image + status badge -->
				<div class="aspect-video overflow-hidden bg-neutral-200 relative">
					<img
						src="${esc(item.imageUrl)}"
						alt="${esc(item.title)}"
						class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
						onerror="this.closest('.aspect-video').style.background='#e5e7eb'"
					/>
					<span class="absolute top-2 left-2 text-xs font-semibold px-2 py-0.5 rounded-full ${isLive ? 'bg-emerald-100 text-emerald-700' : 'bg-neutral-200 text-neutral-500'}">
						${isLive ? 'Live' : 'Hidden'}
					</span>
				</div>
				<!-- Content -->
				<div class="p-4">
					<h3 class="font-semibold text-neutral-900 truncate text-sm ${item.duration ? 'mb-0.5' : 'mb-1'}">${esc(item.title)}</h3>
					${item.duration ? `<span class="inline-flex items-center gap-1 text-xs text-[#0C6B95] font-medium mb-2"><svg class="w-3 h-3 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>${esc(item.duration)}</span>` : ''}
					<p class="text-xs text-neutral-500 leading-relaxed mb-3 overflow-hidden" style="display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical">${esc(item.description)}</p>
					<span class="text-xs font-semibold text-[#0C6B95]">${esc(priceLine)}</span>
					<!-- Actions -->
					<div class="flex items-center gap-2 mt-3 pt-3 border-t border-neutral-100">
						<!-- Toggle On/Off -->
						<button
							class="toggle-btn flex-1 py-1.5 rounded-lg border text-xs font-semibold transition-colors ${isLive ? 'bg-emerald-50 text-emerald-700 border-emerald-200 hover:bg-emerald-100' : 'bg-neutral-100 text-neutral-500 border-neutral-200 hover:bg-neutral-200'}"
							data-id="${item.id}" data-published="${isLive}" type="button"
						>${isLive ? 'On' : 'Off'}</button>
						<!-- Edit -->
						<button
							class="edit-btn p-1.5 rounded-lg border border-neutral-200 text-neutral-400 hover:text-[#0C6B95] hover:border-[#0C6B95]/30 hover:bg-sky-50 transition-colors"
							data-id="${item.id}" type="button" title="Edit"
						>
							<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
								<path stroke-linecap="round" stroke-linejoin="round" d="M15.232 5.232l3.536 3.536M9 13l6.586-6.586a2 2 0 112.828 2.828L11.828 15.828a2 2 0 01-1.414.586H9v-2a2 2 0 01.586-1.414z" />
							</svg>
						</button>
						<!-- Delete -->
						<button
							class="delete-btn p-1.5 rounded-lg border border-neutral-200 text-neutral-400 hover:text-red-500 hover:border-red-200 hover:bg-red-50 transition-colors"
							data-id="${item.id}" data-title="${esc(item.title)}" type="button" title="Delete"
						>
							<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
								<path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7M10 11v6m4-6v6M9 7V4h6v3M4 7h16"/>
							</svg>
						</button>
					</div>
				</div>
			</div>`;
		}).join('');

		/* Attach toggle handlers */
		document.querySelectorAll<HTMLButtonElement>('.toggle-btn').forEach(btn => {
			btn.addEventListener('click', async () => {
				const id     = btn.dataset.id!;
				const isLive = btn.dataset.published === 'true';
				btn.disabled = true;
				try {
					const { error: togErr } = await supabase.from('experiences_catalog').update({ published: !isLive }).eq('id', id);
					if (togErr) throw togErr;
					const item = items.find(i => i.id === id);
					if (item) item.published = !isLive;
					renderGrid();
				} catch (err) { /* error silenced */ btn.disabled = false; }
			});
		});

		/* Attach edit handlers */
		document.querySelectorAll<HTMLButtonElement>('.edit-btn').forEach(btn => {
			btn.addEventListener('click', () => openEditModal(btn.dataset.id!));
		});

		/* Attach delete handlers */
		document.querySelectorAll<HTMLButtonElement>('.delete-btn').forEach(btn => {
			btn.addEventListener('click', () => {
				pendingDeleteId = btn.dataset.id!;
				const modal = document.getElementById('delete-modal')!;
				const body  = document.getElementById('delete-modal-body')!;
				body.textContent = `"${btn.dataset.title}" will be permanently removed from the website.`;
				modal.classList.remove('hidden');
				modal.classList.add('flex');
			});
		});
	}

	/* ── Load from Supabase ── */
	async function loadItems() {
		const grid = document.getElementById('exp-grid')!;
		try {
			const { data, error } = await supabase.from('experiences_catalog').select('*').order('created_at', { ascending: false });
			if (error) throw error;
			items = (data ?? []).map((d: any) => {
				const images: string[] = Array.isArray(d.images) && d.images.length > 0
					? d.images
					: (d.image_url ? [d.image_url] : []);
				return {
					id: d.id,
					title: d.title,
					description: d.description,
					price: d.price,
					price_sedan: d.price_sedan,
					price_van: d.price_van,
					price_minibus: d.price_minibus,
					duration: d.duration,
					highlight1: d.highlight1,
					highlight2: d.highlight2,
					highlight3: d.highlight3,
					imageUrl: images[0] || d.image_url || '',
					images,
					published: d.published,
					category: d.category || 'experience-single',
					entrancePrice: Number(d.entrance_ticket_per_person ?? 0),
					entranceCount: Number(d.entrance_ticket_count ?? 0),
					hotelOption: d.hotel_option || 'none',
				};
			});
			renderGrid();
		} catch (e) {
			/* error silenced */
			grid.innerHTML = `<p class="text-neutral-400 text-sm col-span-full text-center py-10">Could not load experiences.</p>`;
		}
	}

	/* ── Form submit ── */
	const form      = document.getElementById('exp-form')    as HTMLFormElement;
	const statusEl  = document.getElementById('form-status')!;
	const submitBtn = document.getElementById('submit-btn')  as HTMLButtonElement;

	const setStatus = (msg: string, cls: string) => { statusEl.textContent = msg; statusEl.className = `text-sm ${cls}`; };

	form.addEventListener('submit', async (e) => {
		e.preventDefault();
		const title       = (document.getElementById('f-title')       as HTMLInputElement).value.trim();
		const description = (document.getElementById('f-description') as HTMLTextAreaElement).value.trim();
		const category      = (document.getElementById('f-category')      as HTMLSelectElement).value || 'experience-single';
		const entrancePrice = parseFloat((document.getElementById('f-entrance-price') as HTMLInputElement).value) || 0;
		const entranceCount = parseInt((document.getElementById('f-entrance-count') as HTMLInputElement).value) || 0;
		const hotelOption   = (document.getElementById('f-hotel-option')  as HTMLSelectElement).value || 'none';

		const cover = addGallery[0] || '';
		if (!cover) { setStatus('Please add at least one image.', 'text-red-500'); return; }

		if (!title || !description) {
			setStatus('Please fill in all required fields.', 'text-red-500'); return;
		}

		submitBtn.disabled = true;
		submitBtn.textContent = 'Adding…';
		setStatus('', '');

		const payload = {
			title,
			description,
			image_url: cover,
			images: addGallery,
			price:         Number((document.getElementById('f-price-sedan') as HTMLInputElement).value) || null,
			price_sedan:   Number((document.getElementById('f-price-sedan')   as HTMLInputElement).value) || null,
			price_van:     Number((document.getElementById('f-price-van')     as HTMLInputElement).value) || null,
			price_minibus: Number((document.getElementById('f-price-minibus') as HTMLInputElement).value) || null,
			duration:      (document.getElementById('f-duration') as HTMLInputElement).value.trim() || null,
			highlight1:    (document.getElementById('f-h1') as HTMLInputElement).value.trim() || null,
			highlight2:    (document.getElementById('f-h2') as HTMLInputElement).value.trim() || null,
			highlight3:    (document.getElementById('f-h3') as HTMLInputElement).value.trim() || null,
			category,
			entrance_ticket_per_person: entrancePrice,
			entrance_ticket_count: entranceCount,
			hotel_option: hotelOption,
			published: true,
		};

		try {
			const { data: inserted, error: insErr } = await supabase.from('experiences_catalog').insert(payload).select().single();
			if (insErr) throw insErr;
			items.unshift({
				id: inserted.id,
				imageUrl: cover,
				images: [...addGallery],
				title,
				description,
				price: null,
				price_sedan: payload.price_sedan,
				price_van: payload.price_van,
				price_minibus: payload.price_minibus,
				duration: payload.duration,
				highlight1: payload.highlight1,
				highlight2: payload.highlight2,
				highlight3: payload.highlight3,
				category,
				entrancePrice,
				entranceCount,
				hotelOption,
				published: true,
			});
			renderGrid();
			form.reset();
			addGallery.length = 0;
			renderGallery('f-image-list', addGallery);
			toggleHotel('f-category', 'f-hotel-wrap');
			setStatus('✓ Experience published successfully!', 'text-emerald-600 font-medium');
			setTimeout(() => setStatus('', ''), 4000);
		} catch (err) {
			/* error silenced */
			setStatus('Error adding experience. Please try again.', 'text-red-500');
		} finally {
			submitBtn.disabled = false;
			submitBtn.innerHTML = `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg> Add Experience`;
		}
	});

	/* ── Delete modal ── */
	const closeDeleteModal = () => {
		const m = document.getElementById('delete-modal')!;
		m.classList.add('hidden'); m.classList.remove('flex');
	};

	document.getElementById('delete-no')?.addEventListener('click', closeDeleteModal);
	document.getElementById('delete-modal')?.addEventListener('click', (e) => { if (e.target === e.currentTarget) closeDeleteModal(); });

	document.getElementById('delete-yes')?.addEventListener('click', async () => {
		const yesBtn = document.getElementById('delete-yes') as HTMLButtonElement;
		yesBtn.textContent = 'Deleting…'; yesBtn.disabled = true;
		try {
			const { error: delErr } = await supabase.from('experiences_catalog').delete().eq('id', pendingDeleteId);
			if (delErr) throw delErr;
			items = items.filter(i => i.id !== pendingDeleteId);
			renderGrid();
		} catch (err) { /* error silenced */ }
		yesBtn.textContent = 'Yes'; yesBtn.disabled = false;
		closeDeleteModal();
	});

	/* ── Edit modal ── */
	function openEditModal(id: string) {
		const row = items.find(i => i.id === id);
		if (!row) return;
		pendingEditId = id;

		editGallery.length = 0;
		const sourceImages = (row.images && row.images.length > 0)
			? row.images
			: (row.imageUrl ? [row.imageUrl] : []);
		editGallery.push(...sourceImages);
		renderGallery('e-image-list', editGallery);

		(document.getElementById('e-title')         as HTMLInputElement).value    = row.title ?? '';
		(document.getElementById('e-description')   as HTMLTextAreaElement).value = row.description ?? '';
		(document.getElementById('e-price-sedan')   as HTMLInputElement).value    = String(row.price_sedan   ?? row.price ?? '');
		(document.getElementById('e-price-van')     as HTMLInputElement).value    = String(row.price_van     ?? row.price ?? '');
		(document.getElementById('e-price-minibus') as HTMLInputElement).value    = String(row.price_minibus ?? row.price ?? '');
		(document.getElementById('e-duration')      as HTMLInputElement).value    = row.duration   ?? '';
		(document.getElementById('e-h1')            as HTMLInputElement).value    = row.highlight1 ?? '';
		(document.getElementById('e-h2')            as HTMLInputElement).value    = row.highlight2 ?? '';
		(document.getElementById('e-h3')            as HTMLInputElement).value    = row.highlight3 ?? '';
		(document.getElementById('e-category')       as HTMLSelectElement).value = row.category || 'experience-single';
		(document.getElementById('e-entrance-price') as HTMLInputElement).value  = String(row.entrancePrice ?? 0);
		(document.getElementById('e-entrance-count') as HTMLInputElement).value  = String(row.entranceCount ?? 0);
		(document.getElementById('e-hotel-option')   as HTMLSelectElement).value = row.hotelOption || 'none';

		toggleHotel('e-category', 'e-hotel-wrap');

		document.getElementById('edit-status')!.textContent = '';

		const modal = document.getElementById('edit-modal')!;
		modal.classList.remove('hidden');
		modal.classList.add('flex');
	}

	const closeEditModal = () => {
		const m = document.getElementById('edit-modal')!;
		m.classList.add('hidden'); m.classList.remove('flex');
	};

	document.getElementById('edit-close')?.addEventListener('click', closeEditModal);
	document.getElementById('edit-cancel')?.addEventListener('click', closeEditModal);
	document.getElementById('edit-modal')?.addEventListener('click', (e) => { if (e.target === e.currentTarget) closeEditModal(); });

	document.getElementById('edit-save')?.addEventListener('click', async () => {
		const title       = (document.getElementById('e-title')       as HTMLInputElement).value.trim();
		const description = (document.getElementById('e-description') as HTMLTextAreaElement).value.trim();
		const category      = (document.getElementById('e-category')      as HTMLSelectElement).value || 'experience-single';
		const entrancePrice = parseFloat((document.getElementById('e-entrance-price') as HTMLInputElement).value) || 0;
		const entranceCount = parseInt((document.getElementById('e-entrance-count') as HTMLInputElement).value) || 0;
		const hotelOption   = (document.getElementById('e-hotel-option')  as HTMLSelectElement).value || 'none';
		const editStatus  = document.getElementById('edit-status')!;
		const saveBtn     = document.getElementById('edit-save') as HTMLButtonElement;

		const cover = editGallery[0] || '';
		if (!cover) {
			editStatus.textContent = 'Please keep at least one image.';
			editStatus.className = 'text-sm text-red-500';
			return;
		}

		if (!title || !description) {
			editStatus.textContent = 'Please fill in all required fields.';
			editStatus.className = 'text-sm text-red-500';
			return;
		}

		saveBtn.disabled = true;
		saveBtn.textContent = 'Saving…';
		editStatus.textContent = '';

		const existing = items.find((x) => x.id === pendingEditId);
		const payload = {
			title,
			description,
			image_url: cover,
			images: editGallery,
			price_sedan:   Number((document.getElementById('e-price-sedan')   as HTMLInputElement).value) || null,
			price_van:     Number((document.getElementById('e-price-van')     as HTMLInputElement).value) || null,
			price_minibus: Number((document.getElementById('e-price-minibus') as HTMLInputElement).value) || null,
			duration:      (document.getElementById('e-duration') as HTMLInputElement).value.trim() || null,
			highlight1:    (document.getElementById('e-h1') as HTMLInputElement).value.trim() || null,
			highlight2:    (document.getElementById('e-h2') as HTMLInputElement).value.trim() || null,
			highlight3:    (document.getElementById('e-h3') as HTMLInputElement).value.trim() || null,
			category,
			entrance_ticket_per_person: entrancePrice,
			entrance_ticket_count: entranceCount,
			hotel_option: hotelOption,
			published: existing?.published ?? true,
		};

		try {
			const { error: updErr } = await supabase.from('experiences_catalog').update(payload).eq('id', pendingEditId);
			if (updErr) throw updErr;
			const item = items.find(i => i.id === pendingEditId);
			if (item) Object.assign(item, {
				imageUrl: cover,
				images: [...editGallery],
				title,
				description,
				price_sedan: payload.price_sedan,
				price_van: payload.price_van,
				price_minibus: payload.price_minibus,
				duration: payload.duration,
				highlight1: payload.highlight1,
				highlight2: payload.highlight2,
				highlight3: payload.highlight3,
				category,
				entrancePrice,
				entranceCount,
				hotelOption,
			});
			renderGrid();
			closeEditModal();
		} catch (err) {
			/* error silenced */
			editStatus.textContent = 'Error saving changes. Please try again.';
			editStatus.className = 'text-sm text-red-500';
		} finally {
			saveBtn.disabled = false;
			saveBtn.textContent = 'Save Changes';
		}
	});

	/* ── Auth guard observer ── */
	const authEl   = document.getElementById('admin-auth-check');
	const observer = new MutationObserver(() => {
		if (authEl?.classList.contains('hidden')) { observer.disconnect(); loadItems(); }
	});
	if (authEl) observer.observe(authEl, { attributes: true, attributeFilter: ['class'] });
</script>
