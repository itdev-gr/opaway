---
import AdminLayout from '../../components/AdminLayout.astro';
---

<AdminLayout pageTitle="Vehicle Fleet" pageDescription="Add and manage vehicles available for transfers." activeSection="new-entry">

	<!-- Sub-navigation tabs -->
	<div class="flex items-center gap-3 mb-6">
		<a href="/admin/manage-transfers" class="px-5 py-2.5 rounded-xl bg-white border border-neutral-200 text-neutral-600 font-semibold text-sm hover:border-[#0C6B95]/40 hover:text-[#0C6B95] transition-colors">Transfers</a>
		<a href="/admin/manage-tours" class="px-5 py-2.5 rounded-xl bg-white border border-neutral-200 text-neutral-600 font-semibold text-sm hover:border-[#0C6B95]/40 hover:text-[#0C6B95] transition-colors">Tours</a>
		<a href="/admin/manage-experiences" class="px-5 py-2.5 rounded-xl bg-white border border-neutral-200 text-neutral-600 font-semibold text-sm hover:border-[#0C6B95]/40 hover:text-[#0C6B95] transition-colors">Experiences</a>
		<a href="/admin/manage-vehicles" class="px-5 py-2.5 rounded-xl bg-[#0C6B95] text-white font-semibold text-sm shadow-md shadow-[#0C6B95]/25">Vehicles</a>
	</div>

	<!-- Add New Vehicle Form -->
	<div class="bg-white rounded-2xl border border-neutral-200 shadow-sm p-6 mb-6">
		<h2 class="text-base font-semibold text-neutral-800 mb-5 flex items-center gap-2">
			<svg class="w-4 h-4 text-[#0C6B95]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
				<path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
			</svg>
			Add New Vehicle
		</h2>

		<form id="vehicle-form" class="space-y-4" novalidate>

			<!-- Image URL + Live Preview -->
			<div class="flex flex-col sm:flex-row gap-4 items-start">
				<div class="flex-1">
					<label class="block text-xs font-semibold text-neutral-600 mb-1.5 uppercase tracking-wider">Image URL *</label>
					<input
						id="f-image" type="url" required
						placeholder="https://example.com/vehicle.jpg"
						class="w-full px-4 py-2.5 bg-white border border-neutral-200 rounded-xl text-sm text-neutral-800 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95] shadow-sm"
					/>
					<p class="text-xs text-neutral-400 mt-1.5">Paste a URL or upload an image (JPG, PNG, WebP, AVIF)</p>
					<label class="mt-2 inline-flex items-center gap-2 px-4 py-2 bg-neutral-50 border border-neutral-200 rounded-xl text-sm text-neutral-600 hover:bg-neutral-100 cursor-pointer transition-colors">
						<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12" /></svg>
						Upload Image
						<input id="f-file" type="file" accept="image/*" class="hidden" />
					</label>
					<span id="f-upload-status" class="hidden text-xs text-[#0C6B95] ml-2"></span>
				</div>
				<div class="sm:w-48 h-32 rounded-xl overflow-hidden border border-neutral-200 bg-neutral-100 flex items-center justify-center shrink-0">
					<img id="img-preview" src="" alt="Preview" class="w-full h-full object-cover hidden" />
					<span id="img-placeholder" class="text-neutral-400 text-xs font-medium flex flex-col items-center gap-1.5">
						<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
							<path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
						</svg>
						Preview
					</span>
				</div>
			</div>

			<!-- Name + Slug -->
			<div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
				<div>
					<label class="block text-xs font-semibold text-neutral-600 mb-1.5 uppercase tracking-wider">Name *</label>
					<input
						id="f-name" type="text" required
						placeholder="e.g. Business Class"
						class="w-full px-4 py-2.5 bg-white border border-neutral-200 rounded-xl text-sm text-neutral-800 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95] shadow-sm"
					/>
				</div>
				<div>
					<label class="block text-xs font-semibold text-neutral-600 mb-1.5 uppercase tracking-wider">Slug *</label>
					<input
						id="f-slug" type="text" required
						placeholder="e.g. business-class"
						class="w-full px-4 py-2.5 bg-white border border-neutral-200 rounded-xl text-sm text-neutral-800 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95] shadow-sm"
					/>
				</div>
			</div>

			<!-- Models -->
			<div>
				<label class="block text-xs font-semibold text-neutral-600 mb-1.5 uppercase tracking-wider">Models *</label>
				<input
					id="f-models" type="text" required
					placeholder="e.g. Mercedes-Benz E-Class, or similar."
					class="w-full px-4 py-2.5 bg-white border border-neutral-200 rounded-xl text-sm text-neutral-800 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95] shadow-sm"
				/>
			</div>

			<!-- Max Passengers + Max Luggage + Badge + Sort Order -->
			<div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
				<div>
					<label class="block text-xs font-semibold text-neutral-600 mb-1.5 uppercase tracking-wider">Max Passengers *</label>
					<input
						id="f-maxPassengers" type="number" min="1" required
						placeholder="e.g. 3"
						class="w-full px-4 py-2.5 bg-white border border-neutral-200 rounded-xl text-sm text-neutral-800 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95] shadow-sm"
					/>
				</div>
				<div>
					<label class="block text-xs font-semibold text-neutral-600 mb-1.5 uppercase tracking-wider">Max Luggage *</label>
					<input
						id="f-maxLuggage" type="number" min="0" required
						placeholder="e.g. 3"
						class="w-full px-4 py-2.5 bg-white border border-neutral-200 rounded-xl text-sm text-neutral-800 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95] shadow-sm"
					/>
				</div>
				<div>
					<label class="block text-xs font-semibold text-neutral-600 mb-1.5 uppercase tracking-wider">Badge</label>
					<input
						id="f-badge" type="text"
						placeholder="e.g. BEST VALUE"
						class="w-full px-4 py-2.5 bg-white border border-neutral-200 rounded-xl text-sm text-neutral-800 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95] shadow-sm"
					/>
				</div>
				<div>
					<label class="block text-xs font-semibold text-neutral-600 mb-1.5 uppercase tracking-wider">Sort Order</label>
					<input
						id="f-sortOrder" type="number" min="0"
						placeholder="e.g. 0"
						class="w-full px-4 py-2.5 bg-white border border-neutral-200 rounded-xl text-sm text-neutral-800 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95] shadow-sm"
					/>
				</div>
			</div>

			<!-- Status + Submit -->
			<div class="flex items-center justify-between pt-1">
				<span id="form-status" class="text-sm"></span>
				<button
					type="submit"
					id="submit-btn"
					class="inline-flex items-center gap-2 bg-[#0C6B95] hover:bg-[#0a5c82] text-white text-sm font-semibold px-6 py-2.5 rounded-xl transition-colors shadow-sm disabled:opacity-50 disabled:cursor-not-allowed"
				>
					<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
						<path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
					</svg>
					Add Vehicle
				</button>
			</div>
		</form>
	</div>

	<!-- Vehicles Grid -->
	<div class="bg-white rounded-2xl border border-neutral-200 shadow-sm overflow-hidden">
		<div class="px-6 py-4 border-b border-neutral-100 flex items-center justify-between">
			<h2 class="text-base font-semibold text-neutral-800">Vehicle Fleet</h2>
			<span id="vehicles-count" class="text-xs text-neutral-400 font-medium"></span>
		</div>
		<div id="vehicles-grid" class="p-6 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
			<p class="text-neutral-400 text-sm col-span-full text-center py-10">Loading…</p>
		</div>
	</div>

	<!-- Delete confirmation modal -->
	<div id="delete-modal" class="fixed inset-0 bg-black/50 z-50 hidden items-center justify-center p-4">
		<div class="bg-white rounded-2xl shadow-2xl p-6 w-full max-w-sm">
			<div class="w-12 h-12 rounded-full bg-red-100 flex items-center justify-center mx-auto mb-4">
				<svg class="w-6 h-6 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
					<path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
				</svg>
			</div>
			<h3 class="text-base font-bold text-neutral-900 text-center mb-1">Delete Vehicle</h3>
			<p id="delete-modal-body" class="text-sm text-neutral-500 text-center mb-6">This vehicle will be permanently removed.</p>
			<div class="flex gap-3">
				<button id="delete-no"  class="flex-1 py-2.5 rounded-xl border border-neutral-200 text-neutral-700 font-semibold text-sm hover:bg-neutral-50 transition-colors">No</button>
				<button id="delete-yes" class="flex-1 py-2.5 rounded-xl bg-red-600 hover:bg-red-700 font-semibold text-sm text-white transition-colors">Yes</button>
			</div>
		</div>
	</div>

	<!-- Edit modal -->
	<div id="edit-modal" class="fixed inset-0 bg-black/50 z-50 hidden items-center justify-center p-4">
		<div class="bg-white rounded-2xl shadow-2xl p-6 w-full max-w-lg max-h-[90vh] overflow-y-auto">
			<div class="flex items-center justify-between mb-5">
				<h3 class="text-base font-bold text-neutral-900">Edit Vehicle</h3>
				<button id="edit-close" class="text-neutral-400 hover:text-neutral-600 transition-colors" type="button">
					<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
						<path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
					</svg>
				</button>
			</div>
			<div class="space-y-4">
				<!-- Edit Image URL + Preview -->
				<div class="flex flex-col sm:flex-row gap-4 items-start">
					<div class="flex-1">
						<label class="block text-xs font-semibold text-neutral-600 mb-1.5 uppercase tracking-wider">Image URL *</label>
						<input
							id="e-image" type="url"
							class="w-full px-4 py-2.5 bg-white border border-neutral-200 rounded-xl text-sm text-neutral-800 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95] shadow-sm"
						/>
						<label class="mt-2 inline-flex items-center gap-2 px-3 py-1.5 bg-neutral-50 border border-neutral-200 rounded-lg text-xs text-neutral-600 hover:bg-neutral-100 cursor-pointer transition-colors">
							<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12" /></svg>
							Upload
							<input id="e-file" type="file" accept="image/*" class="hidden" />
						</label>
						<span id="e-upload-status" class="hidden text-xs text-[#0C6B95] ml-2"></span>
					</div>
					<div class="sm:w-36 h-24 rounded-xl overflow-hidden border border-neutral-200 bg-neutral-100 flex items-center justify-center shrink-0">
						<img id="e-img-preview" src="" alt="Preview" class="w-full h-full object-cover hidden" />
						<span id="e-img-placeholder" class="text-neutral-400 text-xs flex flex-col items-center gap-1">
							<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
								<path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
							</svg>
							Preview
						</span>
					</div>
				</div>
				<!-- Edit Name + Slug -->
				<div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
					<div>
						<label class="block text-xs font-semibold text-neutral-600 mb-1.5 uppercase tracking-wider">Name *</label>
						<input
							id="e-name" type="text"
							class="w-full px-4 py-2.5 bg-white border border-neutral-200 rounded-xl text-sm text-neutral-800 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95] shadow-sm"
						/>
					</div>
					<div>
						<label class="block text-xs font-semibold text-neutral-600 mb-1.5 uppercase tracking-wider">Slug *</label>
						<input
							id="e-slug" type="text"
							class="w-full px-4 py-2.5 bg-white border border-neutral-200 rounded-xl text-sm text-neutral-800 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95] shadow-sm"
						/>
					</div>
				</div>
				<!-- Edit Models -->
				<div>
					<label class="block text-xs font-semibold text-neutral-600 mb-1.5 uppercase tracking-wider">Models *</label>
					<input
						id="e-models" type="text"
						class="w-full px-4 py-2.5 bg-white border border-neutral-200 rounded-xl text-sm text-neutral-800 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95] shadow-sm"
					/>
				</div>
				<!-- Edit Max Passengers + Max Luggage + Badge + Sort Order -->
				<div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
					<div>
						<label class="block text-xs font-semibold text-neutral-600 mb-1.5 uppercase tracking-wider">Max Passengers *</label>
						<input
							id="e-maxPassengers" type="number" min="1"
							class="w-full px-4 py-2.5 bg-white border border-neutral-200 rounded-xl text-sm text-neutral-800 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95] shadow-sm"
						/>
					</div>
					<div>
						<label class="block text-xs font-semibold text-neutral-600 mb-1.5 uppercase tracking-wider">Max Luggage *</label>
						<input
							id="e-maxLuggage" type="number" min="0"
							class="w-full px-4 py-2.5 bg-white border border-neutral-200 rounded-xl text-sm text-neutral-800 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95] shadow-sm"
						/>
					</div>
					<div>
						<label class="block text-xs font-semibold text-neutral-600 mb-1.5 uppercase tracking-wider">Badge</label>
						<input
							id="e-badge" type="text"
							class="w-full px-4 py-2.5 bg-white border border-neutral-200 rounded-xl text-sm text-neutral-800 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95] shadow-sm"
						/>
					</div>
					<div>
						<label class="block text-xs font-semibold text-neutral-600 mb-1.5 uppercase tracking-wider">Sort Order</label>
						<input
							id="e-sortOrder" type="number" min="0"
							class="w-full px-4 py-2.5 bg-white border border-neutral-200 rounded-xl text-sm text-neutral-800 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95] shadow-sm"
						/>
					</div>
				</div>
				<!-- Edit status + Save -->
				<div class="flex items-center justify-between pt-1">
					<span id="edit-status" class="text-sm"></span>
					<div class="flex gap-3">
						<button id="edit-cancel" type="button" class="px-5 py-2.5 rounded-xl border border-neutral-200 text-neutral-700 font-semibold text-sm hover:bg-neutral-50 transition-colors">Cancel</button>
						<button id="edit-save"   type="button" class="inline-flex items-center gap-2 bg-[#0C6B95] hover:bg-[#0a5c82] text-white text-sm font-semibold px-6 py-2.5 rounded-xl transition-colors shadow-sm disabled:opacity-50 disabled:cursor-not-allowed">Save Changes</button>
					</div>
				</div>
			</div>
		</div>
	</div>

</AdminLayout>

<script>
	import { supabase } from '../../lib/supabase';
	import { uploadImage } from '../../lib/upload';

	/* ── Types ── */
	interface VehicleItem { id: string; slug: string; name: string; models: string; image: string; maxPassengers: number; maxLuggage: number; badge: string; sortOrder: number; active: boolean; }

	/* ── State ── */
	let items: VehicleItem[] = [];
	let pendingDeleteId = '';
	let pendingEditId   = '';

	/* ── Escape HTML ── */
	const esc = (s: string) => String(s)
		.replace(/&/g, '&amp;').replace(/</g, '&lt;')
		.replace(/>/g, '&gt;').replace(/"/g, '&quot;');

	/* ── Image preview helper ── */
	function applyPreview(input: HTMLInputElement, preview: HTMLImageElement, placeholder: Element) {
		const url = input.value.trim();
		if (url) {
			preview.src = url;
			preview.classList.remove('hidden');
			placeholder.classList.add('hidden');
			preview.onerror = () => { preview.classList.add('hidden'); placeholder.classList.remove('hidden'); };
		} else {
			preview.classList.add('hidden');
			placeholder.classList.remove('hidden');
		}
	}

	/* ── File upload handler ── */
	async function handleFileUpload(fileInput: HTMLInputElement, urlInput: HTMLInputElement, preview: HTMLImageElement, placeholder: Element, statusEl: HTMLElement, folder: string) {
		const file = fileInput.files?.[0];
		if (!file) return;
		statusEl.textContent = 'Uploading…';
		statusEl.classList.remove('hidden');
		try {
			const url = await uploadImage(file, folder);
			urlInput.value = url;
			applyPreview(urlInput, preview, placeholder);
			statusEl.textContent = 'Uploaded';
			setTimeout(() => statusEl.classList.add('hidden'), 2000);
		} catch (err) {
			console.error('Upload failed:', err);
			statusEl.textContent = 'Upload failed';
			setTimeout(() => statusEl.classList.add('hidden'), 3000);
		}
		fileInput.value = '';
	}

	/* ── Render grid ── */
	function renderGrid() {
		const grid    = document.getElementById('vehicles-grid')!;
		const countEl = document.getElementById('vehicles-count');
		if (countEl) countEl.textContent = `${items.length} vehicle${items.length !== 1 ? 's' : ''}`;

		if (items.length === 0) {
			grid.innerHTML = `<p class="text-neutral-400 text-sm col-span-full text-center py-12">No vehicles added yet. Use the form above to add your first vehicle.</p>`;
			return;
		}

		grid.innerHTML = items.map(item => {
			const isActive = item.active !== false;
			return `
			<div class="group rounded-xl border border-neutral-200 overflow-hidden bg-neutral-50 shadow-sm hover:shadow-md transition-shadow duration-200">
				<!-- Image + status badge + optional badge label -->
				<div class="aspect-video overflow-hidden bg-neutral-200 relative">
					<img
						src="${esc(item.image)}"
						alt="${esc(item.name)}"
						class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
						onerror="this.closest('.aspect-video').style.background='#e5e7eb'"
					/>
					<span class="absolute top-2 left-2 text-xs font-semibold px-2 py-0.5 rounded-full ${isActive ? 'bg-emerald-100 text-emerald-700' : 'bg-neutral-200 text-neutral-500'}">
						${isActive ? 'Active' : 'Inactive'}
					</span>
					${item.badge ? `<span class="absolute top-2 right-2 text-[10px] font-bold px-2 py-0.5 rounded-full bg-amber-100 text-amber-700 uppercase tracking-wide">${esc(item.badge)}</span>` : ''}
				</div>
				<!-- Content -->
				<div class="p-4">
					<h3 class="font-semibold text-neutral-900 mb-1 truncate text-sm">${esc(item.name)}</h3>
					<p class="text-xs text-neutral-500 leading-relaxed mb-2 truncate">${esc(item.models)}</p>
					<div class="flex items-center gap-3 text-xs text-neutral-500 mb-3">
						<span class="inline-flex items-center gap-1">
							<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
								<path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
							</svg>
							${Number(item.maxPassengers)} pax
						</span>
						<span class="inline-flex items-center gap-1">
							<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
								<path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
							</svg>
							${Number(item.maxLuggage)} bags
						</span>
					</div>
					<!-- Actions -->
					<div class="flex items-center gap-2 mt-3 pt-3 border-t border-neutral-100">
						<!-- Toggle Active/Inactive -->
						<button
							class="toggle-btn flex-1 py-1.5 rounded-lg border text-xs font-semibold transition-colors ${isActive ? 'bg-emerald-50 text-emerald-700 border-emerald-200 hover:bg-emerald-100' : 'bg-neutral-100 text-neutral-500 border-neutral-200 hover:bg-neutral-200'}"
							data-id="${item.id}" data-active="${isActive}" type="button"
						>${isActive ? 'Active' : 'Inactive'}</button>
						<!-- Edit -->
						<button
							class="edit-btn p-1.5 rounded-lg border border-neutral-200 text-neutral-400 hover:text-[#0C6B95] hover:border-[#0C6B95]/30 hover:bg-sky-50 transition-colors"
							data-id="${item.id}" type="button" title="Edit"
						>
							<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
								<path stroke-linecap="round" stroke-linejoin="round" d="M15.232 5.232l3.536 3.536M9 13l6.586-6.586a2 2 0 112.828 2.828L11.828 15.828a2 2 0 01-1.414.586H9v-2a2 2 0 01.586-1.414z" />
							</svg>
						</button>
						<!-- Delete -->
						<button
							class="delete-btn p-1.5 rounded-lg border border-neutral-200 text-neutral-400 hover:text-red-500 hover:border-red-200 hover:bg-red-50 transition-colors"
							data-id="${item.id}" data-name="${esc(item.name)}" type="button" title="Delete"
						>
							<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
								<path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7M10 11v6m4-6v6M9 7V4h6v3M4 7h16"/>
							</svg>
						</button>
					</div>
				</div>
			</div>`;
		}).join('');

		/* Attach toggle handlers */
		document.querySelectorAll<HTMLButtonElement>('.toggle-btn').forEach(btn => {
			btn.addEventListener('click', async () => {
				const id       = btn.dataset.id!;
				const isActive = btn.dataset.active === 'true';
				btn.disabled = true;
				const { error: togErr } = await supabase.from('vehicles').update({ published: !isActive }).eq('id', id);
				if (togErr) {
					console.error('Toggle vehicle failed:', togErr);
					alert(`Toggle failed: [${togErr.code ?? 'unknown'}] ${togErr.message}`);
					btn.disabled = false;
					return;
				}
				const item = items.find(i => i.id === id);
				if (item) item.active = !isActive;
				renderGrid();
			});
		});

		/* Attach edit handlers */
		document.querySelectorAll<HTMLButtonElement>('.edit-btn').forEach(btn => {
			btn.addEventListener('click', () => openEditModal(btn.dataset.id!));
		});

		/* Attach delete handlers */
		document.querySelectorAll<HTMLButtonElement>('.delete-btn').forEach(btn => {
			btn.addEventListener('click', () => {
				pendingDeleteId = btn.dataset.id!;
				const modal = document.getElementById('delete-modal')!;
				const body  = document.getElementById('delete-modal-body')!;
				body.textContent = `"${btn.dataset.name}" will be permanently removed.`;
				modal.classList.remove('hidden');
				modal.classList.add('flex');
			});
		});
	}

	/* ── Load from Supabase ── */
	async function loadItems() {
		const grid = document.getElementById('vehicles-grid')!;
		const { data, error } = await supabase.from('vehicles').select('*').order('sort_order', { ascending: true });
		if (error) {
			console.error('Load vehicles failed:', error);
			grid.innerHTML = `<p class="text-neutral-400 text-sm col-span-full text-center py-10">Could not load vehicles.</p>`;
			return;
		}
		items = (data ?? []).map((d: any) => ({ id: d.id, slug: d.slug, name: d.name, models: d.models, image: d.image_url, maxPassengers: d.max_passengers, maxLuggage: d.max_luggage, badge: d.badge, sortOrder: d.sort_order, active: d.published }));
		renderGrid();
	}

	/* ── Delete modal ── */
	const closeDeleteModal = () => {
		const m = document.getElementById('delete-modal')!;
		m.classList.add('hidden'); m.classList.remove('flex');
	};

	/* ── Edit modal ── */
	function openEditModal(id: string) {
		const item = items.find(i => i.id === id);
		if (!item) return;
		pendingEditId = id;

		(document.getElementById('e-image')         as HTMLInputElement).value = item.image;
		(document.getElementById('e-name')          as HTMLInputElement).value = item.name;
		(document.getElementById('e-slug')          as HTMLInputElement).value = item.slug;
		(document.getElementById('e-models')        as HTMLInputElement).value = item.models;
		(document.getElementById('e-maxPassengers') as HTMLInputElement).value = String(item.maxPassengers);
		(document.getElementById('e-maxLuggage')    as HTMLInputElement).value = String(item.maxLuggage);
		(document.getElementById('e-badge')         as HTMLInputElement).value = item.badge || '';
		(document.getElementById('e-sortOrder')     as HTMLInputElement).value = String(item.sortOrder ?? 0);

		applyPreview(
			document.getElementById('e-image')       as HTMLInputElement,
			document.getElementById('e-img-preview') as HTMLImageElement,
			document.getElementById('e-img-placeholder')!,
		);

		document.getElementById('edit-status')!.textContent = '';

		const modal = document.getElementById('edit-modal')!;
		modal.classList.remove('hidden');
		modal.classList.add('flex');
	}

	const closeEditModal = () => {
		const m = document.getElementById('edit-modal')!;
		m.classList.add('hidden'); m.classList.remove('flex');
	};

	function pageInit() {
		/* ── Add-form image preview ── */
		const imgInput       = document.getElementById('f-image')       as HTMLInputElement;
		const imgPreview     = document.getElementById('img-preview')    as HTMLImageElement;
		const imgPlaceholder = document.getElementById('img-placeholder')!;
		let previewTimer: ReturnType<typeof setTimeout>;

		imgInput.addEventListener('input', () => {
			clearTimeout(previewTimer);
			previewTimer = setTimeout(() => applyPreview(imgInput, imgPreview, imgPlaceholder), 400);
		});

		/* ── Edit-modal image preview ── */
		const eImgInput       = document.getElementById('e-image')       as HTMLInputElement;
		const eImgPreview     = document.getElementById('e-img-preview') as HTMLImageElement;
		const eImgPlaceholder = document.getElementById('e-img-placeholder')!;
		let ePreviewTimer: ReturnType<typeof setTimeout>;

		eImgInput.addEventListener('input', () => {
			clearTimeout(ePreviewTimer);
			ePreviewTimer = setTimeout(() => applyPreview(eImgInput, eImgPreview, eImgPlaceholder), 400);
		});

		/* ── File upload listeners ── */
		document.getElementById('f-file')?.addEventListener('change', () => {
			handleFileUpload(
				document.getElementById('f-file') as HTMLInputElement,
				document.getElementById('f-image') as HTMLInputElement,
				document.getElementById('img-preview') as HTMLImageElement,
				document.getElementById('img-placeholder')!,
				document.getElementById('f-upload-status')!, 'vehicles'
			);
		});

		document.getElementById('e-file')?.addEventListener('change', () => {
			handleFileUpload(
				document.getElementById('e-file') as HTMLInputElement,
				document.getElementById('e-image') as HTMLInputElement,
				document.getElementById('e-img-preview') as HTMLImageElement,
				document.getElementById('e-img-placeholder')!,
				document.getElementById('e-upload-status')!, 'vehicles'
			);
		});

		/* ── Form submit ── */
		const form      = document.getElementById('vehicle-form') as HTMLFormElement;
		const statusEl  = document.getElementById('form-status')!;
		const submitBtn = document.getElementById('submit-btn')    as HTMLButtonElement;

		const setStatus = (msg: string, cls: string) => { statusEl.textContent = msg; statusEl.className = `text-sm ${cls}`; };

		form.addEventListener('submit', async (e) => {
			e.preventDefault();
			const image         = (document.getElementById('f-image')         as HTMLInputElement).value.trim();
			const name          = (document.getElementById('f-name')          as HTMLInputElement).value.trim();
			const slug          = (document.getElementById('f-slug')          as HTMLInputElement).value.trim();
			const models        = (document.getElementById('f-models')        as HTMLInputElement).value.trim();
			const maxPassengers = parseInt((document.getElementById('f-maxPassengers') as HTMLInputElement).value);
			const maxLuggage    = parseInt((document.getElementById('f-maxLuggage')    as HTMLInputElement).value);
			const badge         = (document.getElementById('f-badge')         as HTMLInputElement).value.trim();
			const sortOrder     = parseInt((document.getElementById('f-sortOrder')     as HTMLInputElement).value) || 0;

			if (!image || !name || !slug || !models || isNaN(maxPassengers) || isNaN(maxLuggage)) {
				setStatus('Please fill in all required fields.', 'text-red-500'); return;
			}

			submitBtn.disabled = true;
			submitBtn.textContent = 'Adding…';
			setStatus('', '');

			const { data: inserted, error: insErr } = await supabase.from('vehicles').insert({
				slug, name, models, image_url: image, max_passengers: maxPassengers, max_luggage: maxLuggage, badge, sort_order: sortOrder,
				published: true, owner_id: null, is_platform: true,
			}).select().single();
			if (insErr) {
				console.error('Add vehicle failed:', insErr);
				setStatus(`Error: [${insErr.code ?? 'unknown'}] ${insErr.message}`, 'text-red-500');
			} else {
				items.push({ id: inserted.id, slug, name, models, image, maxPassengers, maxLuggage, badge, sortOrder, active: true });
				items.sort((a, b) => (a.sortOrder ?? 0) - (b.sortOrder ?? 0));
				renderGrid();
				form.reset();
				(document.getElementById('img-preview') as HTMLImageElement).classList.add('hidden');
				document.getElementById('img-placeholder')!.classList.remove('hidden');
				setStatus('Vehicle added successfully!', 'text-emerald-600 font-medium');
				setTimeout(() => setStatus('', ''), 4000);
			}
			submitBtn.disabled = false;
			submitBtn.innerHTML = `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg> Add Vehicle`;
		});

		/* ── Delete modal listeners ── */
		document.getElementById('delete-no')?.addEventListener('click', closeDeleteModal);
		document.getElementById('delete-modal')?.addEventListener('click', (e) => { if (e.target === e.currentTarget) closeDeleteModal(); });

		document.getElementById('delete-yes')?.addEventListener('click', async () => {
			const yesBtn = document.getElementById('delete-yes') as HTMLButtonElement;
			yesBtn.textContent = 'Deleting…'; yesBtn.disabled = true;
			{
				const { error: delErr } = await supabase.from('vehicles').delete().eq('id', pendingDeleteId);
				if (delErr) {
					console.error('Vehicle delete failed:', delErr);
					alert(`Delete failed: [${delErr.code ?? 'unknown'}] ${delErr.message}`);
				} else {
					items = items.filter(i => i.id !== pendingDeleteId);
					renderGrid();
				}
			}
			yesBtn.textContent = 'Yes'; yesBtn.disabled = false;
			closeDeleteModal();
		});

		/* ── Edit modal listeners ── */
		document.getElementById('edit-close')?.addEventListener('click', closeEditModal);
		document.getElementById('edit-cancel')?.addEventListener('click', closeEditModal);
		document.getElementById('edit-modal')?.addEventListener('click', (e) => { if (e.target === e.currentTarget) closeEditModal(); });

		document.getElementById('edit-save')?.addEventListener('click', async () => {
			const image         = (document.getElementById('e-image')         as HTMLInputElement).value.trim();
			const name          = (document.getElementById('e-name')          as HTMLInputElement).value.trim();
			const slug          = (document.getElementById('e-slug')          as HTMLInputElement).value.trim();
			const models        = (document.getElementById('e-models')        as HTMLInputElement).value.trim();
			const maxPassengers = parseInt((document.getElementById('e-maxPassengers') as HTMLInputElement).value);
			const maxLuggage    = parseInt((document.getElementById('e-maxLuggage')    as HTMLInputElement).value);
			const badge         = (document.getElementById('e-badge')         as HTMLInputElement).value.trim();
			const sortOrder     = parseInt((document.getElementById('e-sortOrder')     as HTMLInputElement).value) || 0;
			const editStatus    = document.getElementById('edit-status')!;
			const saveBtn       = document.getElementById('edit-save') as HTMLButtonElement;

			if (!image || !name || !slug || !models || isNaN(maxPassengers) || isNaN(maxLuggage)) {
				editStatus.textContent = 'Please fill in all required fields.';
				editStatus.className = 'text-sm text-red-500';
				return;
			}

			saveBtn.disabled = true;
			saveBtn.textContent = 'Saving…';
			editStatus.textContent = '';

			const { error: updErr } = await supabase.from('vehicles').update({ image_url: image, name, slug, models, max_passengers: maxPassengers, max_luggage: maxLuggage, badge, sort_order: sortOrder }).eq('id', pendingEditId);
			if (updErr) {
				console.error('Update vehicle failed:', updErr);
				editStatus.textContent = `Error: [${updErr.code ?? 'unknown'}] ${updErr.message}`;
				editStatus.className = 'text-sm text-red-500';
			} else {
				const item = items.find(i => i.id === pendingEditId);
				if (item) Object.assign(item, { image, name, slug, models, maxPassengers, maxLuggage, badge, sortOrder });
				items.sort((a, b) => (a.sortOrder ?? 0) - (b.sortOrder ?? 0));
				renderGrid();
				closeEditModal();
			}
			saveBtn.disabled = false;
			saveBtn.textContent = 'Save Changes';
		});

		/* ── Auth guard observer ── */
		const authEl = document.getElementById('admin-auth-check');
		if (authEl) {
			const observer = new MutationObserver(() => {
				if (authEl.classList.contains('hidden')) { observer.disconnect(); loadItems(); }
			});
			observer.observe(authEl, { attributes: true, attributeFilter: ['class'] });
		}
	}

	document.addEventListener('astro:page-load', pageInit);
</script>
