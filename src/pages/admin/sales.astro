---
import AdminLayout from '../../components/AdminLayout.astro';
---

<AdminLayout pageTitle="Sales Report" pageDescription="Revenue overview across all booking types." activeSection="sales">

	<!-- Period selector -->
	<div class="flex items-center gap-3 mb-6">
		<button data-period="week" class="period-btn px-4 py-2 text-sm font-semibold rounded-xl border border-neutral-200 text-neutral-600 hover:border-[#0C6B95]/40 hover:text-[#0C6B95] transition-colors">This Week</button>
		<button data-period="month" class="period-btn px-4 py-2 text-sm font-semibold rounded-xl bg-[#0C6B95] text-white shadow-sm">This Month</button>
		<button data-period="quarter" class="period-btn px-4 py-2 text-sm font-semibold rounded-xl border border-neutral-200 text-neutral-600 hover:border-[#0C6B95]/40 hover:text-[#0C6B95] transition-colors">This Quarter</button>
		<button data-period="year" class="period-btn px-4 py-2 text-sm font-semibold rounded-xl border border-neutral-200 text-neutral-600 hover:border-[#0C6B95]/40 hover:text-[#0C6B95] transition-colors">This Year</button>
		<button data-period="all" class="period-btn px-4 py-2 text-sm font-semibold rounded-xl border border-neutral-200 text-neutral-600 hover:border-[#0C6B95]/40 hover:text-[#0C6B95] transition-colors">All Time</button>
	</div>

	<!-- Summary cards -->
	<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
		<div class="bg-white rounded-2xl border border-neutral-200 shadow-sm p-5">
			<p class="text-xs font-semibold text-neutral-500 uppercase tracking-wider mb-1">Total Revenue</p>
			<p id="stat-total" class="text-2xl font-bold text-neutral-900">—</p>
			<p id="stat-total-count" class="text-xs text-neutral-400 mt-1">— bookings</p>
		</div>
		<div class="bg-white rounded-2xl border border-neutral-200 shadow-sm p-5">
			<p class="text-xs font-semibold text-neutral-500 uppercase tracking-wider mb-1">Transfers</p>
			<p id="stat-transfers" class="text-2xl font-bold text-[#0C6B95]">—</p>
			<p id="stat-transfers-count" class="text-xs text-neutral-400 mt-1">— bookings</p>
		</div>
		<div class="bg-white rounded-2xl border border-neutral-200 shadow-sm p-5">
			<p class="text-xs font-semibold text-neutral-500 uppercase tracking-wider mb-1">Tours</p>
			<p id="stat-tours" class="text-2xl font-bold text-emerald-600">—</p>
			<p id="stat-tours-count" class="text-xs text-neutral-400 mt-1">— bookings</p>
		</div>
		<div class="bg-white rounded-2xl border border-neutral-200 shadow-sm p-5">
			<p class="text-xs font-semibold text-neutral-500 uppercase tracking-wider mb-1">Experiences</p>
			<p id="stat-experiences" class="text-2xl font-bold text-violet-600">—</p>
			<p id="stat-experiences-count" class="text-xs text-neutral-400 mt-1">— bookings</p>
		</div>
	</div>

	<!-- Payment method breakdown -->
	<div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
		<div class="bg-white rounded-2xl border border-neutral-200 shadow-sm p-5">
			<h3 class="text-sm font-bold text-neutral-800 mb-4">By Payment Method</h3>
			<div id="by-method" class="space-y-3">
				<p class="text-sm text-neutral-400">Loading...</p>
			</div>
		</div>
		<div class="bg-white rounded-2xl border border-neutral-200 shadow-sm p-5">
			<h3 class="text-sm font-bold text-neutral-800 mb-4">By Vehicle Type</h3>
			<div id="by-vehicle" class="space-y-3">
				<p class="text-sm text-neutral-400">Loading...</p>
			</div>
		</div>
	</div>

	<!-- Revenue table -->
	<div class="bg-white rounded-2xl border border-neutral-200 shadow-sm overflow-hidden">
		<div class="px-6 py-4 border-b border-neutral-100">
			<h3 class="text-base font-semibold text-neutral-800">All Bookings</h3>
		</div>
		<div class="overflow-x-auto">
			<table class="w-full text-sm">
				<thead>
					<tr class="bg-neutral-50 text-left">
						<th class="px-4 py-3 text-xs font-semibold text-neutral-500 uppercase tracking-wider">Date</th>
						<th class="px-4 py-3 text-xs font-semibold text-neutral-500 uppercase tracking-wider">Type</th>
						<th class="px-4 py-3 text-xs font-semibold text-neutral-500 uppercase tracking-wider">Customer</th>
						<th class="px-4 py-3 text-xs font-semibold text-neutral-500 uppercase tracking-wider">Vehicle</th>
						<th class="px-4 py-3 text-xs font-semibold text-neutral-500 uppercase tracking-wider">Payment</th>
						<th class="px-4 py-3 text-xs font-semibold text-neutral-500 uppercase tracking-wider text-right">Amount</th>
					</tr>
				</thead>
				<tbody id="revenue-tbody">
					<tr><td colspan="6" class="px-6 py-10 text-center text-neutral-400">Loading…</td></tr>
				</tbody>
			</table>
		</div>
	</div>

</AdminLayout>

<script>
	import { supabase } from '../../lib/supabase';

	interface Booking {
		id: string;
		type: 'transfer' | 'tour' | 'experience';
		date: string;
		name: string;
		email: string;
		vehicleName: string;
		totalPrice: number;
		paymentMethod: string;
		paymentStatus: string;
		createdAt: Date | null;
	}

	let allBookings: Booking[] = [];
	let currentPeriod = 'month';

	const setText = (id: string, text: string) => { const el = document.getElementById(id); if (el) el.textContent = text; };
	const esc = (s: string) => String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');

	async function loadAllBookings() {
		const collections = [
			{ name: 'transfers', type: 'transfer' as const },
			{ name: 'tours', type: 'tour' as const },
			{ name: 'experiences', type: 'experience' as const },
		];

		allBookings = [];

		for (const col of collections) {
			const { data, error } = await supabase.from(col.name).select('*').order('created_at', { ascending: false });
			if (error) {
				console.error(`Sales report load failed for ${col.name}:`, error);
				continue;
			}
			(data ?? []).forEach((d: any) => {
				const createdAt = d.created_at ? new Date(d.created_at) : null;
				allBookings.push({
					id: d.id,
					type: col.type,
					date: d.date || (createdAt ? createdAt.toLocaleDateString() : '—'),
					name: d.first_name ? `${d.first_name} ${d.last_name || ''}`.trim() : (d.name || '—'),
					email: d.email || '—',
					vehicleName: d.vehicle_name || d.vehicle || '—',
					totalPrice: Number(d.total_price) || 0,
					paymentMethod: d.payment_method || '—',
					paymentStatus: d.payment_status || (d.status === 'payed' ? 'paid' : 'pending'),
					createdAt,
				});
			});
		}

		allBookings.sort((a, b) => (b.createdAt?.getTime() ?? 0) - (a.createdAt?.getTime() ?? 0));
		renderReport();
	}

	function getFilteredBookings(): Booking[] {
		if (currentPeriod === 'all') return allBookings;

		const now = new Date();
		let startDate: Date;

		switch (currentPeriod) {
			case 'week':
				startDate = new Date(now); startDate.setDate(now.getDate() - 7); break;
			case 'month':
				startDate = new Date(now.getFullYear(), now.getMonth(), 1); break;
			case 'quarter':
				startDate = new Date(now.getFullYear(), Math.floor(now.getMonth() / 3) * 3, 1); break;
			case 'year':
				startDate = new Date(now.getFullYear(), 0, 1); break;
			default:
				return allBookings;
		}

		return allBookings.filter(b => b.createdAt && b.createdAt >= startDate);
	}

	function renderReport() {
		const bookings = getFilteredBookings();

		// Stats
		const transferBookings = bookings.filter(b => b.type === 'transfer');
		const tourBookings = bookings.filter(b => b.type === 'tour');
		const expBookings = bookings.filter(b => b.type === 'experience');

		const totalRev = bookings.reduce((s, b) => s + b.totalPrice, 0);
		const transferRev = transferBookings.reduce((s, b) => s + b.totalPrice, 0);
		const tourRev = tourBookings.reduce((s, b) => s + b.totalPrice, 0);
		const expRev = expBookings.reduce((s, b) => s + b.totalPrice, 0);

		setText('stat-total', `\u20AC${totalRev.toFixed(2)}`);
		setText('stat-total-count', `${bookings.length} bookings`);
		setText('stat-transfers', `\u20AC${transferRev.toFixed(2)}`);
		setText('stat-transfers-count', `${transferBookings.length} bookings`);
		setText('stat-tours', `\u20AC${tourRev.toFixed(2)}`);
		setText('stat-tours-count', `${tourBookings.length} bookings`);
		setText('stat-experiences', `\u20AC${expRev.toFixed(2)}`);
		setText('stat-experiences-count', `${expBookings.length} bookings`);

		// By payment method
		const byMethod: Record<string, { count: number; total: number }> = {};
		bookings.forEach(b => {
			const m = b.paymentMethod || 'unknown';
			if (!byMethod[m]) byMethod[m] = { count: 0, total: 0 };
			byMethod[m].count++;
			byMethod[m].total += b.totalPrice;
		});

		const methodEl = document.getElementById('by-method')!;
		const methodEntries = Object.entries(byMethod);
		methodEl.innerHTML = methodEntries.length === 0
			? '<p class="text-sm text-neutral-400">No data</p>'
			: methodEntries.map(([method, data]) => `
				<div class="flex items-center justify-between">
					<div class="flex items-center gap-2">
						<span class="text-sm font-medium text-neutral-700 capitalize">${esc(method.replace('-', ' '))}</span>
						<span class="text-xs text-neutral-400">${data.count} bookings</span>
					</div>
					<span class="text-sm font-bold text-neutral-900">\u20AC${data.total.toFixed(2)}</span>
				</div>
			`).join('');

		// By vehicle
		const byVehicle: Record<string, { count: number; total: number }> = {};
		bookings.forEach(b => {
			const v = b.vehicleName || 'Unknown';
			if (!byVehicle[v]) byVehicle[v] = { count: 0, total: 0 };
			byVehicle[v].count++;
			byVehicle[v].total += b.totalPrice;
		});

		const vehicleEl = document.getElementById('by-vehicle')!;
		const vehicleEntries = Object.entries(byVehicle);
		vehicleEl.innerHTML = vehicleEntries.length === 0
			? '<p class="text-sm text-neutral-400">No data</p>'
			: vehicleEntries.map(([vehicle, data]) => `
				<div class="flex items-center justify-between">
					<div class="flex items-center gap-2">
						<span class="text-sm font-medium text-neutral-700">${esc(vehicle)}</span>
						<span class="text-xs text-neutral-400">${data.count}</span>
					</div>
					<span class="text-sm font-bold text-neutral-900">\u20AC${data.total.toFixed(2)}</span>
				</div>
			`).join('');

		// Revenue table
		const typeBadge: Record<string, string> = {
			transfer: 'bg-sky-100 text-sky-700',
			tour: 'bg-emerald-100 text-emerald-700',
			experience: 'bg-violet-100 text-violet-700',
		};

		const tbody = document.getElementById('revenue-tbody')!;
		if (bookings.length === 0) {
			tbody.innerHTML = `<tr><td colspan="6" class="px-6 py-10 text-center text-neutral-400">No bookings in this period.</td></tr>`;
			return;
		}

		tbody.innerHTML = bookings.map(b => `
			<tr class="border-t border-neutral-100 hover:bg-neutral-50 transition-colors">
				<td class="px-4 py-3 text-neutral-600 whitespace-nowrap">${esc(b.date)}</td>
				<td class="px-4 py-3"><span class="text-xs font-medium px-2 py-0.5 rounded-full ${typeBadge[b.type] || 'bg-neutral-100 text-neutral-600'} capitalize">${b.type}</span></td>
				<td class="px-4 py-3 font-medium text-neutral-900 whitespace-nowrap">${esc(b.name)}</td>
				<td class="px-4 py-3 text-neutral-600 whitespace-nowrap">${esc(b.vehicleName)}</td>
				<td class="px-4 py-3">
					<span class="text-xs font-medium px-2 py-0.5 rounded-full ${b.paymentStatus === 'paid' ? 'bg-emerald-50 text-emerald-700' : 'bg-amber-50 text-amber-700'} capitalize">${esc(b.paymentMethod.replace('-', ' '))} · ${b.paymentStatus}</span>
				</td>
				<td class="px-4 py-3 text-right font-bold text-neutral-900">\u20AC${b.totalPrice.toFixed(2)}</td>
			</tr>
		`).join('');
	}

	// Period buttons
	document.querySelectorAll<HTMLButtonElement>('.period-btn').forEach(btn => {
		btn.addEventListener('click', () => {
			currentPeriod = btn.dataset.period || 'month';
			document.querySelectorAll('.period-btn').forEach(b => {
				const isActive = b.dataset.period === currentPeriod;
				b.className = `period-btn px-4 py-2 text-sm font-semibold rounded-xl transition-colors ${
					isActive ? 'bg-[#0C6B95] text-white shadow-sm' : 'border border-neutral-200 text-neutral-600 hover:border-[#0C6B95]/40 hover:text-[#0C6B95]'
				}`;
			});
			renderReport();
		});
	});

	// Auth guard
	const authEl = document.getElementById('admin-auth-check');
	const observer = new MutationObserver(() => {
		if (authEl?.classList.contains('hidden')) { observer.disconnect(); loadAllBookings(); }
	});
	if (authEl) observer.observe(authEl, { attributes: true, attributeFilter: ['class'] });
</script>
</AdminLayout>
