---
import AdminLayout from '../../components/AdminLayout.astro';
---

<AdminLayout pageTitle="Dashboard" pageDescription="Calendar overview of all bookings." activeSection="dashboard" docTitle="Dashboard — Opaway">

	<!-- Month Navigation -->
	<div class="flex items-center justify-between mb-6">
		<button id="prev-month" class="inline-flex items-center gap-1.5 px-3 py-2 rounded-lg border border-neutral-200 bg-white text-sm font-medium text-neutral-700 hover:bg-neutral-50 hover:border-neutral-300 transition-all">
			<svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
			Prev
		</button>
		<h2 id="month-label" class="text-lg font-semibold text-neutral-800"></h2>
		<button id="next-month" class="inline-flex items-center gap-1.5 px-3 py-2 rounded-lg border border-neutral-200 bg-white text-sm font-medium text-neutral-700 hover:bg-neutral-50 hover:border-neutral-300 transition-all">
			Next
			<svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
		</button>
	</div>

	<!-- Legend -->
	<div class="flex items-center gap-5 mb-4 text-xs text-neutral-500">
		<span class="flex items-center gap-1.5"><span class="w-2 h-2 rounded-full bg-[#0C6B95]"></span> Transfer</span>
		<span class="flex items-center gap-1.5"><span class="w-2 h-2 rounded-full bg-emerald-500"></span> Tour</span>
		<span class="flex items-center gap-1.5"><span class="w-2 h-2 rounded-full bg-violet-500"></span> Experience</span>
		<span class="flex items-center gap-1.5"><span class="w-2 h-2 rounded-full bg-amber-500"></span> Request</span>
	</div>

	<!-- Calendar -->
	<div class="bg-white rounded-2xl border border-neutral-200 shadow-sm overflow-hidden mb-8">
		<!-- Day headers -->
		<div class="grid grid-cols-7 bg-neutral-50 border-b border-neutral-100">
			<div class="px-2 py-2.5 text-center text-xs font-semibold text-neutral-500 uppercase tracking-wider">Mon</div>
			<div class="px-2 py-2.5 text-center text-xs font-semibold text-neutral-500 uppercase tracking-wider">Tue</div>
			<div class="px-2 py-2.5 text-center text-xs font-semibold text-neutral-500 uppercase tracking-wider">Wed</div>
			<div class="px-2 py-2.5 text-center text-xs font-semibold text-neutral-500 uppercase tracking-wider">Thu</div>
			<div class="px-2 py-2.5 text-center text-xs font-semibold text-neutral-500 uppercase tracking-wider">Fri</div>
			<div class="px-2 py-2.5 text-center text-xs font-semibold text-neutral-500 uppercase tracking-wider">Sat</div>
			<div class="px-2 py-2.5 text-center text-xs font-semibold text-neutral-500 uppercase tracking-wider">Sun</div>
		</div>
		<!-- Calendar grid -->
		<div id="calendar-grid" class="grid grid-cols-7">
			<div class="p-2 min-h-[80px] flex items-center justify-center text-neutral-400 text-sm col-span-7">Loading…</div>
		</div>
	</div>

	<!-- Selected day bookings -->
	<div id="day-bookings" class="hidden">
		<div class="flex items-center justify-between mb-4">
			<h3 id="day-bookings-title" class="text-base font-semibold text-neutral-800"></h3>
			<button id="close-day-bookings" class="text-neutral-400 hover:text-neutral-600 transition-colors text-sm">✕ Close</button>
		</div>
		<div id="day-bookings-list" class="space-y-3"></div>
	</div>

</AdminLayout>

<script>
	import { supabase } from '../../lib/supabase';

	interface Booking {
		id: string;
		type: 'transfer' | 'tour' | 'experience' | 'request';
		firstName: string;
		lastName: string;
		from: string;
		to: string;
		date: string;
		time: string;
		vehicleName: string;
		rideStatus: string;
		paymentStatus: string;
		paymentMethod: string;
	}

	let allBookings: Booking[] = [];
	let currentYear = new Date().getFullYear();
	let currentMonth = new Date().getMonth();
	let selectedDay: string | null = null;

	// Helpers
	function parseBooking(row: any, type: 'transfer' | 'tour' | 'experience' | 'request'): Booking {
		const d = row;
		let dateStr = d.date || '';
		if (!dateStr && d.created_at) {
			const cd = new Date(d.created_at);
			if (!isNaN(cd.getTime())) dateStr = cd.toISOString().slice(0, 10);
		}
		return {
			id: d.id,
			type,
			firstName: d.first_name || d.name || '',
			lastName: d.last_name || '',
			from: d.from || d.pickup || '',
			to: d.to || d.dropoff || d.destination || '',
			date: dateStr,
			time: d.time || '',
			vehicleName: d.vehicle_name || '',
			rideStatus: d.ride_status || d.status || 'pending',
			paymentStatus: d.payment_status || 'pending',
			paymentMethod: d.payment_method || '',
		};
	}

	function getBookingsForDate(dateStr: string): Booking[] {
		return allBookings.filter(b => b.date === dateStr);
	}

	function getBookingTypesForDate(dateStr: string): Set<string> {
		const types = new Set<string>();
		allBookings.forEach(b => {
			if (b.date === dateStr) types.add(b.type);
		});
		return types;
	}

	function formatDateStr(year: number, month: number, day: number): string {
		return `${year}-${String(month + 1).padStart(2, '0')}-${String(day).padStart(2, '0')}`;
	}

	function renderCalendar() {
		const grid = document.getElementById('calendar-grid');
		const label = document.getElementById('month-label');
		if (!grid || !label) return;

		const monthNames = ['January', 'February', 'March', 'April', 'May', 'June', 'July', 'August', 'September', 'October', 'November', 'December'];
		label.textContent = `${monthNames[currentMonth]} ${currentYear}`;

		const firstDay = new Date(currentYear, currentMonth, 1);
		const lastDay = new Date(currentYear, currentMonth + 1, 0);
		const totalDays = lastDay.getDate();

		// Monday = 0, Sunday = 6
		let startDow = firstDay.getDay() - 1;
		if (startDow < 0) startDow = 6;

		const today = new Date();
		const todayStr = formatDateStr(today.getFullYear(), today.getMonth(), today.getDate());

		let html = '';

		// Empty cells before first day
		for (let i = 0; i < startDow; i++) {
			html += `<div class="p-2 min-h-[80px] border border-neutral-100 rounded-lg bg-neutral-50/50"></div>`;
		}

		for (let day = 1; day <= totalDays; day++) {
			const dateStr = formatDateStr(currentYear, currentMonth, day);
			const bookings = getBookingsForDate(dateStr);
			const types = getBookingTypesForDate(dateStr);
			const isToday = dateStr === todayStr;
			const isSelected = dateStr === selectedDay;

			let cellClasses = 'p-2 min-h-[80px] border border-neutral-100 rounded-lg cursor-pointer hover:bg-neutral-50 transition-all';
			if (isToday) cellClasses = 'p-2 min-h-[80px] border border-sky-200 rounded-lg bg-sky-50 cursor-pointer hover:bg-sky-100 transition-all';
			if (isSelected) cellClasses += ' ring-2 ring-[#0C6B95]';

			html += `<div class="${cellClasses}" data-date="${dateStr}">`;
			html += `<div class="flex items-center justify-between mb-1">`;
			html += `<span class="text-sm font-medium ${isToday ? 'text-[#0C6B95]' : 'text-neutral-700'}">${day}</span>`;
			if (bookings.length > 0) {
				html += `<span class="inline-flex items-center justify-center w-5 h-5 rounded-full bg-neutral-200 text-[10px] font-bold text-neutral-700">${bookings.length}</span>`;
			}
			html += `</div>`;

			if (types.size > 0) {
				html += `<div class="flex items-center gap-1 mt-1 flex-wrap">`;
				if (types.has('transfer')) html += `<span class="w-2 h-2 rounded-full bg-[#0C6B95]"></span>`;
				if (types.has('tour')) html += `<span class="w-2 h-2 rounded-full bg-emerald-500"></span>`;
				if (types.has('experience')) html += `<span class="w-2 h-2 rounded-full bg-violet-500"></span>`;
				if (types.has('request')) html += `<span class="w-2 h-2 rounded-full bg-amber-500"></span>`;
				html += `</div>`;
			}

			html += `</div>`;
		}

		// Empty cells after last day
		const totalCells = startDow + totalDays;
		const remaining = totalCells % 7 === 0 ? 0 : 7 - (totalCells % 7);
		for (let i = 0; i < remaining; i++) {
			html += `<div class="p-2 min-h-[80px] border border-neutral-100 rounded-lg bg-neutral-50/50"></div>`;
		}

		grid.innerHTML = html;

		// Attach click handlers to day cells
		grid.querySelectorAll('[data-date]').forEach(cell => {
			cell.addEventListener('click', () => {
				const date = cell.getAttribute('data-date');
				if (date) {
					selectedDay = date;
					renderCalendar();
					renderDayBookings(date);
				}
			});
		});
	}

	function renderDayBookings(dateStr: string) {
		const container = document.getElementById('day-bookings');
		const title = document.getElementById('day-bookings-title');
		const list = document.getElementById('day-bookings-list');
		if (!container || !title || !list) return;

		const bookings = getBookingsForDate(dateStr);

		// Format the date for display
		const d = new Date(dateStr + 'T00:00:00');
		const options: Intl.DateTimeFormatOptions = { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' };
		title.textContent = `Bookings for ${d.toLocaleDateString('en-US', options)}`;

		if (bookings.length === 0) {
			list.innerHTML = `<p class="text-sm text-neutral-400 py-6 text-center">No bookings on this day.</p>`;
			container.classList.remove('hidden');
			return;
		}

		const typeBadge = (type: string) => {
			const map: Record<string, string> = {
				transfer: 'bg-sky-50 text-[#0C6B95] border-sky-200',
				tour: 'bg-emerald-50 text-emerald-700 border-emerald-200',
				experience: 'bg-violet-50 text-violet-700 border-violet-200',
				request: 'bg-amber-50 text-amber-700 border-amber-200',
			};
			const cls = map[type] || 'bg-neutral-50 text-neutral-600 border-neutral-200';
			return `<span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium border ${cls} capitalize">${type}</span>`;
		};

		const statusBadge = (status: string, prefix: string) => {
			const map: Record<string, string> = {
				pending: 'bg-amber-50 text-amber-700 border-amber-200',
				confirmed: 'bg-emerald-50 text-emerald-700 border-emerald-200',
				completed: 'bg-sky-50 text-sky-700 border-sky-200',
				cancelled: 'bg-red-50 text-red-600 border-red-200',
				paid: 'bg-emerald-50 text-emerald-700 border-emerald-200',
				unpaid: 'bg-red-50 text-red-600 border-red-200',
			};
			const cls = map[status.toLowerCase()] || 'bg-neutral-50 text-neutral-600 border-neutral-200';
			return `<span class="inline-flex items-center px-2 py-0.5 rounded-full text-[11px] font-medium border ${cls} capitalize">${prefix}: ${status}</span>`;
		};

		list.innerHTML = bookings.map(b => `
			<div class="bg-white rounded-xl border border-neutral-200 shadow-sm p-4 flex flex-col sm:flex-row sm:items-center gap-3">
				<div class="flex items-center gap-3 flex-1 min-w-0">
					${typeBadge(b.type)}
					<span class="font-medium text-sm text-neutral-900 truncate">${b.firstName} ${b.lastName}</span>
				</div>
				<div class="flex items-center gap-2 text-sm text-neutral-600 flex-1 min-w-0">
					<span class="truncate">${b.from || '—'}</span>
					<svg class="w-4 h-4 text-neutral-400 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
					<span class="truncate">${b.to || '—'}</span>
				</div>
				<div class="text-sm text-neutral-500 whitespace-nowrap">
					${b.time || '—'}
				</div>
				<div class="flex items-center gap-2 flex-shrink-0">
					${statusBadge(b.rideStatus, 'Ride')}
					${statusBadge(b.paymentStatus, 'Pay')}
				</div>
			</div>
		`).join('');

		container.classList.remove('hidden');
	}

	async function loadAllBookings() {
		{
			const [transfersRes, toursRes, experiencesRes, requestsRes] = await Promise.all([
				supabase.from('transfers').select('*').order('created_at', { ascending: false }),
				supabase.from('tours').select('*').order('created_at', { ascending: false }),
				supabase.from('experiences').select('*').order('created_at', { ascending: false }),
				supabase.from('requests').select('*').order('created_at', { ascending: false }),
			]);

			const firstErr = transfersRes.error || toursRes.error || experiencesRes.error || requestsRes.error;
			if (firstErr) {
				console.error('Admin calendar bookings load failed:', firstErr);
				const grid = document.getElementById('calendar-grid');
				if (grid) grid.innerHTML = `<div class="p-2 min-h-[80px] flex items-center justify-center text-neutral-400 text-sm col-span-7">Could not load bookings.</div>`;
				return;
			}

			allBookings = [];
			(transfersRes.data ?? []).forEach(row => allBookings.push(parseBooking(row, 'transfer')));
			(toursRes.data ?? []).forEach(row => allBookings.push(parseBooking(row, 'tour')));
			(experiencesRes.data ?? []).forEach(row => allBookings.push(parseBooking(row, 'experience')));
			(requestsRes.data ?? []).forEach(row => allBookings.push(parseBooking(row, 'request')));

			renderCalendar();
		}
	}

	// Navigation
	document.getElementById('prev-month')?.addEventListener('click', () => {
		currentMonth--;
		if (currentMonth < 0) { currentMonth = 11; currentYear--; }
		selectedDay = null;
		document.getElementById('day-bookings')?.classList.add('hidden');
		renderCalendar();
	});

	document.getElementById('next-month')?.addEventListener('click', () => {
		currentMonth++;
		if (currentMonth > 11) { currentMonth = 0; currentYear++; }
		selectedDay = null;
		document.getElementById('day-bookings')?.classList.add('hidden');
		renderCalendar();
	});

	document.getElementById('close-day-bookings')?.addEventListener('click', () => {
		selectedDay = null;
		document.getElementById('day-bookings')?.classList.add('hidden');
		renderCalendar();
	});

	/* ── Auth guard observer ── */
	// Race fix: AdminLayout's async getSession() can flip auth-check to hidden BEFORE
	// this script attaches its observer. Check current state first; only observe if pending.
	const authEl = document.getElementById('admin-auth-check');
	if (authEl) {
		if (authEl.classList.contains('hidden')) {
			loadAllBookings();
		} else {
			const observer = new MutationObserver(() => {
				if (authEl.classList.contains('hidden')) { observer.disconnect(); loadAllBookings(); }
			});
			observer.observe(authEl, { attributes: true, attributeFilter: ['class'] });
		}
	}
</script>
