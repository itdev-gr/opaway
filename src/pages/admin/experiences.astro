---
import AdminLayout from '../../components/AdminLayout.astro';
import ReservationDetailModal from '../../components/ReservationDetailModal.astro';
---

<AdminLayout pageTitle="Experiences" pageDescription="All experience bookings." activeSection="experiences">

	<div class="bg-white rounded-2xl border border-neutral-200 shadow-sm">
		<div class="px-6 py-4 border-b border-neutral-100 flex items-center justify-between gap-4">
			<div class="flex items-center gap-3">
				<h2 class="text-base font-semibold text-neutral-800">All Experiences</h2>
				<span id="experiences-count" class="text-xs text-neutral-400 font-medium"></span>
			</div>
			<button id="add-exp-btn" type="button"
				class="flex items-center gap-2 px-4 py-2 bg-[#0C6B95] hover:bg-[#0a5c82] text-white text-sm font-semibold rounded-xl transition-colors shadow-sm shadow-[#0C6B95]/20">
				<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
					<path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
				</svg>
				Add Booking
			</button>
		</div>
		<div class="overflow-x-auto">
			<table class="w-full text-sm">
				<thead>
					<tr class="bg-neutral-50 text-left">
						<th class="px-4 py-3 text-xs font-semibold text-neutral-500 uppercase tracking-wider">Date</th>
						<th class="px-4 py-3 text-xs font-semibold text-neutral-500 uppercase tracking-wider">Time</th>
						<th class="px-4 py-3 text-xs font-semibold text-neutral-500 uppercase tracking-wider">Name</th>
						<th class="px-4 py-3 text-xs font-semibold text-neutral-500 uppercase tracking-wider">Email</th>
						<th class="px-4 py-3 text-xs font-semibold text-neutral-500 uppercase tracking-wider">Phone</th>
						<th class="px-4 py-3 text-xs font-semibold text-neutral-500 uppercase tracking-wider">From</th>
						<th class="px-4 py-3 text-xs font-semibold text-neutral-500 uppercase tracking-wider">To</th>
						<th class="px-4 py-3 text-xs font-semibold text-neutral-500 uppercase tracking-wider">Passengers</th>
						<th class="px-4 py-3 text-xs font-semibold text-neutral-500 uppercase tracking-wider">Vehicle</th>
						<th class="px-4 py-3 text-xs font-semibold text-neutral-500 uppercase tracking-wider">Driver</th>
						<th class="px-4 py-3 text-xs font-semibold text-neutral-500 uppercase tracking-wider">Ride Status</th>
						<th class="px-4 py-3 text-xs font-semibold text-neutral-500 uppercase tracking-wider">Released</th>
						<th class="px-4 py-3 text-xs font-semibold text-neutral-500 uppercase tracking-wider">Payment Status</th>
					</tr>
				</thead>
				<tbody id="experiences-tbody">
					<tr><td colspan="13" class="px-4 py-10 text-center text-neutral-400">Loading…</td></tr>
				</tbody>
			</table>
		</div>
	</div>

	<!-- Add Booking Modal -->
	<div id="add-exp-modal" class="fixed inset-0 z-50 hidden flex items-center justify-center bg-black/40 backdrop-blur-sm px-4 py-6">
		<div class="bg-white rounded-2xl shadow-2xl border border-neutral-200 w-full max-w-lg max-h-[90vh] overflow-y-auto">

			<div class="flex items-center justify-between px-6 py-4 border-b border-neutral-100">
				<h3 class="text-lg font-bold text-neutral-900">Add Experience Booking</h3>
				<button id="add-exp-close" type="button" class="p-1.5 rounded-lg hover:bg-neutral-100 text-neutral-400 transition-colors">
					<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
				</button>
			</div>

			<form id="add-exp-form" class="px-6 py-5 flex flex-col gap-4">

				<div class="grid grid-cols-2 gap-4">
					<div class="flex flex-col gap-1.5">
						<label class="text-xs font-semibold text-neutral-500 uppercase tracking-wider">Full Name *</label>
						<input id="ex-name" type="text" placeholder="John Smith" required
							class="px-3 py-2.5 border border-neutral-200 rounded-xl text-sm text-neutral-800 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95] bg-neutral-50" />
					</div>
					<div class="flex flex-col gap-1.5">
						<label class="text-xs font-semibold text-neutral-500 uppercase tracking-wider">Email *</label>
						<input id="ex-email" type="email" placeholder="john@example.com" required
							class="px-3 py-2.5 border border-neutral-200 rounded-xl text-sm text-neutral-800 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95] bg-neutral-50" />
					</div>
				</div>

				<div class="flex flex-col gap-1.5">
					<label class="text-xs font-semibold text-neutral-500 uppercase tracking-wider">Phone</label>
					<input id="ex-phone" type="text" placeholder="+30 69..."
						class="px-3 py-2.5 border border-neutral-200 rounded-xl text-sm text-neutral-800 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95] bg-neutral-50" />
				</div>

				<div class="flex flex-col gap-1.5">
					<label class="text-xs font-semibold text-neutral-500 uppercase tracking-wider">Experience *</label>
					<select id="ex-experience"
						class="px-3 py-2.5 border border-neutral-200 rounded-xl text-sm text-neutral-800 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95] bg-neutral-50">
						<option value="" disabled selected>Loading experiences…</option>
					</select>
				</div>

				<div class="flex flex-col gap-1.5">
					<label class="text-xs font-semibold text-neutral-500 uppercase tracking-wider">Pickup Location *</label>
					<input id="ex-pickup" type="text" placeholder="Hotel, address or landmark..." required
						class="px-3 py-2.5 border border-neutral-200 rounded-xl text-sm text-neutral-800 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95] bg-neutral-50" />
				</div>

				<div class="grid grid-cols-2 gap-4">
					<div class="flex flex-col gap-1.5">
						<label class="text-xs font-semibold text-neutral-500 uppercase tracking-wider">Date *</label>
						<input id="ex-date" type="date" required
							class="px-3 py-2.5 border border-neutral-200 rounded-xl text-sm text-neutral-800 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95] bg-neutral-50" />
					</div>
					<div class="flex flex-col gap-1.5">
						<label class="text-xs font-semibold text-neutral-500 uppercase tracking-wider">Time</label>
						<input id="ex-time" type="time"
							class="px-3 py-2.5 border border-neutral-200 rounded-xl text-sm text-neutral-800 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95] bg-neutral-50" />
					</div>
				</div>

				<div class="flex flex-col gap-1.5">
					<label class="text-xs font-semibold text-neutral-500 uppercase tracking-wider">Passengers *</label>
					<input id="ex-participants" type="number" min="1" max="60" placeholder="1" required
						class="px-3 py-2.5 border border-neutral-200 rounded-xl text-sm text-neutral-800 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95] bg-neutral-50" />
				</div>

				<div class="flex flex-col gap-1.5">
					<label class="text-xs font-semibold text-neutral-500 uppercase tracking-wider">Notes</label>
					<textarea id="ex-notes" rows="2" placeholder="Special requests or notes..."
						class="px-3 py-2.5 border border-neutral-200 rounded-xl text-sm text-neutral-800 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95] bg-neutral-50 resize-none"></textarea>
				</div>

				<div class="flex flex-col gap-1.5">
					<label class="text-xs font-semibold text-neutral-500 uppercase tracking-wider">Ride Status</label>
					<select id="ex-rideStatus"
						class="px-3 py-2.5 border border-neutral-200 rounded-xl text-sm text-neutral-800 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95] bg-neutral-50">
						<option value="new">New</option>
						<option value="assigned">Assigned</option>
						<option value="pickup">Pickup</option>
						<option value="onboard">Onboard</option>
						<option value="completed">Completed</option>
						<option value="cancelled">Cancelled</option>
					</select>
				</div>

				<p id="ex-error" class="hidden text-sm text-red-600"></p>

				<div class="flex gap-3 pt-1">
					<button type="button" id="add-exp-cancel2"
						class="flex-1 py-2.5 rounded-xl border border-neutral-200 text-neutral-700 text-sm font-semibold hover:bg-neutral-50 transition-colors">Cancel</button>
					<button type="submit" id="ex-submit"
						class="flex-1 py-2.5 rounded-xl bg-[#0C6B95] hover:bg-[#0a5c82] text-white text-sm font-semibold transition-colors disabled:opacity-60">
						Save Booking
					</button>
				</div>

			</form>
		</div>
	</div>

	<ReservationDetailModal />

</AdminLayout>

<script>
	import { supabase } from '../../lib/supabase';

	const rowsById = new Map<string, any>();

	/* ── Ride Status colours ── */
	const RIDE_STATUS_COLORS: Record<string, string> = {
		new:       'bg-sky-50 text-sky-700 border-sky-200',
		assigned:  'bg-amber-50 text-amber-700 border-amber-200',
		pickup:    'bg-violet-50 text-violet-700 border-violet-200',
		onboard:   'bg-indigo-50 text-indigo-700 border-indigo-200',
		completed: 'bg-emerald-50 text-emerald-700 border-emerald-200',
		cancelled: 'bg-red-50 text-red-600 border-red-200',
	};

	const RIDE_STATUS_OPTIONS = ['new', 'assigned', 'pickup', 'onboard', 'completed', 'cancelled'];

	/* ── Payment Status colours ── */
	const PAYMENT_STATUS_COLORS: Record<string, string> = {
		pending:        'bg-amber-50 text-amber-700',
		paid:           'bg-emerald-50 text-emerald-700',
		paid_to_driver: 'bg-teal-50 text-teal-700',
		cancelled:      'bg-red-50 text-red-700',
	};

	const PAYMENT_STATUS_OPTIONS = [
		{ value: 'pending',        label: 'Pending Payment' },
		{ value: 'paid',           label: 'Paid' },
		{ value: 'paid_to_driver', label: 'Paid to Driver' },
		{ value: 'cancelled',      label: 'Cancelled' },
	];

	const applyRideStatusColor = (sel: HTMLSelectElement) => {
		const cls = RIDE_STATUS_COLORS[sel.value] ?? 'bg-neutral-50 text-neutral-600 border-neutral-200';
		sel.className = `ride-status-select appearance-none text-xs font-medium border rounded-full px-2.5 py-0.5 focus:outline-none cursor-pointer capitalize ${cls}`;
	};

	const buildRideStatusSelect = (docId: string, current: string) => {
		const val = current?.toLowerCase() ?? 'new';
		const opts = RIDE_STATUS_OPTIONS.map(s =>
			`<option value="${s}" ${val === s ? 'selected' : ''}>${s.charAt(0).toUpperCase() + s.slice(1)}</option>`
		).join('');
		return `<select class="ride-status-select" data-id="${docId}" data-col="experiences">${opts}</select>`;
	};

	const applyPaymentStatusColor = (sel: HTMLSelectElement) => {
		const cls = PAYMENT_STATUS_COLORS[sel.value] ?? 'bg-neutral-50 text-neutral-600';
		sel.className = `payment-status-select appearance-none text-xs font-medium border rounded-full px-2.5 py-0.5 focus:outline-none cursor-pointer ${cls}`;
	};

	const buildPaymentBadge = (docId: string, method: string, status: string) => {
		const s = (status || 'pending').toLowerCase();
		const opts = PAYMENT_STATUS_OPTIONS.map(o =>
			`<option value="${o.value}" ${s === o.value ? 'selected' : ''}>${o.label}</option>`
		).join('');
		return `<select class="payment-status-select" data-id="${docId}">${opts}</select>`;
	};

	const buildDriverCell = (docId: string, current: string) => {
		const display = current || '—';
		return `<span class="driver-display cursor-pointer hover:text-[#0C6B95] transition-colors" data-id="${docId}" data-col="experiences" title="Click to edit">${display}</span>`;
	};

	/* ── Load experience catalog into select ── */
	async function loadExperienceOptions() {
		const sel = document.getElementById('ex-experience') as HTMLSelectElement;
		try {
			const { data, error } = await supabase.from('experiences_catalog').select('*').order('created_at', { ascending: false });
			if (error) throw error;
			const published = (data ?? []).filter(d => d.published !== false);
			sel.innerHTML = published.length === 0
				? '<option value="" disabled selected>No experiences available</option>'
				: '<option value="" disabled selected>Select an experience…</option>' +
				  published.map(d => `<option value="${d.id}">${d.title ?? '—'}</option>`).join('');
		} catch {
			sel.innerHTML = '<option value="" disabled selected>Could not load experiences</option>';
		}
	}

	async function loadExperiences() {
		const tbody = document.getElementById('experiences-tbody')!;
		const countEl = document.getElementById('experiences-count');
		try {
			const { data, error } = await supabase.from('experiences').select('*').order('created_at', { ascending: false });
			if (error) throw error;
			const rows = data ?? [];
			rowsById.clear();
			rows.forEach((r: any) => rowsById.set(r.id, r));
			if (countEl) countEl.textContent = `${rows.length} record${rows.length !== 1 ? 's' : ''}`;
			if (rows.length === 0) {
				tbody.innerHTML = `<tr><td colspan="13" class="px-4 py-10 text-center text-neutral-400">No experiences found.</td></tr>`;
				return;
			}
			tbody.innerHTML = rows.map(d => {
				const date = d.date ? String(d.date) : (d.created_at ? (() => { const _d = new Date(d.created_at); return !isNaN(_d.getTime()) ? _d.toLocaleDateString() : '—'; })() : '—');
				const time = d.time ? String(d.time) : '—';
				const rideStatus = String(d.ride_status ?? d.status ?? 'new');
				const paymentMethod = String(d.payment_method ?? 'cash');
				const paymentStatus = String(d.payment_status ?? 'pending');
				return `<tr data-row-id="${d.id}" class="border-t border-neutral-100 hover:bg-neutral-50 transition-colors cursor-pointer">
					<td class="px-4 py-3 text-neutral-600 whitespace-nowrap">${date}</td>
					<td class="px-4 py-3 text-neutral-600 whitespace-nowrap">${time}</td>
					<td class="px-4 py-3 font-medium text-neutral-900 whitespace-nowrap">${d.name ?? '—'}</td>
					<td class="px-4 py-3 text-neutral-500 whitespace-nowrap">${d.email ?? '—'}</td>
					<td class="px-4 py-3 text-neutral-600 whitespace-nowrap">${d.phone ?? '—'}</td>
					<td class="px-4 py-3 text-neutral-600 whitespace-nowrap">${d.pickup ?? d.pickup_location ?? '—'}</td>
					<td class="px-4 py-3 text-neutral-600 whitespace-nowrap">${d.experience ?? d.experience_name ?? '—'}</td>
					<td class="px-4 py-3 text-neutral-600 text-center">${d.participants ?? d.passengers ?? d.guests ?? '—'}</td>
					<td class="px-4 py-3 text-neutral-600 whitespace-nowrap">${d.vehicle ?? '—'}</td>
					<td class="px-4 py-3 text-neutral-600 whitespace-nowrap">${buildDriverCell(d.id, String(d.driver ?? ''))}</td>
					<td class="px-4 py-3">${buildRideStatusSelect(d.id, rideStatus)}</td>
					<td class="px-4 py-3">
						<button data-release="${d.id}" data-released="${d.released_to_drivers ? '1' : '0'}"
							class="text-xs px-3 py-1 rounded-lg border transition-colors ${d.released_to_drivers ? 'bg-emerald-50 text-emerald-700 border-emerald-200 hover:bg-emerald-100' : 'bg-amber-50 text-amber-700 border-amber-200 hover:bg-amber-100'}">
							${d.released_to_drivers ? 'Released' : 'Release'}
						</button>
					</td>
					<td class="px-4 py-3">${buildPaymentBadge(d.id, paymentMethod, paymentStatus)}</td>
				</tr>`;
			}).join('');

			/* Apply colours to all ride status selects */
			document.querySelectorAll<HTMLSelectElement>('.ride-status-select').forEach(applyRideStatusColor);
			/* Apply colours to all payment status selects */
			document.querySelectorAll<HTMLSelectElement>('.payment-status-select').forEach(applyPaymentStatusColor);
			/* Wire release-toggle buttons */
			const tbody2 = document.getElementById('experiences-tbody');
			tbody2?.querySelectorAll<HTMLButtonElement>('[data-release]').forEach(btn => {
				btn.addEventListener('click', async () => {
					const id = btn.dataset.release!;
					const next = btn.dataset.released !== '1';
					const { error } = await supabase.from('experiences').update({ released_to_drivers: next }).eq('id', id);
					if (error) { console.error('Release toggle failed:', error); alert(`Release toggle failed: ${error.message}`); return; }
					await loadExperiences();
				});
			});
			/* Row-click → reservation detail modal */
			tbody2?.querySelectorAll<HTMLElement>('[data-row-id]').forEach(tr => {
				tr.addEventListener('click', (e) => {
					if ((e.target as HTMLElement).closest('input, select, button, [data-release], .driver-text, .driver-display')) return;
					const row = rowsById.get(tr.dataset.rowId!);
					if (row) (window as any).OpawayReservationDetail.open(row, 'experience');
				});
			});
		} catch {
			tbody.innerHTML = `<tr><td colspan="13" class="px-4 py-10 text-center text-neutral-400">Could not load data.</td></tr>`;
		}
	}

	/* ── Ride Status & Payment Status change delegation ── */
	document.getElementById('experiences-tbody')?.addEventListener('change', async (e) => {
		const sel = e.target as HTMLSelectElement;
		if (sel.classList.contains('ride-status-select')) {
			const docId = sel.dataset.id!;
			applyRideStatusColor(sel);
			const { error } = await supabase.from('experiences').update({ ride_status: sel.value }).eq('id', docId);
			if (error) {
				console.error('Experience ride_status update failed:', error);
				alert(`Save failed: [${error.code ?? 'unknown'}] ${error.message}`);
			}
		}
		if (sel.classList.contains('payment-status-select')) {
			const docId = sel.dataset.id!;
			applyPaymentStatusColor(sel);
			const { error } = await supabase.from('experiences').update({ payment_status: sel.value }).eq('id', docId);
			if (error) {
				console.error('Experience payment_status update failed:', error);
				alert(`Save failed: [${error.code ?? 'unknown'}] ${error.message}`);
			}
		}
	});

	/* ── Driver inline edit delegation ── */
	document.getElementById('experiences-tbody')?.addEventListener('click', (e) => {
		const target = e.target as HTMLElement;
		if (!target.classList.contains('driver-display')) return;
		const docId = target.dataset.id!;
		const current = target.textContent === '—' ? '' : target.textContent ?? '';
		const input = document.createElement('input');
		input.type = 'text';
		input.value = current;
		input.className = 'px-2 py-0.5 border border-neutral-300 rounded-lg text-sm text-neutral-800 focus:outline-none focus:ring-2 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95] w-24';
		const save = async () => {
			const val = input.value.trim();
			const span = document.createElement('span');
			span.className = 'driver-display cursor-pointer hover:text-[#0C6B95] transition-colors';
			span.dataset.id = docId;
			span.dataset.col = 'experiences';
			span.title = 'Click to edit';
			span.textContent = val || '—';
			input.replaceWith(span);
			const { error } = await supabase.from('experiences').update({ driver: val }).eq('id', docId);
			if (error) {
				console.error('Driver update failed:', error);
				alert(`Save failed: [${error.code ?? 'unknown'}] ${error.message}`);
			}
		};
		input.addEventListener('blur', save);
		input.addEventListener('keydown', (ev) => { if (ev.key === 'Enter') { ev.preventDefault(); input.blur(); } if (ev.key === 'Escape') { input.value = current; input.blur(); } });
		target.replaceWith(input);
		input.focus();
	});

	/* ── Modal ── */
	const modal      = document.getElementById('add-exp-modal')!;
	const openModal  = async () => { modal.classList.remove('hidden'); await loadExperienceOptions(); };
	const closeModal = () => { modal.classList.add('hidden'); (document.getElementById('add-exp-form') as HTMLFormElement)?.reset(); document.getElementById('ex-error')!.classList.add('hidden'); };

	document.getElementById('add-exp-btn')?.addEventListener('click', openModal);
	document.getElementById('add-exp-close')?.addEventListener('click', closeModal);
	document.getElementById('add-exp-cancel2')?.addEventListener('click', closeModal);
	modal.addEventListener('click', (e) => { if (e.target === modal) closeModal(); });

	document.getElementById('add-exp-form')?.addEventListener('submit', async (e) => {
		e.preventDefault();
		const errorEl  = document.getElementById('ex-error')!;
		const submitBtn = document.getElementById('ex-submit') as HTMLButtonElement;
		errorEl.classList.add('hidden');

		const val = (id: string) => (document.getElementById(id) as HTMLInputElement)?.value.trim();

		const name         = val('ex-name');
		const email        = val('ex-email');
		const phone        = val('ex-phone');
		const expSel       = document.getElementById('ex-experience') as HTMLSelectElement;
		const experienceId = expSel.value;
		const experienceName = experienceId ? expSel.options[expSel.selectedIndex]?.text : '';
		const pickup       = val('ex-pickup');
		const date         = val('ex-date');
		const time         = val('ex-time');
		const participants = parseInt(val('ex-participants') || '1', 10);
		const notes        = val('ex-notes');
		const rideStatus   = val('ex-rideStatus') || 'new';

		if (!name || !email || !experienceId || !pickup || !date || !participants) {
			errorEl.textContent = 'Please fill in all required fields.';
			errorEl.classList.remove('hidden');
			return;
		}

		submitBtn.disabled = true;
		submitBtn.textContent = 'Saving…';
		try {
			const { error } = await supabase.from('experiences').insert({
				name, email, phone: phone || '',
				experience: experienceName, experience_id: experienceId,
				pickup, pickup_location: pickup,
				date, time: time || '',
				participants,
				notes: notes || '',
				ride_status: rideStatus,
				payment_status: 'pending',
				payment_method: 'cash',
				added_by_admin: true,
			}).select().single();
			if (error) {
				console.error('Experience booking insert failed:', error);
				errorEl.textContent = `Failed to save: [${error.code ?? 'unknown'}] ${error.message}`;
				errorEl.classList.remove('hidden');
				return;
			}
			closeModal();
			await loadExperiences();
		} finally {
			submitBtn.disabled = false;
			submitBtn.textContent = 'Save Booking';
		}
	});

	/* ── Auth guard ── */
	const authEl = document.getElementById('admin-auth-check');
	const observer = new MutationObserver(() => {
		if (authEl?.classList.contains('hidden')) { observer.disconnect(); loadExperiences(); }
	});
	if (authEl) observer.observe(authEl, { attributes: true, attributeFilter: ['class'] });
</script>

