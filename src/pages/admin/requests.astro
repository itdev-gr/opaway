---
import AdminLayout from '../../components/AdminLayout.astro';
---

<AdminLayout
	pageTitle="Requests"
	pageDescription="Contact forms and inquiries only — bookings appear in their own sections."
	activeSection="requests"
	docTitle="Requests — Opawey Admin"
>

	<!-- Filter tabs -->
	<div class="flex flex-wrap items-center gap-2 mb-6">
		<button data-filter="all" class="filter-tab px-4 py-2 text-sm font-semibold rounded-xl bg-[#0C6B95] text-white shadow-sm transition-colors">
			All <span id="tab-count-all" class="ml-1 opacity-80">—</span>
		</button>
		<button data-filter="new" class="filter-tab px-4 py-2 text-sm font-semibold rounded-xl border border-sky-200 text-sky-700 bg-sky-50 hover:bg-sky-100 transition-colors">
			New <span id="tab-count-new" class="ml-1 opacity-80">—</span>
		</button>
		<button data-filter="answered" class="filter-tab px-4 py-2 text-sm font-semibold rounded-xl border border-emerald-200 text-emerald-700 bg-emerald-50 hover:bg-emerald-100 transition-colors">
			Answered <span id="tab-count-answered" class="ml-1 opacity-80">—</span>
		</button>
		<button data-filter="follow-up" class="filter-tab px-4 py-2 text-sm font-semibold rounded-xl border border-amber-200 text-amber-700 bg-amber-50 hover:bg-amber-100 transition-colors">
			Follow up <span id="tab-count-followup" class="ml-1 opacity-80">—</span>
		</button>
		<button data-filter="discarded" class="filter-tab px-4 py-2 text-sm font-semibold rounded-xl border border-neutral-200 text-neutral-500 bg-neutral-50 hover:bg-neutral-100 transition-colors">
			Discarded <span id="tab-count-discarded" class="ml-1 opacity-80">—</span>
		</button>
		<div class="w-px h-6 bg-neutral-200 mx-1"></div>
		<button data-filter="tour" class="filter-tab px-4 py-2 text-sm font-semibold rounded-xl border border-neutral-200 text-neutral-600 hover:border-[#0C6B95]/40 hover:text-[#0C6B95] transition-colors">
			Tour Requests
		</button>
		<button data-filter="contact" class="filter-tab px-4 py-2 text-sm font-semibold rounded-xl border border-neutral-200 text-neutral-600 hover:border-violet-300 hover:text-violet-700 transition-colors">
			Contact Messages
		</button>
	</div>

	<!-- Table -->
	<div class="bg-white rounded-2xl border border-neutral-200 shadow-sm">
		<div class="overflow-x-auto">
			<table class="w-full text-sm">
				<thead>
					<tr class="bg-neutral-50 text-left">
						<th class="px-4 py-3 text-xs font-semibold text-neutral-500 uppercase tracking-wider">Date</th>
						<th class="px-4 py-3 text-xs font-semibold text-neutral-500 uppercase tracking-wider">Source</th>
						<th class="px-4 py-3 text-xs font-semibold text-neutral-500 uppercase tracking-wider">Name / Contact</th>
						<th class="px-4 py-3 text-xs font-semibold text-neutral-500 uppercase tracking-wider">Subject / Details</th>
						<th class="px-4 py-3 text-xs font-semibold text-neutral-500 uppercase tracking-wider">Status</th>
						<th class="px-4 py-3 text-xs font-semibold text-neutral-500 uppercase tracking-wider text-right">Actions</th>
					</tr>
				</thead>
				<tbody id="req-tbody">
					<tr><td colspan="6" class="px-6 py-16 text-center text-neutral-400">Loading…</td></tr>
				</tbody>
			</table>
		</div>
	</div>

	<!-- Delete confirm modal -->
	<div id="req-delete-modal" class="fixed inset-0 z-50 hidden flex items-center justify-center bg-black/40 backdrop-blur-sm px-4">
		<div class="bg-white rounded-2xl shadow-2xl border border-neutral-200 w-full max-w-sm p-6">
			<h3 class="text-lg font-bold text-neutral-900 mb-2">Delete Request</h3>
			<p class="text-sm text-neutral-500 mb-6">Are you sure you want to permanently delete this request? This cannot be undone.</p>
			<div class="flex gap-3">
				<button id="req-delete-cancel" type="button" class="flex-1 py-2.5 rounded-xl border border-neutral-200 text-neutral-700 text-sm font-semibold hover:bg-neutral-50 transition-colors">Cancel</button>
				<button id="req-delete-confirm" type="button" class="flex-1 py-2.5 rounded-xl bg-red-600 hover:bg-red-700 text-white text-sm font-semibold transition-colors">Delete</button>
			</div>
		</div>
	</div>

</AdminLayout>

<script>
	import { supabase } from '../../lib/supabase';

	interface Request {
		id: string;
		source: 'tour' | 'contact';
		status: 'new' | 'answered' | 'follow-up' | 'discarded';
		created_at: string | null;
		user_id?: string | null;
		user_display_name?: string | null;
		user_email?: string | null;
		tour_name?: string;
		name?: string;
		contact_info?: string;
		pickup_location?: string;
		date?: string;
		time?: string;
		participants?: number;
		special_requests?: string;
		email?: string;
		subject?: string;
		message?: string;
	}

	const esc = (s: unknown) => String(s ?? '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');

	let allRequests: Request[] = [];
	let currentFilter = 'all';
	let deleteTargetId: string | null = null;
	let openDropdownId: string | null = null;

	const fmtDate = (r: Request) => {
		if (!r.created_at) return '—';
		const d = new Date(r.created_at);
		if (isNaN(d.getTime())) return '—';
		return d.toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' });
	};

	const STATUS_BADGE: Record<string, string> = {
		'new':       'bg-sky-50 text-sky-700 border-sky-200',
		'answered':  'bg-emerald-50 text-emerald-700 border-emerald-200',
		'follow-up': 'bg-amber-50 text-amber-700 border-amber-200',
		'discarded': 'bg-neutral-100 text-neutral-500 border-neutral-200',
	};

	const SOURCE_BADGE: Record<string, string> = {
		'tour':    'bg-[#0C6B95]/10 text-[#0C6B95]',
		'contact': 'bg-violet-50 text-violet-700',
	};

	function closeAllDropdowns() {
		document.querySelectorAll('.req-dd-menu').forEach(m => m.classList.add('hidden'));
		openDropdownId = null;
	}

	/* ── Update tab counts ── */
	function updateCounts() {
		const nonDiscarded = allRequests.filter(r => r.status !== 'discarded').length;
		const setText = (id: string, val: number) => { const el = document.getElementById(id); if (el) el.textContent = String(val); };
		setText('tab-count-all', nonDiscarded);
		setText('tab-count-new', allRequests.filter(r => r.status === 'new').length);
		setText('tab-count-answered', allRequests.filter(r => r.status === 'answered').length);
		setText('tab-count-followup', allRequests.filter(r => r.status === 'follow-up').length);
		setText('tab-count-discarded', allRequests.filter(r => r.status === 'discarded').length);
	}

	/* ── Render table ── */
	function renderTable() {
		const tbody = document.getElementById('req-tbody')!;
		updateCounts();

		let filtered = allRequests;

		// "All" hides discarded — discarded only visible via "discarded" tab
		if (currentFilter === 'all') {
			filtered = allRequests.filter(r => r.status !== 'discarded');
		} else if (currentFilter === 'tour') {
			filtered = allRequests.filter(r => r.source === 'tour' && r.status !== 'discarded');
		} else if (currentFilter === 'contact') {
			filtered = allRequests.filter(r => r.source === 'contact' && r.status !== 'discarded');
		} else {
			filtered = allRequests.filter(r => r.status === currentFilter);
		}

		if (filtered.length === 0) {
			tbody.innerHTML = `<tr><td colspan="6" class="px-6 py-16 text-center text-neutral-400">No requests found.</td></tr>`;
			return;
		}

		tbody.innerHTML = filtered.map(r => {
			const isTour = r.source === 'tour';
			const sourceCls = SOURCE_BADGE[r.source] || 'bg-neutral-100 text-neutral-600';
			const statusCls = STATUS_BADGE[r.status] || 'bg-neutral-50 text-neutral-600 border-neutral-200';
			const statusLabel = r.status === 'follow-up' ? 'Follow up' : r.status.charAt(0).toUpperCase() + r.status.slice(1);

			const nameContact = isTour
				? `<div class="font-medium text-neutral-900">${esc(r.name || '—')}</div><div class="text-xs text-neutral-500">${esc(r.contact_info || r.email || '')}</div>`
				: `<div class="font-medium text-neutral-900">${esc(r.name || '—')}</div><div class="text-xs text-neutral-500">${esc(r.email || '')}</div>`;

			const details = isTour
				? `<div class="text-neutral-800">${esc(r.tour_name || '—')}</div><div class="text-xs text-neutral-500">${esc(r.pickup_location || '')}${r.date ? ` · ${esc(r.date)}` : ''}</div>`
				: `<div class="text-neutral-800">${esc(r.subject || '—')}</div><div class="text-xs text-neutral-500 truncate max-w-[300px]">${esc(r.message || '')}</div>`;

			// Action buttons for dropdown
			const actions: string[] = [];
			if (r.status !== 'answered')  actions.push(`<button class="req-action w-full text-left px-4 py-2 text-sm hover:bg-emerald-50 text-emerald-700 transition-colors" data-id="${esc(r.id)}" data-action="answered">Mark as Answered</button>`);
			if (r.status !== 'follow-up') actions.push(`<button class="req-action w-full text-left px-4 py-2 text-sm hover:bg-amber-50 text-amber-700 transition-colors" data-id="${esc(r.id)}" data-action="follow-up">Mark as Follow up</button>`);
			if (r.status !== 'discarded') actions.push(`<button class="req-action w-full text-left px-4 py-2 text-sm hover:bg-neutral-100 text-neutral-500 transition-colors" data-id="${esc(r.id)}" data-action="discarded">Discard</button>`);
			if (r.status === 'discarded') actions.push(`<button class="req-action w-full text-left px-4 py-2 text-sm hover:bg-sky-50 text-sky-700 transition-colors" data-id="${esc(r.id)}" data-action="new">Restore</button>`);
			actions.push(`<div class="border-t border-neutral-100 my-1"></div>`);
			actions.push(`<button class="req-delete w-full text-left px-4 py-2 text-sm hover:bg-red-50 text-red-600 transition-colors" data-id="${esc(r.id)}">Delete</button>`);

			return `
			<tr class="border-t border-neutral-100 hover:bg-neutral-50/50 transition-colors">
				<td class="px-4 py-3 text-neutral-500 whitespace-nowrap text-xs">${fmtDate(r)}</td>
				<td class="px-4 py-3"><span class="inline-flex px-2 py-0.5 rounded-md text-xs font-semibold ${sourceCls}">${isTour ? 'Tour' : 'Contact'}</span></td>
				<td class="px-4 py-3 min-w-[150px]">${nameContact}</td>
				<td class="px-4 py-3 min-w-[200px]">${details}</td>
				<td class="px-4 py-3"><span class="inline-flex px-2 py-0.5 rounded-full text-xs font-semibold border ${statusCls}">${esc(statusLabel)}</span></td>
				<td class="px-4 py-3 text-right">
					<div class="relative inline-block">
						<button class="req-dd-trigger px-3 py-1.5 rounded-lg border border-neutral-200 bg-white hover:bg-neutral-50 text-neutral-600 text-xs font-medium transition-colors" data-id="${esc(r.id)}">
							Actions
							<svg class="w-3 h-3 inline-block ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
						</button>
						<div class="req-dd-menu fixed w-44 bg-white rounded-xl border border-neutral-200 shadow-lg z-[100] hidden py-1" id="req-dd-${esc(r.id)}">
							${actions.join('')}
						</div>
					</div>
				</td>
			</tr>`;
		}).join('');

		attachListeners();
	}

	/* ── Attach listeners ── */
	function attachListeners() {
		// Dropdown triggers
		document.querySelectorAll<HTMLButtonElement>('.req-dd-trigger').forEach(btn => {
			btn.addEventListener('click', (e) => {
				e.stopPropagation();
				const id = btn.dataset.id!;
				const menu = document.getElementById(`req-dd-${id}`)!;
				if (openDropdownId === id) { closeAllDropdowns(); return; }
				closeAllDropdowns();
				const rect = btn.getBoundingClientRect();
				menu.style.top = `${rect.bottom + 6}px`;
				menu.style.left = `${rect.right - 176}px`;
				menu.classList.remove('hidden');
				openDropdownId = id;
			});
		});

		// Status actions
		document.querySelectorAll<HTMLButtonElement>('.req-action').forEach(btn => {
			btn.addEventListener('click', async (e) => {
				e.stopPropagation();
				closeAllDropdowns();
				const id = btn.dataset.id!;
				const action = btn.dataset.action!;
				{
					const { error } = await supabase.from('requests').update({ status: action }).eq('id', id);
					if (error) {
						console.error('Request status update failed:', error);
						alert(`Save failed: [${error.code ?? 'unknown'}] ${error.message}`);
						return;
					}
					const req = allRequests.find(r => r.id === id);
					if (req) req.status = action as any;
					renderTable();
				}
			});
		});

		// Delete buttons
		document.querySelectorAll<HTMLButtonElement>('.req-delete').forEach(btn => {
			btn.addEventListener('click', (e) => {
				e.stopPropagation();
				closeAllDropdowns();
				deleteTargetId = btn.dataset.id!;
				document.getElementById('req-delete-modal')?.classList.remove('hidden');
			});
		});
	}

	// Close dropdown on click outside
	document.addEventListener('click', closeAllDropdowns);

	/* ── Load ── */
	async function loadRequests() {
		{
			const { data, error } = await supabase.from('requests').select('*').order('created_at', { ascending: false });
			if (error) {
				console.error('Requests load failed:', error);
				document.getElementById('req-tbody')!.innerHTML = `<tr><td colspan="6" class="px-6 py-16 text-center text-neutral-400">Could not load requests.</td></tr>`;
				return;
			}
			allRequests = (data ?? []).map(d => {
				// Map legacy statuses to new ones
				if (d.status === 'resolved' || d.status === 'read') d.status = 'answered';
				return d as Request;
			});
			renderTable();
		}
	}

	function pageInit() {
		/* ── Filter tabs ── */
		document.querySelectorAll<HTMLButtonElement>('.filter-tab').forEach(tab => {
			tab.addEventListener('click', () => {
				currentFilter = tab.dataset.filter || 'all';

				// Update tab styles
				document.querySelectorAll('.filter-tab').forEach(t => {
					const f = (t as HTMLElement).dataset.filter || '';
					const isActive = f === currentFilter;
					if (isActive) {
						t.className = 'filter-tab px-4 py-2 text-sm font-semibold rounded-xl bg-[#0C6B95] text-white shadow-sm transition-colors';
					} else {
						// Restore original style based on filter type
						const styles: Record<string, string> = {
							'all':       'border border-neutral-200 text-neutral-600 hover:bg-neutral-50',
							'new':       'border border-sky-200 text-sky-700 bg-sky-50 hover:bg-sky-100',
							'answered':  'border border-emerald-200 text-emerald-700 bg-emerald-50 hover:bg-emerald-100',
							'follow-up': 'border border-amber-200 text-amber-700 bg-amber-50 hover:bg-amber-100',
							'discarded': 'border border-neutral-200 text-neutral-500 bg-neutral-50 hover:bg-neutral-100',
							'tour':      'border border-neutral-200 text-neutral-600 hover:border-[#0C6B95]/40 hover:text-[#0C6B95]',
							'contact':   'border border-neutral-200 text-neutral-600 hover:border-violet-300 hover:text-violet-700',
						};
						t.className = `filter-tab px-4 py-2 text-sm font-semibold rounded-xl ${styles[f] || styles['all']} transition-colors`;
					}
				});

				renderTable();
			});
		});

		/* ── Delete modal ── */
		document.getElementById('req-delete-cancel')?.addEventListener('click', () => {
			deleteTargetId = null;
			document.getElementById('req-delete-modal')?.classList.add('hidden');
		});

		document.getElementById('req-delete-confirm')?.addEventListener('click', async () => {
			if (!deleteTargetId) return;
			const confirmBtn = document.getElementById('req-delete-confirm') as HTMLButtonElement;
			confirmBtn.disabled = true;
			confirmBtn.textContent = 'Deleting…';
			{
				const { error } = await supabase.from('requests').delete().eq('id', deleteTargetId);
				if (error) {
					console.error('Request delete failed:', error);
					alert(`Delete failed: [${error.code ?? 'unknown'}] ${error.message}`);
				} else {
					allRequests = allRequests.filter(r => r.id !== deleteTargetId);
					deleteTargetId = null;
					document.getElementById('req-delete-modal')?.classList.add('hidden');
					renderTable();
				}
				confirmBtn.disabled = false;
				confirmBtn.textContent = 'Delete';
			}
		});

		/* ── Auth guard ── */
		const authEl = document.getElementById('admin-auth-check');
		if (authEl) {
			const observer = new MutationObserver(() => {
				if (authEl.classList.contains('hidden')) { observer.disconnect(); loadRequests(); }
			});
			observer.observe(authEl, { attributes: true, attributeFilter: ['class'] });
		}
	}

	document.addEventListener('astro:page-load', pageInit);
</script>
