---
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<main>
		<section class="relative min-h-screen bg-sky-50 flex items-center py-32 px-6 lg:px-10 overflow-hidden">

			<!-- Soft gradient blobs for depth -->
			<div class="absolute top-0 right-0 w-[600px] h-[600px] bg-[#0C6B95]/8 rounded-full blur-3xl -translate-y-1/3 translate-x-1/4 pointer-events-none"></div>
			<div class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-sky-100/60 rounded-full blur-3xl translate-y-1/3 -translate-x-1/4 pointer-events-none"></div>

			<!-- Content -->
			<div class="relative z-10 max-w-6xl mx-auto w-full">

				<!-- Two-column grid -->
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-14 lg:gap-20 items-start">

					<!-- ── Left: Label + Heading + Contact Info ── -->
					<div class="flex flex-col items-center lg:items-start text-center lg:text-left">

						<!-- Label -->
						<div class="flex items-center justify-center lg:justify-start gap-2 mb-4">
							<span class="w-2 h-2 rounded-full bg-[#0C6B95] shrink-0"></span>
							<span class="text-sm font-medium text-[#0C6B95] tracking-widest uppercase" data-i18n-el="Επικοινωνήστε μαζί μας" data-i18n-es="Póngase en contacto">Get in Touch</span>
						</div>

						<!-- Heading -->
						<h1 class="text-5xl lg:text-7xl font-bold text-neutral-900 mb-12 leading-tight" data-i18n-el="Επικοινωνία" data-i18n-es="Contacto">Contact Us</h1>

						<!-- Info blocks -->
						<div class="flex flex-col gap-8 w-full">

							<!-- Call Us -->
							<div class="flex items-start gap-5">
								<div class="w-12 h-12 rounded-xl bg-[#0C6B95] flex items-center justify-center shrink-0 shadow-md shadow-[#0C6B95]/20">
									<svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
										<path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
									</svg>
								</div>
								<div>
									<p class="text-neutral-400 text-xs font-medium uppercase tracking-widest mb-1" data-i18n-el="Καλέστε μας" data-i18n-es="Llámenos">Call Us</p>
									<p class="text-neutral-900 font-semibold text-lg">+30 210 933 3164</p>
								</div>
							</div>

							<!-- Location -->
							<div class="flex items-start gap-5">
								<div class="w-12 h-12 rounded-xl bg-[#0C6B95] flex items-center justify-center shrink-0 shadow-md shadow-[#0C6B95]/20">
									<svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
										<path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
										<path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
									</svg>
								</div>
								<div>
									<p class="text-neutral-400 text-xs font-medium uppercase tracking-widest mb-1" data-i18n-el="Βρείτε μας" data-i18n-es="Encuéntrenos">Find Us</p>
									<p class="text-neutral-900 font-semibold text-lg" data-i18n-el="Μαγκριώτου 6" data-i18n-es="Magkriotou 6">Magkriotou 6</p>
									<p class="text-neutral-500 text-sm mt-0.5" data-i18n-el="Αθήνα, Ελλάδα" data-i18n-es="Atenas, Grecia">Athens, Greece</p>
								</div>
							</div>

							<!-- Email -->
							<div class="flex items-start gap-5">
								<div class="w-12 h-12 rounded-xl bg-[#0C6B95] flex items-center justify-center shrink-0 shadow-md shadow-[#0C6B95]/20">
									<svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
										<path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
									</svg>
								</div>
								<div>
									<p class="text-neutral-400 text-xs font-medium uppercase tracking-widest mb-1" data-i18n-el="Στείλτε μας email" data-i18n-es="Envíenos un correo">Email Us</p>
									<a href="mailto:info@opawey.com" class="text-neutral-900 font-semibold text-lg hover:text-[#0C6B95] transition-colors">info@opawey.com</a>
								</div>
							</div>

							<!-- Business Hours -->
							<div class="flex items-start gap-5">
								<div class="w-12 h-12 rounded-xl bg-[#0C6B95] flex items-center justify-center shrink-0 shadow-md shadow-[#0C6B95]/20">
									<svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
										<path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
									</svg>
								</div>
								<div>
									<p class="text-neutral-400 text-xs font-medium uppercase tracking-widest mb-1" data-i18n-el="Ωράριο λειτουργίας" data-i18n-es="Horario comercial">Business Hours</p>
									<p class="text-neutral-900 font-semibold text-lg" data-i18n-el="Δευ – Παρ: 8:00 – 21:30" data-i18n-es="Lun – Vie: 8:00 – 21:30">Mon – Fri: 8:00 – 21:30</p>
									<p class="text-neutral-500 text-sm mt-0.5" data-i18n-el="Σάββατο: 9:00 – 16:00" data-i18n-es="Sábado: 9:00 – 16:00">Saturday: 9:00 – 16:00</p>
								</div>
							</div>

						</div><!-- end info blocks -->
					</div><!-- end left column -->

					<!-- ── Right: Contact Form ── -->
					<div class="bg-white rounded-3xl p-8 lg:p-10 border border-neutral-200 shadow-xl shadow-neutral-200/60">

						<!-- Success state -->
						<div id="contact-success" class="hidden flex flex-col items-center justify-center py-10 gap-4 text-center">
							<div class="w-16 h-16 rounded-full bg-emerald-50 border border-emerald-200 flex items-center justify-center">
								<svg class="w-8 h-8 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
									<path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
								</svg>
							</div>
							<div>
								<p class="text-xl font-bold text-neutral-900" data-i18n-el="Το μήνυμα στάλθηκε!" data-i18n-es="¡Mensaje enviado!">Message sent!</p>
								<p class="text-neutral-500 text-sm mt-1" data-i18n-el="Σας ευχαριστούμε για την επικοινωνία. Θα σας απαντήσουμε σύντομα." data-i18n-es="Gracias por ponerse en contacto. Le responderemos a la mayor brevedad.">Thank you for reaching out. We'll get back to you shortly.</p>
							</div>
							<button id="contact-reset-btn" type="button" class="mt-2 text-sm text-[#0C6B95] font-medium hover:underline" data-i18n-el="Αποστολή νέου μηνύματος" data-i18n-es="Enviar otro mensaje">Send another message</button>
						</div>

						<form id="contact-form" class="flex flex-col gap-7">

							<!-- Country -->
							<div class="flex flex-col gap-2">
								<label class="text-neutral-700 text-xs font-medium uppercase tracking-widest" data-i18n-el="Χώρα *" data-i18n-es="País *">Country *</label>
								<select
									id="contact-country"
									name="country"
									class="bg-transparent border-b border-neutral-200 focus:border-[#0C6B95] text-neutral-900 py-3 text-base outline-none transition-colors duration-200 cursor-pointer"
								>
									<option value="" disabled selected data-i18n-el="Επιλέξτε τη χώρα σας" data-i18n-es="Seleccione su país">Select your country</option>
									<option value="Greece" data-i18n-el="Ελλάδα" data-i18n-es="Grecia">Greece</option>
									<option value="United Kingdom" data-i18n-el="Ηνωμένο Βασίλειο" data-i18n-es="Reino Unido">United Kingdom</option>
									<option value="United States" data-i18n-el="Ηνωμένες Πολιτείες" data-i18n-es="Estados Unidos">United States</option>
									<option value="Germany" data-i18n-el="Γερμανία" data-i18n-es="Alemania">Germany</option>
									<option value="France" data-i18n-el="Γαλλία" data-i18n-es="Francia">France</option>
									<option value="Italy" data-i18n-el="Ιταλία" data-i18n-es="Italia">Italy</option>
									<option value="Spain" data-i18n-el="Ισπανία" data-i18n-es="España">Spain</option>
									<option value="Netherlands" data-i18n-el="Ολλανδία" data-i18n-es="Países Bajos">Netherlands</option>
									<option value="Turkey" data-i18n-el="Τουρκία" data-i18n-es="Turquía">Turkey</option>
									<option value="Cyprus" data-i18n-el="Κύπρος" data-i18n-es="Chipre">Cyprus</option>
									<option value="Australia" data-i18n-el="Αυστραλία" data-i18n-es="Australia">Australia</option>
									<option value="Canada" data-i18n-el="Καναδάς" data-i18n-es="Canadá">Canada</option>
									<option value="Switzerland" data-i18n-el="Ελβετία" data-i18n-es="Suiza">Switzerland</option>
									<option value="Austria" data-i18n-el="Αυστρία" data-i18n-es="Austria">Austria</option>
									<option value="Belgium" data-i18n-el="Βέλγιο" data-i18n-es="Bélgica">Belgium</option>
									<option value="Sweden" data-i18n-el="Σουηδία" data-i18n-es="Suecia">Sweden</option>
									<option value="Norway" data-i18n-el="Νορβηγία" data-i18n-es="Noruega">Norway</option>
									<option value="Denmark" data-i18n-el="Δανία" data-i18n-es="Dinamarca">Denmark</option>
									<option value="Portugal" data-i18n-el="Πορτογαλία" data-i18n-es="Portugal">Portugal</option>
									<option value="Ireland" data-i18n-el="Ιρλανδία" data-i18n-es="Irlanda">Ireland</option>
									<option value="Other" data-i18n-el="Άλλο" data-i18n-es="Otro">Other</option>
								</select>
							</div>

							<!-- City -->
							<div class="flex flex-col gap-2">
								<label class="text-neutral-700 text-xs font-medium uppercase tracking-widest" data-i18n-el="Πόλη *" data-i18n-es="Ciudad *">City *</label>
								<input
									id="contact-city"
									type="text"
									name="city"
									placeholder="e.g. Athens"
									data-i18n-placeholder-el="π.χ. Αθήνα"
									data-i18n-placeholder-es="p. ej. Madrid"
									class="bg-transparent border-b border-neutral-200 focus:border-[#0C6B95] text-neutral-900 placeholder-neutral-300 py-3 text-base outline-none transition-colors duration-200"
								/>
							</div>

							<!-- Name + Last Name -->
							<div class="grid grid-cols-1 sm:grid-cols-2 gap-7">
								<div class="flex flex-col gap-2">
									<label class="text-neutral-700 text-xs font-medium uppercase tracking-widest" data-i18n-el="Όνομα *" data-i18n-es="Nombre *">Name *</label>
									<input
										id="contact-name"
										type="text"
										name="name"
										placeholder="e.g. John"
										data-i18n-placeholder-el="π.χ. Γιάννης"
										data-i18n-placeholder-es="p. ej. Juan"
										class="bg-transparent border-b border-neutral-200 focus:border-[#0C6B95] text-neutral-900 placeholder-neutral-300 py-3 text-base outline-none transition-colors duration-200"
									/>
								</div>
								<div class="flex flex-col gap-2">
									<label class="text-neutral-700 text-xs font-medium uppercase tracking-widest" data-i18n-el="Επώνυμο *" data-i18n-es="Apellido *">Last Name *</label>
									<input
										id="contact-last-name"
										type="text"
										name="last_name"
										placeholder="e.g. Smith"
										data-i18n-placeholder-el="π.χ. Παπαδόπουλος"
										data-i18n-placeholder-es="p. ej. García"
										class="bg-transparent border-b border-neutral-200 focus:border-[#0C6B95] text-neutral-900 placeholder-neutral-300 py-3 text-base outline-none transition-colors duration-200"
									/>
								</div>
							</div>

							<!-- Phone Number -->
							<div class="flex flex-col gap-2">
								<label class="text-neutral-700 text-xs font-medium uppercase tracking-widest" data-i18n-el="Αριθμός τηλεφώνου *" data-i18n-es="Número de teléfono *">Phone Number *</label>
								<input
									id="contact-phone"
									type="tel"
									name="phone"
									placeholder="e.g. +30 210 933 3164"
									data-i18n-placeholder-el="π.χ. +30 210 933 3164"
									data-i18n-placeholder-es="p. ej. +30 210 933 3164"
									class="bg-transparent border-b border-neutral-200 focus:border-[#0C6B95] text-neutral-900 placeholder-neutral-300 py-3 text-base outline-none transition-colors duration-200"
								/>
							</div>

							<!-- Email -->
							<div class="flex flex-col gap-2">
								<label class="text-neutral-700 text-xs font-medium uppercase tracking-widest" data-i18n-el="Διεύθυνση email *" data-i18n-es="Correo electrónico *">Email Address *</label>
								<input
									id="contact-email"
									type="email"
									name="email"
									placeholder="e.g. john@example.com"
									data-i18n-placeholder-el="π.χ. giannis@example.com"
									data-i18n-placeholder-es="p. ej. juan@ejemplo.com"
									class="bg-transparent border-b border-neutral-200 focus:border-[#0C6B95] text-neutral-900 placeholder-neutral-300 py-3 text-base outline-none transition-colors duration-200"
								/>
							</div>

							<!-- Number of Passengers + Type of Vehicle -->
							<div class="grid grid-cols-1 sm:grid-cols-2 gap-7">
								<div class="flex flex-col gap-2">
									<label class="text-neutral-700 text-xs font-medium uppercase tracking-widest" data-i18n-el="Αριθμός επιβατών *" data-i18n-es="Número de pasajeros *">Number of Passengers *</label>
									<input
										id="contact-passengers"
										type="number"
										name="passengers"
										min="1"
										placeholder="e.g. 4"
										data-i18n-placeholder-el="π.χ. 4"
										data-i18n-placeholder-es="p. ej. 4"
										class="bg-transparent border-b border-neutral-200 focus:border-[#0C6B95] text-neutral-900 placeholder-neutral-300 py-3 text-base outline-none transition-colors duration-200"
									/>
								</div>
								<div class="flex flex-col gap-2">
									<label class="text-neutral-700 text-xs font-medium uppercase tracking-widest" data-i18n-el="Τύπος οχήματος *" data-i18n-es="Tipo de vehículo *">Type of Vehicle *</label>
									<select
										id="contact-vehicle"
										name="vehicle_type"
										class="bg-transparent border-b border-neutral-200 focus:border-[#0C6B95] text-neutral-900 py-3 text-base outline-none transition-colors duration-200 cursor-pointer"
									>
										<option value="" disabled selected data-i18n-el="Επιλέξτε όχημα" data-i18n-es="Seleccione un vehículo">Select vehicle</option>
										<option value="Sedan" data-i18n-el="Sedan" data-i18n-es="Sedán">Sedan</option>
										<option value="Van" data-i18n-el="Van" data-i18n-es="Furgoneta">Van</option>
										<option value="Minibus" data-i18n-el="Minibus" data-i18n-es="Microbús">Minibus</option>
									</select>
								</div>
							</div>

							<!-- Comments -->
							<div class="flex flex-col gap-2">
								<label class="text-neutral-700 text-xs font-medium uppercase tracking-widest" data-i18n-el="Σχόλια *" data-i18n-es="Comentarios *">Comments *</label>
								<textarea
									id="contact-message"
									name="message"
									rows="4"
									placeholder="Tell us about your transfer or experience request..."
									data-i18n-placeholder-el="Πείτε μας για το αίτημα μεταφοράς ή εμπειρίας σας..."
									data-i18n-placeholder-es="Cuéntenos sobre su solicitud de traslado o experiencia..."
									class="bg-transparent border-b border-neutral-200 focus:border-[#0C6B95] text-neutral-900 placeholder-neutral-300 py-3 text-base outline-none transition-colors duration-200 resize-none"
								></textarea>
							</div>

							<!-- Error -->
							<p id="contact-error" class="hidden text-sm text-red-600 -mt-3"></p>

							<!-- Submit -->
							<button
								id="contact-submit-btn"
								type="submit"
								class="mt-2 w-full bg-[#0C6B95] hover:bg-[#0a5c82] text-white font-semibold py-4 px-8 rounded-xl transition-colors duration-200 flex items-center justify-center gap-2 shadow-lg shadow-[#0C6B95]/25 disabled:opacity-60 disabled:cursor-not-allowed"
							>
								<span data-i18n-el="Αποστολή μηνύματος" data-i18n-es="Enviar mensaje">Send Message</span>
								<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
									<path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
								</svg>
							</button>

						</form>
					</div><!-- end right column -->

				</div><!-- end grid -->
			</div><!-- end content -->
		</section>
	</main>
</Layout>

<script>
	import { supabase } from '../lib/supabase';

	document.addEventListener('astro:page-load', () => {
		const form       = document.getElementById('contact-form') as HTMLFormElement;
		const errorEl    = document.getElementById('contact-error')!;
		const successEl  = document.getElementById('contact-success')!;
		const resetBtn   = document.getElementById('contact-reset-btn')!;
		const submitBtn  = document.getElementById('contact-submit-btn') as HTMLButtonElement;

		const nameInput  = document.getElementById('contact-name')  as HTMLInputElement;
		const emailInput = document.getElementById('contact-email') as HTMLInputElement;

		if (!form) return;

		// Pre-fill form if user is already logged in
		supabase.auth.onAuthStateChange((_event, session) => {
			if (!session?.user) return;
			const user = session.user;
			if (nameInput && !nameInput.value)   nameInput.value  = user.user_metadata?.display_name || user.user_metadata?.full_name || '';
			if (emailInput && !emailInput.value) emailInput.value = user.email || '';
		});

		form.addEventListener('submit', async (e) => {
			e.preventDefault();
			errorEl.classList.add('hidden');

			const country      = (document.getElementById('contact-country')    as HTMLSelectElement)?.value.trim();
			const city         = (document.getElementById('contact-city')       as HTMLInputElement)?.value.trim();
			const name         = (document.getElementById('contact-name')       as HTMLInputElement)?.value.trim();
			const lastName     = (document.getElementById('contact-last-name')  as HTMLInputElement)?.value.trim();
			const phone        = (document.getElementById('contact-phone')      as HTMLInputElement)?.value.trim();
			const email        = (document.getElementById('contact-email')      as HTMLInputElement)?.value.trim();
			const passengers   = (document.getElementById('contact-passengers') as HTMLInputElement)?.value.trim();
			const vehicleType  = (document.getElementById('contact-vehicle')    as HTMLSelectElement)?.value.trim();
			const message      = (document.getElementById('contact-message')    as HTMLTextAreaElement)?.value.trim();

			if (!country)      { errorEl.textContent = 'Please select your country.';          errorEl.classList.remove('hidden'); return; }
			if (!city)         { errorEl.textContent = 'Please enter your city.';              errorEl.classList.remove('hidden'); return; }
			if (!name)         { errorEl.textContent = 'Please enter your name.';              errorEl.classList.remove('hidden'); return; }
			if (!lastName)     { errorEl.textContent = 'Please enter your last name.';         errorEl.classList.remove('hidden'); return; }
			if (!phone)        { errorEl.textContent = 'Please enter your phone number.';      errorEl.classList.remove('hidden'); return; }
			if (!email)        { errorEl.textContent = 'Please enter your email address.';     errorEl.classList.remove('hidden'); return; }
			if (!passengers || parseInt(passengers) < 1) { errorEl.textContent = 'Please enter the number of passengers.'; errorEl.classList.remove('hidden'); return; }
			if (!vehicleType)  { errorEl.textContent = 'Please select a vehicle type.';        errorEl.classList.remove('hidden'); return; }
			if (!message)      { errorEl.textContent = 'Please write a comment.';              errorEl.classList.remove('hidden'); return; }

			submitBtn.disabled = true;
			submitBtn.textContent = 'Sending…';

			// Capture logged-in user info at the moment of submission
			const { data: { session } } = await supabase.auth.getSession();
			const currentUser = session?.user;

			try {
				const { error: insertError } = await supabase.from('requests').insert({
					source:  'contact',
					country,
					city,
					name,
					last_name:    lastName,
					phone,
					email,
					participants: parseInt(passengers),
					vehicle_type: vehicleType,
					message,
					status:  'new',
					// User account info (null if not logged in)
					user_id:           currentUser?.id          || null,
					user_display_name: currentUser?.user_metadata?.display_name || currentUser?.user_metadata?.full_name || null,
					user_email:        currentUser?.email        || null,
				});
				if (insertError) throw insertError;

				form.classList.add('hidden');
				successEl.classList.remove('hidden');

			} catch (err) {
				console.error(err);
				errorEl.textContent = 'Something went wrong. Please try again.';
				errorEl.classList.remove('hidden');
				submitBtn.disabled = false;
				submitBtn.innerHTML = `<span data-i18n-el="Αποστολή μηνύματος" data-i18n-es="Enviar mensaje">Send Message</span> <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>`;
			}
		});

		resetBtn?.addEventListener('click', () => {
			form.reset();
			successEl.classList.add('hidden');
			form.classList.remove('hidden');
			submitBtn.disabled = false;
