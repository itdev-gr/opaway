---
import HotelLayout from '../../components/HotelLayout.astro';
---

<HotelLayout pageTitle="Reservations" pageDescription="Bookings linked to your hotel" activeSection="reservations">

	<!-- Booking Calendar -->
	<div id="calendar-section" class="mb-8 hidden">
		<!-- Month Navigation -->
		<div class="flex items-center justify-between mb-6">
			<button id="prev-month" class="inline-flex items-center gap-1.5 px-3 py-2 rounded-lg border border-neutral-200 bg-white text-sm font-medium text-neutral-700 hover:bg-neutral-50 hover:border-neutral-300 transition-all">
				<svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
				Prev
			</button>
			<h2 id="month-label" class="text-lg font-semibold text-neutral-800"></h2>
			<button id="next-month" class="inline-flex items-center gap-1.5 px-3 py-2 rounded-lg border border-neutral-200 bg-white text-sm font-medium text-neutral-700 hover:bg-neutral-50 hover:border-neutral-300 transition-all">
				Next
				<svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
			</button>
		</div>

		<!-- Legend -->
		<div class="flex items-center gap-5 mb-4 text-xs text-neutral-500">
			<span class="flex items-center gap-1.5"><span class="w-2 h-2 rounded-full bg-[#0C6B95]"></span> Transfer</span>
			<span class="flex items-center gap-1.5"><span class="w-2 h-2 rounded-full bg-emerald-500"></span> Tour</span>
			<span class="flex items-center gap-1.5"><span class="w-2 h-2 rounded-full bg-violet-500"></span> Experience</span>
		</div>

		<!-- Calendar -->
		<div class="bg-white rounded-2xl border border-neutral-200 shadow-sm overflow-hidden mb-8">
			<div class="grid grid-cols-7 bg-neutral-50 border-b border-neutral-100">
				<div class="px-2 py-2.5 text-center text-xs font-semibold text-neutral-500 uppercase tracking-wider">Mon</div>
				<div class="px-2 py-2.5 text-center text-xs font-semibold text-neutral-500 uppercase tracking-wider">Tue</div>
				<div class="px-2 py-2.5 text-center text-xs font-semibold text-neutral-500 uppercase tracking-wider">Wed</div>
				<div class="px-2 py-2.5 text-center text-xs font-semibold text-neutral-500 uppercase tracking-wider">Thu</div>
				<div class="px-2 py-2.5 text-center text-xs font-semibold text-neutral-500 uppercase tracking-wider">Fri</div>
				<div class="px-2 py-2.5 text-center text-xs font-semibold text-neutral-500 uppercase tracking-wider">Sat</div>
				<div class="px-2 py-2.5 text-center text-xs font-semibold text-neutral-500 uppercase tracking-wider">Sun</div>
			</div>
			<div id="calendar-grid" class="grid grid-cols-7">
				<div class="p-2 min-h-[80px] flex items-center justify-center text-neutral-400 text-sm col-span-7">Loading…</div>
			</div>
		</div>

		<!-- Selected day bookings -->
		<div id="day-bookings" class="hidden">
			<div class="flex items-center justify-between mb-4">
				<h3 id="day-bookings-title" class="text-base font-semibold text-neutral-800"></h3>
				<button id="close-day-bookings" class="text-neutral-400 hover:text-neutral-600 transition-colors text-sm">✕ Close</button>
			</div>
			<div id="day-bookings-list" class="space-y-3"></div>
		</div>
	</div>

	<!-- Loading state -->
	<div id="reservations-loading" class="flex items-center justify-center py-20">
		<svg class="w-8 h-8 text-[#0C6B95] animate-spin" fill="none" viewBox="0 0 24 24">
			<circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
			<path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"></path>
		</svg>
	</div>

	<!-- Content -->
	<div id="reservations-content" class="hidden">
		<div class="bg-white rounded-2xl border border-neutral-200 shadow-sm">
			<div class="px-6 py-4 border-b border-neutral-100 flex items-center justify-between gap-4">
				<div class="flex items-center gap-3">
					<h2 class="text-base font-semibold text-neutral-800">All Reservations</h2>
					<span id="reservations-count" class="text-xs text-neutral-400 font-medium"></span>
				</div>
			</div>
			<div class="overflow-x-auto">
				<table class="w-full text-sm">
					<thead>
						<tr class="bg-neutral-50 text-left">
							<th class="px-6 py-3 text-xs font-semibold text-neutral-500 uppercase tracking-wider">Date</th>
							<th class="px-6 py-3 text-xs font-semibold text-neutral-500 uppercase tracking-wider">Time</th>
							<th class="px-6 py-3 text-xs font-semibold text-neutral-500 uppercase tracking-wider">Vehicle</th>
							<th class="px-6 py-3 text-xs font-semibold text-neutral-500 uppercase tracking-wider">Passenger</th>
							<th class="px-6 py-3 text-xs font-semibold text-neutral-500 uppercase tracking-wider">Pax</th>
							<th class="px-6 py-3 text-xs font-semibold text-neutral-500 uppercase tracking-wider">Pickup</th>
							<th class="px-6 py-3 text-xs font-semibold text-neutral-500 uppercase tracking-wider">Dropoff</th>
							<th class="px-6 py-3 text-xs font-semibold text-neutral-500 uppercase tracking-wider">Customer Price</th>
							<th class="px-6 py-3 text-xs font-semibold text-neutral-500 uppercase tracking-wider">Hotel Commission</th>
							<th class="px-6 py-3 text-xs font-semibold text-neutral-500 uppercase tracking-wider">Status</th>
						</tr>
					</thead>
					<tbody id="reservations-tbody">
						<tr><td colspan="10" class="px-6 py-10 text-center text-neutral-400">Loading&hellip;</td></tr>
					</tbody>
				</table>
			</div>
		</div>
	</div>

	<!-- Empty state -->
	<div id="reservations-empty" class="hidden flex flex-col items-center justify-center py-16 text-center">
		<svg class="w-12 h-12 text-neutral-300 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
			<path stroke-linecap="round" stroke-linejoin="round" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0H4m13-3l-4 4-4-4" />
		</svg>
		<p class="text-neutral-500 font-medium">No reservations yet</p>
		<p class="text-sm text-neutral-400 mt-1">When guests book through your hotel, their reservations will appear here.</p>
	</div>

</HotelLayout>

<script>
	import { supabase } from '../../lib/supabase';

	function initHotelReservations() {
		const loadingEl = document.getElementById('reservations-loading');
		const contentEl = document.getElementById('reservations-content');
		const emptyEl   = document.getElementById('reservations-empty');
		const authCheck = document.getElementById('hotel-auth-check');

		function waitForAuth(): Promise<void> {
			return new Promise((resolve) => {
				if (authCheck?.classList.contains('hidden')) { resolve(); return; }
				const obs = new MutationObserver(() => {
					if (authCheck?.classList.contains('hidden')) { obs.disconnect(); resolve(); }
				});
				if (authCheck) obs.observe(authCheck, { attributes: true, attributeFilter: ['class'] });
			});
		}

		const escHtml = (s: string) => s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');

		function statusBadge(rideStatus: string): string {
			const rs = rideStatus || 'new';
			if (rs === 'new' || rs === 'assigned') {
				return `<span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold border bg-blue-50 border-blue-200 text-blue-700">Upcoming</span>`;
			}
			if (rs === 'pickup' || rs === 'onboard') {
				return `<span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold border bg-amber-50 border-amber-200 text-amber-700">On Board</span>`;
			}
			if (rs === 'completed') {
				return `<span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold border bg-emerald-50 border-emerald-200 text-emerald-700">Completed</span>`;
			}
			if (rs === 'commission_paid') {
				return `<span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold border bg-teal-50 border-teal-200 text-teal-700">Commission Paid</span>`;
			}
			return `<span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold border bg-neutral-50 border-neutral-200 text-neutral-600">${escHtml(rs)}</span>`;
		}

		(async () => {
			const { data: { session } } = await supabase.auth.getSession();
			if (!session?.user) return;
			await waitForAuth();

			const userId = session.user.id;

			// Get partner commission
			const { data: partner } = await supabase
				.from('partners')
				.select('discount, commission_eur')
				.eq('id', userId)
				.maybeSingle();

			// Load bookings from all three tables (linked via partner_id)
			const [transfersRes, toursRes, experiencesRes] = await Promise.all([
				supabase.from('transfers').select('*').eq('partner_id', userId).order('created_at', { ascending: false }),
				supabase.from('tours').select('*').eq('partner_id', userId).order('created_at', { ascending: false }),
				supabase.from('experiences').select('*').eq('partner_id', userId).order('created_at', { ascending: false }),
			]);

			interface Booking {
				id: string;
				date: string;
				time: string;
				vehicle_name?: string;
				vehicle?: string;
				first_name?: string;
				last_name?: string;
				name?: string;
				passengers?: number;
				from?: string;
				to?: string;
				pickup?: string;
				dropoff?: string;
				total_price?: number;
				ride_status?: string;
				status?: string;
				created_at?: string;
				type: string;
			}

			const transfers: Booking[] = (transfersRes.data ?? []).map(d => ({ ...d, type: 'Transfer' }));
			const tours: Booking[] = (toursRes.data ?? []).map(d => ({ ...d, type: 'Tour' }));
			const experiences: Booking[] = (experiencesRes.data ?? []).map(d => ({ ...d, type: 'Experience' }));

			const allBookings = [...transfers, ...tours, ...experiences].sort((a, b) => {
				const da = a.date || a.created_at || '';
				const db = b.date || b.created_at || '';
				return db.localeCompare(da);
			});

			// Calendar
			const calendarSection = document.getElementById('calendar-section');
			calendarSection?.classList.remove('hidden');

			interface CalendarBooking {
				id: string; type: string; firstName: string; lastName: string;
				from: string; to: string; date: string; time: string;
				rideStatus: string; paymentStatus: string;
			}

			const calBookings: CalendarBooking[] = allBookings.map(d => ({
				id: d.id,
				type: d.type.toLowerCase(),
				firstName: d.first_name || d.name || '',
				lastName: d.last_name || '',
				from: d.from || d.pickup || '',
				to: d.to || d.dropoff || '',
				date: d.date || (d.created_at ? new Date(d.created_at).toISOString().slice(0, 10) : ''),
				time: d.time || '',
				rideStatus: d.ride_status || d.status || 'pending',
				paymentStatus: (d as any).payment_status || 'pending',
			}));

			let currentYear = new Date().getFullYear();
			let currentMonth = new Date().getMonth();
			let selectedDay: string | null = null;

			function formatDateStr(y: number, m: number, d: number) {
				return `${y}-${String(m + 1).padStart(2, '0')}-${String(d).padStart(2, '0')}`;
			}

			function getForDate(dateStr: string) { return calBookings.filter(b => b.date === dateStr); }
			function getTypesForDate(dateStr: string) {
				const s = new Set<string>();
				calBookings.forEach(b => { if (b.date === dateStr) s.add(b.type); });
				return s;
			}

			function renderCalendar() {
				const grid = document.getElementById('calendar-grid');
				const label = document.getElementById('month-label');
				if (!grid || !label) return;
				const monthNames = ['January','February','March','April','May','June','July','August','September','October','November','December'];
				label.textContent = `${monthNames[currentMonth]} ${currentYear}`;
				const firstDay = new Date(currentYear, currentMonth, 1);
				const totalDays = new Date(currentYear, currentMonth + 1, 0).getDate();
				let startDow = firstDay.getDay() - 1; if (startDow < 0) startDow = 6;
				const today = new Date();
				const todayStr = formatDateStr(today.getFullYear(), today.getMonth(), today.getDate());
				let html = '';
				for (let i = 0; i < startDow; i++) html += `<div class="p-2 min-h-[80px] border border-neutral-100 rounded-lg bg-neutral-50/50"></div>`;
				for (let day = 1; day <= totalDays; day++) {
					const ds = formatDateStr(currentYear, currentMonth, day);
					const bk = getForDate(ds);
					const types = getTypesForDate(ds);
					const isToday = ds === todayStr;
					const isSel = ds === selectedDay;
					let cls = 'p-2 min-h-[80px] border border-neutral-100 rounded-lg cursor-pointer hover:bg-neutral-50 transition-all';
					if (isToday) cls = 'p-2 min-h-[80px] border border-sky-200 rounded-lg bg-sky-50 cursor-pointer hover:bg-sky-100 transition-all';
					if (isSel) cls += ' ring-2 ring-[#0C6B95]';
					html += `<div class="${cls}" data-date="${ds}"><div class="flex items-center justify-between mb-1"><span class="text-sm font-medium ${isToday ? 'text-[#0C6B95]' : 'text-neutral-700'}">${day}</span>`;
					if (bk.length > 0) html += `<span class="inline-flex items-center justify-center w-5 h-5 rounded-full bg-neutral-200 text-[10px] font-bold text-neutral-700">${bk.length}</span>`;
					html += `</div>`;
					if (types.size > 0) {
						html += `<div class="flex items-center gap-1 mt-1 flex-wrap">`;
						if (types.has('transfer')) html += `<span class="w-2 h-2 rounded-full bg-[#0C6B95]"></span>`;
						if (types.has('tour')) html += `<span class="w-2 h-2 rounded-full bg-emerald-500"></span>`;
						if (types.has('experience')) html += `<span class="w-2 h-2 rounded-full bg-violet-500"></span>`;
						html += `</div>`;
					}
					html += `</div>`;
				}
				const totalCells = startDow + totalDays;
				const rem = totalCells % 7 === 0 ? 0 : 7 - (totalCells % 7);
				for (let i = 0; i < rem; i++) html += `<div class="p-2 min-h-[80px] border border-neutral-100 rounded-lg bg-neutral-50/50"></div>`;
				grid.innerHTML = html;
				grid.querySelectorAll('[data-date]').forEach(cell => {
					cell.addEventListener('click', () => { const dt = cell.getAttribute('data-date'); if (dt) { selectedDay = dt; renderCalendar(); renderDayBookings(dt); } });
				});
			}

			function renderDayBookings(dateStr: string) {
				const container = document.getElementById('day-bookings');
				const title = document.getElementById('day-bookings-title');
				const list = document.getElementById('day-bookings-list');
				if (!container || !title || !list) return;
				const bk = getForDate(dateStr);
				const d = new Date(dateStr + 'T00:00:00');
				title.textContent = `Bookings for ${d.toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' })}`;
				if (bk.length === 0) { list.innerHTML = `<p class="text-sm text-neutral-400 py-6 text-center">No bookings on this day.</p>`; container.classList.remove('hidden'); return; }
				const typeBadge = (t: string) => {
					const m: Record<string,string> = { transfer:'bg-sky-50 text-[#0C6B95] border-sky-200', tour:'bg-emerald-50 text-emerald-700 border-emerald-200', experience:'bg-violet-50 text-violet-700 border-violet-200' };
					return `<span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium border ${m[t]||'bg-neutral-50 text-neutral-600 border-neutral-200'} capitalize">${t}</span>`;
				};
				const sBadge = (s: string, p: string) => {
					const m: Record<string,string> = { pending:'bg-amber-50 text-amber-700 border-amber-200', completed:'bg-sky-50 text-sky-700 border-sky-200', cancelled:'bg-red-50 text-red-600 border-red-200', paid:'bg-emerald-50 text-emerald-700 border-emerald-200' };
					return `<span class="inline-flex items-center px-2 py-0.5 rounded-full text-[11px] font-medium border ${m[s.toLowerCase()]||'bg-neutral-50 text-neutral-600 border-neutral-200'} capitalize">${p}: ${s}</span>`;
				};
				list.innerHTML = bk.map(b => `
					<div class="bg-white rounded-xl border border-neutral-200 shadow-sm p-4 flex flex-col sm:flex-row sm:items-center gap-3">
						<div class="flex items-center gap-3 flex-1 min-w-0">${typeBadge(b.type)}<span class="font-medium text-sm text-neutral-900 truncate">${b.firstName} ${b.lastName}</span></div>
						<div class="flex items-center gap-2 text-sm text-neutral-600 flex-1 min-w-0"><span class="truncate">${b.from||'\u2014'}</span><svg class="w-4 h-4 text-neutral-400 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg><span class="truncate">${b.to||'\u2014'}</span></div>
						<div class="text-sm text-neutral-500 whitespace-nowrap">${b.time||'\u2014'}</div>
						<div class="flex items-center gap-2 flex-shrink-0">${sBadge(b.rideStatus,'Ride')} ${sBadge(b.paymentStatus,'Pay')}</div>
					</div>`).join('');
				container.classList.remove('hidden');
			}

			renderCalendar();

			document.getElementById('prev-month')?.addEventListener('click', () => {
				currentMonth--; if (currentMonth < 0) { currentMonth = 11; currentYear--; }
				selectedDay = null; document.getElementById('day-bookings')?.classList.add('hidden'); renderCalendar();
			});
			document.getElementById('next-month')?.addEventListener('click', () => {
				currentMonth++; if (currentMonth > 11) { currentMonth = 0; currentYear++; }
				selectedDay = null; document.getElementById('day-bookings')?.classList.add('hidden'); renderCalendar();
			});
			document.getElementById('close-day-bookings')?.addEventListener('click', () => {
				selectedDay = null; document.getElementById('day-bookings')?.classList.add('hidden'); renderCalendar();
			});

			loadingEl?.classList.add('hidden');

			if (allBookings.length === 0) {
				emptyEl?.classList.remove('hidden');
				return;
			}

			const countEl = document.getElementById('reservations-count');
			if (countEl) countEl.textContent = `${allBookings.length} reservation${allBookings.length !== 1 ? 's' : ''}`;

			const tbody = document.getElementById('reservations-tbody')!;
			tbody.innerHTML = allBookings.map(d => {
				const dateVal = d.date ? String(d.date) : '\u2014';
				const timeVal = d.time ? String(d.time) : '\u2014';
				const vehicle = d.vehicle_name ? String(d.vehicle_name) : (d.vehicle ? String(d.vehicle) : '\u2014');
				const firstName = d.first_name ? String(d.first_name) : '';
				const lastName = d.last_name ? String(d.last_name) : '';
				const passenger = (firstName || lastName) ? `${firstName} ${lastName}`.trim() : (d.name ? String(d.name) : '\u2014');
				const pax = d.passengers ?? '\u2014';
				const pickup = d.from || d.pickup || '\u2014';
				const dropoff = d.to || d.dropoff || '\u2014';
				const totalPrice = typeof d.total_price === 'number' ? d.total_price : 0;
				const commissionEur = Number(partner?.commission_eur ?? 0);
				const commission = commissionEur; // flat per-booking EUR amount
				const rideStatus = d.ride_status || d.status || 'new';

				return `<tr class="border-t border-neutral-100 hover:bg-neutral-50 transition-colors">
					<td class="px-6 py-3 text-neutral-600 whitespace-nowrap">${escHtml(String(dateVal))}</td>
					<td class="px-6 py-3 text-neutral-600 whitespace-nowrap">${escHtml(String(timeVal))}</td>
					<td class="px-6 py-3 text-neutral-600 whitespace-nowrap">${escHtml(vehicle)}</td>
					<td class="px-6 py-3 font-medium text-neutral-900 whitespace-nowrap">${escHtml(passenger)}</td>
					<td class="px-6 py-3 text-neutral-600 text-center">${pax}</td>
					<td class="px-6 py-3 text-neutral-600">${escHtml(String(pickup))}</td>
					<td class="px-6 py-3 text-neutral-600">${escHtml(String(dropoff))}</td>
					<td class="px-6 py-3 text-neutral-800 font-medium whitespace-nowrap">&euro;${totalPrice.toFixed(2)}</td>
					<td class="px-6 py-3 text-emerald-700 font-medium whitespace-nowrap">&euro;${commission.toFixed(2)}</td>
					<td class="px-6 py-3">${statusBadge(rideStatus)}</td>
				</tr>`;
			}).join('');

			contentEl?.classList.remove('hidden');
		})();
	}

	initHotelReservations();
	document.addEventListener('astro:page-load', initHotelReservations);
</script>
