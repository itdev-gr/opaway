---
import HotelLayout from '../../components/HotelLayout.astro';
---

<HotelLayout pageTitle="Profile" pageDescription="Your hotel registration details" activeSection="profile">

	<!-- Loading state -->
	<div id="profile-loading" class="flex items-center justify-center py-20">
		<svg class="w-8 h-8 text-[#0C6B95] animate-spin" fill="none" viewBox="0 0 24 24">
			<circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
			<path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"></path>
		</svg>
	</div>

	<!-- Profile content -->
	<div id="profile-content" class="hidden space-y-8">

		<!-- Hotel Logo / Avatar -->
		<section class="bg-white rounded-2xl border border-neutral-200 shadow-sm p-6 md:p-8">
			<h2 class="text-lg font-bold text-neutral-900 mb-1">Logo</h2>
			<p class="text-sm text-neutral-500 mb-6">Shown next to your business name in admin views and customer-facing booking cards.</p>

			<div class="flex items-center gap-4">
				<div class="shrink-0">
					<div class="w-24 h-24 rounded-2xl overflow-hidden border-2 border-neutral-200 bg-neutral-100 flex items-center justify-center">
						<img id="hotelAvatarPreview" src="" alt="Hotel logo" class="w-full h-full object-cover hidden" />
						<svg id="hotelAvatarPlaceholder" class="w-10 h-10 text-neutral-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
							<path stroke-linecap="round" stroke-linejoin="round" d="M2 20l4.586-4.586a2 2 0 012.828 0L14 20m0 0l2-2a2 2 0 012.828 0L22 20M3 7h18v13H3V7zm3-3h12v3H6V4z" />
						</svg>
					</div>
				</div>
				<div class="flex-1">
					<div class="flex items-center gap-2">
						<label class="inline-flex items-center gap-2 px-4 py-2 bg-neutral-50 border border-neutral-200 rounded-xl text-sm text-neutral-600 hover:bg-neutral-100 cursor-pointer transition-colors">
							<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12" /></svg>
							Upload logo
							<input id="hotelAvatarFile" type="file" accept="image/*" class="hidden" />
						</label>
						<button id="hotelAvatarRemove" type="button" class="px-3 py-2 text-xs font-medium text-red-600 hover:bg-red-50 rounded-lg transition-colors hidden">Remove</button>
						<span id="hotelAvatarStatus" class="hidden text-xs"></span>
					</div>
					<p class="text-xs text-neutral-400 mt-1.5">JPG, PNG or WebP. Max 5 MB.</p>
				</div>
			</div>
		</section>

		<!-- Hotel Information -->
		<section class="bg-white rounded-2xl border border-neutral-200 shadow-sm p-6 md:p-8">
			<h2 class="text-lg font-bold text-neutral-900 mb-1">Hotel Information</h2>
			<p class="text-sm text-neutral-500 mb-6">Update your hotel registration details.</p>

			<form id="hotel-form" class="space-y-5">
				<div class="grid grid-cols-1 md:grid-cols-2 gap-5">
					<div>
						<label for="hotelName" class="block text-sm font-medium text-neutral-700 mb-1.5">Hotel Name</label>
						<input type="text" id="hotelName" name="hotelName"
							class="w-full px-4 py-3 bg-white border border-neutral-200 rounded-xl text-sm text-neutral-800 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95] outline-none transition-colors" />
					</div>
					<div>
						<label for="hotelType" class="block text-sm font-medium text-neutral-700 mb-1.5">Hotel Type</label>
						<input type="text" id="hotelType" name="hotelType"
							class="w-full px-4 py-3 bg-white border border-neutral-200 rounded-xl text-sm text-neutral-800 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95] outline-none transition-colors" />
					</div>
					<div>
						<label for="vat" class="block text-sm font-medium text-neutral-700 mb-1.5">VAT Number</label>
						<input type="text" id="vat" name="vat"
							class="w-full px-4 py-3 bg-white border border-neutral-200 rounded-xl text-sm text-neutral-800 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95] outline-none transition-colors" />
					</div>
					<div>
						<label for="email" class="block text-sm font-medium text-neutral-700 mb-1.5">Account Email</label>
						<input type="email" id="email" name="email" readonly
							class="w-full px-4 py-3 bg-neutral-50 border border-neutral-200 rounded-xl text-sm text-neutral-500 cursor-not-allowed" />
					</div>
					<div>
						<label for="businessPhone" class="block text-sm font-medium text-neutral-700 mb-1.5">Business Phone</label>
						<input type="tel" id="businessPhone" name="businessPhone"
							class="w-full px-4 py-3 bg-white border border-neutral-200 rounded-xl text-sm text-neutral-800 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95] outline-none transition-colors" />
					</div>
					<div>
						<label for="businessEmail" class="block text-sm font-medium text-neutral-700 mb-1.5">Business Email</label>
						<input type="email" id="businessEmail" name="businessEmail"
							class="w-full px-4 py-3 bg-white border border-neutral-200 rounded-xl text-sm text-neutral-800 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95] outline-none transition-colors" />
					</div>
				</div>

				<div class="flex items-center gap-3 pt-2">
					<button type="submit"
						class="px-6 py-2.5 bg-[#0C6B95] text-white text-sm font-semibold rounded-xl hover:bg-[#0a5c82] transition-colors">
						Save Changes
					</button>
					<span id="hotel-status" class="text-sm hidden"></span>
				</div>
			</form>
		</section>

		<!-- Contact Person -->
		<section class="bg-white rounded-2xl border border-neutral-200 shadow-sm p-6 md:p-8">
			<h2 class="text-lg font-bold text-neutral-900 mb-1">Contact Person</h2>
			<p class="text-sm text-neutral-500 mb-6">Primary contact for this hotel account.</p>

			<form id="contact-form" class="space-y-5">
				<div class="grid grid-cols-1 md:grid-cols-2 gap-5">
					<div>
						<label for="contactName" class="block text-sm font-medium text-neutral-700 mb-1.5">Contact Name</label>
						<input type="text" id="contactName" name="contactName"
							class="w-full px-4 py-3 bg-white border border-neutral-200 rounded-xl text-sm text-neutral-800 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95] outline-none transition-colors" />
					</div>
					<div>
						<label for="contactPhone" class="block text-sm font-medium text-neutral-700 mb-1.5">Contact Phone</label>
						<input type="tel" id="contactPhone" name="contactPhone"
							class="w-full px-4 py-3 bg-white border border-neutral-200 rounded-xl text-sm text-neutral-800 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95] outline-none transition-colors" />
					</div>
					<div class="md:col-span-2">
						<label for="contactEmail" class="block text-sm font-medium text-neutral-700 mb-1.5">Contact Email</label>
						<input type="email" id="contactEmail" name="contactEmail"
							class="w-full px-4 py-3 bg-white border border-neutral-200 rounded-xl text-sm text-neutral-800 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95] outline-none transition-colors" />
					</div>
				</div>

				<div class="flex items-center gap-3 pt-2">
					<button type="submit"
						class="px-6 py-2.5 bg-[#0C6B95] text-white text-sm font-semibold rounded-xl hover:bg-[#0a5c82] transition-colors">
						Save Changes
					</button>
					<span id="contact-status" class="text-sm hidden"></span>
				</div>
			</form>
		</section>

		<!-- Address -->
		<section class="bg-white rounded-2xl border border-neutral-200 shadow-sm p-6 md:p-8">
			<h2 class="text-lg font-bold text-neutral-900 mb-1">Address &amp; Website</h2>
			<p class="text-sm text-neutral-500 mb-6">Registered location details.</p>

			<form id="address-form" class="space-y-5">
				<div class="grid grid-cols-1 md:grid-cols-2 gap-5">
					<div>
						<label for="location" class="block text-sm font-medium text-neutral-700 mb-1.5">Location</label>
						<input type="text" id="location" name="location"
							class="w-full px-4 py-3 bg-white border border-neutral-200 rounded-xl text-sm text-neutral-800 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95] outline-none transition-colors" />
					</div>
					<div>
						<label for="country" class="block text-sm font-medium text-neutral-700 mb-1.5">Country</label>
						<input type="text" id="country" name="country"
							class="w-full px-4 py-3 bg-white border border-neutral-200 rounded-xl text-sm text-neutral-800 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95] outline-none transition-colors" />
					</div>
					<div>
						<label for="zipCode" class="block text-sm font-medium text-neutral-700 mb-1.5">ZIP Code</label>
						<input type="text" id="zipCode" name="zipCode"
							class="w-full px-4 py-3 bg-white border border-neutral-200 rounded-xl text-sm text-neutral-800 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95] outline-none transition-colors" />
					</div>
					<div>
						<label for="website" class="block text-sm font-medium text-neutral-700 mb-1.5">Website</label>
						<input type="url" id="website" name="website" placeholder="https://..."
							class="w-full px-4 py-3 bg-white border border-neutral-200 rounded-xl text-sm text-neutral-800 focus:ring-[#0C6B95]/20 focus:border-[#0C6B95] outline-none transition-colors" />
					</div>
				</div>

				<div class="flex items-center gap-3 pt-2">
					<button type="submit"
						class="px-6 py-2.5 bg-[#0C6B95] text-white text-sm font-semibold rounded-xl hover:bg-[#0a5c82] transition-colors">
						Save Changes
					</button>
					<span id="address-status" class="text-sm hidden"></span>
				</div>
			</form>
		</section>

		<!-- Account Information (read-only) -->
		<section class="bg-white rounded-2xl border border-neutral-200 shadow-sm p-6 md:p-8">
			<h2 class="text-lg font-bold text-neutral-900 mb-1">Account</h2>
			<p class="text-sm text-neutral-500 mb-6">Admin-controlled account details.</p>

			<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
				<div>
					<p class="text-sm text-neutral-500 mb-1.5">Account Status</p>
					<span id="p-status-badge"></span>
				</div>
				<div>
					<p class="text-sm text-neutral-500 mb-1.5">Partner Type</p>
					<p id="p-type" class="text-sm font-medium text-neutral-800">-</p>
				</div>
				<div>
					<p class="text-sm text-neutral-500 mb-1.5">Member Since</p>
					<p id="p-created" class="text-sm font-medium text-neutral-800">-</p>
				</div>
			</div>
		</section>

	</div>
</HotelLayout>

<script>
	import { supabase } from '../../lib/supabase';
	import { uploadImage } from '../../lib/upload';

	function initHotelProfile() {
		const loadingEl = document.getElementById('profile-loading');
		const contentEl = document.getElementById('profile-content');
		const authCheck = document.getElementById('hotel-auth-check');

		function waitForAuth(): Promise<void> {
			return new Promise((resolve) => {
				if (authCheck?.classList.contains('hidden')) { resolve(); return; }
				const obs = new MutationObserver(() => {
					if (authCheck?.classList.contains('hidden')) { obs.disconnect(); resolve(); }
				});
				if (authCheck) obs.observe(authCheck, { attributes: true, attributeFilter: ['class'] });
			});
		}

		function renderStatusBadge(status: string): string {
			const map: Record<string, { bg: string; text: string; label: string }> = {
				approved: { bg: 'bg-emerald-50 border-emerald-200', text: 'text-emerald-700', label: 'Approved' },
				pending:  { bg: 'bg-amber-50 border-amber-200',    text: 'text-amber-700',   label: 'Pending'  },
				rejected: { bg: 'bg-red-50 border-red-200',         text: 'text-red-700',      label: 'Rejected' },
			};
			const s = map[status] || map.pending;
			return `<span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-semibold border ${s.bg} ${s.text}">${s.label}</span>`;
		}

		function showStatus(el: HTMLElement | null, msg: string, success: boolean) {
			if (!el) return;
			el.textContent = msg;
			el.className = `text-sm ${success ? 'text-emerald-600' : 'text-red-600'}`;
			el.classList.remove('hidden');
			setTimeout(() => el.classList.add('hidden'), 4000);
		}

		(async () => {
			const { data: { session } } = await supabase.auth.getSession();
			if (!session?.user) return;
			const user = session.user;
			await waitForAuth();

			const { data: partner } = await supabase
				.from('partners')
				.select('*')
				.eq('id', user.id)
				.maybeSingle();

			if (!partner) {
				if (loadingEl) loadingEl.innerHTML = '<p class="text-neutral-500 text-sm">Profile data not found.</p>';
				return;
			}

			const setVal = (id: string, val: any) => {
				const el = document.getElementById(id) as HTMLInputElement | null;
				if (el) el.value = val == null ? '' : String(val);
			};

			// Hotel
			setVal('hotelName', partner.hotel_name);
			setVal('hotelType', partner.hotel_type);
			setVal('vat', partner.vat);
			setVal('email', partner.email || user.email || '');
			setVal('businessPhone', partner.business_phone);
			setVal('businessEmail', partner.business_email);

			// Logo / avatar
			const avatarFile   = document.getElementById('hotelAvatarFile') as HTMLInputElement | null;
			const avatarPrev   = document.getElementById('hotelAvatarPreview') as HTMLImageElement | null;
			const avatarPh     = document.getElementById('hotelAvatarPlaceholder');
			const avatarRemove = document.getElementById('hotelAvatarRemove');
			const avatarStatus = document.getElementById('hotelAvatarStatus');

			function setAvatarStatus(msg: string, tone: 'info' | 'success' | 'error') {
				if (!avatarStatus) return;
				avatarStatus.textContent = msg;
				avatarStatus.className = `text-xs ${tone === 'error' ? 'text-red-600' : tone === 'success' ? 'text-emerald-600' : 'text-[#0C6B95]'}`;
				avatarStatus.classList.remove('hidden');
			}
			function showAvatar(url: string) {
				if (avatarPrev) { avatarPrev.src = url; avatarPrev.classList.remove('hidden'); }
				avatarPh?.classList.add('hidden');
				avatarRemove?.classList.remove('hidden');
			}
			function clearAvatar() {
				if (avatarPrev) { avatarPrev.src = ''; avatarPrev.classList.add('hidden'); }
				avatarPh?.classList.remove('hidden');
				avatarRemove?.classList.add('hidden');
			}

			if (partner.photo_url) showAvatar(partner.photo_url);

			avatarFile?.addEventListener('change', async () => {
				const file = avatarFile.files?.[0];
				if (!file) return;
				if (file.size > 5 * 1024 * 1024) { setAvatarStatus('File too large (max 5 MB).', 'error'); avatarFile.value = ''; return; }
				setAvatarStatus('Uploading…', 'info');
				try {
					const url = await uploadImage(file, `avatars/${user.id}`);
					const { error } = await supabase.from('partners').update({ photo_url: url }).eq('id', user.id);
					if (error) throw error;
					showAvatar(url);
					setAvatarStatus('Uploaded.', 'success');
					setTimeout(() => avatarStatus?.classList.add('hidden'), 3000);
				} catch (err: any) {
					console.error('Hotel avatar upload failed:', err);
					setAvatarStatus(err?.message || 'Upload failed.', 'error');
				} finally {
					avatarFile.value = '';
				}
			});

			avatarRemove?.addEventListener('click', async () => {
				setAvatarStatus('Removing…', 'info');
				const { error } = await supabase.from('partners').update({ photo_url: null }).eq('id', user.id);
				if (error) { setAvatarStatus(error.message, 'error'); return; }
				clearAvatar();
				setAvatarStatus('Removed.', 'success');
				setTimeout(() => avatarStatus?.classList.add('hidden'), 3000);
			});

			// Contact
			setVal('contactName', partner.contact_name);
			setVal('contactPhone', partner.contact_phone);
			setVal('contactEmail', partner.contact_email);

			// Address
			setVal('location', partner.location);
			setVal('country', partner.country);
			setVal('zipCode', partner.zip_code);
			setVal('website', partner.website);

			// Read-only account info
			const typeEl = document.getElementById('p-type');
			if (typeEl) typeEl.textContent = partner.type ? partner.type.charAt(0).toUpperCase() + partner.type.slice(1) : '-';

			const badgeEl = document.getElementById('p-status-badge');
			if (badgeEl) badgeEl.innerHTML = renderStatusBadge(partner.status || 'pending');

			const createdEl = document.getElementById('p-created');
			if (createdEl && partner.created_at) {
				const d = new Date(partner.created_at);
				createdEl.textContent = d.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
			}

			loadingEl?.classList.add('hidden');
			contentEl?.classList.remove('hidden');

			/* ── Hotel form submit ── */
			document.getElementById('hotel-form')?.addEventListener('submit', async (e) => {
				e.preventDefault();
				const form = e.target as HTMLFormElement;
				const statusEl = document.getElementById('hotel-status');
				const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
				btn.disabled = true;
				btn.textContent = 'Saving…';

				try {
					const { error } = await supabase
						.from('partners')
						.update({
							hotel_name:     (document.getElementById('hotelName') as HTMLInputElement).value.trim(),
							hotel_type:     (document.getElementById('hotelType') as HTMLInputElement).value.trim(),
							vat:            (document.getElementById('vat') as HTMLInputElement).value.trim(),
							business_phone: (document.getElementById('businessPhone') as HTMLInputElement).value.trim(),
							business_email: (document.getElementById('businessEmail') as HTMLInputElement).value.trim(),
						})
						.eq('id', user.id);

					if (error) {
						showStatus(statusEl, `[${error.code ?? 'unknown'}] ${error.message}`, false);
					} else {
						showStatus(statusEl, 'Changes saved successfully.', true);
					}
				} catch (err: any) {
					showStatus(statusEl, err.message || 'Failed to save changes.', false);
				} finally {
					btn.disabled = false;
					btn.textContent = 'Save Changes';
				}
			});

			/* ── Contact form submit ── */
			document.getElementById('contact-form')?.addEventListener('submit', async (e) => {
				e.preventDefault();
				const form = e.target as HTMLFormElement;
				const statusEl = document.getElementById('contact-status');
				const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
				btn.disabled = true;
				btn.textContent = 'Saving…';

				try {
					const { error } = await supabase
						.from('partners')
						.update({
							contact_name:  (document.getElementById('contactName') as HTMLInputElement).value.trim(),
							contact_phone: (document.getElementById('contactPhone') as HTMLInputElement).value.trim(),
							contact_email: (document.getElementById('contactEmail') as HTMLInputElement).value.trim(),
						})
						.eq('id', user.id);

					if (error) {
						showStatus(statusEl, `[${error.code ?? 'unknown'}] ${error.message}`, false);
					} else {
						showStatus(statusEl, 'Changes saved successfully.', true);
					}
				} catch (err: any) {
					showStatus(statusEl, err.message || 'Failed to save changes.', false);
				} finally {
					btn.disabled = false;
					btn.textContent = 'Save Changes';
				}
			});

			/* ── Address form submit ── */
			document.getElementById('address-form')?.addEventListener('submit', async (e) => {
				e.preventDefault();
				const form = e.target as HTMLFormElement;
				const statusEl = document.getElementById('address-status');
				const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
				btn.disabled = true;
				btn.textContent = 'Saving…';

				try {
					const { error } = await supabase
						.from('partners')
						.update({
							location: (document.getElementById('location') as HTMLInputElement).value.trim(),
							country:  (document.getElementById('country') as HTMLInputElement).value.trim(),
							zip_code: (document.getElementById('zipCode') as HTMLInputElement).value.trim(),
							website:  (document.getElementById('website') as HTMLInputElement).value.trim(),
						})
						.eq('id', user.id);

					if (error) {
						showStatus(statusEl, `[${error.code ?? 'unknown'}] ${error.message}`, false);
					} else {
						showStatus(statusEl, 'Changes saved successfully.', true);
					}
				} catch (err: any) {
					showStatus(statusEl, err.message || 'Failed to save changes.', false);
				} finally {
					btn.disabled = false;
					btn.textContent = 'Save Changes';
				}
			});
		})();
	}

	initHotelProfile();
	document.addEventListener('astro:page-load', initHotelProfile);
</script>
